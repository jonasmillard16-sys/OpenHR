@inherits LayoutComponentBase
@namespace RegionHR.Web.Components.Layout
@using Microsoft.Extensions.Localization
@inject RegionHR.Web.Services.AuthService Auth
@inject NavigationManager Nav
@inject IStringLocalizer<RegionHR.Web.SharedResources> L

<div class="@(_isDarkMode ? "ohr-dark" : "ohr-light")">
    <MudThemeProvider Theme="_openHrTheme" IsDarkMode="_isDarkMode" />
    <MudPopoverProvider />
    <MudDialogProvider />
    <MudSnackbarProvider />

    @if (!Auth.IsInitialized)
    {
        <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100vh;">
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" Style="width: 300px;" />
            <MudText Typo="Typo.h6" Style="color: var(--mud-palette-text-secondary);">@L["LoadingApp"]</MudText>
        </div>
    }
    else if (!Auth.IsLoggedIn)
    {
        @* Redirect to login *@
    }
    else
    {
        <MudLayout>
            <TopBar UserName="@(Auth.UserName!)" UnreadCount="5"
                    IsDarkMode="_isDarkMode"
                    IsDarkModeChanged="OnDarkModeToggled" />
            <MudDrawer @bind-Open="_drawerOpen" Variant="DrawerVariant.Responsive"
                       Elevation="1" ClipMode="DrawerClipMode.Always"
                       Breakpoint="Breakpoint.Lg">
                <NavMenu />
            </MudDrawer>
            <MudMainContent Class="pt-16" id="main-content" role="main">
                <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-6">
                    @Body
                </MudContainer>
            </MudMainContent>
            <RegionHR.Web.Components.Shared.OhrAssistant />
        </MudLayout>
        <RegionHR.Web.Components.Shared.OhrOnboarding UserRole="@(Auth.Role ?? "Anstalld")" />
    }
</div>

@* Performance tip: For pages that import large data lists (e.g., employee tables,
   scheduling grids), use <MudVirtualize> to virtualize rendering and reduce DOM size.
   Example: <MudVirtualize Items="_employees" Context="emp">...</MudVirtualize> *@

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Auth.InitializeAsync();
            _isDarkMode = Auth.IsDarkMode;
            if (!Auth.IsLoggedIn)
            {
                Nav.NavigateTo("/login");
            }
            StateHasChanged();
        }
    }

    private async Task OnDarkModeToggled(bool value)
    {
        _isDarkMode = value;
        await Auth.SetDarkModeAsync(value);
        StateHasChanged();
    }

    private readonly MudTheme _openHrTheme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#0e7490",
            PrimaryDarken = "#0c6078",
            PrimaryLighten = "#ecfeff",
            Secondary = "#0891b2",
            Success = "#059669",
            Warning = "#d97706",
            Error = "#dc2626",
            Info = "#0284c7",
            Background = "#f6f5f2",
            Surface = "#ffffff",
            AppbarBackground = "#1b2838",
            DrawerBackground = "#fafaf8",
            TextPrimary = "#1a1a2e",
            TextSecondary = "#6b7280",
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#38bdf8",
            PrimaryDarken = "#0e7490",
            PrimaryLighten = "#0c4a6e",
            Secondary = "#22d3ee",
            Success = "#34d399",
            Warning = "#fbbf24",
            Error = "#f87171",
            Info = "#38bdf8",
            Background = "#0f1419",
            Surface = "#1a2332",
            AppbarBackground = "#0d1117",
            DrawerBackground = "#141c27",
            TextPrimary = "#e2e8f0",
            TextSecondary = "#94a3b8",
        },
        Typography = new Typography
        {
            Default = new DefaultTypography
            {
                FontFamily = new[] { "Plus Jakarta Sans", "-apple-system", "system-ui", "sans-serif" },
                FontSize = "1rem",
            },
            H1 = new H1Typography { FontSize = "2rem", FontWeight = "800" },
            H2 = new H2Typography { FontSize = "1.5rem", FontWeight = "700" },
            H4 = new H4Typography { FontSize = "1.5rem", FontWeight = "800" },
            H6 = new H6Typography { FontSize = "1.125rem", FontWeight = "700" },
            Button = new ButtonTypography { FontSize = "0.9rem", FontWeight = "600" },
        },
        LayoutProperties = new LayoutProperties
        {
            DefaultBorderRadius = "12px",
        }
    };
}
