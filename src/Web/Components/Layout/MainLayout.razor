@inherits LayoutComponentBase

<div class="rhr-app">
    <aside class="rhr-sidebar" role="navigation" aria-label="Huvudnavigation">
        <div class="rhr-sidebar__header">
            <h2>OpenHR</h2>
            <span class="rhr-sidebar__subtitle">Fritt HR-system</span>
        </div>
        <NavMenu />
    </aside>
    <main class="rhr-main" id="main-content">
        <header class="rhr-topbar">
            <div class="rhr-topbar__breadcrumb">@Body?.GetType().Name</div>
            <div class="rhr-topbar__user">
                <span>Användare</span>
            </div>
        </header>
        <div class="rhr-content">
            @Body
        </div>
    </main>
</div>
