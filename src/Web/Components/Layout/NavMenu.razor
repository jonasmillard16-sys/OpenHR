@inject RegionHR.Web.Services.AuthService Auth
@using Microsoft.Extensions.Localization
@using RegionHR.Web
@inject IStringLocalizer<SharedResources> L

<MudNavMenu Bordered="true" Class="py-2">
    <MudNavLink Href="/" Icon="@Icons.Material.Filled.Home" Match="NavLinkMatch.All">@L["Start"]</MudNavLink>

    @if (Auth.IsInitialized && Auth.IsChef)
    {
        <MudNavGroup Title="@L["Personnel"]" Icon="@Icons.Material.Filled.People"
                     Expanded="@_personalOpen" ExpandedChanged="@(v => _personalOpen = v)">
            <MudNavLink Href="/anstallda">@L["Employees"]</MudNavLink>
            <MudNavLink Href="/organisation">@L["Organisation"]</MudNavLink>
            <MudNavLink Href="/positioner">@L["Positions"]</MudNavLink>
            <MudNavLink Href="/kompetens">@L["CompetenceRegistry"]</MudNavLink>
        </MudNavGroup>
    }

    @if (Auth.IsInitialized && Auth.IsHR)
    {
        <MudNavGroup Title="@L["Salary"]" Icon="@Icons.Material.Filled.Payments"
                     Expanded="@_lonOpen" ExpandedChanged="@(v => _lonOpen = v)">
            <MudNavLink Href="/lon/korningar">@L["PayRuns"]</MudNavLink>
            <MudNavLink Href="/lon/lonearter">@L["PayTypes"]</MudNavLink>
            <MudNavLink Href="/loneoversyn">@L["SalaryReview"]</MudNavLink>
            <MudNavLink Href="/lon/statistik">@L["Statistics"]</MudNavLink>
        </MudNavGroup>
    }

    @if (Auth.IsInitialized && Auth.IsChef)
    {
        <MudNavGroup Title="@L["ScheduleAndTime"]" Icon="@Icons.Material.Filled.CalendarMonth"
                     Expanded="@_schemaOpen" ExpandedChanged="@(v => _schemaOpen = v)">
            <MudNavLink Href="/schema">@L["ScheduleOverview"]</MudNavLink>
            <MudNavLink Href="/schema/realtid">@L["RealTimeView"]</MudNavLink>
            <MudNavLink Href="/schema/bemanning">@L["Staffing"]</MudNavLink>
            <MudNavLink Href="/schema/optimering">@L["Optimization"]</MudNavLink>
            <MudNavLink Href="/schema/prognos">@L["DemandForecast"]</MudNavLink>
            <MudNavLink Href="/schema/tillganglighet">@L["Availability"]</MudNavLink>
            <MudNavLink Href="/stampling">@L["TimeClocking"]</MudNavLink>
            <MudNavLink Href="/tidrapporter">@L["TimeReports"]</MudNavLink>
        </MudNavGroup>

        <MudNavLink Href="/arenden" Icon="@Icons.Material.Filled.Assignment">@L["Cases"]</MudNavLink>
    }

    <MudNavLink Href="/helpdesk" Icon="@Icons.Material.Filled.SupportAgent">@L["Helpdesk"]</MudNavLink>

    @if (Auth.IsInitialized && Auth.IsHR)
    {
        <MudNavLink Href="/helpdesk/agent" Icon="@Icons.Material.Filled.Headset">@L["AgentWorkspace"]</MudNavLink>
    }

    <MudNavLink Href="/ledighet" Icon="@Icons.Material.Filled.BeachAccess">@L["Leave"]</MudNavLink>

    <MudNavGroup Title="@L["Career"]" Icon="@Icons.Material.Filled.TrendingUp"
                 Expanded="@_karriarOpen" ExpandedChanged="@(v => _karriarOpen = v)">
        <MudNavLink Href="/karriar">@L["TalentMarketplace"]</MudNavLink>
        <MudNavLink Href="/karriar/minutveckling">@L["MyCareerDevelopment"]</MudNavLink>
        <MudNavLink Href="/karriar/mentorskap">@L["Mentorship"]</MudNavLink>
        <MudNavLink Href="/kompetens/endorsements">@L["Endorsements"]</MudNavLink>
    </MudNavGroup>

    @if (Auth.IsInitialized && Auth.IsChef)
    {
        <MudNavLink Href="/godkannanden" Icon="@Icons.Material.Filled.CheckCircle">@L["Approvals"]</MudNavLink>
        <MudNavLink Href="/journeys" Icon="@Icons.Material.Filled.Route">@L["EmployeeJourneys"]</MudNavLink>
        <MudNavLink Href="/halsosam" Icon="@Icons.Material.Filled.LocalHospital">@L["HalsoSAM"]</MudNavLink>
        <MudNavLink Href="/arbetsmiljo" Icon="@Icons.Material.Filled.Shield">@L["WorkEnvironment"]</MudNavLink>
        <MudNavLink Href="/las" Icon="@Icons.Material.Filled.Warning">@L["LAS"]</MudNavLink>
        <MudNavLink Href="/dokument" Icon="@Icons.Material.Filled.Description">@L["Documents"]</MudNavLink>
        <MudNavLink Href="/medarbetarsamtal" Icon="@Icons.Material.Filled.RecordVoiceOver">@L["PerformanceReviews"]</MudNavLink>
        <MudNavLink Href="/chef/1-1" Icon="@Icons.Material.Filled.Forum">1:1-möten</MudNavLink>
        <MudNavLink Href="/chef/scorecard" Icon="@Icons.Material.Filled.Assessment">Chefsstyrkort</MudNavLink>
        <MudNavGroup Title="@L["Recruitment"]" Icon="@Icons.Material.Filled.PersonSearch"
                     Expanded="@_rekryteringOpen" ExpandedChanged="@(v => _rekryteringOpen = v)">
            <MudNavLink Href="/rekrytering/vakanser">@L["Vacancies"]</MudNavLink>
            <MudNavLink Href="/rekrytering/talangpool">@L["TalentPool"]</MudNavLink>
        </MudNavGroup>
        <MudNavGroup Title="@L["Benefits"]" Icon="@Icons.Material.Filled.CardGiftcard"
                     Expanded="@_formanerOpen" ExpandedChanged="@(v => _formanerOpen = v)">
            <MudNavLink Href="/formaner">@L["BenefitsOverview"]</MudNavLink>
            <MudNavLink Href="/formaner/enrollment">@L["BenefitsEnrollment"]</MudNavLink>
            <MudNavLink Href="/formaner/val">@L["OpenEnrollment"]</MudNavLink>
            <MudNavLink Href="/formaner/livshandelse">@L["LifeEvent"]</MudNavLink>
            <MudNavLink Href="/formaner/sammanstallning">@L["BenefitsSummary"]</MudNavLink>
        </MudNavGroup>
        <MudNavGroup Title="@L["Reports"]" Icon="@Icons.Material.Filled.BarChart"
                     Expanded="@_rapporterOpen" ExpandedChanged="@(v => _rapporterOpen = v)">
            <MudNavLink Href="/rapporter">@L["ReportLibrary"]</MudNavLink>
            <MudNavLink Href="/rapporter/bygg">@L["ReportBuilder"]</MudNavLink>
            <MudNavLink Href="/rapporter/kpi">@L["KPIDashboard"]</MudNavLink>
            <MudNavLink Href="/rapporter/prediktion">@L["PredictiveAnalysis"]</MudNavLink>
            <MudNavLink Href="/rapporter/workforce-plan">@L["WorkforcePlanning"]</MudNavLink>
            <MudNavLink Href="/rapporter/flight-risk">@L["FlightRisk"]</MudNavLink>
            <MudNavLink Href="/rapporter/lonetransparens">@L["PayTransparency"]</MudNavLink>
            <MudNavLink Href="/rapporter/scenarioplanering">@L["ScenarioPlanning"]</MudNavLink>
        </MudNavGroup>
        <MudNavGroup Title="@L["ContractStaff"]" Icon="@Icons.Material.Filled.GroupWork"
                     Expanded="@_vmsOpen" ExpandedChanged="@(v => _vmsOpen = v)">
            <MudNavLink Href="/vms">@L["ContractOverview"]</MudNavLink>
            <MudNavLink Href="/vms/leverantorer">@L["Suppliers"]</MudNavLink>
            <MudNavLink Href="/vms/ramavtal">@L["FrameworkAgreements"]</MudNavLink>
            <MudNavLink Href="/vms/bestallningar">@L["Orders"]</MudNavLink>
            <MudNavLink Href="/vms/tidrapporter">@L["TimeReports"]</MudNavLink>
            <MudNavLink Href="/vms/fakturor">@L["Invoices"]</MudNavLink>
            <MudNavLink Href="/vms/statistik">@L["Statistics"]</MudNavLink>
            <MudNavLink Href="/vms/fskatt">@L["FSkattCompliance"]</MudNavLink>
        </MudNavGroup>
    }

    @if (Auth.IsInitialized && Auth.IsHR)
    {
        <MudDivider Class="my-2" />
        <MudNavLink Href="/admin/konfiguration" Icon="@Icons.Material.Filled.Settings">@L["Settings"]</MudNavLink>
        <MudNavLink Href="/admin/provisionering" Icon="@Icons.Material.Filled.ManageAccounts">@L["IdentityManagement"]</MudNavLink>
        <MudNavLink Href="/admin/migration" Icon="@Icons.Material.Filled.CloudUpload">@L["DataMigration"]</MudNavLink>
        <MudNavLink Href="/admin/automatisering" Icon="@Icons.Material.Filled.SmartToy">@L["Automation"]</MudNavLink>
        <MudNavLink Href="/admin/kollektivavtal" Icon="@Icons.Material.Filled.Handshake">@L["CollectiveAgreements"]</MudNavLink>
        <MudNavLink Href="/admin/rapporter/schema" Icon="@Icons.Material.Filled.Schedule">@L["ScheduledReports"]</MudNavLink>
        <MudNavLink Href="/admin/karriarvagar" Icon="@Icons.Material.Filled.Route">@L["CareerPaths"]</MudNavLink>
        <MudNavLink Href="/admin/talangmarknad" Icon="@Icons.Material.Filled.Storefront">@L["TalentMarketplace"]</MudNavLink>
        <MudNavLink Href="/admin/custom-objects" Icon="@Icons.Material.Filled.Extension">@L["CustomObjects"]</MudNavLink>
        <MudNavLink Href="/admin/workflows" Icon="@Icons.Material.Filled.AccountTree">@L["Workflows"]</MudNavLink>
        <MudNavLink Href="/admin/tillagg" Icon="@Icons.Material.Filled.Store">@L["Addons"]</MudNavLink>
        <MudNavGroup Title="@L["HelpdeskAdmin"]" Icon="@Icons.Material.Filled.SupportAgent"
                     Expanded="@_helpdeskAdminOpen" ExpandedChanged="@(v => _helpdeskAdminOpen = v)">
            <MudNavLink Href="/admin/helpdesk/sla">@L["SLAManagement"]</MudNavLink>
            <MudNavLink Href="/admin/helpdesk/koer">@L["QueueManagement"]</MudNavLink>
            <MudNavLink Href="/admin/helpdesk/mallar">@L["ResponseTemplates"]</MudNavLink>
        </MudNavGroup>
        <MudNavGroup Title="@L["BenefitsAdmin"]" Icon="@Icons.Material.Filled.AdminPanelSettings"
                     Expanded="@_formanerAdminOpen" ExpandedChanged="@(v => _formanerAdminOpen = v)">
            <MudNavLink Href="/admin/formaner/planer">@L["Plans"]</MudNavLink>
            <MudNavLink Href="/admin/formaner/regler">@L["EligibilityRules"]</MudNavLink>
            <MudNavLink Href="/admin/formaner/perioder">@L["EnrollmentPeriods"]</MudNavLink>
        </MudNavGroup>
        <MudNavLink Href="/admin/ona" Icon="@Icons.Material.Filled.Hub">Nätverksanalys (ONA)</MudNavLink>
        <MudNavLink Href="/gdpr" Icon="@Icons.Material.Filled.Security">@L["GDPR"]</MudNavLink>
        <MudNavLink Href="/audit" Icon="@Icons.Material.Filled.History">@L["AuditLog"]</MudNavLink>
    }

    <MudNavLink Href="/notiser" Icon="@Icons.Material.Filled.Notifications">@L["Notifications"]</MudNavLink>

    <MudDivider Class="my-2" />
    <MudNavLink Href="/minsida" Icon="@Icons.Material.Filled.AccountCircle">@L["MyPage"]</MudNavLink>
</MudNavMenu>

@code {
    private bool _personalOpen;
    private bool _lonOpen;
    private bool _schemaOpen;
    private bool _rekryteringOpen;
    private bool _formanerOpen;
    private bool _karriarOpen;
    private bool _rapporterOpen;
    private bool _vmsOpen;
    private bool _formanerAdminOpen;
    private bool _helpdeskAdminOpen;
}
