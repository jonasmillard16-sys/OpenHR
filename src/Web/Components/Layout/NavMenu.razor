@inject RegionHR.Web.Services.AuthService Auth
@using Microsoft.Extensions.Localization
@using RegionHR.Web
@inject IStringLocalizer<SharedResources> L

<MudNavMenu Bordered="true" Class="py-2">
    <MudNavLink Href="/" Icon="@Icons.Material.Filled.Home" Match="NavLinkMatch.All">@L["Start"]</MudNavLink>

    @if (Auth.IsInitialized && Auth.IsChef)
    {
        <MudNavGroup Title="@L["Personnel"]" Icon="@Icons.Material.Filled.People"
                     Expanded="@_personalOpen" ExpandedChanged="@(v => _personalOpen = v)">
            <MudNavLink Href="/anstallda">@L["Employees"]</MudNavLink>
            <MudNavLink Href="/organisation">@L["Organisation"]</MudNavLink>
            <MudNavLink Href="/positioner">@L["Positions"]</MudNavLink>
            <MudNavLink Href="/kompetens">@L["CompetenceRegistry"]</MudNavLink>
        </MudNavGroup>
    }

    @if (Auth.IsInitialized && Auth.IsHR)
    {
        <MudNavGroup Title="@L["Salary"]" Icon="@Icons.Material.Filled.Payments"
                     Expanded="@_lonOpen" ExpandedChanged="@(v => _lonOpen = v)">
            <MudNavLink Href="/lon/korningar">@L["PayRuns"]</MudNavLink>
            <MudNavLink Href="/lon/lonearter">@L["PayTypes"]</MudNavLink>
            <MudNavLink Href="/loneoversyn">@L["SalaryReview"]</MudNavLink>
            <MudNavLink Href="/lon/statistik">@L["Statistics"]</MudNavLink>
        </MudNavGroup>
    }

    @if (Auth.IsInitialized && Auth.IsChef)
    {
        <MudNavGroup Title="@L["ScheduleAndTime"]" Icon="@Icons.Material.Filled.CalendarMonth"
                     Expanded="@_schemaOpen" ExpandedChanged="@(v => _schemaOpen = v)">
            <MudNavLink Href="/schema">@L["ScheduleOverview"]</MudNavLink>
            <MudNavLink Href="/schema/realtid">Realtidsvy</MudNavLink>
            <MudNavLink Href="/schema/bemanning">@L["Staffing"]</MudNavLink>
            <MudNavLink Href="/schema/optimering">Optimering</MudNavLink>
            <MudNavLink Href="/schema/prognos">Behovsprognos</MudNavLink>
            <MudNavLink Href="/schema/tillganglighet">Tillganglighet</MudNavLink>
            <MudNavLink Href="/stampling">@L["TimeClocking"]</MudNavLink>
            <MudNavLink Href="/tidrapporter">@L["TimeReports"]</MudNavLink>
        </MudNavGroup>

        <MudNavLink Href="/arenden" Icon="@Icons.Material.Filled.Assignment">@L["Cases"]</MudNavLink>
    }

    <MudNavLink Href="/helpdesk" Icon="@Icons.Material.Filled.SupportAgent">Helpdesk</MudNavLink>

    @if (Auth.IsInitialized && Auth.IsHR)
    {
        <MudNavLink Href="/helpdesk/agent" Icon="@Icons.Material.Filled.Headset">Agent Workspace</MudNavLink>
    }

    <MudNavLink Href="/ledighet" Icon="@Icons.Material.Filled.BeachAccess">@L["Leave"]</MudNavLink>

    <MudNavGroup Title="Karriär" Icon="@Icons.Material.Filled.TrendingUp"
                 Expanded="@_karriarOpen" ExpandedChanged="@(v => _karriarOpen = v)">
        <MudNavLink Href="/karriar">Talangmarknad</MudNavLink>
        <MudNavLink Href="/karriar/minutveckling">Min karriarutveckling</MudNavLink>
        <MudNavLink Href="/karriar/mentorskap">Mentorskap</MudNavLink>
        <MudNavLink Href="/kompetens/endorsements">Endorsements</MudNavLink>
    </MudNavGroup>

    @if (Auth.IsInitialized && Auth.IsChef)
    {
        <MudNavLink Href="/godkannanden" Icon="@Icons.Material.Filled.CheckCircle">@L["Approvals"]</MudNavLink>
        <MudNavLink Href="/journeys" Icon="@Icons.Material.Filled.Route">Medarbetarresor</MudNavLink>
        <MudNavLink Href="/halsosam" Icon="@Icons.Material.Filled.LocalHospital">@L["HalsoSAM"]</MudNavLink>
        <MudNavLink Href="/arbetsmiljo" Icon="@Icons.Material.Filled.Shield">Arbetsmiljö (SAM)</MudNavLink>
        <MudNavLink Href="/las" Icon="@Icons.Material.Filled.Warning">@L["LAS"]</MudNavLink>
        <MudNavLink Href="/dokument" Icon="@Icons.Material.Filled.Description">@L["Documents"]</MudNavLink>
        <MudNavLink Href="/medarbetarsamtal" Icon="@Icons.Material.Filled.RecordVoiceOver">@L["PerformanceReviews"]</MudNavLink>
        <MudNavGroup Title="@L["Recruitment"]" Icon="@Icons.Material.Filled.PersonSearch"
                     Expanded="@_rekryteringOpen" ExpandedChanged="@(v => _rekryteringOpen = v)">
            <MudNavLink Href="/rekrytering/vakanser">Vakanser</MudNavLink>
            <MudNavLink Href="/rekrytering/talangpool">Talangpool</MudNavLink>
        </MudNavGroup>
        <MudNavGroup Title="Förmåner" Icon="@Icons.Material.Filled.CardGiftcard"
                     Expanded="@_formanerOpen" ExpandedChanged="@(v => _formanerOpen = v)">
            <MudNavLink Href="/formaner">Översikt</MudNavLink>
            <MudNavLink Href="/formaner/enrollment">Förmånsval</MudNavLink>
            <MudNavLink Href="/formaner/val">Öppet val</MudNavLink>
            <MudNavLink Href="/formaner/livshandelse">Livshändelse</MudNavLink>
            <MudNavLink Href="/formaner/sammanstallning">Sammanställning</MudNavLink>
        </MudNavGroup>
        <MudNavGroup Title="@L["Reports"]" Icon="@Icons.Material.Filled.BarChart"
                     Expanded="@_rapporterOpen" ExpandedChanged="@(v => _rapporterOpen = v)">
            <MudNavLink Href="/rapporter">Rapportbibliotek</MudNavLink>
            <MudNavLink Href="/rapporter/bygg">Rapportbyggare</MudNavLink>
            <MudNavLink Href="/rapporter/kpi">KPI Dashboard</MudNavLink>
            <MudNavLink Href="/rapporter/prediktion">Prediktiv analys</MudNavLink>
            <MudNavLink Href="/rapporter/workforce-plan">Bemanningsplanering</MudNavLink>
            <MudNavLink Href="/rapporter/flight-risk">Uppsagningsrisk</MudNavLink>
        </MudNavGroup>
        <MudNavGroup Title="Inhyrd personal" Icon="@Icons.Material.Filled.GroupWork"
                     Expanded="@_vmsOpen" ExpandedChanged="@(v => _vmsOpen = v)">
            <MudNavLink Href="/vms">Oversikt</MudNavLink>
            <MudNavLink Href="/vms/leverantorer">Leverantorer</MudNavLink>
            <MudNavLink Href="/vms/ramavtal">Ramavtal</MudNavLink>
            <MudNavLink Href="/vms/bestallningar">Bestallningar</MudNavLink>
            <MudNavLink Href="/vms/tidrapporter">Tidrapporter</MudNavLink>
            <MudNavLink Href="/vms/fakturor">Fakturor</MudNavLink>
            <MudNavLink Href="/vms/statistik">Statistik</MudNavLink>
        </MudNavGroup>
    }

    @if (Auth.IsInitialized && Auth.IsHR)
    {
        <MudDivider Class="my-2" />
        <MudNavLink Href="/admin/konfiguration" Icon="@Icons.Material.Filled.Settings">@L["Settings"]</MudNavLink>
        <MudNavLink Href="/admin/provisionering" Icon="@Icons.Material.Filled.ManageAccounts">Identitetshantering</MudNavLink>
        <MudNavLink Href="/admin/migration" Icon="@Icons.Material.Filled.CloudUpload">Migrering</MudNavLink>
        <MudNavLink Href="/admin/automatisering" Icon="@Icons.Material.Filled.SmartToy">Automatisering</MudNavLink>
        <MudNavLink Href="/admin/kollektivavtal" Icon="@Icons.Material.Filled.Handshake">Kollektivavtal</MudNavLink>
        <MudNavLink Href="/admin/rapporter/schema" Icon="@Icons.Material.Filled.Schedule">Schemalagda rapporter</MudNavLink>
        <MudNavLink Href="/admin/karriarvagar" Icon="@Icons.Material.Filled.Route">Karriarvagar</MudNavLink>
        <MudNavLink Href="/admin/talangmarknad" Icon="@Icons.Material.Filled.Storefront">Talangmarknad</MudNavLink>
        <MudNavLink Href="/admin/custom-objects" Icon="@Icons.Material.Filled.Extension">Anpassade objekt</MudNavLink>
        <MudNavLink Href="/admin/workflows" Icon="@Icons.Material.Filled.AccountTree">Arbetsfloden</MudNavLink>
        <MudNavLink Href="/admin/tillagg" Icon="@Icons.Material.Filled.Store">Tillagg</MudNavLink>
        <MudNavGroup Title="Helpdesk Admin" Icon="@Icons.Material.Filled.SupportAgent"
                     Expanded="@_helpdeskAdminOpen" ExpandedChanged="@(v => _helpdeskAdminOpen = v)">
            <MudNavLink Href="/admin/helpdesk/sla">SLA-hantering</MudNavLink>
            <MudNavLink Href="/admin/helpdesk/koer">Kohantering</MudNavLink>
            <MudNavLink Href="/admin/helpdesk/mallar">Svarsmallar</MudNavLink>
        </MudNavGroup>
        <MudNavGroup Title="Förmånsadmin" Icon="@Icons.Material.Filled.AdminPanelSettings"
                     Expanded="@_formanerAdminOpen" ExpandedChanged="@(v => _formanerAdminOpen = v)">
            <MudNavLink Href="/admin/formaner/planer">Planer</MudNavLink>
            <MudNavLink Href="/admin/formaner/regler">Behörighetsregler</MudNavLink>
            <MudNavLink Href="/admin/formaner/perioder">Valperioder</MudNavLink>
        </MudNavGroup>
        <MudNavLink Href="/gdpr" Icon="@Icons.Material.Filled.Security">@L["GDPR"]</MudNavLink>
        <MudNavLink Href="/audit" Icon="@Icons.Material.Filled.History">@L["AuditLog"]</MudNavLink>
    }

    <MudNavLink Href="/notiser" Icon="@Icons.Material.Filled.Notifications">@L["Notifications"]</MudNavLink>

    <MudDivider Class="my-2" />
    <MudNavLink Href="/minsida" Icon="@Icons.Material.Filled.AccountCircle">@L["MyPage"]</MudNavLink>
</MudNavMenu>

@code {
    private bool _personalOpen;
    private bool _lonOpen;
    private bool _schemaOpen;
    private bool _rekryteringOpen;
    private bool _formanerOpen;
    private bool _karriarOpen;
    private bool _rapporterOpen;
    private bool _vmsOpen;
    private bool _formanerAdminOpen;
    private bool _helpdeskAdminOpen;
}
