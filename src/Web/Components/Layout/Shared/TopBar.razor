@namespace RegionHR.Web.Components.Layout.Shared
@using RegionHR.Infrastructure.Persistence
@using Microsoft.EntityFrameworkCore

<MudAppBar Fixed="true" Color="Color.Primary" Elevation="1">
    <MudText Typo="Typo.h6" Class="ml-3" Style="font-weight: 700;">OpenHR</MudText>
    <MudAutocomplete T="string" Label="" Placeholder="Sök anställd eller sida..."
                     SearchFunc="Search" Variant="Variant.Outlined" Dense="true"
                     Style="max-width: 300px; margin-left: 1rem;"
                     Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                     ValueChanged="OnSearchSelected" />
    <MudSpacer />
    <MudIconButton Icon="@(_darkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                   Color="Color.Inherit" OnClick="ToggleDarkMode" aria-label="Växla mörkt/ljust läge" />
    <MudIconButton Icon="@Icons.Material.Filled.Language"
                   Color="Color.Inherit"
                   aria-label="Byt språk" />
    <MudBadge Content="@UnreadCount" Overlap="true" Color="Color.Error"
              Visible="@(UnreadCount > 0)">
        <MudIconButton Icon="@Icons.Material.Filled.Notifications"
                       Color="Color.Inherit"
                       aria-label="@($"{UnreadCount} olästa notiser")"
                       OnClick="@(() => Nav?.NavigateTo("/notiser"))" />
    </MudBadge>
    <MudMenu Icon="@Icons.Material.Filled.Person" Color="Color.Inherit"
             AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight"
             aria-label="Användarmeny">
        <MudMenuItem>@UserName</MudMenuItem>
        <MudMenuItem Icon="@Icons.Material.Filled.Settings">Inställningar</MudMenuItem>
        <MudMenuItem Icon="@Icons.Material.Filled.Logout">Logga ut</MudMenuItem>
    </MudMenu>
</MudAppBar>

@code {
    [Parameter] public string UserName { get; set; } = "Användare";
    [Parameter] public int UnreadCount { get; set; }

    private bool _darkMode;
    private void ToggleDarkMode() { _darkMode = !_darkMode; }

    [Inject] private RegionHRDbContext? Db { get; set; }
    [Inject] private NavigationManager? Nav { get; set; }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            if (Db is not null)
            {
                UnreadCount = await Db.Notifications.CountAsync(n => !n.IsRead);
            }
        }
        catch { }
    }

    private static readonly Dictionary<string, string> _navSuggestions = new()
    {
        ["schema"] = "/schema",
        ["bemanning"] = "/schema/bemanning",
        ["lönekörning"] = "/lon/korningar",
        ["lönespec"] = "/minsida/lon",
        ["semester"] = "/ledighet",
        ["sjukanmälan"] = "/minsida/sjukanmalan",
        ["las"] = "/las",
        ["gdpr"] = "/gdpr",
        ["rekrytering"] = "/rekrytering/vakanser",
        ["rapporter"] = "/rapporter",
        ["inställningar"] = "/admin/konfiguration",
        ["medarbetarsamtal"] = "/medarbetarsamtal",
        ["dokument"] = "/dokument",
        ["kompetens"] = "/kompetens",
        ["notiser"] = "/notiser",
    };

    private async Task<IEnumerable<string>> Search(string value, CancellationToken ct)
    {
        if (string.IsNullOrWhiteSpace(value) || value.Length < 2)
            return Array.Empty<string>();

        var term = value.ToLower();
        var results = new List<string>();

        // Navigation suggestions
        var navMatches = _navSuggestions
            .Where(kv => kv.Key.Contains(term))
            .Select(kv => $"\u27a1 {char.ToUpper(kv.Key[0])}{kv.Key[1..]} ({kv.Value})")
            .Take(5);
        results.AddRange(navMatches);

        // Employee search
        if (Db is not null)
        {
            var employees = await Db.Employees
                .Where(e => e.Fornamn.ToLower().Contains(term) || e.Efternamn.ToLower().Contains(term))
                .Take(10)
                .Select(e => $"{e.Fornamn} {e.Efternamn} ({e.Id.Value})")
                .ToListAsync(ct);
            results.AddRange(employees);
        }

        return results;
    }

    private void OnSearchSelected(string value)
    {
        if (string.IsNullOrEmpty(value))
            return;

        // Navigation suggestion selected (starts with arrow)
        if (value.StartsWith("\u27a1") && value.Contains('(') && value.Contains(')'))
        {
            var route = value.Split('(').Last().TrimEnd(')');
            Nav?.NavigateTo(route);
            return;
        }

        // Employee selected
        if (value.Contains('(') && value.Contains(')'))
        {
            var guidStr = value.Split('(').Last().TrimEnd(')');
            if (Guid.TryParse(guidStr, out var id))
                Nav?.NavigateTo($"/anstallda/{id}");
        }
    }
}
