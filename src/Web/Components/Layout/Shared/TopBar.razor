@namespace RegionHR.Web.Components.Layout.Shared
@using RegionHR.Infrastructure.Persistence
@using Microsoft.EntityFrameworkCore
@using Microsoft.Extensions.Localization
@using RegionHR.Web.Localization

<MudAppBar Fixed="true" Color="Color.Primary" Elevation="1">
    <MudText Typo="Typo.h6" Class="ml-3" Style="font-weight: 700; cursor: pointer;" @onclick="@(() => Nav?.NavigateTo("/"))">OpenHR</MudText>

    <div style="margin-left: 1rem; max-width: 320px; flex: 1;">
        <MudAutocomplete T="string" Placeholder="@L["Search"]"
                         SearchFunc="Search" Variant="Variant.Filled" Dense="true"
                         Style="background: rgba(255,255,255,0.15); border-radius: 8px;"
                         Class="white-text-field"
                         Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                         AdornmentColor="Color.Inherit"
                         ValueChanged="OnSearchSelected" />
    </div>

    <MudSpacer />

    @* Dark mode toggle *@
    <MudTooltip Text="@(IsDarkMode ? L["LightMode"] : L["DarkMode"])">
        <MudIconButton Icon="@(IsDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit" OnClick="ToggleDarkMode" aria-label="@L["DarkMode"]" />
    </MudTooltip>

    @* Language selector *@
    <MudMenu Icon="@Icons.Material.Filled.Language" Color="Color.Inherit"
             AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight"
             aria-label="@L["ChangeLanguage"]">
        <MudMenuItem OnClick="@(() => SetLanguage("sv"))">
            Svenska @(_currentLang == "sv" ? "\u2713" : "")
        </MudMenuItem>
        <MudMenuItem OnClick="@(() => SetLanguage("en"))">
            English @(_currentLang == "en" ? "\u2713" : "")
        </MudMenuItem>
    </MudMenu>

    @* Notifications *@
    <MudTooltip Text="@($"{UnreadCount} {L["Notifications"].ToString().ToLower()}")">
        <MudBadge Content="@UnreadCount" Overlap="true" Color="Color.Error"
                  Visible="@(UnreadCount > 0)">
            <MudIconButton Icon="@Icons.Material.Filled.Notifications"
                           Color="Color.Inherit"
                           OnClick="@(() => Nav?.NavigateTo("/notiser"))"
                           aria-label="@L["Notifications"]" />
        </MudBadge>
    </MudTooltip>

    @* User menu *@
    <MudMenu Icon="@Icons.Material.Filled.Person" Color="Color.Inherit"
             AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight"
             aria-label="Användarmeny">
        <MudMenuItem>@UserName</MudMenuItem>
        <MudMenuItem Icon="@Icons.Material.Filled.AccountCircle"
                     OnClick="@(() => Nav?.NavigateTo("/minsida"))">@L["MyPage"]</MudMenuItem>
        <MudMenuItem Icon="@Icons.Material.Filled.Settings"
                     OnClick="@(() => Nav?.NavigateTo("/notiser/installningar"))">@L["Settings"]</MudMenuItem>
        <MudDivider />
        <MudMenuItem Icon="@Icons.Material.Filled.Logout" OnClick="HandleLogout">@L["Logout"]</MudMenuItem>
    </MudMenu>
</MudAppBar>

<style>
    .white-text-field input,
    .white-text-field .mud-input-adornment { color: white !important; }
    .white-text-field input::placeholder { color: rgba(255,255,255,0.7) !important; }
    .white-text-field .mud-input-outlined-border { border-color: rgba(255,255,255,0.3) !important; }
</style>

@code {
    [Parameter] public string UserName { get; set; } = "Användare";
    [Parameter] public int UnreadCount { get; set; }
    [Parameter] public bool IsDarkMode { get; set; }
    [Parameter] public EventCallback<bool> IsDarkModeChanged { get; set; }

    private string _currentLang = "sv";
    private List<string> _recentSearches = new();

    [Inject] private RegionHRDbContext? Db { get; set; }
    [Inject] private NavigationManager? Nav { get; set; }
    [Inject] private IJSRuntime? JS { get; set; }
    [Inject] private RegionHR.Web.Services.AuthService? AuthService { get; set; }
    [Inject] private IStringLocalizer<SharedResources> L { get; set; } = default!;

    private async Task ToggleDarkMode()
    {
        await IsDarkModeChanged.InvokeAsync(!IsDarkMode);
    }

    private async Task SetLanguage(string lang)
    {
        _currentLang = lang;
        // Set culture cookie and reload page
        if (JS is not null)
        {
            await JS.InvokeVoidAsync("eval",
                $"document.cookie = '.AspNetCore.Culture=c={lang}|uic={lang};path=/;max-age=31536000'; location.reload();");
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            if (Db is not null)
                UnreadCount = await Db.Notifications.CountAsync(n => !n.IsRead);
        }
        catch { }
    }

    private static readonly Dictionary<string, string> _navSuggestions = new()
    {
        ["schema"] = "/schema",
        ["bemanning"] = "/schema/bemanning",
        ["lönekörning"] = "/lon/korningar",
        ["lönespec"] = "/minsida/lon",
        ["semester"] = "/ledighet",
        ["sjukanmälan"] = "/minsida/sjukanmalan",
        ["las"] = "/las",
        ["gdpr"] = "/gdpr",
        ["rekrytering"] = "/rekrytering/vakanser",
        ["rapporter"] = "/rapporter",
        ["inställningar"] = "/admin/konfiguration",
        ["medarbetarsamtal"] = "/medarbetarsamtal",
        ["dokument"] = "/dokument",
        ["kompetens"] = "/kompetens",
        ["notiser"] = "/notiser",
        // Ärende types
        ["rehab"] = "/halsosam",
        ["rehabilitering"] = "/halsosam",
        // Document types
        ["anställningsavtal"] = "/dokument",
        ["tjänstgöringsintyg"] = "/dokument",
        // More page routes
        ["godkännanden"] = "/godkannanden",
        ["dashboard"] = "/",
        ["start"] = "/",
        ["personal"] = "/anstallda",
        ["anställda"] = "/anstallda",
        ["organisation"] = "/organisation",
        ["positioner"] = "/positioner",
        ["tidrapporter"] = "/tidrapporter",
        ["instämpling"] = "/stampling",
        ["löneöversyn"] = "/loneoversyn",
        ["lönearter"] = "/lon/lonearter",
        ["statistik"] = "/lon/statistik",
        ["hälsosam"] = "/halsosam",
        ["ärenden"] = "/arenden",
        ["mbl"] = "/arenden/mbl",
        ["ledighet"] = "/ledighet",
        ["kalender"] = "/ledighet/kalender",
        ["vab"] = "/ledighet/vab",
        ["föräldraledighet"] = "/ledighet/foraldraledighet",
        ["min sida"] = "/minsida",
        ["profil"] = "/minsida/profil",
        ["offboarding"] = "/offboarding",
        ["förmåner"] = "/formaner",
        ["friskvård"] = "/formaner/friskvard",
        ["utbildning"] = "/utbildning",
        ["e-learning"] = "/utbildning/elearning",
        ["audit"] = "/audit",
        ["granskningslogg"] = "/audit",
    };

    private async Task<IEnumerable<string>> Search(string value, CancellationToken ct)
    {
        // Show recent searches when search field is focused with empty text
        if (string.IsNullOrWhiteSpace(value) || value.Length < 2)
        {
            if (string.IsNullOrEmpty(value) && _recentSearches.Count > 0)
            {
                return _recentSearches.Select(s => $"\U0001F552 {s}");
            }
            return Array.Empty<string>();
        }

        var term = value.ToLower();
        var results = new List<string>();

        var navMatches = _navSuggestions
            .Where(kv => kv.Key.Contains(term))
            .Select(kv => $"\u27a1 {char.ToUpper(kv.Key[0])}{kv.Key[1..]} ({kv.Value})")
            .Take(5);
        results.AddRange(navMatches);

        if (Db is not null)
        {
            try
            {
                var employees = await Db.Employees
                    .Where(e => e.Fornamn.ToLower().Contains(term) || e.Efternamn.ToLower().Contains(term))
                    .Take(10)
                    .Select(e => $"{e.Fornamn} {e.Efternamn} ({e.Id.Value})")
                    .ToListAsync(ct);
                results.AddRange(employees);
            }
            catch { }
        }

        return results;
    }

    private async Task HandleLogout()
    {
        if (AuthService is not null)
            await AuthService.LogoutAsync();
        Nav?.NavigateTo("/login", forceLoad: true);
    }

    private void AddToRecentSearches(string searchTerm)
    {
        if (string.IsNullOrWhiteSpace(searchTerm)) return;
        _recentSearches.Remove(searchTerm);
        _recentSearches.Insert(0, searchTerm);
        if (_recentSearches.Count > 3)
            _recentSearches = _recentSearches.Take(3).ToList();
    }

    private void OnSearchSelected(string value)
    {
        if (string.IsNullOrEmpty(value)) return;

        // Handle recent search selection (clock emoji prefix)
        if (value.StartsWith("\U0001F552"))
        {
            var recentTerm = value[2..].Trim();
            // Re-trigger search with the recent term - navigate if it matches a known route
            var matchingNav = _navSuggestions
                .FirstOrDefault(kv => kv.Key.Equals(recentTerm, StringComparison.OrdinalIgnoreCase));
            if (matchingNav.Value is not null)
            {
                Nav?.NavigateTo(matchingNav.Value);
                return;
            }
        }

        if (value.StartsWith("\u27a1") && value.Contains('(') && value.Contains(')'))
        {
            var route = value.Split('(').Last().TrimEnd(')');
            // Extract search term for recent searches
            var label = value[2..].Split('(')[0].Trim();
            AddToRecentSearches(label);
            Nav?.NavigateTo(route);
            return;
        }

        if (value.Contains('(') && value.Contains(')'))
        {
            var guidStr = value.Split('(').Last().TrimEnd(')');
            if (Guid.TryParse(guidStr, out var id))
            {
                var name = value.Split('(')[0].Trim();
                AddToRecentSearches(name);
                Nav?.NavigateTo($"/anstallda/{id}");
            }
        }
    }
}
