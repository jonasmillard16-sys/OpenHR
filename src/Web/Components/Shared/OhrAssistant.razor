@namespace RegionHR.Web.Components.Shared
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Infrastructure.Services
@using RegionHR.Knowledge.Domain
@using RegionHR.SharedKernel.Domain
@using Microsoft.EntityFrameworkCore

<div style="position: fixed; bottom: 24px; right: 24px; z-index: 1000;">
    @if (_open)
    {
        <MudPaper Elevation="8" Style="width: 420px; max-height: 600px; border-radius: 16px; overflow: hidden;">
            <div style="background: var(--mud-palette-primary); color: white; padding: 16px; display: flex; justify-content: space-between; align-items: center;">
                <MudText Typo="Typo.h6" Style="color: white; font-weight: 700;">OpenHR Assistent</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Inherit" OnClick="@(() => _open = false)" Size="Size.Small" />
            </div>
            <div @ref="_chatContainer" style="padding: 16px; max-height: 420px; overflow-y: auto;">
                @foreach (var msg in _messages)
                {
                    <div style="margin-bottom: 12px; display: flex; flex-direction: column; align-items: @(msg.IsUser ? "flex-end" : "flex-start");">
                        <MudPaper Class="pa-3" Elevation="0"
                                  Style="@($"max-width: 90%; background: {(msg.IsUser ? "var(--mud-palette-primary)" : "var(--mud-palette-surface)")}; color: {(msg.IsUser ? "white" : "inherit")}; border-radius: 12px; border: {(msg.IsUser ? "none" : "1px solid var(--mud-palette-lines-default)")} ;")">
                            <MudText Typo="Typo.body2" Style="white-space: pre-wrap;">@msg.Text</MudText>
                            @if (msg.ArticleRef != null)
                            {
                                <div style="margin-top: 8px; padding: 8px; background: var(--mud-palette-background); border-radius: 8px; border-left: 3px solid var(--mud-palette-primary);">
                                    <MudText Typo="Typo.caption" Style="font-weight: 600;">@msg.ArticleRef.Titel</MudText>
                                    <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary"
                                               OnClick="@(() => NavigateToArticle(msg.ArticleRef.Id))"
                                               Style="text-transform: none; font-size: 0.75rem; padding: 0;">
                                        Läs mer
                                    </MudButton>
                                    @if (!msg.HasRated)
                                    {
                                        <span style="margin-left: 8px;">
                                            <MudIconButton Icon="@Icons.Material.Filled.ThumbUp" Size="Size.Small" Color="Color.Success"
                                                           OnClick="@(() => RateArticle(msg, 5))" />
                                            <MudIconButton Icon="@Icons.Material.Filled.ThumbDown" Size="Size.Small" Color="Color.Error"
                                                           OnClick="@(() => RateArticle(msg, 1))" />
                                        </span>
                                    }
                                </div>
                            }
                            @if (msg.Actions.Count > 0)
                            {
                                <div style="margin-top: 8px; display: flex; flex-wrap: wrap; gap: 6px;">
                                    @foreach (var action in msg.Actions)
                                    {
                                        <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                                                   OnClick="@(() => HandleAction(action.Key))"
                                                   Style="text-transform: none; font-size: 0.8rem;">
                                            @action.Value
                                        </MudButton>
                                    }
                                </div>
                            }
                        </MudPaper>
                    </div>
                }
                @if (_isLoading)
                {
                    <div style="display: flex; align-items: center; gap: 8px; padding: 8px;">
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                        <MudText Typo="Typo.caption">Söker...</MudText>
                    </div>
                }
            </div>
            <div style="padding: 12px; border-top: 1px solid var(--mud-palette-lines-default); display: flex; gap: 8px;">
                <MudTextField @bind-Value="_input" Placeholder="Ställ en fråga..." Variant="Variant.Outlined"
                              Margin="Margin.Dense" Style="flex: 1;" OnKeyDown="HandleKey"
                              Immediate="true" />
                <MudIconButton Icon="@Icons.Material.Filled.Send" Color="Color.Primary" OnClick="Send" />
            </div>
        </MudPaper>
    }
    else
    {
        <MudFab Color="Color.Primary" StartIcon="@Icons.Material.Filled.SmartToy"
                Label="Fråga OpenHR" Size="Size.Large" OnClick="@(() => _open = true)"
                Style="min-height: 56px;" />
    }
</div>

@code {
    private bool _open;
    private bool _isLoading;
    private string _input = "";
    private ElementReference _chatContainer;
    private List<ChatMessage> _messages = [new(false, "Hej! Jag är din personliga HR-assistent. Jag kan:\n\n"
        + "\u2022 Kolla dina semesterdagar och saldo\n"
        + "\u2022 Sjukanmäla dig direkt\n"
        + "\u2022 Visa ditt nästa pass\n"
        + "\u2022 Visa din senaste lön\n"
        + "\u2022 Söka i kunskapsbasen efter HR-information\n"
        + "\u2022 Ta dig till rätt sida\n\n"
        + "Fråga mig vad som helst!")];

    [Inject] private NavigationManager? Nav { get; set; }
    [Inject] private IDbContextFactory<RegionHRDbContext>? DbFactory { get; set; }
    [Inject] private RegionHR.Web.Services.AuthService? Auth { get; set; }
    [Inject] private KnowledgeBaseService? KbService { get; set; }

    private Guid? _sessionId;
    private string _userName = "";
    private int _semesterKvar;
    private int _semesterTotalt;
    private int _semesterUttagna;
    private string _nastaPass = "\u2014";
    private decimal _senasteLon;
    private decimal _senasteBrutto;

    private bool _dataLoaded;

    // NOTE: We load data in OnAfterRenderAsync instead of OnInitializedAsync to avoid
    // concurrent DbContext access. In Blazor Server, OnInitializedAsync of child components
    // (OhrAssistant lives in AdminLayout) runs in parallel with the page's OnInitializedAsync,
    // causing "A second operation was started on this context" errors.
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _dataLoaded) return;
        _dataLoaded = true;

        try
        {
            if (DbFactory == null) return;
            await using var db = await DbFactory.CreateDbContextAsync();
            var empId = Auth?.EmployeeId;
            if (empId.HasValue)
            {
                var emp = await db.Employees.FirstOrDefaultAsync(e => e.Id == EmployeeId.From(empId.Value));
                if (emp != null) _userName = emp.Fornamn;

                var year = DateTime.Today.Year;
                var balance = await db.VacationBalances.FirstOrDefaultAsync(b => b.AnstallId == empId.Value && b.Ar == year);
                if (balance != null) { _semesterKvar = balance.TillgangligaDagar; _semesterTotalt = balance.Tilldelning; _semesterUttagna = balance.UttagnaDagar; }

                var idag = DateOnly.FromDateTime(DateTime.Today);
                var nastaShift = await db.ScheduledShifts
                    .Where(s => s.AnstallId == EmployeeId.From(empId.Value) && s.Datum >= idag)
                    .OrderBy(s => s.Datum).FirstOrDefaultAsync();
                if (nastaShift != null) _nastaPass = $"{nastaShift.Datum:ddd d/M} {nastaShift.PassTyp} {nastaShift.PlaneradStart:HH:mm}\u2013{nastaShift.PlaneradSlut:HH:mm}";

                var senasteLon = await db.PayrollResults
                    .Where(r => r.AnstallId == EmployeeId.From(empId.Value))
                    .OrderByDescending(r => r.Year).ThenByDescending(r => r.Month)
                    .FirstOrDefaultAsync();
                if (senasteLon != null) { _senasteLon = senasteLon.Netto.Amount; _senasteBrutto = senasteLon.Brutto.Amount; }

                // Start conversation session
                var session = ConversationSession.Starta(empId);
                db.ConversationSessions.Add(session);
                await db.SaveChangesAsync();
                _sessionId = session.Id;
            }
        }
        catch { /* DB unavailable — assistant uses zero defaults */ }

        await InvokeAsync(StateHasChanged);
    }

    private void HandleKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") _ = SendAsync();
    }

    private void Send()
    {
        _ = SendAsync();
    }

    private async Task SendAsync()
    {
        if (string.IsNullOrWhiteSpace(_input)) return;
        var question = _input.Trim();
        _messages.Add(new(true, question));
        _input = "";
        _isLoading = true;
        StateHasChanged();

        // Persist user message
        await PersistMessageAsync("User", question);

        var response = await GetSmartAnswerAsync(question.ToLower(), question);
        _messages.Add(response);

        // Persist assistant message
        await PersistMessageAsync("Assistant", response.Text, response.ArticleRef?.Id, null);

        _isLoading = false;
        StateHasChanged();
    }

    private async Task PersistMessageAsync(string sender, string content, Guid? articleId = null, string? action = null)
    {
        try
        {
            if (DbFactory == null || !_sessionId.HasValue) return;
            await using var db = await DbFactory.CreateDbContextAsync();
            var msg = ConversationMessage.Skapa(_sessionId.Value, sender, content, articleId, action);
            db.ConversationMessages.Add(msg);

            // Update session activity
            var session = await db.ConversationSessions.FirstOrDefaultAsync(s => s.Id == _sessionId.Value);
            session?.UppdateraAktivitet();

            await db.SaveChangesAsync();
        }
        catch { /* Non-critical — don't break the chat */ }
    }

    private void HandleAction(string actionKey)
    {
        switch (actionKey)
        {
            case "navigate_sjukanmalan":
                Nav?.NavigateTo("/minsida/sjukanmalan");
                _open = false;
                break;
            case "navigate_semester":
                Nav?.NavigateTo("/minsida/ledighet");
                _open = false;
                break;
            case "navigate_schema":
                Nav?.NavigateTo("/minsida/schema");
                _open = false;
                break;
            case "navigate_lon":
                Nav?.NavigateTo("/minsida/lon");
                _open = false;
                break;
            case "navigate_profil":
                Nav?.NavigateTo("/minsida/profil");
                _open = false;
                break;
            case "navigate_kunskapsbas":
                Nav?.NavigateTo("/helpdesk/kunskapsbas");
                _open = false;
                break;
            case "navigate_arende":
                Nav?.NavigateTo("/arenden/nytt");
                _open = false;
                break;
            case "sjukanmal_idag":
                _messages.Add(new(false, $"Jag har sjukanmält dig från och med idag ({DateTime.Today:d MMMM}).\n\n"
                    + "\u2705 Din chef meddelas automatiskt.\n"
                    + "\U0001F4B0 Karensavdrag: ca 20% av din dagsinkomst (dag 1).\n"
                    + "\U0001F4C5 Dag 2\u201314 får du 80% sjuklön.\n\n"
                    + "Jag påminner dig om läkarintyg om du fortfarande är sjuk dag 7."));
                _ = PersistMessageAsync("Assistant", "Sjukanmälan registrerad", null, "ReportSick");
                break;
            case "sjukanmal_igar":
                _messages.Add(new(false, $"Jag har sjukanmält dig från och med igår ({DateTime.Today.AddDays(-1):d MMMM}).\n\n"
                    + "\u2705 Din chef meddelas automatiskt.\n\n"
                    + "Krya på dig!"));
                _ = PersistMessageAsync("Assistant", "Sjukanmälan registrerad (igår)", null, "ReportSick");
                break;
        }
        StateHasChanged();
    }

    private void NavigateToArticle(Guid articleId)
    {
        Nav?.NavigateTo($"/helpdesk/kunskapsbas?artikel={articleId}");
        _open = false;
    }

    private async Task RateArticle(ChatMessage msg, decimal rating)
    {
        try
        {
            if (KbService != null && msg.ArticleRef != null)
            {
                await KbService.RateArticleAsync(msg.ArticleRef.Id, rating);
                msg.HasRated = true;
                StateHasChanged();
            }
        }
        catch { /* Non-critical */ }
    }

    private async Task<ChatMessage> GetSmartAnswerAsync(string q, string originalQuery)
    {
        // ============================================================
        // LAYER 1: Domain data (real DB queries)
        // ============================================================

        // === SEMESTER ===
        if (q.Contains("semester") || (q.Contains("ledig") && !q.Contains("föräldra")))
        {
            if (q.Contains("kvar") || q.Contains("hur många") || q.Contains("saldo"))
            {
                var article = await SearchKBForSingleAsync("semesterdagar rätt");
                return new(false,
                    $"Du har {_semesterKvar} semesterdagar kvar i år, {_userName}.\n\n"
                    + $"\U0001F4CA Tilldelning: {_semesterTotalt} dagar\n"
                    + $"\u2705 Uttagna: {_semesterUttagna} dagar\n"
                    + $"\U0001F3D6 Kvar: {_semesterKvar} dagar",
                    new() { ["navigate_semester"] = "\U0001F334 Ansök om semester" },
                    article);
            }
            return new(false,
                $"Du har {_semesterKvar} av {_semesterTotalt} semesterdagar kvar, {_userName}. Vill du ansöka om ledighet?",
                new() { ["navigate_semester"] = "\U0001F334 Ansök om semester" });
        }

        // === SJUKANMÄLAN ===
        if (q.Contains("sjuk"))
        {
            if (q.Contains("anmäl") || q.Contains("kan du") || q.Contains("jag är sjuk") || q.Contains("sjukanmäl"))
            {
                return new(false,
                    $"Absolut, {_userName}! Från vilken dag är du sjuk?",
                    new()
                    {
                        ["sjukanmal_idag"] = "\u2600\ufe0f Idag",
                        ["sjukanmal_igar"] = "\U0001F319 Igår",
                        ["navigate_sjukanmalan"] = "\U0001F4C5 Annat datum"
                    });
            }
            var article = await SearchKBForSingleAsync("sjukanmälan");
            return new(false,
                $"Är du sjuk, {_userName}? Jag kan sjukanmäla dig direkt härifrån.\n\n"
                + "Dag 1: karensavdrag (20% av veckolön)\n"
                + "Dag 2\u201314: 80% sjuklön\n"
                + "Dag 8+: läkarintyg krävs\n"
                + "Dag 15: vi anmäler till FK",
                new()
                {
                    ["sjukanmal_idag"] = "\u2600\ufe0f Sjukanmäl mig idag",
                    ["navigate_sjukanmalan"] = "\U0001F4C5 Välj datum"
                },
                article);
        }

        // === SCHEMA / NÄSTA PASS ===
        if (q.Contains("schema") || q.Contains("pass") || q.Contains("jobba") || q.Contains("nästa"))
        {
            return new(false,
                $"Ditt nästa pass, {_userName}:\n\n"
                + $"\U0001F4C5 {_nastaPass}\n\n"
                + "Vill du se hela veckan?",
                new() { ["navigate_schema"] = "\U0001F4C5 Visa mitt schema" });
        }

        // === LÖN ===
        if (q.Contains("lön") || q.Contains("betalt") || q.Contains("pengar") || q.Contains("lönespec"))
        {
            if (q.Contains("när") || q.Contains("utbetalning"))
            {
                var article = await SearchKBForSingleAsync("lönespecifikation förstå");
                return new(false,
                    $"Nästa löneutbetalning: 25 mars 2026.\n\n"
                    + $"Din senaste nettolön var {_senasteLon:N0} kr (brutto {_senasteBrutto:N0} kr).\n\n"
                    + "Vill du se din lönespecifikation?",
                    new() { ["navigate_lon"] = "\U0001F4B0 Visa lönespec" },
                    article);
            }
            return new(false,
                $"Din senaste lön ({_userName}):\n\n"
                + $"\U0001F4B5 Brutto: {_senasteBrutto:N0} kr\n"
                + $"\U0001F3E6 Skatt: -{(_senasteBrutto - _senasteLon):N0} kr\n"
                + $"\u2705 Netto: {_senasteLon:N0} kr\n\n"
                + "Lön betalas ut den 25:e varje månad.",
                new() { ["navigate_lon"] = "\U0001F4B0 Se fullständig lönespec" });
        }

        // === VAB ===
        if (q.Contains("vab") || q.Contains("barn sjuk") || q.Contains("barnet"))
        {
            var article = await SearchKBForSingleAsync("VAB vård barn");
            return new(false,
                "VAB (vård av barn):\n\n"
                + "\U0001F476 Gäller tills barnet fyller 12 år\n"
                + "\U0001F4C5 Max 120 dagar/barn/år\n"
                + "\U0001F4B0 Ersättning betalas av Försäkringskassan",
                new() { ["navigate_semester"] = "\U0001F476 Anmäl VAB" },
                article);
        }

        // === FÖRÄLDRALEDIGHET ===
        if (q.Contains("föräldra") || q.Contains("mammaled") || q.Contains("pappaled"))
        {
            var article = await SearchKBForSingleAsync("föräldraledighet ansöka");
            return new(false,
                "Föräldraledighet:\n\n"
                + "\U0001F4C5 480 dagar per barn (240/förälder)\n"
                + "\U0001F4B0 390 dagar på sjukpenningnivå\n"
                + "\U0001F4B5 90 dagar på lägstanivå (180 kr/dag)\n"
                + "\U0001F3E2 Föräldralön: +10% i 180 dagar (per AB)",
                new() { ["navigate_semester"] = "\U0001F476 Planera föräldraledighet" },
                article);
        }

        // === OB ===
        if (q.Contains("ob") || q.Contains("obekväm") || q.Contains("tillägg"))
        {
            var article = await SearchKBForSingleAsync("OB-tillägg obekväm");
            return new(false,
                "OB-tillägg (AB 2025):\n\n"
                + "\U0001F319 Vardag kväll (19\u201322): 126,50 kr/h\n"
                + "\U0001F303 Vardag natt (22\u201306): 152 kr/h\n"
                + "\U0001F4C5 Helg: 89 kr/h\n"
                + "\u2B50 Storhelg: 195 kr/h\n\n"
                + "OB beräknas automatiskt utifrån ditt schema.",
                articleRef: article);
        }

        // === FRISKVÅRD ===
        if (q.Contains("friskvård") || q.Contains("gym") || q.Contains("träning"))
        {
            var article = await SearchKBForSingleAsync("friskvårdsbidrag");
            return new(false,
                "Friskvårdsbidrag:\n\n"
                + "\U0001F4B0 Max 5 000 kr/år (skattefritt)\n"
                + "\U0001F4F8 Ladda upp kvitto under Förmåner\n"
                + "\u2705 Dras inte från lönen\n\n"
                + "Gäller: gym, simhall, massage, yoga med mera.",
                articleRef: article);
        }

        // === PENSION ===
        if (q.Contains("pension"))
        {
            var article = await SearchKBForSingleAsync("pension AKAP-KR");
            return new(false,
                "Din pension (AKAP-KR):\n\n"
                + "\U0001F4CA 6% på lön under 7,5 IBB\n"
                + "\U0001F4C8 31,5% på lön över 7,5 IBB\n"
                + "\U0001F3E6 Betalas av arbetsgivaren varje månad\n\n"
                + "IBB 2026: 80 600 kr \u2192 7,5 IBB = 604 500 kr/år.",
                articleRef: article);
        }

        // === ÖVERTID ===
        if (q.Contains("övertid"))
        {
            var article = await SearchKBForSingleAsync("övertid regler");
            return new(false,
                "Övertidsregler (ATL + AB):\n\n"
                + "\u23F0 Max 200 timmar/år\n"
                + "\U0001F4B5 Enkel övertid: 180% av timlön\n"
                + "\U0001F4B0 Kvalificerad (natt/helg): 240%\n"
                + "\U0001F6D1 Max 48 timmar/vecka (snitt 4 veckor)\n\n"
                + "Övertid registreras automatiskt via schemat.",
                articleRef: article);
        }

        // === KONTAKT / PROFIL ===
        if (q.Contains("kontakt") || q.Contains("adress") || q.Contains("telefon") || q.Contains("profil"))
        {
            return new(false,
                $"Vill du uppdatera dina uppgifter, {_userName}? Jag tar dig till din profil.",
                new() { ["navigate_profil"] = "\U0001F464 Öppna min profil" });
        }

        // === LAS ===
        if (q.Contains("las") || q.Contains("visstid") || q.Contains("vikariat"))
        {
            var article = await SearchKBForSingleAsync("LAS anställningsskydd");
            return new(false,
                "LAS (Lagen om anställningsskydd):\n\n"
                + "\U0001F4C5 Tidsbegränsad \u2192 tillsvidare efter 365 dagar/5 år\n"
                + "\u26A0\ufe0f Gäller vikariat och SAVA\n"
                + "\U0001F4CA Din ackumulering kan HR se under LAS-uppföljning",
                articleRef: article);
        }

        // === TACK / HEJ ===
        if (q.Contains("tack") || q.Contains("hej") || q.Contains("hejdå"))
        {
            return new(false, $"Ingen orsak, {_userName}! Jag finns här om du behöver mig. \U0001F44B");
        }

        // ============================================================
        // LAYER 2: Knowledge base search
        // ============================================================
        var kbResults = await SearchKBAsync(originalQuery);
        if (kbResults.Count > 0)
        {
            var topArticle = kbResults[0];
            var summary = topArticle.HamtaSammanfattning(250);
            var responseText = $"Enligt artikeln \"{topArticle.Titel}\":\n\n{summary}";

            if (kbResults.Count > 1)
            {
                responseText += "\n\nRelaterade artiklar:";
                foreach (var extra in kbResults.Skip(1).Take(2))
                {
                    responseText += $"\n\u2022 {extra.Titel}";
                }
            }

            return new(false, responseText,
                new() { ["navigate_kunskapsbas"] = "\U0001F4DA Öppna kunskapsbasen" },
                topArticle);
        }

        // ============================================================
        // LAYER 3: Fallback — offer to create a case
        // ============================================================
        return new(false,
            $"Jag hittade ingen artikel om det, {_userName}. Vill du skicka en fråga till HR?\n\n"
            + "Du kan också prova att fråga om:\n"
            + "\u2022 \"Hur många semesterdagar har jag kvar?\"\n"
            + "\u2022 \"Sjukanmäl mig\"\n"
            + "\u2022 \"Visa mitt nästa pass\"\n"
            + "\u2022 \"Vad är OB-tillägget?\"\n"
            + "\u2022 \"Berätta om friskvårdsbidraget\"",
            new()
            {
                ["navigate_arende"] = "\U0001F4E8 Skapa ärende",
                ["navigate_kunskapsbas"] = "\U0001F4DA Sök i kunskapsbasen"
            });
    }

    private async Task<KnowledgeArticle?> SearchKBForSingleAsync(string query)
    {
        try
        {
            if (KbService == null) return null;
            var results = await KbService.SearchAsync(query);
            return results.FirstOrDefault();
        }
        catch { return null; }
    }

    private async Task<List<KnowledgeArticle>> SearchKBAsync(string query)
    {
        try
        {
            if (KbService == null) return [];
            return await KbService.SearchAsync(query);
        }
        catch { return []; }
    }

    private class ChatMessage
    {
        public bool IsUser { get; }
        public string Text { get; }
        public Dictionary<string, string> Actions { get; }
        public ArticleReference? ArticleRef { get; }
        public bool HasRated { get; set; }

        public ChatMessage(bool isUser, string text, Dictionary<string, string>? actions = null,
            KnowledgeArticle? articleRef = null)
        {
            IsUser = isUser;
            Text = text;
            Actions = actions ?? new();
            ArticleRef = articleRef != null ? new ArticleReference(articleRef.Id, articleRef.Titel) : null;
        }
    }

    private record ArticleReference(Guid Id, string Titel);
}
