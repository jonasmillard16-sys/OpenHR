            new("Karl Berg", "Sjuksköterska", "100%", "Sjuk", Color.Error, "070-123 45 02", "karl.berg@region.se", "—", 22),
            new("Lisa Holm", "Undersköterska", "75%", "Arbetar", Color.Success, "070-123 45 03", "lisa.holm@region.se", "08:00–14:00", 15),
            new("Erik Johansson", "Sjuksköterska", "100%", "Semester", Color.Info, "070-123 45 04", "erik.johansson@region.se", "—", 8),
            new("Maria Lindgren", "Undersköterska", "100%", "Arbetar", Color.Success, "070-123 45 05", "maria.lindgren@region.se", "07:00–15:30", 20),
            new("Johan Nilsson", "Läkare", "50%", "Arbetar", Color.Success, "070-123 45 06", "johan.nilsson@region.se", "08:00–12:00", 25),
            new("Sara Karlsson", "Sjuksköterska", "100%", "Arbetar", Color.Success, "070-123 45 07", "sara.karlsson@region.se", "07:00–15:30", 12),
