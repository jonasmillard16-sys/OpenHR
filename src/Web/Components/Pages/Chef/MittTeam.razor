@page "/chef/team"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Leave.Domain
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<RegionHRDbContext> DbFactory
@inject RegionHR.Web.Services.AuthService Auth

<PageTitle>OpenHR - Mitt team</PageTitle>
<OhrBreadcrumb CurrentPage="Mitt team" />
<MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Variant="Variant.Text"
           Color="Color.Primary" Href="/chef" Style="margin-bottom: 1rem;">Tillbaka</MudButton>

<MudText Typo="Typo.h4" Class="mb-2" Style="font-weight: 700;">Mitt team</MudText>
@if (_enhetNamn != null)
{
    <MudText Typo="Typo.body2" Class="mb-4" Style="color: var(--mud-palette-text-secondary);">@_enhetNamn</MudText>
}
else
{
    <MudText Typo="Typo.body2" Class="mb-4" Style="color: var(--mud-palette-text-secondary);">Alla anställda (ingen enhetskoppling)</MudText>
}

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
}
else if (_team.Count == 0)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Text">Inga anställda registrerade.</MudAlert>
}
else
{
    <MudText Typo="Typo.body1" Class="mb-4">@_team.Count anställda</MudText>
    <MudSimpleTable Hover="true" Elevation="2" Style="font-size: 1.125rem;">
        <thead><tr><th>Namn</th><th>Befattning</th><th>Tjänstegrad</th><th>Frånvarostatus</th><th>Semesterdagar kvar</th></tr></thead>
        <tbody>
            @foreach (var person in _team)
            {
                <tr style="cursor: pointer;" @onclick="@(() => _expanderad = _expanderad == person ? null : person)">
                    <td><strong>@person.Namn</strong></td>
                    <td>@person.Befattning</td>
                    <td>@person.Tjanstegrad</td>
                    <td>
                        @if (person.AktivFranvaro != null)
                        {
                            <MudChip T="string" Size="Size.Small" Color="@person.FranvaroFarg">@person.AktivFranvaro</MudChip>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">—</MudText>
                        }
                    </td>
                    <td>@(person.SemesterKvar.HasValue ? $"{person.SemesterKvar} dagar" : "—")</td>
                </tr>
                @if (_expanderad == person)
                {
                    <tr>
                        <td colspan="5">
                            <MudPaper Class="pa-4" Elevation="0" Style="background: var(--mud-palette-background-grey);">
                                <MudGrid Spacing="2">
                                    <MudItem xs="6" md="3">
                                        <MudText Typo="Typo.caption"><strong>Telefon</strong></MudText>
                                        <MudText Typo="Typo.body2">@(person.Telefon ?? "—")</MudText>
                                    </MudItem>
                                    <MudItem xs="6" md="3">
                                        <MudText Typo="Typo.caption"><strong>E-post</strong></MudText>
                                        <MudText Typo="Typo.body2">@(person.Epost ?? "—")</MudText>
                                    </MudItem>
                                    <MudItem xs="6" md="3">
                                        <MudText Typo="Typo.caption"><strong>Enhet</strong></MudText>
                                        <MudText Typo="Typo.body2">@person.Enhet</MudText>
                                    </MudItem>
                                </MudGrid>
                            </MudPaper>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </MudSimpleTable>
}

@code {
    private List<TeamMedlem> _team = [];
    private TeamMedlem? _expanderad;
    private bool _loading = true;
    private string? _error, _enhetNamn;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        try
        {
            var idag = DateOnly.FromDateTime(DateTime.Today);
            var allEmployees = await db.Employees.Include(e => e.Anstallningar).OrderBy(e => e.Efternamn).ToListAsync();

            // Filter on chef's unit if auth provides EmployeeId
            Guid? chefEnhetId = null;
            if (Auth.EmployeeId.HasValue)
            {
                var chef = allEmployees.FirstOrDefault(e => e.Id.Value == Auth.EmployeeId.Value);
                var chefAnst = chef?.AktivAnstallning(idag);
                if (chefAnst != null)
                {
                    chefEnhetId = chefAnst.EnhetId.Value;
                    var enhet = await db.OrganizationUnits.FirstOrDefaultAsync(e => e.Id.Value == chefEnhetId.Value);
                    _enhetNamn = enhet?.Namn;
                }
            }

            var employees = chefEnhetId.HasValue
                ? allEmployees.Where(e => e.AktivAnstallning(idag)?.EnhetId.Value == chefEnhetId.Value).ToList()
                : allEmployees;

            // Aktiva frånvaroperioder idag
            var aktivFranvaro = await db.LeaveRequests
                .Where(r => r.FranDatum <= idag && r.TillDatum >= idag
                    && (r.Status == LeaveRequestStatus.Inskickad || r.Status == LeaveRequestStatus.Godkand))
                .ToListAsync();
            var franvaroPerAnstall = aktivFranvaro.ToDictionary(r => r.AnstallId, r => r.Typ);

            // Semestersaldo
            var balances = await db.VacationBalances.Where(b => b.Ar == idag.Year).ToListAsync();
            var balansPerAnstall = balances.ToDictionary(b => b.AnstallId, b => b.TillgangligaDagar);

            // Enhetnamn
            var enheter = await db.OrganizationUnits.ToListAsync();
            var enhetNamn = enheter.ToDictionary(e => e.Id.Value, e => e.Namn);

            _team = employees.Select(e =>
            {
                var aktiv = e.AktivAnstallning(idag);
                franvaroPerAnstall.TryGetValue(e.Id.Value, out var franTyp);
                balansPerAnstall.TryGetValue(e.Id.Value, out var semester);

                return new TeamMedlem(
                    $"{e.Fornamn} {e.Efternamn}",
                    aktiv?.Befattningstitel ?? "—",
                    aktiv != null ? $"{aktiv.Sysselsattningsgrad.Value}%" : "—",
                    franvaroPerAnstall.ContainsKey(e.Id.Value) ? MapTyp(franTyp) : null,
                    franvaroPerAnstall.ContainsKey(e.Id.Value) ? MapColor(franTyp) : Color.Default,
                    semester > 0 ? semester : (int?)null,
                    e.Telefon, e.Epost,
                    aktiv != null ? enhetNamn.GetValueOrDefault(aktiv.EnhetId.Value, "—") : "—"
                );
            }).ToList();
        }
        catch (Exception ex) { _error = $"Kunde inte hämta personaldata: {ex.Message}"; }
        finally { _loading = false; }
    }

    private static string MapTyp(LeaveType t) => t switch
    {
        LeaveType.Semester => "Semester", LeaveType.Sjukfranvaro => "Sjukfrånvaro",
        LeaveType.VAB => "VAB", LeaveType.Foraldraledighet => "Föräldraledighet",
        LeaveType.Tjanstledighet => "Tjänstledighet", _ => t.ToString()
    };
    private static Color MapColor(LeaveType t) => t switch
    {
        LeaveType.Sjukfranvaro => Color.Error, LeaveType.Semester => Color.Info,
        LeaveType.VAB => Color.Warning, _ => Color.Default
    };

    private record TeamMedlem(string Namn, string Befattning, string Tjanstegrad, string? AktivFranvaro, Color FranvaroFarg, int? SemesterKvar, string? Telefon, string? Epost, string Enhet);
}

