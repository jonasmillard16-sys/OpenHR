@page "/chef/team"
@layout RegionHR.Web.Components.Layout.AdminLayout

<PageTitle>OpenHR - Mitt team</PageTitle>

<MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Variant="Variant.Text"
           Color="Color.Primary" Href="/chef" Style="margin-bottom: 1rem;">
    Tillbaka
</MudButton>

<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">Mitt team</MudText>
<MudText Typo="Typo.body1" Class="mb-4" Style="color: var(--mud-palette-text-secondary);">
    Avdelning 32 — @_team.Count anställda
</MudText>

<MudSimpleTable Hover="true" Elevation="2" Style="font-size: 1.125rem;">
    <thead>
        <tr>
            <th>Namn</th>
            <th>Befattning</th>
            <th>Tjänstegrad</th>
            <th>Status idag</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var person in _team)
        {
            <tr style="cursor: pointer;" @onclick="@(() => ToggleDetalj(person))">
                <td><strong>@person.Namn</strong></td>
                <td>@person.Befattning</td>
                <td>@person.Tjanstegrad</td>
                <td>
                    <MudChip T="string" Size="Size.Small" Color="@person.StatusFarg">@person.Status</MudChip>
                </td>
            </tr>
            @if (_expanderad == person)
            {
                <tr>
                    <td colspan="4">
                        <MudPaper Class="pa-4" Elevation="0" Style="background: var(--mud-palette-background-grey);">
                            <MudGrid Spacing="2">
                                <MudItem xs="6" md="3">
                                    <MudText Typo="Typo.caption"><strong>Telefon</strong></MudText>
                                    <MudText Typo="Typo.body2">@person.Telefon</MudText>
                                </MudItem>
                                <MudItem xs="6" md="3">
                                    <MudText Typo="Typo.caption"><strong>E-post</strong></MudText>
                                    <MudText Typo="Typo.body2">@person.Epost</MudText>
                                </MudItem>
                                <MudItem xs="6" md="3">
                                    <MudText Typo="Typo.caption"><strong>Schema idag</strong></MudText>
                                    <MudText Typo="Typo.body2">@person.Schema</MudText>
                                </MudItem>
                                <MudItem xs="6" md="3">
                                    <MudText Typo="Typo.caption"><strong>Semesterdagar kvar</strong></MudText>
                                    <MudText Typo="Typo.body2">@person.SemesterdagarKvar dagar</MudText>
                                </MudItem>
                            </MudGrid>
                        </MudPaper>
                    </td>
                </tr>
            }
        }
    </tbody>
</MudSimpleTable>

@code {
    private List<TeamMedlem> _team = [];
    private TeamMedlem? _expanderad;

    private void ToggleDetalj(TeamMedlem person) => _expanderad = _expanderad == person ? null : person;

    protected override void OnInitialized()
    {
        _team =
