@page "/chef/bemanning"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Scheduling.Domain
@using RegionHR.SharedKernel.Domain
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<RegionHRDbContext> DbFactory

<PageTitle>OpenHR - Bemanning idag</PageTitle>

<MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Variant="Variant.Text"
           Color="Color.Primary" Href="/chef" Style="margin-bottom: 1rem;">Tillbaka</MudButton>

<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">Bemanning idag</MudText>
<MudText Typo="Typo.body1" Class="mb-4" Style="color: var(--mud-palette-text-secondary);">
    @DateTime.Today.ToString("dddd d MMMM yyyy", System.Globalization.CultureInfo.GetCultureInfo("sv-SE"))
</MudText>

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
}
else if (_passgrupper.Count == 0)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Text">Inga schemalagda pass idag.</MudAlert>
}
else
{
    <MudGrid Spacing="4" Class="mb-6">
        @foreach (var g in _passgrupper)
        {
            <MudItem xs="12" sm="4">
                <MudPaper Class="pa-5 text-center" Elevation="2" Style="border-top: 4px solid var(--mud-palette-primary);">
                    <MudText Typo="Typo.h6" Style="font-weight: 600;">@g.PassTypText</MudText>
                    <MudText Typo="Typo.h3" Class="my-2" Color="Color.Primary" Style="font-weight: 700;">@g.Antal</MudText>
                    <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">schemalagda</MudText>
                </MudPaper>
            </MudItem>
        }
    </MudGrid>

    <MudText Typo="Typo.h6" Class="mb-3">Schemalagd personal idag</MudText>
    <MudSimpleTable Hover="true" Elevation="1">
        <thead><tr><th>Namn</th><th>Pass</th><th>Tid</th><th>Status</th></tr></thead>
        <tbody>
            @foreach (var s in _skift)
            {
                <tr>
                    <td><strong>@s.Namn</strong></td>
                    <td>@MapPassTyp(s.PassTyp)</td>
                    <td>@s.Start.ToString("HH:mm") – @s.Slut.ToString("HH:mm")</td>
                    <td><MudChip T="string" Size="Size.Small" Color="@MapShiftStatusColor(s.Status)">@MapShiftStatus(s.Status)</MudChip></td>
                </tr>
            }
        </tbody>
    </MudSimpleTable>
}

@code {
    private List<PassGrupp> _passgrupper = [];
    private List<SkiftRad> _skift = [];
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        try
        {
            var idag = DateOnly.FromDateTime(DateTime.Today);
            var shifts = await db.ScheduledShifts
                .Where(s => s.Datum == idag && s.Status != ShiftStatus.Avbokad)
                .ToListAsync();

            if (shifts.Count > 0)
            {
                var anstallIds = shifts.Select(s => s.AnstallId.Value).Distinct().ToList();
                var employees = await db.Employees
                    .Where(e => anstallIds.Contains(e.Id.Value)).ToListAsync();
                var names = employees.ToDictionary(e => e.Id.Value, e => $"{e.Fornamn} {e.Efternamn}");

                _passgrupper = shifts.GroupBy(s => s.PassTyp)
                    .Select(g => new PassGrupp(MapPassTyp(g.Key), g.Count()))
                    .OrderBy(g => g.PassTypText).ToList();

                _skift = shifts.OrderBy(s => s.PlaneradStart)
                    .Select(s => new SkiftRad(
                        names.GetValueOrDefault(s.AnstallId.Value, "Okänd"),
                        s.PassTyp, s.PlaneradStart, s.PlaneradSlut, s.Status
                    )).ToList();
            }
        }
        catch (Exception ex) { _error = $"Kunde inte hämta bemanningsdata: {ex.Message}"; }
        finally { _loading = false; }
    }

    private static string MapPassTyp(ShiftType t) => t switch
    {
        ShiftType.Dag => "Dag", ShiftType.Kvall => "Kväll", ShiftType.Natt => "Natt",
        ShiftType.Jour => "Jour", ShiftType.Beredskap => "Beredskap", _ => t.ToString()
    };
    private static string MapShiftStatus(ShiftStatus s) => s switch
    {
        ShiftStatus.Planerad => "Planerad", ShiftStatus.Pagaende => "Pågående",
        ShiftStatus.Avslutad => "Avslutad", _ => s.ToString()
    };
    private static Color MapShiftStatusColor(ShiftStatus s) => s switch
    {
        ShiftStatus.Pagaende => Color.Success, ShiftStatus.Planerad => Color.Info,
        ShiftStatus.Avslutad => Color.Default, _ => Color.Default
    };

    private record PassGrupp(string PassTypText, int Antal);
    private record SkiftRad(string Namn, ShiftType PassTyp, TimeOnly Start, TimeOnly Slut, ShiftStatus Status);
}

