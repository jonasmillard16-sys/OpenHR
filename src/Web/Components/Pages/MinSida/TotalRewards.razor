@page "/minsida/totalrewards"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Compensation.Domain
@using RegionHR.SharedKernel.Domain
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Authorization
@inject IDbContextFactory<RegionHRDbContext> DbFactory
@inject AuthenticationStateProvider AuthState

<PageTitle>OpenHR - Total Rewards</PageTitle>
<MudText Typo="Typo.h4" Class="mb-2" Style="font-weight: 700;">Din totala kompensation</MudText>
<MudText Typo="Typo.body2" Class="mb-6" Style="color: var(--mud-palette-text-secondary);">
    Översikt av din fullständiga ersättning inklusive lön, pension, försäkringar och förmåner.
</MudText>

@if (_loading) { <MudProgressCircular Color="Color.Primary" Indeterminate="true" /> }
else if (_error != null) { <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert> }
else if (_statement == null)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Text">Ingen Total Rewards-data tillgänglig.</MudAlert>
}
else
{
    <MudGrid Spacing="4" Class="mb-6">
        <MudItem xs="12">
            <MudPaper Class="pa-6 text-center" Elevation="2" Style="background: linear-gradient(135deg, #0e7490, #06b6d4); color: white; border-radius: 16px;">
                <MudText Typo="Typo.caption" Style="opacity: 0.8;">Total årlig kompensation @_statement.Ar</MudText>
                <MudText Typo="Typo.h3" Style="font-weight: 800;">@FormatKr(_statement.TotalKompensation * 12m)</MudText>
                <MudText Typo="Typo.body2" Style="opacity: 0.7;">@FormatKr(_statement.TotalKompensation) / månad</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudGrid Spacing="3">
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Class="pa-4 text-center" Elevation="1">
                <MudIcon Icon="@Icons.Material.Filled.Payments" Color="Color.Primary" />
                <MudText Typo="Typo.caption" Class="mt-1">Grundlön</MudText>
                <MudText Typo="Typo.h6" Style="font-weight: 700;">@FormatKr(_statement.GrundLon)</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Class="pa-4 text-center" Elevation="1">
                <MudIcon Icon="@Icons.Material.Filled.AddCircle" Color="Color.Secondary" />
                <MudText Typo="Typo.caption" Class="mt-1">Tillägg</MudText>
                <MudText Typo="Typo.h6" Style="font-weight: 700;">@FormatKr(_statement.Tillagg)</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Class="pa-4 text-center" Elevation="1">
                <MudIcon Icon="@Icons.Material.Filled.Savings" Color="Color.Success" />
                <MudText Typo="Typo.caption" Class="mt-1">Pension</MudText>
                <MudText Typo="Typo.h6" Style="font-weight: 700;">@FormatKr(_statement.Pension)</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Class="pa-4 text-center" Elevation="1">
                <MudIcon Icon="@Icons.Material.Filled.Security" Color="Color.Warning" />
                <MudText Typo="Typo.caption" Class="mt-1">Försäkringar</MudText>
                <MudText Typo="Typo.h6" Style="font-weight: 700;">@FormatKr(_statement.Forsakringar)</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Class="pa-4 text-center" Elevation="1">
                <MudIcon Icon="@Icons.Material.Filled.CardGiftcard" Color="Color.Info" />
                <MudText Typo="Typo.caption" Class="mt-1">Förmåner</MudText>
                <MudText Typo="Typo.h6" Style="font-weight: 700;">@FormatKr(_statement.Formaner)</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="4" md="2">
            <MudPaper Class="pa-4 text-center" Elevation="1">
                <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Color="Color.Dark" />
                <MudText Typo="Typo.caption" Class="mt-1">AG-avgifter</MudText>
                <MudText Typo="Typo.h6" Style="font-weight: 700;">@FormatKr(_statement.AGAvgifter)</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudPaper Class="pa-5 mt-6" Elevation="1">
        <MudText Typo="Typo.h6" Class="mb-3">Fördelning</MudText>
        <MudSimpleTable Hover="true" Dense="true">
            <thead><tr><th>Komponent</th><th>Månad</th><th>År</th><th>Andel</th></tr></thead>
            <tbody>
                @foreach (var row in _rows)
                {
                    <tr>
                        <td>@row.Label</td>
                        <td>@FormatKr(row.Manad)</td>
                        <td>@FormatKr(row.Manad * 12m)</td>
                        <td>
                            <MudProgressLinear Value="@((double)(row.Manad / _statement.TotalKompensation * 100))" Color="@row.Color" Style="min-width: 80px;" />
                        </td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    </MudPaper>

    <MudText Typo="Typo.caption" Class="mt-4" Style="color: var(--mud-palette-text-secondary);">
        Genererad: @_statement.GenereradVid.ToString("yyyy-MM-dd HH:mm")
    </MudText>
}

@code {
    private TotalRewardsStatement? _statement;
    private bool _loading = true;
    private string? _error;
    private List<RowData> _rows = [];

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        try
        {
            var auth = await AuthState.GetAuthenticationStateAsync();
            var employeeIdClaim = auth.User.FindFirst("EmployeeId")?.Value;

            if (employeeIdClaim == null || !Guid.TryParse(employeeIdClaim, out var parsedId))
            {
                _error = "Du måste vara inloggad för att se din kompensationsöversikt. Logga in på nytt.";
                return;
            }
            var anstallId = parsedId;

            var year = DateTime.Now.Year;
            _statement = await db.TotalRewardsStatements
                .FirstOrDefaultAsync(s => s.AnstallId == EmployeeId.From(anstallId) && s.Ar == year);

            if (_statement == null)
            {
                var emp = await db.Employees.Include(e => e.Anstallningar)
                    .FirstOrDefaultAsync(e => e.Id == EmployeeId.From(anstallId));
                if (emp == null) { _error = "Anställd hittades inte"; return; }

                var anst = emp.Anstallningar.FirstOrDefault();
                if (anst == null) { _error = "Ingen anställning"; return; }

                decimal grundLon = anst.Manadslon.Amount;
                _statement = TotalRewardsStatement.Generera(
                    EmployeeId.From(anstallId), year,
                    grundLon, grundLon * 0.05m, grundLon * 0.045m,
                    800m, 2500m, grundLon * 0.3142m);
                await db.TotalRewardsStatements.AddAsync(_statement);
                await db.SaveChangesAsync();
            }

            _rows =
            [
                new("Grundlön", _statement.GrundLon, Color.Primary),
                new("Tillägg", _statement.Tillagg, Color.Secondary),
                new("Pension", _statement.Pension, Color.Success),
                new("Försäkringar", _statement.Forsakringar, Color.Warning),
                new("Förmåner", _statement.Formaner, Color.Info),
                new("AG-avgifter", _statement.AGAvgifter, Color.Dark)
            ];
        }
        catch (Exception ex) { _error = $"Kunde inte hämta Total Rewards: {ex.Message}"; }
        finally { _loading = false; }
    }

    private static string FormatKr(decimal v) => $"{v:N0} kr";

    private record RowData(string Label, decimal Manad, Color Color);
}

