@page "/minsida"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Web.Components.Shared
@using RegionHR.Web.Services
@using RegionHR.SharedKernel.Domain
@using Microsoft.Extensions.Localization
@inject SelfServiceApiClient SelfService
@inject AuthService Auth
@inject IStringLocalizer<SharedResources> L

<PageTitle>OpenHR - @L["MyPage"]</PageTitle>

@if (Auth.EmployeeId == null)
{
    <MudAlert Severity="Severity.Warning" Class="mb-4">@L["NoEmployeeLinked"]</MudAlert>
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
}
else
{
    <OhrBreadcrumb CurrentPage="Min sida" />

    <MudText Typo="Typo.h4" Class="mb-6" Style="font-weight: 700;">
        @L["HelloUser"] @_data.Fornamn!
    </MudText>

    <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight: 600;">Vad vill du göra?</MudText>
    <MudGrid Spacing="3" Class="mb-6">
        <MudItem xs="12" sm="6" md="3">
            <MudButton Href="/minsida/sjukanmalan" Variant="Variant.Filled" Color="Color.Primary"
                       FullWidth="true" Size="Size.Large"
                       StartIcon="@Icons.Material.Filled.Sick"
                       Style="min-height: 56px; text-transform: none; font-size: 1rem;">
                Sjukanmäl dig
            </MudButton>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudButton Href="/ledighet/ny" Variant="Variant.Filled" Color="Color.Primary"
                       FullWidth="true" Size="Size.Large"
                       StartIcon="@Icons.Material.Filled.BeachAccess"
                       Style="min-height: 56px; text-transform: none; font-size: 1rem;">
                Begär ledighet
            </MudButton>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudButton Href="/minsida/schema" Variant="Variant.Filled" Color="Color.Primary"
                       FullWidth="true" Size="Size.Large"
                       StartIcon="@Icons.Material.Filled.CalendarMonth"
                       Style="min-height: 56px; text-transform: none; font-size: 1rem;">
                Se mitt schema
            </MudButton>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudButton Href="/minsida/lon" Variant="Variant.Filled" Color="Color.Primary"
                       FullWidth="true" Size="Size.Large"
                       StartIcon="@Icons.Material.Filled.Payments"
                       Style="min-height: 56px; text-transform: none; font-size: 1rem;">
                Se min lön
            </MudButton>
        </MudItem>
    </MudGrid>

    @if (_tips.Count > 0)
    {
        <MudStack Spacing="2" Class="mb-4">
            @foreach (var tip in _tips)
            {
                <MudAlert Severity="@tip.Severity" Variant="Variant.Text" Dense="true">@tip.Text</MudAlert>
            }
        </MudStack>
    }

    <MudGrid Spacing="4">
        <MudItem xs="12" sm="6">
            <OhrBigCard Icon="📅" Title="@L["MySchedule"]" Description="@L["MyScheduleDesc"]"
                        BadgeValue="@(_data.NastaPass != "-" ? $"{_data.NastaPass} {_data.NastaPassTid}" : null)"
                        Href="/minsida/schema" />
        </MudItem>
        <MudItem xs="12" sm="6">
            <OhrBigCard Icon="🌴" Title="@L["MyLeave"]"
                        Description="@($"Du har {_data.SemesterdagarKvar} dagar ledigt kvar i år")"
                        BadgeValue="@($"{_data.SemesterdagarKvar} {L["DaysLeft"]}")"
                        Href="/minsida/ledighet" />
            <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary); margin-top: 0.25rem; display: block;">
                Vad är <OhrTerm Term="Semester" DisplayText="dagar ledigt" />?
            </MudText>
        </MudItem>
        <MudItem xs="12" sm="6">
            <OhrBigCard Icon="💰" Title="@L["MySalary"]" Description="@L["MySalaryDesc"]" Href="/minsida/lon" />
        </MudItem>
        <MudItem xs="12" sm="6">
            <OhrBigCard Icon="😷" Title="@L["ImSick"]" Description="@L["ImSickDesc"]" Href="/minsida/sjukanmalan" />
        </MudItem>
        <MudItem xs="12" sm="6">
            <OhrBigCard Icon="📋" Title="Dina ansökningar och förfrågningar" Description="@L["MyThingsDesc"]"
                        BadgeValue="@(_data.OppnaArenden > 0 ? $"{_data.OppnaArenden} öppna" : null)"
                        Href="/minsida/arenden" />
        </MudItem>
        <MudItem xs="12" sm="6">
            <OhrBigCard Icon="👤" Title="@L["AboutMe"]" Description="@L["AboutMeDesc"]" Href="/minsida/profil" />
        </MudItem>
    </MudGrid>
}

@code {
    private DashboardData _data = new();
    private List<TipData> _tips = [];
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        if (Auth.EmployeeId == null) return;
        try
        {
            _data = await SelfService.GetDashboardAsync(EmployeeId.From(Auth.EmployeeId.Value));
            if (_data.SemesterdagarKvar > 15)
                _tips.Add(new(Severity.Info, $"{L["HelloUser"].Value.Split(' ')[0]} har {_data.SemesterdagarKvar} {L["TipVacationDays"]}"));
            if (_data.OppnaArenden > 0)
                _tips.Add(new(Severity.Warning, $"{L["HelloUser"].Value.Split(' ')[0]} har {_data.OppnaArenden} {L["TipOpenCases"]}"));
            if (_tips.Count == 0)
                _tips.Add(new(Severity.Success, L["TipAllGood"].Value));
        }
        catch (Exception ex) { _error = $"{L["ErrorLoadingData"]}: {ex.Message}"; }
    }

    private record TipData(Severity Severity, string Text);
}
