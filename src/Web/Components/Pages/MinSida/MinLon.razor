@page "/minsida/lon"
@rendermode InteractiveServer
@layout RegionHR.Web.Components.Layout.EmployeeLayout
@using RegionHR.Web.Services
@using RegionHR.Infrastructure.Export
@inject SelfServiceApiClient SelfService
@inject PdfPayslipGenerator PdfGenerator
@inject IJSRuntime JS

<PageTitle>OpenHR - Min lön</PageTitle>

<MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Variant="Variant.Text"
           Color="Color.Primary" Href="/minsida" Style="margin-bottom: 1rem;">
    Tillbaka
</MudButton>

<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">💰 Min lön</MudText>

<MudPaper Class="pa-6 mb-6" Elevation="2">
    <MudText Typo="Typo.h6" Class="mb-3">@_senastePeriod</MudText>
    <MudGrid Spacing="3">
        <MudItem xs="6" sm="3">
            <MudText Typo="Typo.caption">Bruttolön</MudText>
            <MudText Typo="Typo.h5" Style="font-weight: 700;">@FormatKr(_senasteBrutto)</MudText>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudText Typo="Typo.caption">Skatt</MudText>
            <MudText Typo="Typo.h5" Style="font-weight: 700; color: var(--mud-palette-error);">-@FormatKr(_senasteSkatt)</MudText>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudText Typo="Typo.caption">Tillägg</MudText>
            <MudText Typo="Typo.h5" Style="font-weight: 700; color: var(--mud-palette-success);">+@FormatKr(_senasteTillagg)</MudText>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudText Typo="Typo.caption">Nettolön</MudText>
            <MudText Typo="Typo.h5" Color="Color.Primary" Style="font-weight: 700;">@FormatKr(_senasteNetto)</MudText>
        </MudItem>
    </MudGrid>

    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Class="mt-4"
               StartIcon="@Icons.Material.Filled.PictureAsPdf"
               Size="Size.Large" Style="min-height: 48px;"
               OnClick="@(() => LaddaNerPdf(_senastePeriod, _senasteBrutto, _senasteSkatt, _senasteNetto, _senasteTillagg))">
        Ladda ner lönespecifikation (PDF)
    </MudButton>
</MudPaper>

<MudText Typo="Typo.h6" Class="mb-3">Tidigare månader</MudText>
<MudSimpleTable Hover="true" Elevation="1">
    <thead>
        <tr><th>Period</th><th>Brutto</th><th>Netto</th><th></th></tr>
    </thead>
    <tbody>
        @foreach (var period in _historik)
        {
            <tr>
                <td>@period.Period</td>
                <td>@period.Brutto</td>
                <td><strong>@period.Netto</strong></td>
                <td>
                    <MudIconButton Icon="@Icons.Material.Filled.PictureAsPdf"
                                   Size="Size.Small" Color="Color.Primary"
                                   aria-label="Ladda ner PDF"
                                   OnClick="@(() => LaddaNerPdf(period.Period, period.BruttoDecimal, period.SkattDecimal, period.NettoDecimal, 0m))" />
                </td>
            </tr>
        }
    </tbody>
</MudSimpleTable>

@code {
    private List<LonPeriod> _historik = [];
    private string _senastePeriod = "Mars 2026";
    private decimal _senasteBrutto = 32_400m;
    private decimal _senasteSkatt = 8_650m;
    private decimal _senasteTillagg = 3_900m;
    private decimal _senasteNetto = 27_650m;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var data = await SelfService.GetSalaryHistoryAsync(
                EmployeeId.From(Guid.Empty));

            if (data.Count > 0)
            {
                var senaste = data[0];
                _senastePeriod = senaste.Period;
                _senasteBrutto = senaste.Brutto;
                _senasteSkatt = senaste.Skatt;
                _senasteTillagg = senaste.OBTillagg + senaste.Overtid;
                _senasteNetto = senaste.Netto;

                _historik = data.Skip(1).Select(r => new LonPeriod(
                    r.Period,
                    FormatKr(r.Brutto),
                    FormatKr(r.Netto),
                    r.Brutto,
                    r.Skatt,
                    r.Netto
                )).ToList();
                return;
            }
        }
        catch
        {
            // Fallback to demo data
        }

        _historik =
        [
            new("Februari 2026", "28 500 kr", "21 420 kr", 28_500m, 7_080m, 21_420m),
            new("Januari 2026", "28 500 kr", "21 420 kr", 28_500m, 7_080m, 21_420m),
            new("December 2025", "31 200 kr", "23 850 kr", 31_200m, 7_350m, 23_850m),
            new("November 2025", "28 500 kr", "21 420 kr", 28_500m, 7_080m, 21_420m),
            new("Oktober 2025", "29 100 kr", "21 870 kr", 29_100m, 7_230m, 21_870m),
        ];
    }

    private async Task LaddaNerPdf(string period, decimal brutto, decimal skatt, decimal netto, decimal tillagg)
    {
        var payslipData = new PayslipData
        {
            AnstallNamn = "Anställd",
            Personnummer = "XXXXXX-XXXX",
            Period = period,
            Enhet = "Min enhet",
            Brutto = brutto,
            Skatt = skatt,
            Netto = netto,
            OBTillagg = tillagg,
            Rader = new List<PayslipLine>
            {
                new() { Loneart = "1010", Benamning = "Grundlön", Antal = 1, Sats = brutto, Belopp = brutto },
            }
        };

        // Try to enrich with real employee data
        try
        {
            var profil = await SelfService.GetProfileAsync(EmployeeId.From(Guid.Empty));
            if (profil is not null)
            {
                payslipData.AnstallNamn = $"{profil.Fornamn} {profil.Efternamn}";
                payslipData.Personnummer = profil.PersonnummerMaskerat;
                payslipData.Enhet = profil.Enhet;
            }
        }
        catch
        {
            // Use defaults
        }

        var pdfBytes = PdfGenerator.Generate(payslipData);
        var base64 = Convert.ToBase64String(pdfBytes);
        var safeFilename = period.Replace(" ", "-").ToLowerInvariant();
        await JS.InvokeVoidAsync("downloadFile", $"lonespec-{safeFilename}.pdf", base64, "application/pdf");
    }

    private static string FormatKr(decimal belopp) =>
        $"{belopp:N0} kr".Replace(",", " ");

    private record LonPeriod(string Period, string Brutto, string Netto, decimal BruttoDecimal, decimal SkattDecimal, decimal NettoDecimal);
}
