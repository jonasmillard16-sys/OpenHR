@page "/minsida/sjukanmalan"
@rendermode InteractiveServer
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Web.Components.Shared
@using RegionHR.Leave.Domain
@using RegionHR.Infrastructure.Persistence
@inject RegionHRDbContext Db
@inject NavigationManager Nav

<PageTitle>OpenHR - Jag är sjuk</PageTitle>

<OhrConversationFlow Steps="@_steps" CurrentStep="@_currentStep" OnBack="GoBack">
    @switch (_currentStep)
    {
        case 0:
            <MudText Typo="Typo.h5" Class="mb-4" Style="font-weight: 600;">
                Från och med vilken dag är du sjuk?
            </MudText>

            <MudStack Spacing="3">
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           Size="Size.Large" FullWidth="true"
                           Style="min-height: 64px; font-size: 1.25rem;"
                           OnClick="@(() => SelectStartDate(DateOnly.FromDateTime(DateTime.Today)))">
                    Idag
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                           Size="Size.Large" FullWidth="true"
                           Style="min-height: 56px; font-size: 1.125rem;"
                           OnClick="@(() => SelectStartDate(DateOnly.FromDateTime(DateTime.Today.AddDays(-1))))">
                    Igår
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Default"
                           Size="Size.Large" FullWidth="true"
                           Style="min-height: 56px; font-size: 1.125rem;"
                           OnClick="@(() => _showDatePicker = true)">
                    Annat datum
                </MudButton>

                @if (_showDatePicker)
                {
                    <MudDatePicker Label="Välj datum" @bind-Date="_customDate"
                                   @bind-Date:after="OnCustomDateSelected"
                                   MaxDate="DateTime.Today" />
                }
            </MudStack>
            break;

        case 1:
            <MudText Typo="Typo.h5" Class="mb-4" Style="font-weight: 600;">
                Vet du när du kan jobba igen?
            </MudText>

            <MudStack Spacing="3">
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           Size="Size.Large" FullWidth="true"
                           Style="min-height: 64px; font-size: 1.25rem;"
                           OnClick="@(() => SubmitSickLeave(null))">
                    Nej, vet inte ännu
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                           Size="Size.Large" FullWidth="true"
                           Style="min-height: 56px; font-size: 1.125rem;"
                           OnClick="@(() => _showEndDatePicker = true)">
                    Ja, jag vet ungefär
                </MudButton>

                @if (_showEndDatePicker)
                {
                    <MudDatePicker Label="Tillbaka ungefär" @bind-Date="_endDate"
                                   @bind-Date:after="OnEndDateSelected"
                                   MinDate="DateTime.Today" />
                }
            </MudStack>
            break;

        case 2:
            <div style="text-align: center; padding: 2rem 0;">
                <MudText Typo="Typo.h4" Color="Color.Success" Style="font-weight: 700;" Class="mb-4">
                    Klart!
                </MudText>
                <MudText Typo="Typo.h6" Class="mb-2">
                    Vi har registrerat att du är sjuk från @_startDate.ToString("d MMMM").
                </MudText>
                <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary);" Class="mb-4">
                    Din chef meddelas automatiskt.
                </MudText>

                <MudAlert Severity="Severity.Info" Variant="Variant.Text" Class="mt-4" Dense="false">
                    <MudText Typo="Typo.body1">
                        Om du är sjuk mer än 7 dagar behöver du ett läkarintyg. Vi påminner dig.
                    </MudText>
                </MudAlert>

                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           Size="Size.Large" Class="mt-6"
                           Style="min-height: 56px; font-size: 1.125rem;"
                           OnClick="@(() => Nav.NavigateTo("/minsida"))">
                    Tillbaka till startsidan
                </MudButton>
            </div>
            break;
    }
</OhrConversationFlow>

@code {
    private readonly List<string> _steps = ["Vilken dag?", "Tillbaka när?", "Klart!"];
    private int _currentStep;
    private DateOnly _startDate;
    private DateOnly? _endDateValue;
    private bool _showDatePicker;
    private bool _showEndDatePicker;
    private DateTime? _customDate;
    private DateTime? _endDate;

    private void SelectStartDate(DateOnly date)
    {
        _startDate = date;
        _currentStep = 1;
    }

    private void OnCustomDateSelected()
    {
        if (_customDate.HasValue)
        {
            SelectStartDate(DateOnly.FromDateTime(_customDate.Value));
        }
    }

    private async Task OnEndDateSelected()
    {
        if (_endDate.HasValue)
        {
            _endDateValue = DateOnly.FromDateTime(_endDate.Value);
            await SubmitSickLeave(_endDateValue);
        }
    }

    private async Task SubmitSickLeave(DateOnly? endDate)
    {
        try
        {
            // Create SickLeaveNotification
            var notification = SickLeaveNotification.Skapa(Guid.Empty, _startDate);
            await Db.SickLeaveNotifications.AddAsync(notification);

            // Create LeaveRequest
            var request = LeaveRequest.Skapa(
                Guid.Empty,
                LeaveType.Sjukfranvaro,
                _startDate,
                endDate ?? _startDate.AddDays(1),
                null);
            request.SkickaIn();
            await Db.LeaveRequests.AddAsync(request);

            await Db.SaveChangesAsync();
        }
        catch
        {
            // Demo mode - proceed to confirmation anyway
        }

        _currentStep = 2;
    }

    private void GoBack()
    {
        if (_currentStep > 0)
        {
            _currentStep--;
            _showDatePicker = false;
            _showEndDatePicker = false;
        }
    }
}
