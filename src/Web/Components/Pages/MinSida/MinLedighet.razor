@page "/minsida/ledighet"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Web.Components.Shared
@using RegionHR.Web.Services
@inject SelfServiceApiClient SelfService
@inject AuthService Auth

<PageTitle>OpenHR - Min ledighet</PageTitle>

<OhrBreadcrumb CurrentPage="Min ledighet" ExtraItems="@(new List<BreadcrumbItem> { new("Min sida", "/minsida") })" />

<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">🌴 Min ledighet</MudText>

<MudAlert Severity="Severity.Info" Variant="Variant.Text" Dense="true" Class="mb-4">
    Du har <strong>@_tillgangliga dagar</strong> kvar att ta ut.
</MudAlert>

<MudGrid Spacing="4" Class="mb-6">
    <MudItem xs="6" sm="3">
        <MudPaper Class="pa-4 text-center" Elevation="2">
            <MudText Typo="Typo.h3" Color="Color.Primary" Style="font-weight: 700;">@_tillgangliga</MudText>
            <MudText Typo="Typo.body1">Dagar du kan ta ledigt</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="6" sm="3">
        <MudPaper Class="pa-4 text-center" Elevation="1">
            <MudText Typo="Typo.h3" Style="font-weight: 700;">@_intjanade</MudText>
            <MudText Typo="Typo.body1">Dagar du har tjänat in</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="6" sm="3">
        <MudPaper Class="pa-4 text-center" Elevation="1">
            <MudText Typo="Typo.h3" Style="font-weight: 700;">@_uttagna</MudText>
            <MudText Typo="Typo.body1">Redan använda dagar</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="6" sm="3">
        <MudPaper Class="pa-4 text-center" Elevation="1">
            <MudText Typo="Typo.h3" Style="font-weight: 700;">@_sparade</MudText>
            <MudText Typo="Typo.body1">Sparade från förra året</MudText>
        </MudPaper>
    </MudItem>
</MudGrid>

<MudButton Variant="Variant.Filled" Color="Color.Primary"
           Size="Size.Large" FullWidth="true"
           Style="min-height: 64px; font-size: 1.25rem;"
           StartIcon="@Icons.Material.Filled.Add"
           Href="/ledighet/ny">
    Jag vill ha ledigt
</MudButton>

@code {
    private int _tillgangliga, _intjanade, _uttagna, _sparade;

    protected override async Task OnInitializedAsync()
    {
        if (Auth.EmployeeId == null) return;
        try
        {
            var balance = await SelfService.GetVacationBalanceAsync(
                Auth.EmployeeId.Value, DateTime.Today.Year);

            if (balance is not null)
            {
                _tillgangliga = balance.TillgangligaDagar;
                _intjanade = balance.Tilldelning;
                _uttagna = balance.UttagnaDagar;
                _sparade = balance.SparadeDagar;
            }
        }
        catch
        {
            // Saldo kunde inte hämtas — sidan visas ändå utan siffror
        }
    }
}
