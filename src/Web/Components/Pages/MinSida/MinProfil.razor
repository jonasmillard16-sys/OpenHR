@page "/minsida/profil"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Web.Components.Shared
@using RegionHR.Web.Services
@using RegionHR.SharedKernel.Domain
@inject SelfServiceApiClient SelfService
@inject AuthService Auth

<PageTitle>OpenHR - Om mig</PageTitle>

<OhrBreadcrumb CurrentPage="Om mig" ExtraItems="@(new List<BreadcrumbItem> { new("Min sida", "/minsida") })" />

@if (_noAuth)
{
    <MudAlert Severity="Severity.Warning" Class="mb-4">Ingen anställd kopplad till ditt konto. Profiluppgifter kan inte visas.</MudAlert>
}

<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">Om mig</MudText>

<MudGrid Spacing="4">
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-6" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-4">Personuppgifter</MudText>
            <MudTextField Value="@_namn" Label="Namn" Variant="Variant.Outlined" Class="mb-3"
                          Disabled="true" HelperText="Kan bara ändras av HR" />
            <MudTextField Value="@_personnummer" Label="Personnummer" Variant="Variant.Outlined" Class="mb-3"
                          Disabled="true" HelperText="Kan bara ändras av HR" />
            <MudTextField Value="@_enhet" Label="Enhet" Variant="Variant.Outlined" Class="mb-3"
                          Disabled="true" HelperText="Kan bara ändras av HR" />
            <MudTextField Value="@_befattning" Label="Befattning" Variant="Variant.Outlined" Class="mb-3"
                          Disabled="true" HelperText="Kan bara ändras av HR" />
            <MudTextField Value="@_anstaldSedan" Label="Anställd sedan" Variant="Variant.Outlined" Class="mb-3"
                          Disabled="true" HelperText="Kan bara ändras av HR" />
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="6">
        <MudPaper Class="pa-6" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-4">Kontaktuppgifter</MudText>
            <MudText Typo="Typo.body2" Class="mb-3" Style="color: var(--mud-palette-text-secondary);">
                Ändra dina uppgifter nedan och klicka Spara.
            </MudText>
            <MudTextField @bind-Value="_epost" Label="E-post" Variant="Variant.Outlined" Class="mb-3"
                          Required="true" Error="@_epostFel" ErrorText="@("E-postadressen måste innehålla @")" />
            <MudTextField @bind-Value="_telefon" Label="Telefon" Variant="Variant.Outlined" Class="mb-3"
                          Required="true" Error="@_telefonFel" ErrorText="Ange telefonnummer i format 07X-XXX XX XX" />
            <MudTextField @bind-Value="_adress" Label="Gatuadress" Variant="Variant.Outlined" Class="mb-3" />
            <MudTextField @bind-Value="_postnummer" Label="Postnummer" Variant="Variant.Outlined" Class="mb-3" />
            <MudTextField @bind-Value="_ort" Label="Ort" Variant="Variant.Outlined" Class="mb-3" />

            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                       FullWidth="true" Style="min-height: 48px;"
                       OnClick="SparaKontaktuppgifter">
                Spara
            </MudButton>

            @if (_sparad)
            {
                <MudAlert Severity="Severity.Success" Class="mt-3">
                    Dina kontaktuppgifter har sparats.
                </MudAlert>
            }
        </MudPaper>
    </MudItem>

    <MudItem xs="12">
        <MudPaper Class="pa-6" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-4">Nödkontakter</MudText>
            <MudText Typo="Typo.body2" Class="mb-3" Style="color: var(--mud-palette-text-secondary);">
                Vem ska vi kontakta om något händer dig på jobbet?
            </MudText>
            @if (_nodkontakter.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Text" Class="mb-3">
                    Du har inga nödkontakter registrerade ännu. Lägg till en nedan.
                </MudAlert>
            }
            else
            {
                <MudSimpleTable Hover="true">
                    <thead>
                        <tr><th>Namn</th><th>Relation</th><th>Telefon</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var k in _nodkontakter)
                        {
                            <tr><td>@k.Namn</td><td>@k.Relation</td><td>@k.Telefon</td></tr>
                        }
                    </tbody>
                </MudSimpleTable>
            }
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Class="mt-3"
                       StartIcon="@Icons.Material.Filled.Add" Size="Size.Large"
                       Style="min-height: 48px;" OnClick="@(() => _visaNodkontaktForm = true)">
                Lägg till nödkontakt
            </MudButton>
            @if (_visaNodkontaktForm)
            {
                <MudPaper Class="pa-4 mt-3" Elevation="1" Style="border-left: 4px solid var(--mud-palette-primary);">
                    <div class="d-flex justify-space-between align-center mb-3">
                        <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">Ny nödkontakt</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="@(() => _visaNodkontaktForm = false)" />
                    </div>
                    <MudTextField @bind-Value="_nodkontaktNamn" Label="Namn" Variant="Variant.Outlined" Class="mb-3" />
                    <MudTextField @bind-Value="_nodkontaktRelation" Label="Relation" Variant="Variant.Outlined" Class="mb-3" />
                    <MudTextField @bind-Value="_nodkontaktTelefon" Label="Telefon" Variant="Variant.Outlined" Class="mb-3" />
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LaggTillNodkontakt">Spara</MudButton>
                </MudPaper>
            }
            @if (_nodkontaktSparad)
            {
                <MudAlert Severity="Severity.Success" Class="mt-3" ShowCloseIcon="true" CloseIconClicked="@(() => _nodkontaktSparad = false)">Nödkontakt tillagd!</MudAlert>
            }
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private string _namn = "";
    private string _personnummer = "";
    private string _enhet = "";
    private string _befattning = "";
    private string _anstaldSedan = "";
    private string _epost = "";
    private string _telefon = "";
    private string _adress = "";
    private string _postnummer = "";
    private string _ort = "";
    private bool _sparad, _noAuth;
    private bool _epostFel;
    private bool _telefonFel;

    private static readonly System.Text.RegularExpressions.Regex _telefonRegex =
        new(@"^[\d\s\-\+\(\)]{7,}$", System.Text.RegularExpressions.RegexOptions.Compiled);

    protected override async Task OnInitializedAsync()
    {
        if (Auth.EmployeeId == null) { _noAuth = true; return; }
        try
        {
            var profil = await SelfService.GetProfileAsync(
                EmployeeId.From(Auth.EmployeeId.Value));

            if (profil is not null)
            {
                _namn = $"{profil.Fornamn} {profil.Efternamn}";
                _personnummer = profil.PersonnummerMaskerat;
                _enhet = profil.Enhet;
                _befattning = profil.Befattning;
                _anstaldSedan = profil.AnstaldSedan;
                _epost = profil.Epost;
                _telefon = profil.Telefon;
                _adress = profil.Adress;
                _postnummer = profil.Postnummer;
                _ort = profil.Ort;
            }
        }
        catch (Exception ex)
        {
            _namn = $"Fel: {ex.Message}";
        }
    }

    private bool _visaNodkontaktForm;
    private bool _nodkontaktSparad;
    private string _nodkontaktNamn = "";
    private string _nodkontaktRelation = "";
    private string _nodkontaktTelefon = "";
    private List<NodkontaktData> _nodkontakter = [];

    private void LaggTillNodkontakt()
    {
        if (!string.IsNullOrWhiteSpace(_nodkontaktNamn))
        {
            _nodkontakter.Add(new NodkontaktData(_nodkontaktNamn, _nodkontaktRelation, _nodkontaktTelefon));
        }
        _visaNodkontaktForm = false;
        _nodkontaktSparad = true;
        _nodkontaktNamn = "";
        _nodkontaktRelation = "";
        _nodkontaktTelefon = "";
    }

    private record NodkontaktData(string Namn, string Relation, string Telefon);

    private async Task SparaKontaktuppgifter()
    {
        _sparad = false;
        _epostFel = false;
        _telefonFel = false;

        // Validate email contains @
        if (string.IsNullOrWhiteSpace(_epost) || !_epost.Contains('@'))
        {
            _epostFel = true;
        }

        // Validate phone format (digits, spaces, dashes, at least 7 chars)
        if (string.IsNullOrWhiteSpace(_telefon) || !_telefonRegex.IsMatch(_telefon))
        {
            _telefonFel = true;
        }

        if (_epostFel || _telefonFel)
            return;

        try
        {
            if (Auth.EmployeeId == null) return;
            await SelfService.SaveContactInfoAsync(
                EmployeeId.From(Auth.EmployeeId.Value),
                _epost, _telefon, _adress, _postnummer, _ort);
            _sparad = true;
        }
        catch (Exception ex)
        {
            _namn = $"Kunde inte spara: {ex.Message}";
        }
    }
}
