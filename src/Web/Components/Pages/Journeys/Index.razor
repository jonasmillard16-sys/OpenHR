@page "/journeys"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Journeys
@using RegionHR.Infrastructure.Persistence
@using Microsoft.EntityFrameworkCore
@inject RegionHRDbContext Db

<PageTitle>OpenHR — Medarbetarresor</PageTitle>

<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4" Style="font-weight: 700;">Medarbetarresor</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
               StartIcon="@Icons.Material.Filled.Add" Style="min-height: 48px;"
               OnClick="@(() => _showCreate = !_showCreate)">Starta ny journey</MudButton>
</div>

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error">@_error</MudAlert>
}
else
{
    @if (_showCreate)
    {
        <MudPaper Class="pa-5 mb-4" Elevation="3" Style="border-left: 4px solid var(--mud-palette-primary);">
            <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight: 600;">Starta ny medarbetarresa</MudText>
            <MudGrid Spacing="3">
                <MudItem xs="12" sm="4">
                    <MudSelect T="Guid?" @bind-Value="_createTemplateId" Label="Välj mall" Variant="Variant.Outlined">
                        @foreach (var t in _templates)
                        {
                            <MudSelectItem T="Guid?" Value="@((Guid?)t.Id)">@t.Namn (@t.Steg.Count steg)</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudSelect T="Guid?" @bind-Value="_createAnstallId" Label="Välj anställd" Variant="Variant.Outlined">
                        @foreach (var e in _employees)
                        {
                            <MudSelectItem T="Guid?" Value="@((Guid?)e.Id.Value)">@e.Fornamn @e.Efternamn</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudDatePicker @bind-Date="_createStart" Label="Startdatum" Variant="Variant.Outlined" />
                </MudItem>
            </MudGrid>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-3" OnClick="SkapaInstans">Starta</MudButton>
        </MudPaper>
    }

    @if (_success != null)
    {
        <MudAlert Severity="Severity.Success" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="@(() => _success = null)">@_success</MudAlert>
    }

    <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight: 600;">Aktiva journeys (@_instances.Count(i => i.Status != JourneyInstanceStatus.Slutford))</MudText>
    @if (_instances.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Text" Class="mb-4">Inga journeys har startats.</MudAlert>
    }
    else
    {
        <MudSimpleTable Hover="true" Elevation="2" Class="mb-6">
            <thead><tr><th>Anställd</th><th>Mall</th><th>Start</th><th>Progress</th><th>Status</th><th></th></tr></thead>
            <tbody>
                @foreach (var i in _instances.OrderByDescending(i => i.Startdatum))
                {
                    <tr>
                        <td><strong>@i.AnstallNamn</strong></td>
                        <td>@i.MallNamn</td>
                        <td>@i.Startdatum.ToLocalTime().ToString("yyyy-MM-dd")</td>
                        <td>
                            <MudProgressLinear Value="@i.Progress" Color="@(i.Progress >= 100 ? Color.Success : Color.Primary)" Style="min-width: 80px;" />
                            <MudText Typo="Typo.caption">@i.Progress%</MudText>
                        </td>
                        <td><MudChip T="string" Size="Size.Small" Color="@(i.Status == JourneyInstanceStatus.Slutford ? Color.Success : Color.Info)">@i.Status</MudChip></td>
                        <td><MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary" Href="@($"/journeys/{i.Id}")">Öppna</MudButton></td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    }

    <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight: 600;">Mallar (@_templates.Count)</MudText>
    <MudGrid Spacing="3">
        @foreach (var t in _templates)
        {
            <MudItem xs="12" sm="6">
                <MudPaper Class="pa-4" Elevation="2">
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">@t.Namn</MudText>
                    <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">@(t.Beskrivning ?? "—")</MudText>
                    <MudChip T="string" Size="Size.Small" Class="mt-2">@t.Steg.Count steg</MudChip>
                </MudPaper>
            </MudItem>
        }
    </MudGrid>
}

@code {
    private List<JourneyTemplate> _templates = [];
    private List<JourneyInstance> _instances = [];
    private List<RegionHR.Core.Domain.Employee> _employees = [];
    private bool _loading = true, _showCreate;
    private string? _error, _success;
    private Guid? _createTemplateId, _createAnstallId;
    private DateTime? _createStart = DateTime.Today;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _templates = await Db.JourneyTemplates.Include("Steg").ToListAsync();
            _instances = await Db.JourneyInstances.Include("Steg").ToListAsync();
            _employees = await Db.Employees.OrderBy(e => e.Efternamn).ToListAsync();
        }
        catch (Exception ex) { _error = $"Kunde inte hämta data: {ex.Message}"; }
        finally { _loading = false; }
    }

    private async Task SkapaInstans()
    {
        if (_createTemplateId is null || _createAnstallId is null) return;
        var mall = _templates.FirstOrDefault(t => t.Id == _createTemplateId);
        var emp = _employees.FirstOrDefault(e => e.Id.Value == _createAnstallId);
        if (mall is null || emp is null) return;

        var inst = JourneyInstance.SkapaFranMall(mall, emp.Id.Value,
            $"{emp.Fornamn} {emp.Efternamn}", _createStart?.ToUniversalTime() ?? DateTime.UtcNow);
        Db.JourneyInstances.Add(inst);
        await Db.SaveChangesAsync();
        _instances.Add(inst);
        _showCreate = false;
        _success = $"Journey \"{mall.Namn}\" startad för {emp.Fornamn} {emp.Efternamn}.";
    }
}
