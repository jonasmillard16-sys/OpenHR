@page "/journeys/{InstanceId:guid}"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Journeys
@using RegionHR.Infrastructure.Persistence
@using Microsoft.EntityFrameworkCore
@inject RegionHRDbContext Db

<PageTitle>OpenHR — Journey</PageTitle>
<MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Variant="Variant.Text"
           Color="Color.Primary" Href="/journeys" Style="margin-bottom: 1rem;">Tillbaka</MudButton>

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_instance == null)
{
    <MudAlert Severity="Severity.Error">Journey hittades inte.</MudAlert>
}
else
{
    <MudText Typo="Typo.h4" Class="mb-1" Style="font-weight: 700;">@_instance.MallNamn</MudText>
    <MudText Typo="Typo.body2" Class="mb-4" Style="color: var(--mud-palette-text-secondary);">
        @_instance.AnstallNamn — startad @_instance.Startdatum.ToLocalTime().ToString("yyyy-MM-dd")
    </MudText>

    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-3 text-center" Elevation="2">
                <MudText Typo="Typo.h4" Color="Color.Primary" Style="font-weight: 700;">@_instance.Progress%</MudText>
                <MudText Typo="Typo.body2">Progress</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-3 text-center" Elevation="2">
                <MudText Typo="Typo.h4" Style="font-weight: 700;">@_instance.Steg.Count(s => s.Klar) / @_instance.Steg.Count</MudText>
                <MudText Typo="Typo.body2">Steg klara</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-3 text-center" Elevation="2">
                <MudText Typo="Typo.h4" Style="font-weight: 700;">@_instance.Status</MudText>
                <MudText Typo="Typo.body2">Status</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudProgressLinear Value="@_instance.Progress" Color="@(_instance.Progress >= 100 ? Color.Success : Color.Primary)"
                       Class="mb-4" Style="height: 8px; border-radius: 4px;" />

    <MudSimpleTable Hover="true" Elevation="2">
        <thead>
            <tr><th style="width: 40px;"></th><th>Steg</th><th>Beskrivning</th><th>Ansvarig</th><th>Planerad</th><th>Status</th></tr>
        </thead>
        <tbody>
            @foreach (var steg in _instance.Steg.OrderBy(s => s.Ordning))
            {
                var deadline = _instance.Startdatum.AddDays(steg.DagOffset);
                var forsenad = !steg.Klar && deadline < DateTime.UtcNow;
                <tr>
                    <td>
                        <MudCheckBox T="bool" Value="@steg.Klar" Disabled="@steg.Klar"
                                     ValueChanged="@(async (v) => { if (v) await MarkeraKlar(steg.Id); })"
                                     Color="Color.Success" />
                    </td>
                    <td><strong style="@(steg.Klar ? "text-decoration: line-through; opacity: 0.6;" : "")">@steg.Ordning. @steg.Titel</strong></td>
                    <td style="@(steg.Klar ? "opacity: 0.6;" : "")">@steg.Beskrivning</td>
                    <td><MudChip T="string" Size="Size.Small">@steg.AnsvarigRoll</MudChip></td>
                    <td>
                        <MudText Typo="Typo.body2" Style="@(forsenad ? "color: var(--mud-palette-error); font-weight: 600;" : "")">
                            Dag @steg.DagOffset (@deadline.ToLocalTime().ToString("yyyy-MM-dd"))
                        </MudText>
                    </td>
                    <td>
                        @if (steg.Klar)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Success">
                                Klar @(steg.KlarVid?.ToLocalTime().ToString("MM-dd"))
                            </MudChip>
                        }
                        else if (forsenad)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Error">Försenad</MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Default">Ej klar</MudChip>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </MudSimpleTable>
}

@code {
    [Parameter] public Guid InstanceId { get; set; }
    private JourneyInstance? _instance;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _instance = await Db.JourneyInstances
                .Include("Steg")
                .FirstOrDefaultAsync(i => i.Id == InstanceId);
        }
        catch { }
        finally { _loading = false; }
    }

    private async Task MarkeraKlar(Guid stegId)
    {
        if (_instance == null) return;
        _instance.MarkeraStegKlart(stegId, "Admin");
        await Db.SaveChangesAsync();
    }
}
