@page "/tidrapporter"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Scheduling.Domain
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<RegionHRDbContext> DbFactory

<PageTitle>OpenHR - Tidrapporter</PageTitle>
<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4" Style="font-weight: 700;">Tidrapporter</MudText>
</div>

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
}
else
{
    @if (_pendingCount > 0)
    {
        <MudAlert Severity="Severity.Info" Class="mb-4" Icon="@Icons.Material.Filled.AccessTime">
            <strong>@_pendingCount tidrapporter</strong> väntar på granskning.
        </MudAlert>
    }

    @if (_timesheets.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Text">Inga tidrapporter registrerade.</MudAlert>
    }
    else
    {
        <MudSimpleTable Hover="true" Elevation="2">
            <thead><tr><th>Anställd</th><th>Period</th><th>Planerade h</th><th>Faktiska h</th><th>Övertid</th><th>Status</th><th></th></tr></thead>
            <tbody>
                @foreach (var ts in _timesheets)
                {
                    <tr>
                        <td><strong>@ts.Namn</strong></td>
                        <td>@ts.Period</td>
                        <td>@ts.Planerade.ToString("F1")</td>
                        <td>@ts.Faktiska.ToString("F1")</td>
                        <td>@(ts.Overtid > 0 ? ts.Overtid.ToString("F1") : "—")</td>
                        <td><MudChip T="string" Size="Size.Small" Color="@StatusFarg(ts.Status)">@StatusText(ts.Status)</MudChip></td>
                        <td>
                            @if (ts.Status == TimesheetStatus.Inskickad)
                            {
                                <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary"
                                           Href="@($"/tidrapporter/{ts.Id}")" StartIcon="@Icons.Material.Filled.RateReview">Granska</MudButton>
                            }
                            else
                            {
                                <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Default"
                                           Href="@($"/tidrapporter/{ts.Id}")">Visa</MudButton>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    }
}

@code {
    private List<TimesheetVm> _timesheets = [];
    private int _pendingCount;
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        try
        {
            var timesheets = await db.Timesheets
                .OrderByDescending(t => t.Ar).ThenByDescending(t => t.Manad)
                .Take(50).ToListAsync();

            var anstallGuids = timesheets.Select(t => t.AnstallId).Distinct().ToList();
            var anstallIds = anstallGuids.Select(g => new EmployeeId(g)).ToList();
            var employees = await db.Employees
                .Where(e => anstallIds.Contains(e.Id)).ToListAsync();
            var names = employees.ToDictionary(e => e.Id.Value, e => $"{e.Fornamn} {e.Efternamn}");

            _timesheets = timesheets.Select(t => new TimesheetVm(
                t.Id,
                names.GetValueOrDefault(t.AnstallId, "Okänd"),
                $"{t.Ar}-{t.Manad:D2}",
                t.PlaneradeTimmar, t.FaktiskaTimmar, t.Overtid, t.Status
            )).ToList();

            _pendingCount = timesheets.Count(t => t.Status == TimesheetStatus.Inskickad);
        }
        catch (Exception ex) { _error = $"Kunde inte hämta tidrapporter: {ex.Message}"; }
        finally { _loading = false; }
    }

    private static string StatusText(TimesheetStatus s) => s switch
    {
        TimesheetStatus.Oppen => "Öppen",
        TimesheetStatus.Inskickad => "Inskickad",
        TimesheetStatus.Godkand => "Godkänd",
        TimesheetStatus.Avslagen => "Avslagen",
        _ => s.ToString()
    };

    private static Color StatusFarg(TimesheetStatus s) => s switch
    {
        TimesheetStatus.Inskickad => Color.Warning,
        TimesheetStatus.Godkand => Color.Success,
        TimesheetStatus.Avslagen => Color.Error,
        _ => Color.Default
    };

    private record TimesheetVm(Guid Id, string Namn, string Period, decimal Planerade, decimal Faktiska, decimal Overtid, TimesheetStatus Status);
}

