@page "/audit"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Audit.Domain
@using Microsoft.EntityFrameworkCore
@inject RegionHRDbContext Db

<PageTitle>OpenHR - Granskningslogg</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">Granskningslogg</MudText>

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
}
else
{
    <MudGrid Spacing="3" Class="mb-6">
        <MudItem xs="3"><MudPaper Class="pa-4 text-center" Elevation="2" Style="border-top: 4px solid var(--mud-palette-primary);"><MudText Typo="Typo.h3" Color="Color.Primary" Style="font-weight: 700;">@_totalCount</MudText><MudText Typo="Typo.body2">Händelser idag</MudText></MudPaper></MudItem>
        <MudItem xs="3"><MudPaper Class="pa-4 text-center" Elevation="2" Style="border-top: 4px solid var(--mud-palette-success);"><MudText Typo="Typo.h3" Color="Color.Success" Style="font-weight: 700;">@_createCount</MudText><MudText Typo="Typo.body2">Skapa</MudText></MudPaper></MudItem>
        <MudItem xs="3"><MudPaper Class="pa-4 text-center" Elevation="2" Style="border-top: 4px solid var(--mud-palette-warning);"><MudText Typo="Typo.h3" Color="Color.Warning" Style="font-weight: 700;">@_updateCount</MudText><MudText Typo="Typo.body2">Ändra</MudText></MudPaper></MudItem>
        <MudItem xs="3"><MudPaper Class="pa-4 text-center" Elevation="2" Style="border-top: 4px solid var(--mud-palette-error);"><MudText Typo="Typo.h3" Color="Color.Error" Style="font-weight: 700;">@_deleteCount</MudText><MudText Typo="Typo.body2">Ta bort</MudText></MudPaper></MudItem>
    </MudGrid>

    <MudText Typo="Typo.h6" Class="mb-3">Senaste händelser</MudText>
    @if (_entries.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Text">Inga audit-händelser registrerade.</MudAlert>
    }
    else
    {
        <MudSimpleTable Hover="true" Elevation="2">
            <thead><tr><th>Tidpunkt</th><th>Användare</th><th>Entitet</th><th>Åtgärd</th><th>Sammanfattning</th></tr></thead>
            <tbody>
                @foreach (var entry in _entries)
                {
                    <tr>
                        <td>@entry.Timestamp.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                        <td>@(entry.UserName ?? entry.UserId)</td>
                        <td>@entry.EntityType #@entry.EntityId</td>
                        <td>
                            @switch (entry.Action)
                            {
                                case AuditAction.Create:
                                    <MudChip T="string" Size="Size.Small" Color="Color.Success">Skapa</MudChip>
                                    break;
                                case AuditAction.Update:
                                    <MudChip T="string" Size="Size.Small" Color="Color.Warning">Ändra</MudChip>
                                    break;
                                case AuditAction.Delete:
                                    <MudChip T="string" Size="Size.Small" Color="Color.Error">Ta bort</MudChip>
                                    break;
                            }
                        </td>
                        <td>@FormatSummary(entry)</td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    }
}

@code {
    private List<AuditEntry> _entries = [];
    private int _totalCount, _createCount, _updateCount, _deleteCount;
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _entries = await Db.AuditEntries
                .OrderByDescending(e => e.Timestamp)
                .Take(100)
                .ToListAsync();

            var today = DateTime.UtcNow.Date;
            var todayEntries = _entries.Where(e => e.Timestamp.Date == today).ToList();
            _totalCount = todayEntries.Count;
            _createCount = todayEntries.Count(e => e.Action == AuditAction.Create);
            _updateCount = todayEntries.Count(e => e.Action == AuditAction.Update);
            _deleteCount = todayEntries.Count(e => e.Action == AuditAction.Delete);
        }
        catch (Exception ex) { _error = $"Kunde inte hämta granskningslogg: {ex.Message}"; }
        finally { _loading = false; }
    }

    private static string FormatSummary(AuditEntry entry) => entry.Action switch
    {
        AuditAction.Create => $"Nytt objekt skapat i {entry.EntityType}",
        AuditAction.Update => entry.NewValues is not null ? $"Uppdaterad: {Truncate(entry.NewValues, 80)}" : $"{entry.EntityType} uppdaterad",
        AuditAction.Delete => $"{entry.EntityType} borttagen",
        _ => ""
    };

    private static string Truncate(string value, int maxLength) =>
        value.Length <= maxLength ? value : value[..maxLength] + "...";
}
