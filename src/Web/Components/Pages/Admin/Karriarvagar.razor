@page "/admin/karriarvagar"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Competence.Domain
@using RegionHR.Infrastructure.Persistence
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<RegionHRDbContext> DbFactory

<PageTitle>OpenHR — Karriarvagar</PageTitle>

<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4" Style="font-weight: 700;">Karriarvagar</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
               StartIcon="@Icons.Material.Filled.Add" Style="min-height: 48px;"
               OnClick="@(() => _showForm = true)">Ny karriarvag</MudButton>
</div>

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error">@_error</MudAlert>
}
else
{
    @if (_showForm)
    {
        <MudPaper Class="pa-6 mb-4" Elevation="3" Style="border-left: 4px solid var(--mud-palette-primary);">
            <div class="d-flex justify-space-between align-center mb-3">
                <MudText Typo="Typo.h6" Style="font-weight: 600;">Skapa karriarvag</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="@(() => _showForm = false)" />
            </div>
            <MudTextField @bind-Value="_newNamn" Label="Namn" Variant="Variant.Outlined" Class="mb-3" />
            <MudTextField @bind-Value="_newBransch" Label="Bransch" Variant="Variant.Outlined" Class="mb-3" />
            <MudTextField @bind-Value="_newBeskrivning" Label="Beskrivning" Variant="Variant.Outlined" Lines="2" Class="mb-3" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SkapaKarriarvag">Skapa</MudButton>
        </MudPaper>
    }

    @if (_created)
    {
        <MudAlert Severity="Severity.Success" Class="mb-4" ShowCloseIcon="true"
                  CloseIconClicked="@(() => _created = false)">Karriarvag skapad!</MudAlert>
    }

    @foreach (var cp in _careerPaths)
    {
        <MudPaper Class="pa-4 mb-4" Elevation="2">
            <div class="d-flex justify-space-between align-center mb-2">
                <div>
                    <MudText Typo="Typo.h6" Style="font-weight: 600;">@cp.Namn</MudText>
                    <MudText Typo="Typo.caption">@cp.Bransch — @(cp.Beskrivning ?? "")</MudText>
                </div>
                <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary"
                           OnClick="@(() => ToggleSteg(cp))">
                    @(IsExpanded(cp) ? "Dolj steg" : "Visa steg")
                </MudButton>
            </div>

            @if (IsExpanded(cp))
            {
                var steps = cp.Steg.OrderBy(s => s.Ordning).ToList();

                <MudSimpleTable Hover="true" Elevation="0" Class="mt-2">
                    <thead><tr><th>#</th><th>Befattning</th><th>Typisk tid</th><th>Kravd erfarenhet</th><th>Kravda skills</th></tr></thead>
                    <tbody>
                        @foreach (var step in steps)
                        {
                            <tr>
                                <td><MudChip T="string" Size="Size.Small" Color="Color.Primary">@step.Ordning</MudChip></td>
                                <td><strong>@step.Befattning</strong></td>
                                <td>@step.TypiskTidManader man</td>
                                <td>@step.KravdErfarenhetManader man</td>
                                <td style="max-width: 300px; font-family: monospace; font-size: 0.8em;">@(step.KravdaSkills ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>

                @* Add step form *@
                <MudPaper Class="pa-3 mt-3" Elevation="0" Style="background: var(--mud-palette-background-grey);">
                    <MudText Typo="Typo.subtitle2" Class="mb-2" Style="font-weight: 600;">Lagg till steg</MudText>
                    <div class="d-flex gap-2 align-end">
                        <MudTextField @bind-Value="_newStepBefattning" Label="Befattning" Variant="Variant.Outlined" Style="flex: 2;" />
                        <MudNumericField @bind-Value="_newStepOrdning" Label="Ordning" Variant="Variant.Outlined" Style="flex: 1;" />
                        <MudNumericField @bind-Value="_newStepTid" Label="Tid (man)" Variant="Variant.Outlined" Style="flex: 1;" />
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                   OnClick="@(() => LaggTillSteg(cp))">Lagg till</MudButton>
                    </div>
                </MudPaper>
            }
        </MudPaper>
    }

    @if (_careerPaths.Count == 0)
    {
        <MudAlert Severity="Severity.Info">Inga karriarvagar skapade annu.</MudAlert>
    }
}

@code {
    private List<CareerPath> _careerPaths = [];
    private HashSet<Guid> _expandedPaths = [];
    private bool _loading = true;
    private string? _error;
    private bool _showForm;
    private bool _created;
    private string _newNamn = "";
    private string _newBransch = "";
    private string _newBeskrivning = "";
    private string _newStepBefattning = "";
    private int _newStepOrdning = 1;
    private int _newStepTid = 24;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        try
        {
            _careerPaths = await db.CareerPaths
                .Include(cp => cp.Steg)
                .OrderBy(cp => cp.Namn)
                .ToListAsync();
        }
        catch (Exception ex) { _error = $"Kunde inte hamta data: {ex.Message}"; }
        finally { _loading = false; }
    }

    private bool IsExpanded(CareerPath cp) => _expandedPaths.Contains(cp.Id.Value);

    private void ToggleSteg(CareerPath cp)
    {
        if (!_expandedPaths.Remove(cp.Id.Value))
            _expandedPaths.Add(cp.Id.Value);
    }

    private async Task SkapaKarriarvag()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        if (string.IsNullOrWhiteSpace(_newNamn) || string.IsNullOrWhiteSpace(_newBransch)) return;

        var cp = CareerPath.Skapa(_newNamn, _newBransch, _newBeskrivning);
        await db.CareerPaths.AddAsync(cp);
        await db.SaveChangesAsync();
        _careerPaths.Add(cp);

        _showForm = false;
        _created = true;
        _newNamn = "";
        _newBransch = "";
        _newBeskrivning = "";
    }

    private async Task LaggTillSteg(CareerPath cp)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        if (string.IsNullOrWhiteSpace(_newStepBefattning)) return;

        cp.LaggTillSteg(_newStepBefattning, _newStepOrdning, _newStepTid);
        await db.SaveChangesAsync();

        _newStepBefattning = "";
        _newStepOrdning = cp.Steg.Count + 1;
        _newStepTid = 24;
    }
}

