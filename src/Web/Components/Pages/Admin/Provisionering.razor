@page "/admin/provisionering"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Provisioning
@using RegionHR.Infrastructure.Persistence
@using Microsoft.EntityFrameworkCore
@inject RegionHRDbContext Db
@inject ProvisioningService ProvService

<PageTitle>OpenHR — Identitetshantering</PageTitle>

<MudText Typo="Typo.h4" Class="mb-2" Style="font-weight: 700;">Identitetshantering</MudText>
<MudText Typo="Typo.body2" Class="mb-4" Style="color: var(--mud-palette-text-secondary);">
    Lokal registrering — ingen extern provisionering har utförts. Åtgärder loggas i databasen.
</MudText>

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error">@_error</MudAlert>
}
else
{
    @* KPI *@
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="2">
                <MudText Typo="Typo.h3" Color="Color.Primary" Style="font-weight: 700;">@_events.Count</MudText>
                <MudText Typo="Typo.body2">Registrerade händelser</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="2">
                <MudText Typo="Typo.h3" Style="font-weight: 700;">@_rules.Count(r => r.ArAktiv)</MudText>
                <MudText Typo="Typo.body2">Aktiva regler</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="2">
                <MudText Typo="Typo.h3" Style="font-weight: 700;">@_rules.Select(r => r.TargetSystem).Distinct().Count()</MudText>
                <MudText Typo="Typo.body2">Målsystem konfigurerade</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="2">
                <MudText Typo="Typo.h3" Color="Color.Warning" Style="font-weight: 700;">0</MudText>
                <MudText Typo="Typo.body2">Externa kopplingar (v1: 0)</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudAlert Severity="Severity.Info" Variant="Variant.Text" Class="mb-4" Dense="true">
        <strong>v1 begränsning:</strong> Alla åtgärder registreras lokalt i databasen.
        Ingen extern integration mot Active Directory, Entra ID eller andra system har utförts.
        Status "RegistreradLokalt" betyder att åtgärden är loggad, inte exekverad externt.
    </MudAlert>

    @* Manuell beräkning *@
    <MudPaper Class="pa-4 mb-4" Elevation="2">
        <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight: 600;">Beräkna provisioneringsåtgärder</MudText>
        <MudGrid Spacing="3">
            <MudItem xs="12" sm="5">
                <MudSelect T="Guid?" @bind-Value="_selectedAnstallId" Label="Anställd" Variant="Variant.Outlined">
                    @foreach (var e in _employees)
                    {
                        <MudSelectItem T="Guid?" Value="@((Guid?)e.Id.Value)">@e.Fornamn @e.Efternamn</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudSelect T="ProvisioningTrigger" @bind-Value="_selectedTrigger" Label="Trigger" Variant="Variant.Outlined">
                    @foreach (var t in Enum.GetValues<ProvisioningTrigger>())
                    {
                        <MudSelectItem Value="@t">@TriggerText(t)</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="3" Class="d-flex align-end">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                           Style="min-height: 48px; width: 100%;"
                           OnClick="BeraknaAtgarder" Disabled="_calculating">
                    @if (_calculating)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    Beräkna åtgärder
                </MudButton>
            </MudItem>
        </MudGrid>

        @if (_lastResult != null)
        {
            <MudAlert Severity="Severity.Success" Class="mt-3">
                @_lastResult.Count åtgärd(er) registrerade lokalt.
            </MudAlert>
        }
    </MudPaper>

    @* Regler *@
    <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight: 600;">Konfigurerade regler</MudText>
    <MudSimpleTable Hover="true" Elevation="2" Class="mb-4">
        <thead><tr><th>Trigger</th><th>Målsystem</th><th>Åtgärd</th><th>Beskrivning</th><th>Aktiv</th></tr></thead>
        <tbody>
            @foreach (var r in _rules)
            {
                <tr>
                    <td>@TriggerText(r.Trigger)</td>
                    <td><strong>@r.TargetSystem</strong></td>
                    <td>@AktionText(r.Aktion)</td>
                    <td>@(r.Beskrivning ?? "—")</td>
                    <td><MudChip T="string" Size="Size.Small" Color="@(r.ArAktiv ? Color.Success : Color.Default)">@(r.ArAktiv ? "Aktiv" : "Inaktiv")</MudChip></td>
                </tr>
            }
        </tbody>
    </MudSimpleTable>

    @* Händelselogg *@
    <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight: 600;">Händelselogg</MudText>
    @if (_events.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Text">
            Inga provisioneringshändelser har registrerats ännu.
            Använd "Beräkna åtgärder" ovan för att skapa loggposter.
        </MudAlert>
    }
    else
    {
        <MudSimpleTable Hover="true" Elevation="2">
            <thead><tr><th>Tidpunkt</th><th>Anställd</th><th>System</th><th>Åtgärd</th><th>Trigger</th><th>Status</th></tr></thead>
            <tbody>
                @foreach (var e in _events.OrderByDescending(e => e.Tidpunkt))
                {
                    <tr>
                        <td>@e.Tidpunkt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                        <td><strong>@e.AnstallNamn</strong></td>
                        <td>@e.TargetSystem</td>
                        <td>@AktionText(e.Aktion)</td>
                        <td>@TriggerText(e.Trigger)</td>
                        <td><MudChip T="string" Size="Size.Small" Color="Color.Info">@StatusText(e.Status)</MudChip></td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    }
}

@code {
    private List<ProvisioningEvent> _events = [];
    private List<ProvisioningRule> _rules = [];
    private List<RegionHR.Core.Domain.Employee> _employees = [];
    private Guid? _selectedAnstallId;
    private ProvisioningTrigger _selectedTrigger = ProvisioningTrigger.NyAnstallning;
    private List<ProvisioningEvent>? _lastResult;
    private bool _loading = true, _calculating;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _events = await Db.ProvisioningEvents.ToListAsync();
            _rules = await Db.ProvisioningRules.ToListAsync();
            _employees = await Db.Employees.OrderBy(e => e.Efternamn).ToListAsync();
        }
        catch (Exception ex) { _error = $"Kunde inte hämta data: {ex.Message}"; }
        finally { _loading = false; }
    }

    private async Task BeraknaAtgarder()
    {
        if (_selectedAnstallId is null) return;
        _calculating = true;
        _lastResult = null;
        StateHasChanged();

        var emp = _employees.FirstOrDefault(e => e.Id.Value == _selectedAnstallId);
        if (emp is null) { _calculating = false; return; }

        _lastResult = await ProvService.BeraknaOchRegistreraAsync(
            emp.Id.Value, $"{emp.Fornamn} {emp.Efternamn}", _selectedTrigger);

        // Reload events from DB
        _events = await Db.ProvisioningEvents.ToListAsync();
        _calculating = false;
    }

    private static string TriggerText(ProvisioningTrigger t) => t switch
    {
        ProvisioningTrigger.NyAnstallning => "Ny anställning",
        ProvisioningTrigger.AvslutadAnstallning => "Avslutad anställning",
        ProvisioningTrigger.EnhetsByte => "Enhetsbyte",
        ProvisioningTrigger.Manuell => "Manuell",
        _ => t.ToString()
    };

    private static string AktionText(ProvisioningAktion a) => a switch
    {
        ProvisioningAktion.SkapaKonto => "Skapa konto",
        ProvisioningAktion.InaktiveraKonto => "Inaktivera konto",
        ProvisioningAktion.UppdateraGruppmedlemskap => "Uppdatera gruppmedlemskap",
        ProvisioningAktion.TilldelaLicens => "Tilldela licens",
        ProvisioningAktion.AterkallLicens => "Återkalla licens",
        ProvisioningAktion.SkapaEpost => "Skapa e-post",
        ProvisioningAktion.SparraPasserkort => "Spärra passerkort",
        _ => a.ToString()
    };

    private static string StatusText(ProvisioningStatus s) => s switch
    {
        ProvisioningStatus.RegistreradLokalt => "Registrerad lokalt",
        ProvisioningStatus.ExekveradExternt => "Exekverad externt",
        ProvisioningStatus.MisslyckadExternt => "Misslyckad externt",
        _ => s.ToString()
    };
}
