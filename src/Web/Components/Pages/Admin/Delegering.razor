@page "/admin/delegering"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Infrastructure.Authorization
@using Microsoft.EntityFrameworkCore
@inject RegionHRDbContext Db

<PageTitle>OpenHR - Delegering</PageTitle>
<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4" Style="font-weight: 700;">Delegering</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" StartIcon="@Icons.Material.Filled.Add" Style="min-height: 48px;" OnClick="@(() => _showForm = true)">Ny delegering</MudButton>
</div>

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
}
else
{
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="4"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Success" Style="font-weight: 700;">@_aktiva</MudText><MudText Typo="Typo.body2">Aktiva</MudText></MudPaper></MudItem>
        <MudItem xs="4"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Info" Style="font-weight: 700;">@_kommande</MudText><MudText Typo="Typo.body2">Kommande</MudText></MudPaper></MudItem>
        <MudItem xs="4"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Style="font-weight: 700;">@_utgangna</MudText><MudText Typo="Typo.body2">Utgångna</MudText></MudPaper></MudItem>
    </MudGrid>

    @if (_showForm)
    {
        <MudPaper Class="pa-5 mb-4" Elevation="3" Style="border-left: 4px solid var(--mud-palette-primary);">
            <div class="d-flex justify-space-between align-center mb-3">
                <MudText Typo="Typo.h6" Style="font-weight: 600;">Ny delegering</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="@(() => _showForm = false)" />
            </div>
            <MudGrid Spacing="3">
                <MudItem xs="12" sm="4">
                    <MudSelect T="Guid?" @bind-Value="_formDelegator" Label="Från (chef)" Variant="Variant.Outlined">
                        @foreach (var e in _employees) { <MudSelectItem T="Guid?" Value="@((Guid?)e.Id.Value)">@e.Fornamn @e.Efternamn</MudSelectItem> }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudSelect T="Guid?" @bind-Value="_formDelegat" Label="Till (ställföreträdare)" Variant="Variant.Outlined">
                        @foreach (var e in _employees) { <MudSelectItem T="Guid?" Value="@((Guid?)e.Id.Value)">@e.Fornamn @e.Efternamn</MudSelectItem> }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4"><MudTextField @bind-Value="_formRoll" Label="Behörighet" Variant="Variant.Outlined" /></MudItem>
                <MudItem xs="12" sm="4"><MudDatePicker @bind-Date="_formFran" Label="Från" Variant="Variant.Outlined" /></MudItem>
                <MudItem xs="12" sm="4"><MudDatePicker @bind-Date="_formTill" Label="Till" Variant="Variant.Outlined" /></MudItem>
                <MudItem xs="12" sm="4"><MudTextField @bind-Value="_formAnledning" Label="Anledning" Variant="Variant.Outlined" /></MudItem>
            </MudGrid>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-3" OnClick="SkapaDelegering"
                       Disabled="@(_formDelegator == null || _formDelegat == null || _formFran == null || _formTill == null || _saving)">Skapa</MudButton>
        </MudPaper>
    }

    @if (_success != null)
    {
        <MudAlert Severity="Severity.Success" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="@(() => _success = null)">@_success</MudAlert>
    }

    @if (_rader.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Text">Inga delegeringar registrerade.</MudAlert>
    }
    else
    {
        <MudSimpleTable Hover="true" Elevation="2">
            <thead><tr><th>Från</th><th>Till</th><th>Behörighet</th><th>Period</th><th>Anledning</th><th>Status</th></tr></thead>
            <tbody>
                @foreach (var r in _rader)
                {
                    var idag = DateOnly.FromDateTime(DateTime.Today);
                    var status = !r.Deleg.ArAktiv ? "Avslutad" : r.Deleg.FranDatum > idag ? "Kommande" : r.Deleg.TillDatum < idag ? "Utgången" : "Aktiv";
                    var farg = status switch { "Aktiv" => Color.Success, "Kommande" => Color.Info, _ => Color.Default };
                    <tr>
                        <td><strong>@r.DelegatorNamn</strong></td>
                        <td>@r.DelegatNamn</td>
                        <td>@r.Deleg.Roll</td>
                        <td>@r.Deleg.FranDatum.ToString("yyyy-MM-dd") – @r.Deleg.TillDatum.ToString("yyyy-MM-dd")</td>
                        <td>@(r.Deleg.Anledning ?? "—")</td>
                        <td><MudChip T="string" Size="Size.Small" Color="@farg">@status</MudChip></td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    }
}

@code {
    private List<DelegVm> _rader = [];
    private List<RegionHR.Core.Domain.Employee> _employees = [];
    private int _aktiva, _kommande, _utgangna;
    private bool _loading = true, _saving, _showForm;
    private string? _error, _success;
    private Guid? _formDelegator, _formDelegat;
    private DateTime? _formFran, _formTill;
    private string _formRoll = "", _formAnledning = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var delegs = await Db.DelegatedAccesses.OrderByDescending(d => d.SkapadVid).ToListAsync();
            _employees = await Db.Employees.OrderBy(e => e.Efternamn).ToListAsync();
            var names = _employees.ToDictionary(e => e.Id.Value, e => $"{e.Fornamn} {e.Efternamn}");

            _rader = delegs.Select(d => new DelegVm(
                names.GetValueOrDefault(d.DelegatorId, "Okänd"),
                names.GetValueOrDefault(d.DelegatId, "Okänd"), d)).ToList();

            var idag = DateOnly.FromDateTime(DateTime.Today);
            _aktiva = delegs.Count(d => d.ArGiltig(idag));
            _kommande = delegs.Count(d => d.ArAktiv && d.FranDatum > idag);
            _utgangna = delegs.Count(d => !d.ArAktiv || d.TillDatum < idag);
        }
        catch (Exception ex) { _error = $"Kunde inte hämta delegeringar: {ex.Message}"; }
        finally { _loading = false; }
    }

    private async Task SkapaDelegering()
    {
        if (_formDelegator == null || _formDelegat == null || _formFran == null || _formTill == null) return;
        _saving = true; _error = null;
        try
        {
            var d = DelegatedAccess.Skapa(_formDelegator.Value, _formDelegat.Value, _formRoll,
                DateOnly.FromDateTime(_formFran.Value), DateOnly.FromDateTime(_formTill.Value), _formAnledning);
            Db.DelegatedAccesses.Add(d);
            await Db.SaveChangesAsync();
            var names = _employees.ToDictionary(e => e.Id.Value, e => $"{e.Fornamn} {e.Efternamn}");
            _rader.Insert(0, new DelegVm(names.GetValueOrDefault(d.DelegatorId, "Okänd"), names.GetValueOrDefault(d.DelegatId, "Okänd"), d));
            _showForm = false; _success = "Delegering skapad.";
        }
        catch (Exception ex) { _error = $"Kunde inte skapa: {ex.Message}"; }
        finally { _saving = false; }
    }

    private record DelegVm(string DelegatorNamn, string DelegatNamn, DelegatedAccess Deleg);
}
