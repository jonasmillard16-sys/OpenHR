@page "/admin/anslagstavla"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Communication.Domain
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<RegionHRDbContext> DbFactory

<PageTitle>OpenHR - Anslagstavla</PageTitle>
<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4" Style="font-weight: 700;">Anslagstavla</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" StartIcon="@Icons.Material.Filled.Add" Style="min-height: 48px;" OnClick="@(() => _showForm = true)">Nytt anslag</MudButton>
</div>

@if (_loading) { <MudProgressCircular Color="Color.Primary" Indeterminate="true" /> }
else if (_error != null) { <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert> }
else
{
    @if (_showForm)
    {
        <MudPaper Class="pa-5 mb-4" Elevation="3" Style="border-left: 4px solid var(--mud-palette-primary);">
            <div class="d-flex justify-space-between align-center mb-3">
                <MudText Typo="Typo.h6" Style="font-weight: 600;">Nytt anslag</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="@(() => _showForm = false)" />
            </div>
            <MudTextField @bind-Value="_newTitel" Label="Titel" Variant="Variant.Outlined" Class="mb-3" Required="true" />
            <MudTextField @bind-Value="_newInnehall" Label="Innehåll" Variant="Variant.Outlined" Lines="3" Class="mb-3" Required="true" />
            <MudSelect T="AnnouncementPriority" @bind-Value="_newPrioritet" Label="Prioritet" Variant="Variant.Outlined" Class="mb-3">
                <MudSelectItem Value="AnnouncementPriority.Normal">Normal</MudSelectItem>
                <MudSelectItem Value="AnnouncementPriority.Viktig">Viktig</MudSelectItem>
                <MudSelectItem Value="AnnouncementPriority.Kritisk">Kritisk</MudSelectItem>
            </MudSelect>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SkapaAnslag"
                       Disabled="@(string.IsNullOrWhiteSpace(_newTitel) || string.IsNullOrWhiteSpace(_newInnehall) || _saving)">Skapa</MudButton>
        </MudPaper>
    }

    @if (_success != null) { <MudAlert Severity="Severity.Success" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="@(() => _success = null)">@_success</MudAlert> }

    @if (_anslag.Count == 0) { <MudAlert Severity="Severity.Info" Variant="Variant.Text">Inga anslag publicerade.</MudAlert> }
    else
    {
        @foreach (var a in _anslag)
        {
            <MudPaper Class="pa-4 mb-3" Elevation="2" Style="@(a.Prioritet == AnnouncementPriority.Kritisk ? "border-left: 4px solid var(--mud-palette-error);" : a.Prioritet == AnnouncementPriority.Viktig ? "border-left: 4px solid var(--mud-palette-warning);" : "")">
                <div class="d-flex justify-space-between align-center mb-1">
                    <MudText Typo="Typo.h6" Style="font-weight: 600;">@a.Titel</MudText>
                    <MudStack Row="true" Spacing="2">
                        <MudChip T="string" Size="Size.Small" Color="@StatusColor(a.Status)">@StatusText(a.Status)</MudChip>
                        @if (a.Prioritet != AnnouncementPriority.Normal)
                        {
                            <MudChip T="string" Size="Size.Small" Color="@(a.Prioritet == AnnouncementPriority.Kritisk ? Color.Error : Color.Warning)">@a.Prioritet</MudChip>
                        }
                    </MudStack>
                </div>
                <MudText Typo="Typo.body1" Class="mb-2">@a.Innehall</MudText>
                <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">@a.SkapadVid.ToLocalTime().ToString("yyyy-MM-dd HH:mm") — @a.SkapadAv</MudText>
                @if (a.Status == AnnouncementStatus.Utkast)
                {
                    <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" Class="mt-2" OnClick="@(() => PubliceraAnslag(a))">Publicera</MudButton>
                }
                else if (a.Status == AnnouncementStatus.Publicerad)
                {
                    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default" Class="mt-2" OnClick="@(() => ArkiveraAnslag(a))">Arkivera</MudButton>
                }
            </MudPaper>
        }
    }
}

@code {
    private List<Announcement> _anslag = [];
    private bool _loading = true, _saving, _showForm;
    private string? _error, _success, _newTitel = "", _newInnehall = "";
    private AnnouncementPriority _newPrioritet = AnnouncementPriority.Normal;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        try { _anslag = await db.Announcements.OrderByDescending(a => a.SkapadVid).ToListAsync(); }
        catch (Exception ex) { _error = $"Kunde inte hämta anslag: {ex.Message}"; }
        finally { _loading = false; }
    }

    private async Task SkapaAnslag()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _saving = true; _error = null;
        try
        {
            var a = Announcement.Skapa(_newTitel!, _newInnehall!, _newPrioritet, "Admin");
            db.Announcements.Add(a);
            await db.SaveChangesAsync();
            _anslag.Insert(0, a);
            _showForm = false; _success = "Anslag skapat."; _newTitel = ""; _newInnehall = "";
        }
        catch (Exception ex) { _error = $"Kunde inte skapa: {ex.Message}"; }
        finally { _saving = false; }
    }

    private async Task PubliceraAnslag(Announcement a)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        try { a.Publicera(); await db.SaveChangesAsync(); }
        catch (Exception ex) { _error = $"Kunde inte publicera: {ex.Message}"; }
    }

    private async Task ArkiveraAnslag(Announcement a)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        try { a.Arkivera(); await db.SaveChangesAsync(); }
        catch (Exception ex) { _error = $"Kunde inte arkivera: {ex.Message}"; }
    }

    private static string StatusText(AnnouncementStatus s) => s switch { AnnouncementStatus.Utkast => "Utkast", AnnouncementStatus.Publicerad => "Publicerad", AnnouncementStatus.Arkiverad => "Arkiverad", _ => s.ToString() };
    private static Color StatusColor(AnnouncementStatus s) => s switch { AnnouncementStatus.Publicerad => Color.Success, AnnouncementStatus.Arkiverad => Color.Default, _ => Color.Info };
}

