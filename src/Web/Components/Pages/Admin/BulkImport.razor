@page "/admin/import"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Core.Domain
@using RegionHR.SharedKernel.Domain
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<RegionHRDbContext> DbFactory

<PageTitle>OpenHR - Import</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">CSV-import av anställda</MudText>
<MudText Typo="Typo.body2" Class="mb-4" Style="color: var(--mud-palette-text-secondary);">
    Klistra in CSV-data med kolumner: Personnummer;Förnamn;Efternamn;Epost (semikolon-separerat).
</MudText>

@if (_error != null) { <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert> }

@if (_imported > 0)
{
    <MudAlert Severity="Severity.Success" Class="mb-4">@_imported anställda importerade till databasen.</MudAlert>
}

<MudPaper Class="pa-5" Elevation="2">
    <MudTextField @bind-Value="_csvData" Label="CSV-data" Variant="Variant.Outlined" Lines="8"
                  Placeholder="198501151234;Anna;Svensson;anna@region.se" Class="mb-3" />
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Style="min-height: 48px;"
               OnClick="Importera" Disabled="@(string.IsNullOrWhiteSpace(_csvData) || _saving)">
        @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
        Importera
    </MudButton>
</MudPaper>

@if (_valideringsfel.Count > 0)
{
    <MudAlert Severity="Severity.Warning" Class="mt-4">
        <MudText Typo="Typo.subtitle2">Valideringsfel:</MudText>
        @foreach (var f in _valideringsfel) { <MudText Typo="Typo.body2">@f</MudText> }
    </MudAlert>
}

@code {
    private string _csvData = "";
    private int _imported;
    private bool _saving;
    private string? _error;
    private List<string> _valideringsfel = [];

    private async Task Importera()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _saving = true; _error = null; _valideringsfel = []; _imported = 0;
        try
        {
            var lines = _csvData.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
            var created = new List<Employee>();

            foreach (var line in lines)
            {
                var parts = line.Split(';');
                if (parts.Length < 3)
                {
                    _valideringsfel.Add($"Rad \"{line}\" har för få kolumner (behöver minst Pnr;Förnamn;Efternamn).");
                    continue;
                }

                try
                {
                    var pnr = Personnummer.CreateValidated(parts[0].Trim());
                    var emp = Employee.Skapa(pnr, parts[1].Trim(), parts[2].Trim());
                    if (parts.Length >= 4 && !string.IsNullOrWhiteSpace(parts[3]))
                    {
                        emp.UppdateraKontaktuppgifter(parts[3].Trim(), null, null);
                    }
                    db.Employees.Add(emp);
                    created.Add(emp);
                }
                catch (Exception ex)
                {
                    _valideringsfel.Add($"Rad \"{line}\": {ex.Message}");
                }
            }

            if (created.Count > 0)
            {
                await db.SaveChangesAsync();
                _imported = created.Count;
                _csvData = "";
            }
        }
        catch (Exception ex) { _error = $"Import misslyckades: {ex.Message}"; }
        finally { _saving = false; }
    }
}

