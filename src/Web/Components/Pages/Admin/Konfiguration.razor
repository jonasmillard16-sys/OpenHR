@page "/admin/konfiguration"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<RegionHRDbContext> DbFactory

<PageTitle>OpenHR - Konfiguration</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">Systemkonfiguration</MudText>

@if (_loading) { <MudProgressCircular Color="Color.Primary" Indeterminate="true" /> }
else if (_error != null) { <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert> }
else
{
    <MudText Typo="Typo.h6" Class="mb-3">Systemstatus</MudText>
    <MudSimpleTable Hover="true" Elevation="2" Class="mb-6">
        <thead><tr><th>Parameter</th><th>Värde</th></tr></thead>
        <tbody>
            <tr><td><strong>Anställda i systemet</strong></td><td>@_antalAnstallda</td></tr>
            <tr><td><strong>Organisationsenheter</strong></td><td>@_antalEnheter</td></tr>
            <tr><td><strong>Positioner</strong></td><td>@_antalPositioner</td></tr>
            <tr><td><strong>Lönekörningar</strong></td><td>@_antalKorningar</td></tr>
            <tr><td><strong>Lönearter</strong></td><td>@_antalLonearter</td></tr>
            <tr><td><strong>Policyer</strong></td><td>@_antalPolicyer</td></tr>
        </tbody>
    </MudSimpleTable>

    <MudText Typo="Typo.h6" Class="mb-3">Systemparametrar</MudText>
    <MudAlert Severity="Severity.Info" Variant="Variant.Text" Class="mb-4">Systeminställningar lagras i TenantConfiguration. Ändring kräver admin-behörighet.</MudAlert>
    <MudSimpleTable Hover="true" Elevation="1">
        <thead><tr><th>Inställning</th><th>Värde</th><th>Beskrivning</th></tr></thead>
        <tbody>
            <tr><td><strong>Kollektivavtal</strong></td><td>AB + HOK</td><td>Primära avtal för löneberäkning</td></tr>
            <tr><td><strong>Löneperiod</strong></td><td>Månad (25:e)</td><td>Utbetalningsdatum</td></tr>
            <tr><td><strong>AG-avgift</strong></td><td>31,42%</td><td>Standard arbetsgivaravgift</td></tr>
            <tr><td><strong>Kommunalskatt</strong></td><td>32,13%</td><td>Standard kommunalskatt Göteborg</td></tr>
        </tbody>
    </MudSimpleTable>
}

@code {
    private int _antalAnstallda, _antalEnheter, _antalPositioner, _antalKorningar, _antalLonearter, _antalPolicyer;
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        try
        {
            _antalAnstallda = await db.Employees.CountAsync();
            _antalEnheter = await db.OrganizationUnits.CountAsync();
            _antalPositioner = await db.Positions_Table.CountAsync();
            _antalKorningar = await db.PayrollRuns.CountAsync();
            _antalLonearter = await db.SalaryCodes.CountAsync();
            _antalPolicyer = await db.Policies.CountAsync();
        }
        catch (Exception ex) { _error = $"Kunde inte hämta systemstatus: {ex.Message}"; }
        finally { _loading = false; }
    }
}

