@page "/admin/succession"
@rendermode InteractiveServer
@layout RegionHR.Web.Components.Layout.AdminLayout

<PageTitle>OpenHR - Successionsplanering</PageTitle>
<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4" Style="font-weight: 700;">Successionsplanering</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" StartIcon="@Icons.Material.Filled.Add" Style="min-height: 48px;" OnClick="@(() => _visaNyDialog = true)">Lägg till nyckelposition</MudButton>
</div>

<MudGrid Spacing="3" Class="mb-4">
    <MudItem xs="3">
        <MudPaper Class="pa-3 text-center" Elevation="1">
            <MudText Typo="Typo.h4" Color="Color.Primary" Style="font-weight: 700;">@_nyckelpositioner</MudText>
            <MudText Typo="Typo.body2">Identifierade nyckelpositioner</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="3">
        <MudPaper Class="pa-3 text-center" Elevation="1">
            <MudText Typo="Typo.h4" Color="Color.Success" Style="font-weight: 700;">@_medEftradare</MudText>
            <MudText Typo="Typo.body2">Har identifierad efterträdare</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="3">
        <MudPaper Class="pa-3 text-center" Elevation="1">
            <MudText Typo="Typo.h4" Color="Color.Error" Style="font-weight: 700;">@_utanEftradare</MudText>
            <MudText Typo="Typo.body2">Saknar efterträdare</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="3">
        <MudPaper Class="pa-3 text-center" Elevation="1">
            <MudText Typo="Typo.h4" Color="Color.Warning" Style="font-weight: 700;">@_pensionsnara</MudText>
            <MudText Typo="Typo.body2">Pensionsnära (≤3 år)</MudText>
        </MudPaper>
    </MudItem>
</MudGrid>

<MudAlert Severity="Severity.Warning" Class="mb-4">
    <strong>@_utanEftradare nyckelpositioner</strong> saknar identifierad efterträdare.
    Prioritera dessa i kommande ledarutvecklingsprogram.
</MudAlert>

<MudText Typo="Typo.h6" Class="mb-3">Nyckelpositioner och potentiella efterträdare</MudText>
<MudSimpleTable Hover="true" Elevation="2">
    <thead>
        <tr>
            <th>Position</th>
            <th>Nuvarande innehavare</th>
            <th>Pensionsålder</th>
            <th>Potentiell efterträdare</th>
            <th>Beredskapsnivå</th>
            <th>Utvecklingsplan</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var rad in _positioner)
        {
            <tr>
                <td><strong>@rad.Position</strong></td>
                <td>@rad.Innehavare</td>
                <td>@rad.PensionsAr</td>
                <td>@(string.IsNullOrEmpty(rad.Efterfoljare) ? "—" : rad.Efterfoljare)</td>
                <td>
                    @if (!string.IsNullOrEmpty(rad.Efterfoljare))
                    {
                        <MudChip T="string" Size="Size.Small" Color="@rad.BeredskapFarg">@rad.BeredskapText</MudChip>
                    }
                    else
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Error">Ej identifierad</MudChip>
                    }
                </td>
                <td>
                    @if (!string.IsNullOrEmpty(rad.Efterfoljare))
                    {
                        <MudProgressLinear Value="@rad.UtvecklingProcent" Color="Color.Info" Class="my-1" Style="min-width: 80px;" />
                        <MudText Typo="Typo.caption">@rad.UtvecklingProcent % genomförd</MudText>
                    }
                </td>
                <td><MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary">Detaljer</MudButton></td>
            </tr>
        }
    </tbody>
</MudSimpleTable>

<MudDialog @bind-Visible="_visaNyDialog" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
    <TitleContent>
        <MudText Typo="Typo.h6">Lägg till nyckelposition</MudText>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body2" Class="mb-4">Funktionen är under utveckling. Kontakta HR för att registrera nyckelpositioner.</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _visaNyDialog = false)">Stäng</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private bool _visaNyDialog;
    private int _nyckelpositioner = 14;
    private int _medEftradare = 9;
    private int _utanEftradare = 5;
    private int _pensionsnara = 4;

    private List<SuccessionsRad> _positioner = [];

    protected override void OnInitialized()
    {
        _positioner =
        [
            new("Verksamhetschef Medicin", "Björn Andersson", "2028", "Anna Svensson", "Redo inom 1 år", Color.Success, 75),
            new("Chefläkare", "Margareta Ström", "2027", "Erik Johansson", "Redo inom 2 år", Color.Warning, 45),
            new("HR-direktör", "Lars Pettersson", "2029", "Lisa Holm", "Redo nu", Color.Success, 95),
            new("IT-chef", "Helena Kraft", "2030", "Per Gustafsson", "Redo inom 1 år", Color.Success, 60),
            new("Ekonomichef", "Gunnar Löfgren", "2027", "", "", Color.Default, 0),
            new("Chefssjuksköterska", "Ingrid Wallin", "2028", "Sara Karlsson", "Redo inom 2 år", Color.Warning, 35),
            new("Forskningschef", "Ulf Bergström", "2029", "", "", Color.Default, 0),
            new("Verksamhetschef Kirurgi", "Eva Nilsson", "2031", "Karl Berg", "Redo inom 1 år", Color.Success, 70),
            new("Utvecklingschef", "Anders Ström", "2030", "Jonas Eriksson", "Redo inom 2 år", Color.Warning, 40),
            new("Kommunikationschef", "Maria Lindström", "2032", "", "", Color.Default, 0),
        ];
    }

    private record SuccessionsRad(string Position, string Innehavare, string PensionsAr, string Efterfoljare, string BeredskapText, Color BeredskapFarg, int UtvecklingProcent);
}
