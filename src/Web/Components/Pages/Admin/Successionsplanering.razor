@page "/admin/succession"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Positions.Domain
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<RegionHRDbContext> DbFactory

<PageTitle>OpenHR - Successionsplanering</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">Successionsplanering</MudText>

@if (_loading) { <MudProgressCircular Color="Color.Primary" Indeterminate="true" /> }
else if (_error != null) { <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert> }
else
{
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="3"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Primary" Style="font-weight: 700;">@_plans.Count</MudText><MudText Typo="Typo.body2">Nyckelpositioner</MudText></MudPaper></MudItem>
        <MudItem xs="3"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Success" Style="font-weight: 700;">@_plans.Count(p => p.Plan.EftertradarKandidat.HasValue)</MudText><MudText Typo="Typo.body2">Med efterträdare</MudText></MudPaper></MudItem>
        <MudItem xs="3"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Error" Style="font-weight: 700;">@_plans.Count(p => !p.Plan.EftertradarKandidat.HasValue)</MudText><MudText Typo="Typo.body2">Utan efterträdare</MudText></MudPaper></MudItem>
        <MudItem xs="3"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Warning" Style="font-weight: 700;">@_plans.Count(p => p.Plan.BeraknadPensionAr <= DateTime.Today.Year + 3)</MudText><MudText Typo="Typo.body2">Pensionsnära (3 år)</MudText></MudPaper></MudItem>
    </MudGrid>

    @if (_plans.Count == 0) { <MudAlert Severity="Severity.Info" Variant="Variant.Text">Inga successionsplaner registrerade.</MudAlert> }
    else
    {
        <MudSimpleTable Hover="true" Elevation="2">
            <thead><tr><th>Position</th><th>Nuvarande</th><th>Pension (år)</th><th>Efterträdare</th><th>Beredskap</th></tr></thead>
            <tbody>
                @foreach (var p in _plans)
                {
                    <tr>
                        <td><strong>@p.PositionTitel</strong></td>
                        <td>@(p.NuvarandeNamn ?? "—")</td>
                        <td>@(p.Plan.BeraknadPensionAr?.ToString() ?? "—")</td>
                        <td>@(p.KandidatNamn ?? "—")</td>
                        <td>
                            @if (p.Plan.EftertradarKandidat.HasValue)
                            {
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudChip T="string" Size="Size.Small" Color="@BeredskapFarg(p.Plan.Beredskap)">@BeredskapText(p.Plan.Beredskap)</MudChip>
                                    <MudText Typo="Typo.caption">@p.Plan.BeredskapProcent%</MudText>
                                </MudStack>
                            }
                            else { <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">—</MudText> }
                        </td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    }
}

@code {
    private List<PlanVm> _plans = [];
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        try
        {
            var plans = await db.SuccessionPlans.ToListAsync();
            var positions = await db.Positions_Table.ToListAsync();
            var employees = await db.Employees.ToListAsync();
            var posTitles = positions.ToDictionary(p => p.Id, p => p.Titel);
            var empNames = employees.ToDictionary(e => e.Id.Value, e => $"{e.Fornamn} {e.Efternamn}");

            _plans = plans.Select(p => new PlanVm(
                posTitles.GetValueOrDefault(p.PositionId, "Okänd position"),
                p.NuvarandeInnehavare.HasValue ? empNames.GetValueOrDefault(p.NuvarandeInnehavare.Value, "Okänd") : null,
                p.EftertradarKandidat.HasValue ? empNames.GetValueOrDefault(p.EftertradarKandidat.Value, "Okänd") : null,
                p
            )).OrderBy(p => p.Plan.BeraknadPensionAr).ToList();
        }
        catch (Exception ex) { _error = $"Kunde inte hämta data: {ex.Message}"; }
        finally { _loading = false; }
    }

    private static string BeredskapText(SuccessionReadiness r) => r switch
    {
        SuccessionReadiness.RedoNu => "Redo nu", SuccessionReadiness.RedoInom1Ar => "Redo inom 1 år",
        SuccessionReadiness.RedoInom2Ar => "Redo inom 2 år", SuccessionReadiness.UnderUtveckling => "Under utveckling",
        SuccessionReadiness.EjIdentifierad => "Ej identifierad", _ => r.ToString()
    };
    private static Color BeredskapFarg(SuccessionReadiness r) => r switch
    {
        SuccessionReadiness.RedoNu => Color.Success, SuccessionReadiness.RedoInom1Ar => Color.Success,
        SuccessionReadiness.RedoInom2Ar => Color.Warning, _ => Color.Default
    };

    private record PlanVm(string PositionTitel, string? NuvarandeNamn, string? KandidatNamn, SuccessionPlan Plan);
}

