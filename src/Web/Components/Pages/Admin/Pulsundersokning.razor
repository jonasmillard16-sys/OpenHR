@page "/admin/pulsundersokning"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Pulse.Domain
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<RegionHRDbContext> DbFactory

<PageTitle>OpenHR — Pulsundersökningar</PageTitle>
<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4" Style="font-weight: 700;">Pulsundersökningar</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" StartIcon="@Icons.Material.Filled.Add"
               Style="min-height: 48px;" OnClick="@(() => _showCreate = true)">Ny enkät</MudButton>
</div>

<MudAlert Severity="Severity.Info" Variant="Variant.Text" Class="mb-4" Dense="true">
    Svaren är helt anonyma. Systemet lagrar inte vem som svarat. Samma person kan i v1 svara flera gånger.
</MudAlert>

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
}
else
{
    @if (_showCreate)
    {
        <MudPaper Class="pa-5 mb-4" Elevation="3" Style="border-left: 4px solid var(--mud-palette-primary);">
            <div class="d-flex justify-space-between align-center mb-3">
                <MudText Typo="Typo.h6" Style="font-weight: 600;">Ny pulsundersökning</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="@(() => _showCreate = false)" />
            </div>
            <MudTextField @bind-Value="_newTitel" Label="Titel" Variant="Variant.Outlined" Class="mb-3" Required="true" />
            <MudTextField @bind-Value="_newBeskrivning" Label="Beskrivning (valfritt)" Variant="Variant.Outlined" Class="mb-3" />
            <MudText Typo="Typo.subtitle2" Class="mb-2">Frågor (besvaras på skala 1–5)</MudText>
            @for (var i = 0; i < _newFragor.Count; i++)
            {
                var idx = i;
                <MudTextField @bind-Value="_newFragor[idx]" Label="@($"Fråga {idx + 1}")" Variant="Variant.Outlined" Class="mb-2" />
            }
            <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary" OnClick="@(() => _newFragor.Add(""))" Class="mb-3">+ Lägg till fråga</MudButton>
            <div>
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           OnClick="SkapaEnkat"
                           Disabled="@(string.IsNullOrWhiteSpace(_newTitel) || _newFragor.All(string.IsNullOrWhiteSpace) || _saving)">Skapa enkät</MudButton>
            </div>
        </MudPaper>
    }

    @if (_success != null)
    {
        <MudAlert Severity="Severity.Success" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="@(() => _success = null)">@_success</MudAlert>
    }

    @if (_surveys.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Text">Inga pulsundersökningar registrerade.</MudAlert>
    }
    else
    {
        @foreach (var s in _surveys)
        {
            <MudPaper Class="pa-4 mb-4" Elevation="2">
                <div class="d-flex justify-space-between align-center mb-2">
                    <div>
                        <MudText Typo="Typo.h6" Style="font-weight: 600;">@s.Survey.Titel</MudText>
                        @if (s.Survey.Beskrivning != null)
                        {
                            <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">@s.Survey.Beskrivning</MudText>
                        }
                    </div>
                    <MudChip T="string" Size="Size.Small" Color="@StatusColor(s.Survey.Status)">@StatusText(s.Survey.Status)</MudChip>
                </div>
                <MudStack Row="true" Spacing="4" Class="mb-3">
                    <MudText Typo="Typo.body2"><strong>@s.Survey.Fragor.Count</strong> frågor</MudText>
                    <MudText Typo="Typo.body2"><strong>@s.AntalSvar</strong> svar</MudText>
                    <MudText Typo="Typo.body2">Skapad @s.Survey.SkapadVid.ToLocalTime().ToString("yyyy-MM-dd")</MudText>
                </MudStack>
                <MudStack Row="true" Spacing="2">
                    @if (s.Survey.Status == PulseSurveyStatus.Utkast)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" OnClick="@(() => OppnaEnkat(s.Survey))">Öppna</MudButton>
                    }
                    else if (s.Survey.Status == PulseSurveyStatus.Oppnad)
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Warning" Size="Size.Small" OnClick="@(() => StangEnkat(s.Survey))">Stäng</MudButton>
                        <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" Href="@($"/admin/pulsundersokning/svara/{s.Survey.Id}")">Svara</MudButton>
                    }
                    <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="@(() => _expanderad = _expanderad == s ? null : s)">
                        @(_expanderad == s ? "Dölj resultat" : "Visa resultat")
                    </MudButton>
                </MudStack>
                @if (_expanderad == s && s.Survey.Fragor.Count > 0)
                {
                    <MudDivider Class="my-3" />
                    <MudText Typo="Typo.subtitle2" Class="mb-2" Style="font-weight: 600;">Resultat (@s.AntalSvar svar)</MudText>
                    @if (s.AntalSvar == 0)
                    {
                        <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">Inga svar ännu.</MudText>
                    }
                    else
                    {
                        <MudSimpleTable Dense="true" Elevation="0">
                            <thead><tr><th>Fråga</th><th>Snitt</th><th>Antal svar</th></tr></thead>
                            <tbody>
                                @foreach (var f in s.Survey.Fragor.OrderBy(f => f.Ordning))
                                {
                                    var answers = s.AllaSvar.Where(a => a.FragaId == f.Id).ToList();
                                    var snitt = answers.Count > 0 ? answers.Average(a => a.Varde) : 0;
                                    <tr>
                                        <td>@f.Text</td>
                                        <td><strong>@snitt.ToString("F1")</strong> / 5</td>
                                        <td>@answers.Count</td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                    }
                }
            </MudPaper>
        }
    }
}

@code {
    private List<SurveyVm> _surveys = [];
    private SurveyVm? _expanderad;
    private bool _loading = true, _saving, _showCreate;
    private string? _error, _success;
    private string _newTitel = "", _newBeskrivning = "";
    private List<string> _newFragor = ["", "", ""];

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        try
        {
            var surveys = await db.PulseSurveys.OrderByDescending(s => s.SkapadVid).ToListAsync();
            var surveyIds = surveys.Select(s => s.Id).ToList();
            var responses = await db.PulseSurveyResponses
                .Where(r => surveyIds.Contains(r.SurveyId)).ToListAsync();

            _surveys = surveys.Select(s =>
            {
                var svarFor = responses.Where(r => r.SurveyId == s.Id).ToList();
                return new SurveyVm(s, svarFor.Count, svarFor.SelectMany(r => r.Svar).ToList());
            }).ToList();
        }
        catch (Exception ex) { _error = $"Kunde inte hämta pulsundersökningar: {ex.Message}"; }
        finally { _loading = false; }
    }

    private async Task SkapaEnkat()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        if (string.IsNullOrWhiteSpace(_newTitel)) return;
        _saving = true; _error = null;
        try
        {
            var survey = PulseSurvey.Skapa(_newTitel, string.IsNullOrWhiteSpace(_newBeskrivning) ? null : _newBeskrivning, "Admin");
            var ordning = 1;
            foreach (var f in _newFragor.Where(f => !string.IsNullOrWhiteSpace(f)))
                survey.LaggTillFraga(f, ordning++);
            db.PulseSurveys.Add(survey);
            await db.SaveChangesAsync();
            _surveys.Insert(0, new SurveyVm(survey, 0, []));
            _showCreate = false;
            _success = $"Enkät \"{_newTitel}\" skapad med {survey.Fragor.Count} frågor.";
            _newTitel = ""; _newBeskrivning = ""; _newFragor = ["", "", ""];
        }
        catch (Exception ex) { _error = $"Kunde inte skapa enkät: {ex.Message}"; }
        finally { _saving = false; }
    }

    private async Task OppnaEnkat(PulseSurvey s)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        try { s.Oppna(); await db.SaveChangesAsync(); }
        catch (Exception ex) { _error = $"Kunde inte öppna: {ex.Message}"; }
    }

    private async Task StangEnkat(PulseSurvey s)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        try { s.Stang(); await db.SaveChangesAsync(); }
        catch (Exception ex) { _error = $"Kunde inte stänga: {ex.Message}"; }
    }

    private static Color StatusColor(PulseSurveyStatus s) => s switch
    {
        PulseSurveyStatus.Oppnad => Color.Success, PulseSurveyStatus.Stangd => Color.Info, _ => Color.Default
    };
    private static string StatusText(PulseSurveyStatus s) => s switch
    {
        PulseSurveyStatus.Utkast => "Utkast", PulseSurveyStatus.Oppnad => "Öppen",
        PulseSurveyStatus.Stangd => "Stängd", _ => s.ToString()
    };

    private record SurveyVm(PulseSurvey Survey, int AntalSvar, List<PulseSurveyAnswer> AllaSvar);
}

