@page "/admin/berom"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Communication.Domain
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<RegionHRDbContext> DbFactory
@inject RegionHR.Web.Services.AuthService Auth

<PageTitle>OpenHR - Beröm</PageTitle>
<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4" Style="font-weight: 700;">Beröm och erkännande</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" StartIcon="@Icons.Material.Filled.Star" Style="min-height: 48px;" OnClick="@(() => _showForm = true)">Ge beröm</MudButton>
</div>

@if (_loading) { <MudProgressCircular Color="Color.Primary" Indeterminate="true" /> }
else if (_error != null) { <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert> }
else
{
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="4"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Primary" Style="font-weight: 700;">@_items.Count</MudText><MudText Typo="Typo.body2">Beröm totalt</MudText></MudPaper></MudItem>
        <MudItem xs="4"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Success" Style="font-weight: 700;">@_items.Select(i => i.TillNamn).Distinct().Count()</MudText><MudText Typo="Typo.body2">Unika mottagare</MudText></MudPaper></MudItem>
        <MudItem xs="4"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Style="font-weight: 700;">@(_items.GroupBy(i => i.Rec.Kategori).OrderByDescending(g => g.Count()).FirstOrDefault()?.Key ?? "—")</MudText><MudText Typo="Typo.body2">Populäraste kategori</MudText></MudPaper></MudItem>
    </MudGrid>

    @if (_showForm && Auth.EmployeeId.HasValue)
    {
        <MudPaper Class="pa-5 mb-4" Elevation="3" Style="border-left: 4px solid var(--mud-palette-primary);">
            <div class="d-flex justify-space-between align-center mb-3">
                <MudText Typo="Typo.h6" Style="font-weight: 600;">Ge beröm till en kollega</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="@(() => _showForm = false)" />
            </div>
            <MudGrid Spacing="3">
                <MudItem xs="12" sm="6">
                    <MudSelect T="Guid?" @bind-Value="_formTill" Label="Till kollega" Variant="Variant.Outlined" Required="true">
                        @foreach (var e in _employees.Where(e => e.Id.Value != Auth.EmployeeId))
                        { <MudSelectItem T="Guid?" Value="@((Guid?)e.Id.Value)">@e.Fornamn @e.Efternamn</MudSelectItem> }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="string" @bind-Value="_formKategori" Label="Kategori" Variant="Variant.Outlined">
                        @foreach (var k in new[] { "Samarbete", "Hjälpsamhet", "Innovation", "Ledarskap" })
                        { <MudSelectItem Value="@k">@k</MudSelectItem> }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12"><MudTextField @bind-Value="_formMeddelande" Label="Meddelande" Variant="Variant.Outlined" Lines="3" Required="true" /></MudItem>
            </MudGrid>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-3" OnClick="SkickaBerom"
                       Disabled="@(_formTill == null || string.IsNullOrWhiteSpace(_formMeddelande) || _saving)">Skicka</MudButton>
        </MudPaper>
    }
    else if (_showForm) { <MudAlert Severity="Severity.Warning" Class="mb-4">Beröm kräver kopplad anställd.</MudAlert> }

    @if (_success != null) { <MudAlert Severity="Severity.Success" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="@(() => _success = null)">@_success</MudAlert> }

    @if (_items.Count == 0) { <MudAlert Severity="Severity.Info" Variant="Variant.Text">Inget beröm registrerat ännu.</MudAlert> }
    else
    {
        @foreach (var i in _items)
        {
            <MudPaper Class="pa-4 mb-3" Elevation="1">
                <div class="d-flex justify-space-between align-center mb-1">
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">@i.FranNamn → @i.TillNamn</MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary">@i.Rec.Kategori</MudChip>
                </div>
                <MudText Typo="Typo.body1" Class="mb-1">@i.Rec.Meddelande</MudText>
                <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">@i.Rec.SkapadVid.ToLocalTime().ToString("yyyy-MM-dd")</MudText>
            </MudPaper>
        }
    }
}

@code {
    private List<RecVm> _items = [];
    private List<RegionHR.Core.Domain.Employee> _employees = [];
    private bool _loading = true, _saving, _showForm;
    private string? _error, _success, _formMeddelande = "", _formKategori = "Samarbete";
    private Guid? _formTill;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        try
        {
            var recs = await db.Recognitions.OrderByDescending(r => r.SkapadVid).ToListAsync();
            _employees = await db.Employees.OrderBy(e => e.Efternamn).ToListAsync();
            var names = _employees.ToDictionary(e => e.Id.Value, e => $"{e.Fornamn} {e.Efternamn}");
            _items = recs.Select(r => new RecVm(names.GetValueOrDefault(r.FranAnstallId, "Okänd"), names.GetValueOrDefault(r.TillAnstallId, "Okänd"), r)).ToList();
        }
        catch (Exception ex) { _error = $"Kunde inte hämta data: {ex.Message}"; }
        finally { _loading = false; }
    }

    private async Task SkickaBerom()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        if (!Auth.EmployeeId.HasValue || _formTill == null || string.IsNullOrWhiteSpace(_formMeddelande)) return;
        _saving = true; _error = null;
        try
        {
            var rec = Recognition.Skapa(Auth.EmployeeId.Value, _formTill.Value, _formKategori ?? "Samarbete", _formMeddelande!);
            db.Recognitions.Add(rec);
            await db.SaveChangesAsync();
            var names = _employees.ToDictionary(e => e.Id.Value, e => $"{e.Fornamn} {e.Efternamn}");
            _items.Insert(0, new RecVm(Auth.UserName ?? "Jag", names.GetValueOrDefault(_formTill.Value, "Okänd"), rec));
            _showForm = false; _success = "Beröm skickat!"; _formMeddelande = ""; _formTill = null;
        }
        catch (Exception ex) { _error = $"Kunde inte skicka: {ex.Message}"; }
        finally { _saving = false; }
    }

    private record RecVm(string FranNamn, string TillNamn, Recognition Rec);
}

