@page "/schema/passbyte"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Scheduling.Domain
@using RegionHR.SharedKernel.Domain
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<RegionHRDbContext> DbFactory
@inject RegionHR.Web.Services.AuthService Auth

<PageTitle>OpenHR - Passbyte</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">Passbyten</MudText>

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
}
else
{
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="4"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Warning" Style="font-weight: 700;">@_rader.Count(r => r.Status == ShiftSwapStatus.Accepterad)</MudText><MudText Typo="Typo.body2">Väntar godkännande</MudText></MudPaper></MudItem>
        <MudItem xs="4"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Info" Style="font-weight: 700;">@_rader.Count(r => r.Status == ShiftSwapStatus.Begard || r.Status == ShiftSwapStatus.Erbjuden)</MudText><MudText Typo="Typo.body2">Pågående</MudText></MudPaper></MudItem>
        <MudItem xs="4"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Success" Style="font-weight: 700;">@_rader.Count(r => r.Status == ShiftSwapStatus.Godkand)</MudText><MudText Typo="Typo.body2">Godkända</MudText></MudPaper></MudItem>
    </MudGrid>

    @if (_actionMsg != null)
    {
        <MudAlert Severity="@_actionSev" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="@(() => _actionMsg = null)">@_actionMsg</MudAlert>
    }

    @if (_rader.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Text">Inga passbyten registrerade.</MudAlert>
    }
    else
    {
        <MudSimpleTable Hover="true" Elevation="2">
            <thead><tr><th>Begärande</th><th>Motivering</th><th>Status</th><th></th></tr></thead>
            <tbody>
                @foreach (var r in _rader)
                {
                    <tr>
                        <td><strong>@r.BegarandeNamn</strong></td>
                        <td>@(r.Motivering ?? "—")</td>
                        <td><MudChip T="string" Size="Size.Small" Color="@StatusFarg(r.Status)">@StatusText(r.Status)</MudChip></td>
                        <td>
                            @if (r.Status == ShiftSwapStatus.Accepterad && Auth.EmployeeId.HasValue)
                            {
                                <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Success" OnClick="@(() => GodkannSwap(r))">Godkänn</MudButton>
                                <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error" OnClick="@(() => NekaSwap(r))" Class="ml-1">Nej</MudButton>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    }
}

@code {
    private List<SwapVm> _rader = [];
    private bool _loading = true;
    private string? _error, _actionMsg;
    private Severity _actionSev;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        try
        {
            var swaps = await db.ShiftSwapRequests
                .OrderByDescending(s => s.SkapadVid).Take(50).ToListAsync();

            var empIds = swaps.Select(s => s.BegardAv).Distinct().ToList();
            var employees = await db.Employees.Where(e => empIds.Contains(e.Id)).ToListAsync();
            var names = employees.ToDictionary(e => e.Id.Value, e => $"{e.Fornamn} {e.Efternamn}");

            _rader = swaps.Select(s => new SwapVm(s.Id.Value, names.GetValueOrDefault(s.BegardAv.Value, "Okänd"),
                s.Motivering, s.Status, s)).ToList();
        }
        catch (Exception ex) { _error = $"Kunde inte hämta passbyten: {ex.Message}"; }
        finally { _loading = false; }
    }

    private async Task GodkannSwap(SwapVm vm)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        if (!Auth.EmployeeId.HasValue) { _error = "Kräver kopplad anställd."; return; }
        try
        {
            vm.Entity.Godkann(Auth.UserName ?? "Chef");
            await db.SaveChangesAsync();
            _actionMsg = $"Passbyte godkänt."; _actionSev = Severity.Success;
        }
        catch (Exception ex) { _actionMsg = $"Fel: {ex.Message}"; _actionSev = Severity.Error; }
    }

    private async Task NekaSwap(SwapVm vm)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        if (!Auth.EmployeeId.HasValue) { _error = "Kräver kopplad anställd."; return; }
        try
        {
            vm.Entity.Avvisa(Auth.UserName ?? "Chef", "Nekat av chef");
            await db.SaveChangesAsync();
            _actionMsg = $"Passbyte nekat."; _actionSev = Severity.Warning;
        }
        catch (Exception ex) { _actionMsg = $"Fel: {ex.Message}"; _actionSev = Severity.Error; }
    }

    private static string StatusText(ShiftSwapStatus s) => s switch
    {
        ShiftSwapStatus.Begard => "Begärd", ShiftSwapStatus.Erbjuden => "Erbjuden",
        ShiftSwapStatus.Accepterad => "Väntar godkännande", ShiftSwapStatus.Godkand => "Godkänd",
        ShiftSwapStatus.Avvisad => "Avvisad", ShiftSwapStatus.Makulerad => "Makulerad", _ => s.ToString()
    };
    private static Color StatusFarg(ShiftSwapStatus s) => s switch
    {
        ShiftSwapStatus.Accepterad => Color.Warning, ShiftSwapStatus.Godkand => Color.Success,
        ShiftSwapStatus.Avvisad => Color.Error, _ => Color.Default
    };

    private record SwapVm(Guid Id, string BegarandeNamn, string? Motivering, ShiftSwapStatus Status, ShiftSwapRequest Entity);
}

