@page "/schema/passbyte"
@layout RegionHR.Web.Components.Layout.AdminLayout

<PageTitle>OpenHR - Passbyte</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">Passbyten</MudText>

<MudGrid Spacing="3" Class="mb-4">
    <MudItem xs="4"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Warning" Style="font-weight: 700;">@_rader.Count(r => r.StatusText == "Väntar")</MudText><MudText Typo="Typo.body2">Väntar godkännande</MudText></MudPaper></MudItem>
    <MudItem xs="4"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Info" Style="font-weight: 700;">2</MudText><MudText Typo="Typo.body2">Erbjudna</MudText></MudPaper></MudItem>
    <MudItem xs="4"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Success" Style="font-weight: 700;">12</MudText><MudText Typo="Typo.body2">Genomförda (mars)</MudText></MudPaper></MudItem>
</MudGrid>

@if (_meddelande is not null)
{
    <MudAlert Severity="@_meddelandeSeverity" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="@(() => _meddelande = null)">@_meddelande</MudAlert>
}

<MudSimpleTable Hover="true" Elevation="2">
    <thead><tr><th>Begärande</th><th>Deras pass</th><th>Byter med</th><th>Deras pass</th><th>Status</th><th></th></tr></thead>
    <tbody>
        @foreach (var rad in _rader)
        {
            <tr>
                <td><strong>@rad.Begarande</strong></td>
                <td>@rad.DerasPass</td>
                <td>@rad.ByterMed</td>
                <td>@rad.MotpartPass</td>
                <td><MudChip T="string" Size="Size.Small" Color="@rad.StatusFarg">@rad.StatusText</MudChip></td>
                <td>
                    @if (rad.StatusText == "Väntar")
                    {
                        <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Success" OnClick="@(() => Godkann(rad))">Godkänn</MudButton>
                        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error" OnClick="@(() => Neka(rad))" Class="ml-1">Nej</MudButton>
                    }
                </td>
            </tr>
        }
    </tbody>
</MudSimpleTable>

@code {
    private string? _meddelande;
    private Severity _meddelandeSeverity = Severity.Success;

    private List<PassbyteRad> _rader = [];

    protected override void OnInitialized()
    {
        _rader =
        [
            new("Anna Svensson", "Natt 20/3", "Sara Karlsson", "Dag 20/3", "Väntar", Color.Warning),
            new("Karl Berg", "Kväll 22/3", "Lisa Holm", "Dag 22/3", "Väntar", Color.Warning),
            new("Maria Lindgren", "Dag 25/3", "Helena Bergström", "Kväll 25/3", "Godkänd", Color.Success),
        ];
    }

    private void Godkann(PassbyteRad rad)
    {
        _rader.Remove(rad);
        _meddelande = $"Passbyte för {rad.Begarande} godkänt.";
        _meddelandeSeverity = Severity.Success;
    }

    private void Neka(PassbyteRad rad)
    {
        _rader.Remove(rad);
        _meddelande = $"Passbyte för {rad.Begarande} nekat.";
        _meddelandeSeverity = Severity.Warning;
    }

    private record PassbyteRad(string Begarande, string DerasPass, string ByterMed, string MotpartPass, string StatusText, Color StatusFarg);
}
