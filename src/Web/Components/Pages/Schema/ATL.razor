@page "/schema/atl"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Scheduling.Domain
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<RegionHRDbContext> DbFactory

<OhrBreadcrumb CurrentPage="ATL-efterlevnad" ExtraItems="@(new List<BreadcrumbItem>{new("Schema", "/schema")})" />

<PageTitle>OpenHR - ATL-efterlevnad</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;"><OhrTerm Term="ATL" DisplayText="ATL-efterlevnad" /></MudText>
<MudText Typo="Typo.body2" Class="mb-4" Style="color: var(--mud-palette-text-secondary);">Arbetstidslagens efterlevnad baserad på schemalagda pass (senaste 4 veckor).</MudText>

<MudExpansionPanels Class="mb-4">
    <MudExpansionPanel Text="Vad är ATL? — Klicka för förklaring" Icon="@Icons.Material.Filled.Info">
        <MudText Typo="Typo.body2" Class="mb-2">
            <strong>ATL — Arbetstidslagen</strong> är en lag som skyddar anställda från alltför långa arbetsdagar och arbetsveckor. Lagen gäller alla anställda i Sverige.
        </MudText>
        <MudText Typo="Typo.body2" Class="mb-2">
            Reglerna i korthet:
        </MudText>
        <ul style="margin: 0 0 0.5rem 1.2rem;">
            <li><MudText Typo="Typo.body2"><strong>Max 48 timmar per vecka</strong> i genomsnitt, räknat över 4 veckor</MudText></li>
            <li><MudText Typo="Typo.body2"><strong>Dygnsvila:</strong> Minst 11 timmars sammanhängande ledighet per dygn (9 timmar gäller för sjukvård)</MudText></li>
            <li><MudText Typo="Typo.body2"><strong>Veckovila:</strong> Minst 36 timmars sammanhängande ledighet per vecka</MudText></li>
        </ul>
        <MudText Typo="Typo.body2">
            Om en anställd riskerar att bryta mot ATL visas det här med varning. Röd status betyder att gränsen redan överskridits — åtgärda schemat snarast.
        </MudText>
    </MudExpansionPanel>
</MudExpansionPanels>

@if (_loading) { <MudProgressCircular Color="Color.Primary" Indeterminate="true" /> }
else if (_error != null) { <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert> }
else
{
    @if (_overtraders.Count == 0)
    {
        <MudAlert Severity="Severity.Success" Class="mb-4">Inga ATL-överträdelser eller varningar.</MudAlert>
    }
    else
    {
        <MudText Typo="Typo.h6" Class="mb-3">Nära gränsvärden / överträdelser</MudText>
        <MudSimpleTable Hover="true" Elevation="2">
            <thead><tr><th>Anställd</th><th>Regel</th><th>Gräns</th><th>Aktuellt</th><th>Status</th></tr></thead>
            <tbody>
                @foreach (var r in _overtraders)
                {
                    <tr>
                        <td><strong>@r.Namn</strong></td>
                        <td>Veckoarbetstid (4v snitt)</td>
                        <td>48h</td>
                        <td>@r.SnittTimmarPerVecka.ToString("F1")h</td>
                        <td><MudChip T="string" Size="Size.Small" Color="@(r.SnittTimmarPerVecka >= 48 ? Color.Error : r.SnittTimmarPerVecka >= 45 ? Color.Warning : Color.Success)">
                            @(r.SnittTimmarPerVecka >= 48 ? "Överträder" : r.SnittTimmarPerVecka >= 45 ? $"{(48 - r.SnittTimmarPerVecka):F1}h kvar" : "OK")
                        </MudChip></td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    }

    <MudAlert Severity="Severity.Info" Variant="Variant.Text" Class="mt-4" Dense="true">
        ATL: max 48h/vecka i snitt över 4-veckorsperiod. Dygnsvila min 11h (9h med sjukvårdsundantag). Veckovila min 36h sammanhängande.
    </MudAlert>
}

@code {
    private List<ATLRad> _overtraders = [];
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        try
        {
            var idag = DateOnly.FromDateTime(DateTime.Today);
            var fyraVeckorSedan = idag.AddDays(-28);

            var shifts = await db.ScheduledShifts
                .Where(s => s.Datum >= fyraVeckorSedan && s.Datum <= idag && s.Status != ShiftStatus.Avbokad)
                .ToListAsync();

            var employees = await db.Employees.ToListAsync();
            var names = employees.ToDictionary(e => e.Id.Value, e => $"{e.Fornamn} {e.Efternamn}");

            var perEmployee = shifts.GroupBy(s => s.AnstallId.Value);
            foreach (var g in perEmployee)
            {
                var totalTimmar = g.Sum(s => (decimal)s.PlaneradeTimmar);
                var snitt = totalTimmar / 4m;
                if (snitt >= 40)
                {
                    _overtraders.Add(new ATLRad(names.GetValueOrDefault(g.Key, "Okänd"), snitt));
                }
            }
            _overtraders = _overtraders.OrderByDescending(r => r.SnittTimmarPerVecka).ToList();
        }
        catch (Exception ex) { _error = $"Kunde inte beräkna ATL: {ex.Message}"; }
        finally { _loading = false; }
    }

    private record ATLRad(string Namn, decimal SnittTimmarPerVecka);
}

