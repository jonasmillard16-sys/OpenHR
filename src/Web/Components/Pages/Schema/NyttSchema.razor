@page "/schema/ny"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Scheduling.Domain
@using RegionHR.SharedKernel.Domain
@using Microsoft.EntityFrameworkCore
@inject RegionHRDbContext Db
@inject NavigationManager Nav

<PageTitle>OpenHR - Skapa schema</PageTitle>
<MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Variant="Variant.Text" Color="Color.Primary" Href="/schema" Style="margin-bottom: 1rem;">Tillbaka</MudButton>

<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">Skapa schema</MudText>

@if (_loading) { <MudProgressCircular Color="Color.Primary" Indeterminate="true" /> }
else if (_error != null) { <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert> }
else if (_created)
{
    <MudPaper Class="pa-5" Elevation="2" Style="border-left: 4px solid var(--mud-palette-success);">
        <MudText Typo="Typo.h5" Color="Color.Success" Style="font-weight: 700;" Class="mb-3">Schema skapat</MudText>
        <MudSimpleTable Dense="true" Class="mb-3">
            <tbody>
                <tr><td><strong>Namn</strong></td><td>@_schema!.Namn</td></tr>
                <tr><td><strong>Enhet</strong></td><td>@_enhetNamn</td></tr>
                <tr><td><strong>Period</strong></td><td>@_formFran?.ToString("yyyy-MM-dd") – @_formTill?.ToString("yyyy-MM-dd")</td></tr>
                <tr><td><strong>Status</strong></td><td><MudChip T="string" Size="Size.Small" Color="Color.Info">Utkast</MudChip></td></tr>
            </tbody>
        </MudSimpleTable>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/schema">Till schemaöversikt</MudButton>
    </MudPaper>
}
else
{
    <MudPaper Class="pa-5" Elevation="2">
        <MudGrid Spacing="3">
            <MudItem xs="12" sm="6">
                <MudSelect T="Guid?" @bind-Value="_formEnhetId" Label="Enhet" Variant="Variant.Outlined" Required="true">
                    @foreach (var e in _enheter) { <MudSelectItem T="Guid?" Value="@((Guid?)e.Id.Value)">@e.Namn</MudSelectItem> }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6"><MudTextField @bind-Value="_formNamn" Label="Schemanamn" Variant="Variant.Outlined" Required="true" /></MudItem>
            <MudItem xs="12" sm="6"><MudDatePicker @bind-Date="_formFran" Label="Startdatum" Variant="Variant.Outlined" Required="true" /></MudItem>
            <MudItem xs="12" sm="6"><MudDatePicker @bind-Date="_formTill" Label="Slutdatum" Variant="Variant.Outlined" Required="true" /></MudItem>
        </MudGrid>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Class="mt-4" Style="min-height: 48px;"
                   OnClick="SkapaSchema" Disabled="@(_formEnhetId == null || string.IsNullOrWhiteSpace(_formNamn) || _formFran == null || _formTill == null || _saving)">
            @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
            Skapa schema
        </MudButton>
    </MudPaper>
}

@code {
    private List<RegionHR.Core.Domain.OrganizationUnit> _enheter = [];
    private Schedule? _schema;
    private string _enhetNamn = "", _formNamn = "";
    private Guid? _formEnhetId;
    private DateTime? _formFran, _formTill;
    private bool _loading = true, _saving, _created;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try { _enheter = await Db.OrganizationUnits.ToListAsync(); }
        catch (Exception ex) { _error = $"Kunde inte hämta enheter: {ex.Message}"; }
        finally { _loading = false; }
    }

    private async Task SkapaSchema()
    {
        if (_formEnhetId == null || _formFran == null || _formTill == null || string.IsNullOrWhiteSpace(_formNamn)) return;
        _saving = true; _error = null;
        try
        {
            var enhet = _enheter.FirstOrDefault(e => e.Id.Value == _formEnhetId.Value);
            _enhetNamn = enhet?.Namn ?? "Okänd";

            _schema = Schedule.SkapaPeriodschema(
                new OrganizationId(_formEnhetId.Value), _formNamn,
                DateOnly.FromDateTime(_formFran.Value), DateOnly.FromDateTime(_formTill.Value));

            Db.Schedules.Add(_schema);
            await Db.SaveChangesAsync();
            _created = true;
        }
        catch (Exception ex) { _error = $"Kunde inte skapa schema: {ex.Message}"; }
        finally { _saving = false; }
    }
}
