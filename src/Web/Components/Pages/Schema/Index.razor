@page "/schema"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Scheduling.Domain
@using Microsoft.EntityFrameworkCore
@using Microsoft.Extensions.Localization
@inject IDbContextFactory<RegionHRDbContext> DbFactory
@inject IStringLocalizer<SharedResources> L

<PageTitle>OpenHR - @L["ScheduleOverview"]</PageTitle>

<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4" Style="font-weight: 700;">@L["ScheduleOverview"]</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
               StartIcon="@Icons.Material.Filled.Add" Href="/schema/ny" Style="min-height: 48px;">@L["CreateSchedule"]</MudButton>
</div>

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
}
else
{
    <MudGrid Spacing="3" Class="mb-6">
        <MudItem xs="6" sm="3"><MudPaper Class="pa-4 text-center" Elevation="2"><MudText Typo="Typo.h4" Color="Color.Primary" Style="font-weight: 700;">@_totalPass</MudText><MudText Typo="Typo.body2">@L["ShiftsThisWeek"]</MudText></MudPaper></MudItem>
        <MudItem xs="6" sm="3"><MudPaper Class="pa-4 text-center" Elevation="2"><MudText Typo="Typo.h4" Color="Color.Success" Style="font-weight: 700;">@_enheter.Count</MudText><MudText Typo="Typo.body2">@L["Units"]</MudText></MudPaper></MudItem>
    </MudGrid>

    <MudText Typo="Typo.h6" Class="mb-3">@L["Week"] @_veckonummer — @L["WeekScheduledShiftsPerUnit"]</MudText>
    @if (_enhetData.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Text">@L["NoScheduledShifts"]</MudAlert>
    }
    else
    {
        <MudSimpleTable Hover="true" Elevation="2">
            <thead><tr><th>@L["Unit"]</th>@foreach (var d in _veckodagar) { <th>@d.ToString("ddd d/M", _sv)</th> }</tr></thead>
            <tbody>
                @foreach (var e in _enhetData)
                {
                    <tr>
                        <td><strong>@e.Namn</strong></td>
                        @foreach (var count in e.DagAntal)
                        {
                            <td style="text-align: center;"><MudChip T="string" Size="Size.Small" Color="@(count > 0 ? Color.Success : Color.Default)">@count</MudChip></td>
                        }
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    }
}

@code {
    private static readonly System.Globalization.CultureInfo _sv = System.Globalization.CultureInfo.GetCultureInfo("sv-SE");
    private List<RegionHR.Core.Domain.OrganizationUnit> _enheter = [];
    private List<EnhetVecka> _enhetData = [];
    private List<DateOnly> _veckodagar = [];
    private int _totalPass, _veckonummer;
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        try
        {
            var today = DateOnly.FromDateTime(DateTime.Today);
            var monday = today.AddDays(-((int)today.DayOfWeek + 6) % 7);
            _veckodagar = Enumerable.Range(0, 7).Select(i => monday.AddDays(i)).ToList();
            _veckonummer = System.Globalization.ISOWeek.GetWeekOfYear(DateTime.Today);

            var sunday = monday.AddDays(6);
            var shifts = await db.ScheduledShifts
                .Where(s => s.Datum >= monday && s.Datum <= sunday && s.Status != ShiftStatus.Avbokad)
                .ToListAsync();
            _totalPass = shifts.Count;

            _enheter = await db.OrganizationUnits.ToListAsync();
            var enhetNamn = _enheter.ToDictionary(e => e.Id.Value, e => e.Namn);

            // Get employees to map shift -> unit
            var anstallIds = shifts.Select(s => s.AnstallId).Distinct().ToList();
            var employees = await db.Employees.Include(e => e.Anstallningar)
                .Where(e => anstallIds.Contains(e.Id)).ToListAsync();
            var empEnhet = new Dictionary<Guid, Guid>();
            var idag = DateOnly.FromDateTime(DateTime.Today);
            foreach (var emp in employees)
            {
                var anst = emp.AktivAnstallning(idag);
                if (anst != null) empEnhet[emp.Id.Value] = anst.EnhetId.Value;
            }

            _enhetData = _enheter
                .Select(enhet =>
                {
                    var counts = _veckodagar.Select(dag =>
                        shifts.Count(s => s.Datum == dag && empEnhet.GetValueOrDefault(s.AnstallId.Value) == enhet.Id.Value)
                    ).ToList();
                    return new EnhetVecka(enhet.Namn, counts);
                })
                .Where(e => e.DagAntal.Any(c => c > 0))
                .ToList();
        }
        catch (Exception ex) { _error = $"{L["ErrorLoadingSchedule"]}: {ex.Message}"; }
        finally { _loading = false; }
    }

    private record EnhetVecka(string Namn, List<int> DagAntal);
}

