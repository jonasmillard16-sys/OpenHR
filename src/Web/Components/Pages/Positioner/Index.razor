@page "/positioner"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Positions.Domain
@using RegionHR.SharedKernel.Domain
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<RegionHRDbContext> DbFactory

<PageTitle>OpenHR - Positioner</PageTitle>
<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4" Style="font-weight: 700;">Positioner</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" StartIcon="@Icons.Material.Filled.Add" Style="min-height: 48px;" OnClick="@(() => _showForm = true)">Ny position</MudButton>
</div>

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
}
else
{
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="3"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Primary" Style="font-weight: 700;">@_rader.Count</MudText><MudText Typo="Typo.body2">Totalt</MudText></MudPaper></MudItem>
        <MudItem xs="3"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Success" Style="font-weight: 700;">@_rader.Count(r => r.Status == PositionStatus.Aktiv)</MudText><MudText Typo="Typo.body2">Tillsatta</MudText></MudPaper></MudItem>
        <MudItem xs="3"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Warning" Style="font-weight: 700;">@_rader.Count(r => r.Status == PositionStatus.Vakant)</MudText><MudText Typo="Typo.body2">Vakanta</MudText></MudPaper></MudItem>
        <MudItem xs="3"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Style="font-weight: 700;">@_rader.Count(r => r.Status == PositionStatus.Frysta)</MudText><MudText Typo="Typo.body2">Frusna</MudText></MudPaper></MudItem>
    </MudGrid>

    @if (_showForm)
    {
        <MudPaper Class="pa-6 mb-4" Elevation="3" Style="border-left: 4px solid var(--mud-palette-primary);">
            <div class="d-flex justify-space-between align-center mb-3">
                <MudText Typo="Typo.h6" Style="font-weight: 600;">Skapa ny position</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="@(() => _showForm = false)" />
            </div>
            <MudGrid Spacing="3">
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_formTitel" Label="Befattningstitel" Variant="Variant.Outlined" Required="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="Guid?" @bind-Value="_formEnhetId" Label="Enhet" Variant="Variant.Outlined" Required="true">
                        @foreach (var e in _enheter)
                        {
                            <MudSelectItem T="Guid?" Value="@((Guid?)e.Id.Value)">@e.Namn</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudNumericField T="decimal" @bind-Value="_formBudget" Label="Budgeterad månadslön (kr)" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudNumericField T="decimal" @bind-Value="_formSysselsattning" Label="Sysselsättningsgrad (%)" Variant="Variant.Outlined" />
                </MudItem>
            </MudGrid>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Class="mt-3"
                       Style="min-height: 48px;" OnClick="SkapaPosition"
                       Disabled="@(string.IsNullOrWhiteSpace(_formTitel) || _formEnhetId == null || _saving)">
                @if (_saving)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                Skapa
            </MudButton>
        </MudPaper>
    }

    @if (_success != null)
    {
        <MudAlert Severity="Severity.Success" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="@(() => _success = null)">@_success</MudAlert>
    }

    @if (_rader.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Text">Inga positioner registrerade.</MudAlert>
    }
    else
    {
        <MudSimpleTable Hover="true" Elevation="2">
            <thead><tr><th>Befattning</th><th>Enhet</th><th>Anställd</th><th>Sysselsättning</th><th>Status</th></tr></thead>
            <tbody>
                @foreach (var r in _rader)
                {
                    <tr>
                        <td><strong>@r.Titel</strong></td>
                        <td>@r.Enhet</td>
                        <td>@r.Anstalld</td>
                        <td>@($"{r.Sysselsattningsgrad:F0}%")</td>
                        <td><MudChip T="string" Size="Size.Small" Color="@StatusColor(r.Status)">@StatusText(r.Status)</MudChip></td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    }
}

@code {
    private List<PositionRad> _rader = [];
    private List<RegionHR.Core.Domain.OrganizationUnit> _enheter = [];
    private bool _loading = true, _saving, _showForm;
    private string? _error, _success;

    // Formulärfält
    private string _formTitel = "";
    private Guid? _formEnhetId;
    private decimal _formBudget = 30000m;
    private decimal _formSysselsattning = 100m;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        try
        {
            var positions = await db.Positions_Table.ToListAsync();
            _enheter = await db.OrganizationUnits.ToListAsync();
            var enhetNamn = _enheter.ToDictionary(e => e.Id.Value, e => e.Namn);

            var innehavarIds = positions
                .Where(p => p.InnehavareAnstallId.HasValue)
                .Select(p => p.InnehavareAnstallId!.Value)
                .Distinct().ToList();
            var employees = await db.Employees
                .Where(e => innehavarIds.Contains(e.Id.Value))
                .ToListAsync();
            var empNamn = employees.ToDictionary(e => e.Id.Value, e => $"{e.Fornamn} {e.Efternamn}");

            _rader = positions
                .OrderBy(p => p.Status)
                .ThenBy(p => p.Titel)
                .Select(p => new PositionRad(
                    p.Id,
                    p.Titel,
                    enhetNamn.GetValueOrDefault(p.EnhetId, "Okänd enhet"),
                    p.InnehavareAnstallId.HasValue
                        ? empNamn.GetValueOrDefault(p.InnehavareAnstallId.Value, "Okänd")
                        : "—",
                    p.Sysselsattningsgrad,
                    p.Status
                )).ToList();
        }
        catch (Exception ex) { _error = $"Kunde inte hämta positioner: {ex.Message}"; }
        finally { _loading = false; }
    }

    private async Task SkapaPosition()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        if (string.IsNullOrWhiteSpace(_formTitel) || _formEnhetId == null) return;
        _saving = true;
        _error = null;

        try
        {
            var position = RegionHR.Positions.Domain.Position.Skapa(_formEnhetId.Value, _formTitel, _formBudget, _formSysselsattning);
            db.Positions_Table.Add(position);
            await db.SaveChangesAsync();

            var enhetNamn = _enheter.FirstOrDefault(e => e.Id.Value == _formEnhetId.Value)?.Namn ?? "Okänd";
            _rader.Add(new PositionRad(position.Id, position.Titel, enhetNamn, "—", position.Sysselsattningsgrad, position.Status));

            _showForm = false;
            _success = $"Position \"{_formTitel}\" skapad i {enhetNamn}.";
            _formTitel = ""; _formEnhetId = null; _formBudget = 30000m; _formSysselsattning = 100m;
        }
        catch (Exception ex) { _error = $"Kunde inte skapa position: {ex.Message}"; }
        finally { _saving = false; }
    }

    private static Color StatusColor(PositionStatus s) => s switch
    {
        PositionStatus.Aktiv => Color.Success,
        PositionStatus.Vakant => Color.Warning,
        PositionStatus.Frysta => Color.Default,
        PositionStatus.Avvecklad => Color.Error,
        _ => Color.Default
    };

    private static string StatusText(PositionStatus s) => s switch
    {
        PositionStatus.Aktiv => "Tillsatt",
        PositionStatus.Vakant => "Vakant",
        PositionStatus.Frysta => "Frusen",
        PositionStatus.Avvecklad => "Avvecklad",
        _ => s.ToString()
    };

    private record PositionRad(Guid Id, string Titel, string Enhet, string Anstalld, decimal Sysselsattningsgrad, PositionStatus Status);
}

