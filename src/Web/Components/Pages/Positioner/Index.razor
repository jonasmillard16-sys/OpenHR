@page "/positioner"
@rendermode InteractiveServer
@layout RegionHR.Web.Components.Layout.AdminLayout

<PageTitle>OpenHR - Positioner</PageTitle>
<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4" Style="font-weight: 700;">Positioner</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" StartIcon="@Icons.Material.Filled.Add" Style="min-height: 48px;" OnClick="@(() => _showForm = true)">Ny position</MudButton>
</div>

@if (_showForm)
{
    <MudPaper Class="pa-6 mb-4" Elevation="3" Style="border-left: 4px solid var(--mud-palette-primary);">
        <div class="d-flex justify-space-between align-center mb-3">
            <MudText Typo="Typo.h6" Style="font-weight: 600;">Skapa ny position</MudText>
            <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="@(() => _showForm = false)" />
        </div>
        <MudTextField @bind-Value="_newBefattning" Label="Befattning" Variant="Variant.Outlined" Class="mb-3" />
        <MudTextField @bind-Value="_newAvdelning" Label="Avdelning" Variant="Variant.Outlined" Class="mb-3" />
        <MudTextField @bind-Value="_newSysselsattning" Label="Sysselsättningsgrad" Variant="Variant.Outlined" Class="mb-3" />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                   Style="min-height: 48px;" OnClick="SkapaPosition">Skapa</MudButton>
    </MudPaper>
}

@if (_skapad)
{
    <MudAlert Severity="Severity.Success" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="@(() => _skapad = false)">Position skapad!</MudAlert>
}

<MudSimpleTable Hover="true" Elevation="2">
    <thead>
        <tr>
            <th>Befattning</th>
            <th>Avdelning</th>
            <th>Anställd</th>
            <th>Sysselsättning</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var rad in _rader)
        {
            <tr>
                <td>@rad.Befattning</td>
                <td>@rad.Avdelning</td>
                <td>@rad.Anstalld</td>
                <td>@rad.Sysselsattning</td>
                <td><MudChip T="string" Size="Size.Small" Color="@rad.StatusFarg">@rad.StatusText</MudChip></td>
                <td><MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary" OnClick="@(() => Valj(rad))">Visa</MudButton></td>
            </tr>
            @if (_valdRad == rad)
            {
                <tr>
                    <td colspan="6">
                        <MudPaper Class="pa-4" Elevation="0" Style="background: var(--mud-palette-background-grey);">
                            <MudText Typo="Typo.subtitle1" Class="mb-2"><strong>@rad.Befattning — @rad.Avdelning</strong></MudText>
                            <MudText Typo="Typo.body2"><strong>Anställd:</strong> @rad.Anstalld</MudText>
                            <MudText Typo="Typo.body2"><strong>Sysselsättning:</strong> @rad.Sysselsattning</MudText>
                            <MudText Typo="Typo.body2"><strong>Status:</strong> @rad.StatusText</MudText>
                            <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="@(() => _valdRad = null)" Class="mt-2">Stäng</MudButton>
                        </MudPaper>
                    </td>
                </tr>
            }
        }
    </tbody>
</MudSimpleTable>

@code {
    private bool _showForm;
    private bool _skapad;
    private string _newBefattning = "";
    private string _newAvdelning = "";
    private string _newSysselsattning = "";

    private void SkapaPosition()
    {
        _showForm = false;
        _skapad = true;
        _newBefattning = "";
        _newAvdelning = "";
        _newSysselsattning = "";
    }

    private PositionRad? _valdRad;

    private void Valj(PositionRad rad) => _valdRad = _valdRad == rad ? null : rad;

    private List<PositionRad> _rader =
    [
        new("Sjuksköterska", "Akutmottagningen", "Anna Svensson", "100%", "Tillsatt", Color.Success),
        new("Överläkare", "Medicinkliniken", "Erik Johansson", "100%", "Tillsatt", Color.Success),
        new("Undersköterska", "Vårdavdelning 3B", "—", "75%", "Vakant", Color.Warning),
        new("Röntgensjuksköterska", "Röntgen", "—", "100%", "Vakant", Color.Warning),
        new("IT-tekniker", "IT-avdelningen", "—", "100%", "Frusen", Color.Default),
    ];

    private record PositionRad(string Befattning, string Avdelning, string Anstalld, string Sysselsattning, string StatusText, Color StatusFarg);
}
