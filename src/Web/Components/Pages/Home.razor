@page "/"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.LAS.Domain
@using RegionHR.Positions.Domain
@using RegionHR.SharedKernel.Domain
@using RegionHR.CaseManagement.Domain
@using Microsoft.EntityFrameworkCore
@inject RegionHRDbContext Db
@inject NavigationManager Nav

<PageTitle>OpenHR — Dashboard</PageTitle>

<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4" Style="font-weight: 700;">Dashboard</MudText>
    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
               StartIcon="@Icons.Material.Filled.Tune"
               OnClick="@(() => _showCustomize = !_showCustomize)">Anpassa</MudButton>
</div>

@if (_showCustomize)
{
    <MudPaper Class="pa-4 mb-4" Elevation="2">
        <MudText Typo="Typo.subtitle1" Class="mb-2" Style="font-weight: 600;">Visa sektioner</MudText>
        <MudStack Row="true" Spacing="4">
            <MudCheckBox T="bool" @bind-Value="_showKpi" Label="KPI-kort" Color="Color.Primary" />
            <MudCheckBox T="bool" @bind-Value="_showBemanning" Label="Bemanning per enhet" Color="Color.Primary" />
        </MudStack>
    </MudPaper>
}

@if (_error != null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
}

@if (_showKpi)
{
    <MudGrid Spacing="3" Class="mb-6">
        <MudItem xs="6" sm="2">
            <MudPaper Class="pa-4 text-center" Elevation="2" Style="cursor: pointer;" @onclick="@(() => Nav.NavigateTo("/anstallda"))">
                <MudText Typo="Typo.h4" Color="Color.Primary" Style="font-weight: 700;">@_headcount</MudText>
                <MudText Typo="Typo.body2">Anställda</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="2">
            <MudPaper Class="pa-4 text-center" Elevation="2" Style="cursor: pointer;" @onclick="@(() => Nav.NavigateTo("/las"))">
                <MudText Typo="Typo.h4" Color="Color.Warning" Style="font-weight: 700;">@_lasAlarm</MudText>
                <MudText Typo="Typo.body2">LAS-alarm</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="2">
            <MudPaper Class="pa-4 text-center" Elevation="2" Style="cursor: pointer;" @onclick="@(() => Nav.NavigateTo("/positioner"))">
                <MudText Typo="Typo.h4" Style="font-weight: 700;">@_vakantaPositioner</MudText>
                <MudText Typo="Typo.body2">Vakanta positioner</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="2">
            <MudPaper Class="pa-4 text-center" Elevation="2" Style="cursor: pointer;" @onclick="@(() => Nav.NavigateTo("/godkannanden"))">
                <MudText Typo="Typo.h4" Color="Color.Warning" Style="font-weight: 700;">@_godkannanden</MudText>
                <MudText Typo="Typo.body2">Väntar godkännande</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="2">
            <MudPaper Class="pa-4 text-center" Elevation="2" Style="cursor: pointer;" @onclick="@(() => Nav.NavigateTo("/rapporter/workforce-plan"))">
                <MudText Typo="Typo.h4" Color="@(_bemanningsgrad >= 90 ? Color.Success : _bemanningsgrad >= 70 ? Color.Warning : Color.Error)" Style="font-weight: 700;">@_bemanningsgrad%</MudText>
                <MudText Typo="Typo.body2">Bemanningsgrad</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@if (_showBemanning && _bemanningPerEnhet.Count > 0)
{
    <MudPaper Class="pa-4" Elevation="2">
        <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight: 600;">Bemanning per enhet</MudText>
        <MudSimpleTable Dense="true">
            <thead><tr><th>Enhet</th><th>Aktiva</th><th>Vakanta</th><th>Status</th></tr></thead>
            <tbody>
                @foreach (var e in _bemanningPerEnhet)
                {
                    var total = e.Aktiva + e.Vakanta;
                    var grad = total > 0 ? (int)Math.Round(100.0 * e.Aktiva / total) : 0;
                    <tr>
                        <td>@e.Namn</td>
                        <td>@e.Aktiva</td>
                        <td>@e.Vakanta</td>
                        <td>
                            <MudChip T="string" Size="Size.Small" Color="@(e.Vakanta == 0 ? Color.Success : e.Vakanta <= 1 ? Color.Warning : Color.Error)">
                                @grad%
                            </MudChip>
                        </td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    </MudPaper>
}
else if (_showBemanning && _bemanningPerEnhet.Count == 0 && !_loading)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Text">Inga positioner registrerade i databasen.</MudAlert>
}

@code {
    private bool _showCustomize;
    private bool _showKpi = true;
    private bool _showBemanning = true;
    private bool _loading = true;
    private string? _error;

    private int _headcount;
    private int _lasAlarm;
    private int _vakantaPositioner;
    private int _godkannanden;
    private int _bemanningsgrad;
    private List<EnhetBemanningVm> _bemanningPerEnhet = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var idag = DateOnly.FromDateTime(DateTime.Today);

            // Headcount: anställda med aktiv anställning
            var employees = await Db.Employees.Include(e => e.Anstallningar).ToListAsync();
            _headcount = employees.Count(e => e.AktivAnstallning(idag) != null);

            // LAS-alarm
            _lasAlarm = await Db.LASAccumulations
                .CountAsync(l => l.Status == LASStatus.NaraGrans || l.Status == LASStatus.KritiskNara);

            // Positioner — en fråga, gruppera status i minnet
            var positions = await Db.Positions_Table.ToListAsync();
            var statusCounts = positions.GroupBy(p => p.Status)
                .ToDictionary(g => g.Key, g => g.Count());
            var aktiva = statusCounts.GetValueOrDefault(PositionStatus.Aktiv);
            var vakanta = statusCounts.GetValueOrDefault(PositionStatus.Vakant);
            _vakantaPositioner = vakanta;

            // Väntande godkännanden
            _godkannanden = await Db.Cases
                .CountAsync(c => c.Status == CaseStatus.VantarGodkannande);

            // Bemanningsgrad
            var total = aktiva + vakanta;
            _bemanningsgrad = total > 0 ? (int)Math.Round(100.0 * aktiva / total) : 0;

            // Bemanning per enhet
            var enheter = await Db.OrganizationUnits.ToListAsync();
            var enhetNamn = enheter.ToDictionary(e => e.Id.Value, e => e.Namn);

            _bemanningPerEnhet = positions
                .GroupBy(p => p.EnhetId)
                .Select(g => new EnhetBemanningVm(
                    enhetNamn.TryGetValue(g.Key, out var namn) ? namn : "Okänd enhet",
                    g.Count(p => p.Status == PositionStatus.Aktiv),
                    g.Count(p => p.Status == PositionStatus.Vakant)))
                .OrderByDescending(e => e.Vakanta)
                .ToList();
        }
        catch (Exception ex)
        {
            _error = $"Kunde inte hämta dashboard-data: {ex.Message}";
        }
        finally { _loading = false; }
    }

    private record EnhetBemanningVm(string Namn, int Aktiva, int Vakanta);
}
