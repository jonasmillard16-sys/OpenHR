@page "/notiser/installningar"
@layout RegionHR.Web.Components.Layout.AdminLayout

<PageTitle>OpenHR - Notisinställningar</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">Notisinställningar</MudText>
<MudAlert Severity="Severity.Info" Variant="Variant.Text" Class="mb-4">
    Notisinställningar sparas lokalt. Personlig preferensmodell kräver ytterligare datamodell.
</MudAlert>

<MudSimpleTable Hover="true" Elevation="2">
    <thead><tr><th>Notistyp</th><th>Beskrivning</th><th>InApp</th><th>E-post</th></tr></thead>
    <tbody>
        @foreach (var inst in _installningar)
        {
            <tr>
                <td><strong>@inst.Typ</strong></td>
                <td>@inst.Beskrivning</td>
                <td><MudCheckBox T="bool" @bind-Value="inst.InApp" Color="Color.Primary" /></td>
                <td><MudCheckBox T="bool" @bind-Value="inst.Epost" Color="Color.Primary" /></td>
            </tr>
        }
    </tbody>
</MudSimpleTable>

<MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Class="mt-4" Style="min-height: 48px;" OnClick="@(() => _sparad = true)">Spara inställningar</MudButton>

@if (_sparad)
{
    <MudAlert Severity="Severity.Success" Class="mt-4" ShowCloseIcon="true" CloseIconClicked="@(() => _sparad = false)">Inställningar sparade (lokal session — ej persisterad i DB).</MudAlert>
}

@code {
    private bool _sparad;
    private List<NotisInst> _installningar = [];

    protected override void OnInitialized()
    {
        _installningar =
        [
            new() { Typ = "Ledighetsansökan", Beskrivning = "Ny ansökan eller statusändring", InApp = true, Epost = true },
            new() { Typ = "Lönebesked", Beskrivning = "Nytt lönebesked tillgängligt", InApp = true, Epost = true },
            new() { Typ = "Schemaändring", Beskrivning = "Ändringar i ditt schema", InApp = true, Epost = true },
            new() { Typ = "Godkännande", Beskrivning = "Åtgärd krävs", InApp = true, Epost = true },
            new() { Typ = "Certifiering", Beskrivning = "Certifiering går ut snart", InApp = true, Epost = true },
            new() { Typ = "Anslag", Beskrivning = "Organisationsmeddelanden", InApp = true, Epost = false },
        ];
    }

    private class NotisInst { public string Typ { get; set; } = ""; public string Beskrivning { get; set; } = ""; public bool InApp { get; set; } public bool Epost { get; set; } }
}
