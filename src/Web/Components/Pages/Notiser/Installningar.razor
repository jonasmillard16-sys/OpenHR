@page "/notiser/installningar"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Notifications.Domain
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<RegionHRDbContext> DbFactory
@inject RegionHR.Web.Services.AuthService Auth

<PageTitle>OpenHR - Notisinställningar</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">Notisinställningar</MudText>

@if (!Auth.EmployeeId.HasValue)
{
    <MudAlert Severity="Severity.Warning">Notisinställningar kräver kopplad anställd.</MudAlert>
}
else if (_loading) { <MudProgressCircular Color="Color.Primary" Indeterminate="true" /> }
else if (_error != null) { <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert> }
else
{
    <MudSimpleTable Hover="true" Elevation="2">
        <thead><tr><th>Notistyp</th><th>InApp</th><th>E-post</th></tr></thead>
        <tbody>
            @foreach (var pref in _prefs)
            {
                <tr>
                    <td><strong>@pref.NotisTyp</strong></td>
                    <td><MudCheckBox T="bool" Value="@pref.InApp" ValueChanged="@(v => { pref.Uppdatera(v, pref.Epost); _dirty = true; })" Color="Color.Primary" /></td>
                    <td><MudCheckBox T="bool" Value="@pref.Epost" ValueChanged="@(v => { pref.Uppdatera(pref.InApp, v); _dirty = true; })" Color="Color.Primary" /></td>
                </tr>
            }
        </tbody>
    </MudSimpleTable>

    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Class="mt-4" Style="min-height: 48px;"
               OnClick="Spara" Disabled="@(!_dirty || _saving)">
        @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
        Spara inställningar
    </MudButton>

    @if (_sparad) { <MudAlert Severity="Severity.Success" Class="mt-4" ShowCloseIcon="true" CloseIconClicked="@(() => _sparad = false)">Inställningar sparade i databasen.</MudAlert> }
}

@code {
    private static readonly string[] _defaultTyper = ["Ledighetsansökan", "Lönebesked", "Schemaändring", "Godkännande", "Certifiering", "Anslag"];

    private List<NotificationPreference> _prefs = [];
    private bool _loading = true, _saving, _sparad, _dirty;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        if (!Auth.EmployeeId.HasValue) { _loading = false; return; }
        try
        {
            var empId = Auth.EmployeeId.Value;
            _prefs = await db.NotificationPreferences
                .Where(p => p.AnstallId == empId)
                .ToListAsync();

            // Ensure all default types exist
            foreach (var typ in _defaultTyper)
            {
                if (!_prefs.Any(p => p.NotisTyp == typ))
                {
                    var pref = NotificationPreference.Skapa(empId, typ);
                    db.NotificationPreferences.Add(pref);
                    _prefs.Add(pref);
                }
            }
            if (_prefs.Count > _defaultTyper.Length || db.ChangeTracker.HasChanges())
            {
                await db.SaveChangesAsync();
            }
        }
        catch (Exception ex) { _error = $"Kunde inte hämta inställningar: {ex.Message}"; }
        finally { _loading = false; }
    }

    private async Task Spara()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _saving = true; _error = null;
        try
        {
            await db.SaveChangesAsync();
            _sparad = true;
            _dirty = false;
        }
        catch (Exception ex) { _error = $"Kunde inte spara: {ex.Message}"; }
        finally { _saving = false; }
    }
}

