@page "/notiser"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Notifications.Domain
@using Microsoft.EntityFrameworkCore
@inject RegionHRDbContext Db
@inject ISnackbar Snackbar

<PageTitle>OpenHR - Notiser</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">Notiser</MudText>

<MudStack Row="true" Spacing="2" Class="mb-4">
    <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="MarkAllRead"
               StartIcon="@Icons.Material.Filled.DoneAll">
        Markera alla som lästa
    </MudButton>
    <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="SimulateNotification"
               StartIcon="@Icons.Material.Filled.NotificationAdd">
        Simulera notis
    </MudButton>
    @if (_selectedNotiser.Count > 0)
    {
        <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="RaderaValda"
                   StartIcon="@Icons.Material.Filled.DeleteSweep">
            Radera valda (@_selectedNotiser.Count)
        </MudButton>
    }
</MudStack>

@if (!_notiser.Any())
{
    <MudAlert Severity="Severity.Info" Class="mb-4">Inga notiser att visa.</MudAlert>
}
else
{
    <MudStack Spacing="2">
        @foreach (var n in _notiser)
        {
            <MudPaper Class="@($"pa-4 {(n.ArLast ? "" : "mud-elevation-3")}")" Elevation="@(n.ArLast ? 0 : 2)"
                      Style="@(n.ArLast ? "" : "border-left: 4px solid var(--mud-palette-primary);")">
                <div class="d-flex justify-space-between align-center">
                    <div class="d-flex align-center gap-2">
                        <MudCheckBox T="bool" Value="@(_selectedNotiser.Contains(n))"
                                     ValueChanged="@((bool val) => ToggleNotis(n, val))"
                                     Color="Color.Primary" />
                    <div>
                        <MudText Typo="Typo.subtitle1" Style="@($"font-weight: {(n.ArLast ? "400" : "600")};")">@n.Titel</MudText>
                        <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">@n.Meddelande</MudText>
                        <MudText Typo="Typo.caption">@n.Tid</MudText>
                    </div>
                    </div>
                    @if (!n.ArLast)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Primary">Ny</MudChip>
                    }
                </div>
            </MudPaper>
        }
    </MudStack>
}

@code {
    private List<NotisViewModel> _notiser = new();
    private HashSet<NotisViewModel> _selectedNotiser = new();
    private int _simulationCount;

    private static readonly string[] SimTitles =
    [
        "Ny ledighetsansökan",
        "Schemaändring publicerad",
        "Lönebesked tillgängligt",
        "Nytt ärende tilldelat",
        "Medarbetarsamtal påminnelse",
        "Certifiering snart utgången",
        "Ny sjukanmälan",
        "MBL-förhandling kallelse",
    ];

    private static readonly string[] SimMessages =
    [
        "Anna Svensson har ansökt om semester 21–25 april.",
        "Schemat för vecka 14 har uppdaterats av din chef.",
        "Ditt lönebesked för mars 2026 finns nu tillgängligt.",
        "Du har tilldelats ärende #2026-0342 av HR.",
        "Påminnelse: medarbetarsamtal med Erik Johansson imorgon kl 10:00.",
        "Sjuksköterska-legitimation för Lisa Holm går ut om 30 dagar.",
        "Karl Berg har rapporterat sjukfrånvaro idag.",
        "MBL §11-förhandling kring omorganisation kallas den 25 mars.",
    ];

    protected override async Task OnInitializedAsync()
    {
        await LoadNotifications();
    }

    private async Task LoadNotifications()
    {
        try
        {
            var fromDb = await Db.Notifications
                .OrderByDescending(n => n.CreatedAt)
                .Take(50)
                .ToListAsync();

            _notiser = fromDb.Select(n => new NotisViewModel
            {
                Id = n.Id,
                Titel = n.Title,
                Meddelande = n.Message,
                Tid = n.CreatedAt.ToString("yyyy-MM-dd HH:mm"),
                ArLast = n.IsRead
            }).ToList();
        }
        catch
        {
            // Fallback demo data when DB is unavailable
            _notiser = new List<NotisViewModel>
            {
                new() { Titel = "Ledighetsansökan godkänd", Meddelande = "Din semester 14–18 juli har godkänts av chef.", Tid = "2026-03-17 09:00", ArLast = false },
                new() { Titel = "Nytt lönebesked", Meddelande = "Lönebeskedet för mars 2026 finns tillgängligt.", Tid = "2026-03-15 08:00", ArLast = false },
                new() { Titel = "Certifiering går ut snart", Meddelande = "Din sjuksköterska-legitimation går ut om 45 dagar.", Tid = "2026-03-14 12:00", ArLast = false },
                new() { Titel = "Schemaändring", Meddelande = "Ditt schema för vecka 13 har uppdaterats.", Tid = "2026-03-12 14:30", ArLast = true },
                new() { Titel = "Medarbetarsamtal bokat", Meddelande = "Årligt medarbetarsamtal inbokat 25 mars kl. 10:00.", Tid = "2026-03-10 09:15", ArLast = true },
            };
        }
    }

    private void SimulateNotification()
    {
        var index = _simulationCount % SimTitles.Length;
        var now = DateTime.Now;

        var simulated = new NotisViewModel
        {
            Id = Guid.NewGuid(),
            Titel = SimTitles[index],
            Meddelande = SimMessages[index],
            Tid = now.ToString("yyyy-MM-dd HH:mm:ss"),
            ArLast = false
        };

        _notiser.Insert(0, simulated);
        _simulationCount++;

        Snackbar.Add($"Ny notis: {simulated.Titel}", Severity.Info,
            config =>
            {
                config.Icon = Icons.Material.Filled.NotificationsActive;
                config.VisibleStateDuration = 3000;
            });

        StateHasChanged();
    }

    private void ToggleNotis(NotisViewModel notis, bool value)
    {
        if (value)
            _selectedNotiser.Add(notis);
        else
            _selectedNotiser.Remove(notis);
    }

    private void RaderaValda()
    {
        var count = _selectedNotiser.Count;
        foreach (var n in _selectedNotiser.ToList())
            _notiser.Remove(n);
        _selectedNotiser.Clear();
        Snackbar.Add($"{count} notis(er) raderade", Severity.Success,
            config =>
            {
                config.Icon = Icons.Material.Filled.Delete;
                config.VisibleStateDuration = 4000;
            });
    }

    private async Task MarkAllRead()
    {
        // Save previous read-state so we can undo
        var previousStates = _notiser.Select(n => new { n.Titel, WasRead = n.ArLast }).ToList();
        var hadUnread = _notiser.Any(n => !n.ArLast);

        try
        {
            var unread = await Db.Notifications
                .Where(n => !n.IsRead)
                .ToListAsync();

            foreach (var n in unread)
                n.MarkAsRead();

            await Db.SaveChangesAsync();
        }
        catch { }

        foreach (var n in _notiser)
            n.ArLast = true;

        StateHasChanged();

        if (hadUnread)
        {
            Snackbar.Add("Alla notiser markerade som lästa. Ångra?", Severity.Normal, config =>
            {
                config.Action = "Ångra";
                config.ActionColor = Color.Warning;
                config.OnClick = _ =>
                {
                    foreach (var prev in previousStates)
                    {
                        var notis = _notiser.FirstOrDefault(n => n.Titel == prev.Titel);
                        if (notis != null)
                            notis.ArLast = prev.WasRead;
                    }
                    InvokeAsync(StateHasChanged);
                    return Task.CompletedTask;
                };
                config.VisibleStateDuration = 10000;
                config.ShowCloseIcon = true;
            });
        }
    }

    private class NotisViewModel
    {
        public Guid Id { get; set; }
        public string Titel { get; set; } = "";
        public string Meddelande { get; set; } = "";
        public string Tid { get; set; } = "";
        public bool ArLast { get; set; }
    }
}
