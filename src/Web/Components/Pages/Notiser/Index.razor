@page "/notiser"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Notifications.Domain
@using Microsoft.EntityFrameworkCore
@inject RegionHRDbContext Db
@inject ISnackbar Snackbar
@inject RegionHR.Web.Services.AuthService Auth

<PageTitle>OpenHR — Notiser</PageTitle>

<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4" Style="font-weight: 700;">Notiser</MudText>
    <div class="d-flex gap-2">
        @if (_notiser.Any(n => !n.IsRead))
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="MarkeraAllaLasta">
                Markera alla som lästa
            </MudButton>
        }
        @if (Auth.EmployeeId.HasValue)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="SkapaTestNotis">
                Skapa testnotis
            </MudButton>
        }
    </div>
</div>

<MudText Typo="Typo.body2" Class="mb-4" Style="color: var(--mud-palette-text-secondary);">
    In-app-notiser från databasen. Ingen realtidspush i v1.5 — sidan läser vid laddning.
</MudText>

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error">@_error</MudAlert>
}
else if (_notiser.Count == 0)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Text">Inga notiser.</MudAlert>
}
else
{
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-3 text-center" Elevation="2">
                <MudText Typo="Typo.h4" Color="Color.Primary" Style="font-weight: 700;">@_notiser.Count(n => !n.IsRead)</MudText>
                <MudText Typo="Typo.body2">Olästa</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-3 text-center" Elevation="2">
                <MudText Typo="Typo.h4" Style="font-weight: 700;">@_notiser.Count</MudText>
                <MudText Typo="Typo.body2">Totalt</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @foreach (var n in _notiser.OrderByDescending(n => n.CreatedAt))
    {
        <MudPaper Class="@($"pa-4 mb-2 {(n.IsRead ? "" : "mud-elevation-3")}")"
                  Elevation="@(n.IsRead ? 0 : 2)"
                  Style="@(n.IsRead ? "" : "border-left: 4px solid var(--mud-palette-primary);")">
            <div class="d-flex justify-space-between align-center">
                <div>
                    <MudText Typo="Typo.subtitle1" Style="@($"font-weight: {(n.IsRead ? "400" : "600")};")">
                        @n.Title
                    </MudText>
                    <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">@n.Message</MudText>
                    <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">
                        @n.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                        @if (n.Type != NotificationType.Info) { <MudChip T="string" Size="Size.Small" Color="@TypeColor(n.Type)">@n.Type</MudChip> }
                    </MudText>
                </div>
                <div class="d-flex gap-1">
                    @if (!n.IsRead)
                    {
                        <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary"
                                   OnClick="@(async () => await MarkeraLast(n))">Markera läst</MudButton>
                    }
                    @if (n.ActionUrl != null)
                    {
                        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary"
                                   Href="@n.ActionUrl">Öppna</MudButton>
                    }
                </div>
            </div>
        </MudPaper>
    }
}

@code {
    private List<Notification> _notiser = [];
    private bool _loading = true;
    private string? _error;
    private int _testCount;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _notiser = await Db.Notifications
                .OrderByDescending(n => n.CreatedAt)
                .Take(50)
                .ToListAsync();
        }
        catch (Exception ex) { _error = $"Kunde inte hämta notiser: {ex.Message}"; }
        finally { _loading = false; }
    }

    private async Task MarkeraLast(Notification n)
    {
        n.MarkAsRead();
        await Db.SaveChangesAsync();
    }

    private async Task MarkeraAllaLasta()
    {
        var unread = _notiser.Where(n => !n.IsRead).ToList();
        foreach (var n in unread)
            n.MarkAsRead();
        await Db.SaveChangesAsync();
        Snackbar.Add($"{unread.Count} notiser markerade som lästa.", MudBlazor.Severity.Success);
    }

    private async Task SkapaTestNotis()
    {
        _testCount++;
        if (!Auth.EmployeeId.HasValue) return;
        var notis = Notification.Create(
            Auth.EmployeeId.Value,
            $"Testnotis #{_testCount}",
            $"Skapad {DateTime.Now:HH:mm:ss} via Skapa testnotis-knappen.",
            NotificationType.Info);
        Db.Notifications.Add(notis);
        await Db.SaveChangesAsync();
        _notiser.Insert(0, notis);
        Snackbar.Add("Testnotis skapad och sparad i databasen.", MudBlazor.Severity.Info);
    }

    private static MudBlazor.Color TypeColor(NotificationType t) => t switch
    {
        NotificationType.Warning => MudBlazor.Color.Warning,
        NotificationType.Action => MudBlazor.Color.Error,
        NotificationType.Reminder => MudBlazor.Color.Info,
        _ => MudBlazor.Color.Default
    };
}
