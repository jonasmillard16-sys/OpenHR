@page "/offboarding/ny"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Offboarding.Domain
@using Microsoft.EntityFrameworkCore
@inject RegionHRDbContext Db
@inject NavigationManager Nav

<PageTitle>OpenHR - Nytt offboarding-ärende</PageTitle>
<MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Variant="Variant.Text" Color="Color.Primary" Href="/offboarding" Style="margin-bottom: 1rem;">Tillbaka</MudButton>

<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">Nytt offboarding-ärende</MudText>

@if (_loading) { <MudProgressCircular Color="Color.Primary" Indeterminate="true" /> }
else if (_error != null) { <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert> }
else if (_created)
{
    <MudPaper Class="pa-5" Elevation="2" Style="border-left: 4px solid var(--mud-palette-success);">
        <MudText Typo="Typo.h5" Color="Color.Success" Style="font-weight: 700;" Class="mb-3">Offboarding-ärende skapat</MudText>
        <MudSimpleTable Dense="true" Class="mb-3">
            <tbody>
                <tr><td><strong>Anställd</strong></td><td>@_valdNamn</td></tr>
                <tr><td><strong>Anledning</strong></td><td>@_case!.Anledning</td></tr>
                <tr><td><strong>Sista arbetsdag</strong></td><td>@_case.SistaArbetsdag.ToString("yyyy-MM-dd")</td></tr>
                <tr><td><strong>Checklistepunkter</strong></td><td>@_case.Steg.Count</td></tr>
            </tbody>
        </MudSimpleTable>
        <MudText Typo="Typo.h6" Class="mb-2">Checklista</MudText>
        @foreach (var steg in _case!.Steg)
        {
            <MudText Typo="Typo.body2">☐ @steg.Beskrivning</MudText>
        }
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/offboarding" Class="mt-4">Tillbaka till offboarding</MudButton>
    </MudPaper>
}
else
{
    <MudPaper Class="pa-5" Elevation="2">
        <MudGrid Spacing="3">
            <MudItem xs="12" sm="4">
                <MudSelect T="Guid?" @bind-Value="_formAnstallId" Label="Anställd" Variant="Variant.Outlined" Required="true">
                    @foreach (var e in _employees) { <MudSelectItem T="Guid?" Value="@((Guid?)e.Id.Value)">@e.Fornamn @e.Efternamn</MudSelectItem> }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudSelect T="AvslutAnledning" @bind-Value="_formAnledning" Label="Anledning" Variant="Variant.Outlined">
                    @foreach (var a in Enum.GetValues<AvslutAnledning>()) { <MudSelectItem Value="@a">@AnledningText(a)</MudSelectItem> }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudDatePicker @bind-Date="_formSistaDag" Label="Sista arbetsdag" Variant="Variant.Outlined" Required="true" />
            </MudItem>
        </MudGrid>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Class="mt-4" Style="min-height: 48px;"
                   OnClick="SkapaArende" Disabled="@(_formAnstallId == null || _formSistaDag == null || _saving)">
            Skapa offboarding-ärende
        </MudButton>
    </MudPaper>
}

@code {
    private List<RegionHR.Core.Domain.Employee> _employees = [];
    private OffboardingCase? _case;
    private string _valdNamn = "";
    private Guid? _formAnstallId;
    private AvslutAnledning _formAnledning = AvslutAnledning.EgenBegaran;
    private DateTime? _formSistaDag;
    private bool _loading = true, _saving, _created;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try { _employees = await Db.Employees.OrderBy(e => e.Efternamn).ToListAsync(); }
        catch (Exception ex) { _error = $"Kunde inte hämta data: {ex.Message}"; }
        finally { _loading = false; }
    }

    private async Task SkapaArende()
    {
        if (_formAnstallId == null || _formSistaDag == null) return;
        _saving = true; _error = null;
        try
        {
            var emp = _employees.FirstOrDefault(e => e.Id.Value == _formAnstallId.Value);
            _valdNamn = emp != null ? $"{emp.Fornamn} {emp.Efternamn}" : "Okänd";

            _case = OffboardingCase.Skapa(_formAnstallId.Value, _formAnledning, DateOnly.FromDateTime(_formSistaDag.Value));
            _case.MarkeraSomPagar();
            Db.OffboardingCases.Add(_case);
            await Db.SaveChangesAsync();
            _created = true;
        }
        catch (Exception ex) { _error = $"Kunde inte skapa: {ex.Message}"; }
        finally { _saving = false; }
    }

    private static string AnledningText(AvslutAnledning a) => a switch
    {
        AvslutAnledning.EgenBegaran => "Egen uppsägning", AvslutAnledning.Uppsagning => "Uppsägning",
        AvslutAnledning.Pension => "Pension", AvslutAnledning.Vikariat_Slut => "Vikariat slut",
        AvslutAnledning.Provanstallning_Avbruten => "Provanst. avbruten", AvslutAnledning.Overgang => "Övergång",
        AvslutAnledning.Dodsfall => "Dödsfall", AvslutAnledning.Annat => "Annat", _ => a.ToString()
    };
}
