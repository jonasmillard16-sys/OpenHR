@page "/formaner/enrollment"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Benefits.Domain
@using RegionHR.Infrastructure.Persistence
@using Microsoft.EntityFrameworkCore
@inject RegionHRDbContext Db

<PageTitle>OpenHR — Förmånsval</PageTitle>

<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4" Style="font-weight: 700;">Förmånsval</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
               StartIcon="@Icons.Material.Filled.Add" Style="min-height: 48px;"
               OnClick="@(() => _showForm = !_showForm)">Registrera val</MudButton>
</div>

<MudText Typo="Typo.body2" Class="mb-4" Style="color: var(--mud-palette-text-secondary);">
    Förmånskatalog och anställdas förmånsval. Adminvy — data hämtas från databasen.
    Inte full open enrollment-orkestrering.
</MudText>

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error">@_error</MudAlert>
}
else
{
    @* Registrera nytt val *@
    @if (_showForm)
    {
        <MudPaper Class="pa-5 mb-4" Elevation="3" Style="border-left: 4px solid var(--mud-palette-primary);">
            <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight: 600;">Registrera förmånsval</MudText>
            <MudGrid Spacing="3">
                <MudItem xs="12" sm="4">
                    <MudSelect T="Guid?" @bind-Value="_formAnstallId" Label="Anställd" Variant="Variant.Outlined">
                        @foreach (var e in _employees)
                        {
                            <MudSelectItem T="Guid?" Value="@((Guid?)e.Id.Value)">@e.Fornamn @e.Efternamn</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudSelect T="Guid?" @bind-Value="_formBenefitId" Label="Förmån" Variant="Variant.Outlined">
                        @foreach (var b in _benefits.Where(b => b.ArAktiv))
                        {
                            <MudSelectItem T="Guid?" Value="@((Guid?)b.Id)">@b.Namn (@b.Kategori)</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudNumericField @bind-Value="_formBelopp" Label="Belopp (kr)" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_formLivshandelse" Label="Livshändelse (valfritt)" Variant="Variant.Outlined"
                                  Placeholder="T.ex. Nytt barn, Fyllt 40, Gift" />
                </MudItem>
            </MudGrid>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-3" OnClick="SparaVal">Registrera</MudButton>
        </MudPaper>
    }

    @if (_success != null)
    {
        <MudAlert Severity="Severity.Success" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="@(() => _success = null)">@_success</MudAlert>
    }

    @* KPI *@
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="2">
                <MudText Typo="Typo.h3" Color="Color.Primary" Style="font-weight: 700;">@_benefits.Count(b => b.ArAktiv)</MudText>
                <MudText Typo="Typo.body2">Aktiva förmåner</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="2">
                <MudText Typo="Typo.h3" Style="font-weight: 700;">@_selections.Count</MudText>
                <MudText Typo="Typo.body2">Registrerade val</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="2">
                <MudText Typo="Typo.h3" Color="Color.Success" Style="font-weight: 700;">@_selections.Count(s => s.Status == EnrollmentStatus.Aktiv)</MudText>
                <MudText Typo="Typo.body2">Aktiva val</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="2">
                <MudText Typo="Typo.h3" Color="Color.Warning" Style="font-weight: 700;">@_selections.Count(s => s.Status == EnrollmentStatus.Ansokt)</MudText>
                <MudText Typo="Typo.body2">Väntar godkännande</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* Förmånskatalog *@
    <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight: 600;">Förmånskatalog</MudText>
    <MudSimpleTable Hover="true" Elevation="2" Class="mb-6">
        <thead><tr><th>Förmån</th><th>Kategori</th><th>Max belopp</th><th>Arbetsgivarandel</th><th>Skattepliktig</th><th>Status</th></tr></thead>
        <tbody>
            @foreach (var b in _benefits)
            {
                <tr>
                    <td><strong>@b.Namn</strong><br /><MudText Typo="Typo.caption">@b.Beskrivning</MudText></td>
                    <td><MudChip T="string" Size="Size.Small">@b.Kategori</MudChip></td>
                    <td>@(b.MaxBelopp > 0 ? $"{b.MaxBelopp:N0} kr" : "—")</td>
                    <td>@b.ArbetsgivarAndel%</td>
                    <td>@(b.ArSkattepliktig ? "Ja" : "Nej")</td>
                    <td><MudChip T="string" Size="Size.Small" Color="@(b.ArAktiv ? Color.Success : Color.Default)">@(b.ArAktiv ? "Aktiv" : "Inaktiv")</MudChip></td>
                </tr>
            }
        </tbody>
    </MudSimpleTable>

    @* Anställdas val *@
    <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight: 600;">Anställdas förmånsval</MudText>
    @if (_selections.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Text">Inga förmånsval registrerade.</MudAlert>
    }
    else
    {
        <MudSimpleTable Hover="true" Elevation="2">
            <thead><tr><th>Anställd</th><th>Förmån</th><th>Belopp</th><th>Start</th><th>Livshändelse</th><th>Status</th><th></th></tr></thead>
            <tbody>
                @foreach (var s in _selections.OrderByDescending(s => s.SkapadVid))
                {
                    <tr>
                        <td><strong>@GetEmployeeName(s.AnstallId)</strong></td>
                        <td>@GetBenefitName(s.BenefitId)</td>
                        <td>@(s.ValtBelopp > 0 ? $"{s.ValtBelopp:N0} kr" : "—")</td>
                        <td>@s.StartDatum.ToString("yyyy-MM-dd")</td>
                        <td>@(s.LivshandardAnledning ?? "—")</td>
                        <td><MudChip T="string" Size="Size.Small" Color="@StatusFarg(s.Status)">@StatusText(s.Status)</MudChip></td>
                        <td>
                            @if (s.Status == EnrollmentStatus.Ansokt)
                            {
                                <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Success"
                                           OnClick="@(async () => await GodkannVal(s))">Godkänn</MudButton>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    }
}

@code {
    private List<Benefit> _benefits = [];
    private List<EmployeeBenefit> _selections = [];
    private List<RegionHR.Core.Domain.Employee> _employees = [];
    private bool _loading = true, _showForm;
    private string? _error, _success;
    private Guid? _formAnstallId, _formBenefitId;
    private decimal _formBelopp;
    private string _formLivshandelse = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _benefits = await Db.Benefits.OrderBy(b => b.Kategori).ToListAsync();
            _selections = await Db.EmployeeBenefits.ToListAsync();
            _employees = await Db.Employees.OrderBy(e => e.Efternamn).ToListAsync();
        }
        catch (Exception ex) { _error = $"Kunde inte hämta data: {ex.Message}"; }
        finally { _loading = false; }
    }

    private async Task SparaVal()
    {
        if (_formAnstallId is null || _formBenefitId is null) return;
        var val = EmployeeBenefit.Anmala(
            _formAnstallId.Value, _formBenefitId.Value,
            DateOnly.FromDateTime(DateTime.Today), _formBelopp,
            string.IsNullOrWhiteSpace(_formLivshandelse) ? null : _formLivshandelse);
        Db.EmployeeBenefits.Add(val);
        await Db.SaveChangesAsync();
        _selections.Add(val);
        _showForm = false;
        _success = $"Förmånsval registrerat för {GetEmployeeName(_formAnstallId.Value)}.";
        _formBelopp = 0; _formLivshandelse = "";
    }

    private async Task GodkannVal(EmployeeBenefit val)
    {
        val.Godkann();
        await Db.SaveChangesAsync();
    }

    private string GetEmployeeName(Guid id)
    {
        var emp = _employees.FirstOrDefault(e => e.Id.Value == id);
        return emp != null ? $"{emp.Fornamn} {emp.Efternamn}" : "Okänd";
    }

    private string GetBenefitName(Guid id) =>
        _benefits.FirstOrDefault(b => b.Id == id)?.Namn ?? "Okänd";

    private static Color StatusFarg(EnrollmentStatus s) => s switch
    {
        EnrollmentStatus.Aktiv => Color.Success,
        EnrollmentStatus.Ansokt => Color.Warning,
        EnrollmentStatus.Nekad => Color.Error,
        EnrollmentStatus.Avslutad => Color.Default,
        _ => Color.Default
    };

    private static string StatusText(EnrollmentStatus s) => s switch
    {
        EnrollmentStatus.Aktiv => "Aktiv",
        EnrollmentStatus.Ansokt => "Ansökt",
        EnrollmentStatus.Nekad => "Nekad",
        EnrollmentStatus.Avslutad => "Avslutad",
        _ => s.ToString()
    };
}
