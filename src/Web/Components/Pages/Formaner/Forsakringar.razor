@page "/formaner/forsakringar"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Insurance.Domain
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<RegionHRDbContext> DbFactory

<PageTitle>OpenHR - Försäkringar</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">Försäkringar</MudText>
<MudText Typo="Typo.body2" Class="mb-4" Style="color: var(--mud-palette-text-secondary);">Kollektivavtalsbaserade försäkringar som gäller för regionens anställda.</MudText>

@if (_loading) { <MudProgressCircular Color="Color.Primary" Indeterminate="true" /> }
else if (_error != null) { <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert> }
else if (_forsakringar.Count == 0) { <MudAlert Severity="Severity.Info" Variant="Variant.Text">Inga försäkringar registrerade.</MudAlert> }
else
{
    <MudSimpleTable Hover="true" Elevation="2">
        <thead><tr><th>Försäkring</th><th>Typ</th><th>Försäkringsgivare</th><th>Beskrivning</th><th>Status</th></tr></thead>
        <tbody>
            @foreach (var f in _forsakringar)
            {
                <tr>
                    <td><strong>@f.Namn</strong></td>
                    <td><MudChip T="string" Size="Size.Small">@f.Typ</MudChip></td>
                    <td>@f.Forsakringsgivare</td>
                    <td>@(f.Beskrivning ?? "—")</td>
                    <td><MudChip T="string" Size="Size.Small" Color="@(f.ArAktiv ? Color.Success : Color.Default)">@(f.ArAktiv ? "Aktiv" : "Inaktiv")</MudChip></td>
                </tr>
            }
        </tbody>
    </MudSimpleTable>
}

@code {
    private List<InsuranceCoverage> _forsakringar = [];
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        try { _forsakringar = await db.InsuranceCoverages.OrderBy(f => f.Typ).ToListAsync(); }
        catch (Exception ex) { _error = $"Kunde inte hämta försäkringar: {ex.Message}"; }
        finally { _loading = false; }
    }
}

