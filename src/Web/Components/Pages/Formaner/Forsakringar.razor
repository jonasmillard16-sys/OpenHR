@page "/formaner/forsakringar"
@layout RegionHR.Web.Components.Layout.AdminLayout

<PageTitle>OpenHR - Försäkringar</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">Försäkringsöversikt</MudText>

<MudGrid Spacing="3" Class="mb-4">
    <MudItem xs="3">
        <MudPaper Class="pa-3 text-center" Elevation="1">
            <MudText Typo="Typo.h4" Color="Color.Primary" Style="font-weight: 700;">@_antalOmfattade</MudText>
            <MudText Typo="Typo.body2">Anställda med försäkringsskydd</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="3">
        <MudPaper Class="pa-3 text-center" Elevation="1">
            <MudText Typo="Typo.h4" Color="Color.Success" Style="font-weight: 700;">@_antalForsakringar</MudText>
            <MudText Typo="Typo.body2">Aktiva försäkringstyper</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="3">
        <MudPaper Class="pa-3 text-center" Elevation="1">
            <MudText Typo="Typo.h4" Color="Color.Warning" Style="font-weight: 700;">@_pagaendeArenden</MudText>
            <MudText Typo="Typo.body2">Pågående ärenden</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="3">
        <MudPaper Class="pa-3 text-center" Elevation="1">
            <MudText Typo="Typo.h4" Color="Color.Info" Style="font-weight: 700;">@_arskostnad</MudText>
            <MudText Typo="Typo.body2">Årspremie (total)</MudText>
        </MudPaper>
    </MudItem>
</MudGrid>

<MudAlert Severity="Severity.Info" Class="mb-4">
    Försäkringsskyddet regleras av kollektivavtal och gäller samtliga anställda.
    TGL, AGS och AFA-försäkringar administreras centralt via regionen.
</MudAlert>

<MudText Typo="Typo.h6" Class="mb-3">Kollektivavtalade försäkringar</MudText>
<MudSimpleTable Hover="true" Elevation="2" Class="mb-6">
    <thead>
        <tr>
            <th>Försäkring</th>
            <th>Förkortning</th>
            <th>Omfattar</th>
            <th>Beskrivning</th>
            <th>Premie/anställd</th>
            <th>Status</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var rad in _forsakringar)
        {
            <tr>
                <td><strong>@rad.Namn</strong></td>
                <td>@rad.Forkortning</td>
                <td>@rad.Omfattar</td>
                <td>@rad.Beskrivning</td>
                <td>@rad.PremiePerAnst</td>
                <td><MudChip T="string" Size="Size.Small" Color="@rad.StatusFarg">@rad.StatusText</MudChip></td>
            </tr>
        }
    </tbody>
</MudSimpleTable>

<MudText Typo="Typo.h6" Class="mb-3">Försäkringsskydd per anställd (urval)</MudText>
<MudSimpleTable Hover="true" Elevation="2">
    <thead>
        <tr>
            <th>Anställd</th>
            <th>Enhet</th>
            <th>TGL</th>
            <th>AGS</th>
            <th>TFA</th>
            <th>AFA Sjukförsäkring</th>
            <th>PSA</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var rad in _perAnst)
        {
            <tr>
                <td><strong>@rad.Namn</strong></td>
                <td>@rad.Enhet</td>
                <td><MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" /></td>
                <td><MudIcon Icon="@(rad.AGS ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)" Color="@(rad.AGS ? Color.Success : Color.Default)" Size="Size.Small" /></td>
                <td><MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" /></td>
                <td><MudIcon Icon="@(rad.AFASjuk ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)" Color="@(rad.AFASjuk ? Color.Success : Color.Default)" Size="Size.Small" /></td>
                <td><MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" /></td>
            </tr>
        }
    </tbody>
</MudSimpleTable>

@code {
    private int _antalOmfattade = 1254;
    private int _antalForsakringar = 5;
    private int _pagaendeArenden = 8;
    private string _arskostnad = "4,2 Mkr";

    private List<ForsakringsRad> _forsakringar = [];
    private List<AnstForsakring> _perAnst = [];

    protected override void OnInitialized()
    {
        _forsakringar =
        [
            new("Tjänstegrupplivförsäkring", "TGL", "Alla anställda", "Utbetalning vid dödsfall till efterlevande", "89 kr/mån", "Aktiv", Color.Success),
            new("Avtalsgruppsjukförsäkring", "AGS", "Tillsvidareanställda", "Komplettering vid sjukdom dag 15–360", "245 kr/mån", "Aktiv", Color.Success),
            new("Trygghetsförsäkring vid arbetsskada", "TFA", "Alla anställda", "Ersättning vid arbetsskada och arbetssjukdom", "132 kr/mån", "Aktiv", Color.Success),
            new("AFA Sjukförsäkring", "AFA Sjuk", "Tillsvidareanställda", "Ersättning vid långvarig sjukdom och omställning", "178 kr/mån", "Aktiv", Color.Success),
            new("Premiebefrielseförsäkring", "PSA", "Alla anställda", "Fortsatt pensionsavsättning vid sjukdom", "56 kr/mån", "Aktiv", Color.Success),
        ];

        _perAnst =
        [
            new("Anna Svensson", "Kardiologi", true, true, true),
            new("Karl Berg", "Ortopedi", true, true, true),
            new("Erik Johansson", "Akutmottagningen", true, true, true),
            new("Lisa Holm", "HR-avdelningen", true, true, true),
            new("Per Gustafsson", "IT-drift", true, true, true),
            new("Sara Karlsson", "Vårdcentral Centrum", true, false, false),
            new("Maria Lindström", "Kirurgi", true, true, true),
            new("Jonas Eriksson", "Barnmottagningen", true, true, true),
        ];
    }

    private record ForsakringsRad(string Namn, string Forkortning, string Omfattar, string Beskrivning, string PremiePerAnst, string StatusText, Color StatusFarg);
    private record AnstForsakring(string Namn, string Enhet, bool AGS, bool AFASjuk, bool TFA);
}
