@page "/formaner/livshandelse"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Benefits.Domain
@using RegionHR.Infrastructure.Persistence
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<RegionHRDbContext> DbFactory
@inject RegionHR.Web.Services.AuthService Auth

<PageTitle>OpenHR — Registrera livshändelse</PageTitle>

<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4" Style="font-weight: 700;">Registrera livshändelse</MudText>
</div>

<MudText Typo="Typo.body2" Class="mb-4" Style="color: var(--mud-palette-text-secondary);">
    Vid en livshändelse (nyanställning, barns födelse, skilsmässa m.m.) kan du göra
    förmånsändringar utanför det ordinarie valförstret.
</MudText>

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
}
else
{
    @if (_success != null)
    {
        <MudAlert Severity="Severity.Success" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="@(() => _success = null)">@_success</MudAlert>
    }

    @* Registration form *@
    <MudPaper Class="pa-6 mb-6" Elevation="3" Style="border-left: 4px solid var(--mud-palette-primary);">
        <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight: 600;">Ny livshändelse</MudText>
        <MudGrid Spacing="3">
            <MudItem xs="12" sm="6">
                <MudSelect T="Guid?" @bind-Value="_selectedEventId" Label="Typ av livshändelse" Variant="Variant.Outlined">
                    @foreach (var le in _lifeEvents)
                    {
                        <MudSelectItem T="Guid?" Value="@((Guid?)le.Id)">@le.Namn (@le.Typ)</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudDatePicker @bind-Date="_selectedDatum" Label="Datum för händelsen" Variant="Variant.Outlined" />
            </MudItem>
        </MudGrid>

        @if (_selectedEventId.HasValue)
        {
            var evt = _lifeEvents.FirstOrDefault(e => e.Id == _selectedEventId.Value);
            @if (evt != null)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Text" Class="mt-3" Dense="true">
                    <strong>Tidsfönster:</strong> @(evt.TidsFonsterDagar == 0 ? "Inget tidsfönster (alltid giltigt)" : $"{evt.TidsFonsterDagar} dagar efter händelsen")
                </MudAlert>
            }
        }

        <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-4" Size="Size.Large"
                   Style="min-height: 48px;"
                   Disabled="@(!_selectedEventId.HasValue || _selectedDatum == null || _saving)"
                   OnClick="RegistreraHandelse">Registrera</MudButton>
    </MudPaper>

    @* Previous occurrences *@
    <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight: 600;">Mina registrerade livshändelser</MudText>
    @if (_myOccurrences.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Text">Inga livshändelser registrerade.</MudAlert>
    }
    else
    {
        <MudSimpleTable Hover="true" Elevation="2">
            <thead><tr><th>Händelse</th><th>Datum</th><th>Status</th></tr></thead>
            <tbody>
                @foreach (var o in _myOccurrences.OrderByDescending(x => x.Datum))
                {
                    <tr>
                        <td><strong>@GetEventName(o.LifeEventId)</strong></td>
                        <td>@o.Datum.ToString("yyyy-MM-dd")</td>
                        <td><MudChip T="string" Size="Size.Small" Color="@(o.Status == "Processed" ? Color.Success : Color.Warning)">@(o.Status == "Processed" ? "Bearbetad" : "Registrerad")</MudChip></td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    }
}

@code {
    private List<LifeEvent> _lifeEvents = [];
    private List<LifeEventOccurrence> _myOccurrences = [];
    private bool _loading = true, _saving;
    private string? _error, _success;
    private Guid? _selectedEventId;
    private DateTime? _selectedDatum;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        try
        {
            _lifeEvents = await db.LifeEvents.OrderBy(e => e.Namn).ToListAsync();
            if (Auth.EmployeeId.HasValue)
            {
                _myOccurrences = await db.LifeEventOccurrences
                    .Where(o => o.AnstallId == Auth.EmployeeId.Value)
                    .ToListAsync();
            }
        }
        catch (Exception ex) { _error = $"Kunde inte hämta data: {ex.Message}"; }
        finally { _loading = false; }
    }

    private async Task RegistreraHandelse()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        if (!Auth.EmployeeId.HasValue) { _error = "Kräver inloggad anställd."; return; }
        if (!_selectedEventId.HasValue || _selectedDatum == null) return;

        _saving = true; _error = null;
        try
        {
            var lifeEvent = _lifeEvents.First(e => e.Id == _selectedEventId.Value);
            var datum = DateOnly.FromDateTime(_selectedDatum.Value);

            if (!lifeEvent.ArInomTidsFonster(datum))
            {
                _error = $"Tidsfönstret på {lifeEvent.TidsFonsterDagar} dagar har passerat.";
                return;
            }

            var occurrence = LifeEventOccurrence.Registrera(_selectedEventId.Value, Auth.EmployeeId.Value, datum);
            db.LifeEventOccurrences.Add(occurrence);
            await db.SaveChangesAsync();
            _myOccurrences.Add(occurrence);
            _success = $"Livshändelse '{lifeEvent.Namn}' registrerad. Du kan nu göra förmånsändringar.";
            _selectedEventId = null; _selectedDatum = null;
        }
        catch (Exception ex) { _error = $"Kunde inte registrera: {ex.Message}"; }
        finally { _saving = false; }
    }

    private string GetEventName(Guid id) => _lifeEvents.FirstOrDefault(e => e.Id == id)?.Namn ?? "Okänd";
}

