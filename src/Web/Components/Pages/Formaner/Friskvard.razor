@page "/formaner/friskvard"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Wellness.Domain
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<RegionHRDbContext> DbFactory
@inject RegionHR.Web.Services.AuthService Auth

<PageTitle>OpenHR - Friskvårdsbidrag</PageTitle>
<OhrBreadcrumb CurrentPage="Friskvårdsbidrag" />
<MudAlert Severity="Severity.Info" Variant="Variant.Text" Class="mb-4" Dense="true">
    <OhrTerm Term="Friskvårdsbidrag" />: max 5 000 kr per år för träning, gym, simning, massage och andra hälsoaktiviteter.
</MudAlert>
<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4" Style="font-weight: 700;">Friskvårdsbidrag</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" StartIcon="@Icons.Material.Filled.Add" Style="min-height: 48px;" OnClick="@(() => _showForm = true)">Ny ansökan</MudButton>
</div>

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
}
else
{
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="4"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Primary" Style="font-weight: 700;">@_claims.Count</MudText><MudText Typo="Typo.body2">Ansökningar totalt</MudText></MudPaper></MudItem>
        <MudItem xs="4"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Success" Style="font-weight: 700;">@_claims.Count(c => c.Claim.Status == WellnessClaimStatus.Godkand)</MudText><MudText Typo="Typo.body2">Godkända</MudText></MudPaper></MudItem>
        <MudItem xs="4"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Warning" Style="font-weight: 700;">@_claims.Count(c => c.Claim.Status == WellnessClaimStatus.Inskickad)</MudText><MudText Typo="Typo.body2">Väntar godkännande</MudText></MudPaper></MudItem>
    </MudGrid>

    <MudAlert Severity="Severity.Info" Variant="Variant.Text" Class="mb-4" Dense="true">
        Friskvårdsbidrag: max 5 000 kr per kalenderår. Gäller aktiviteter som motion, massage, simning m.m.
    </MudAlert>

    @if (_showForm && Auth.EmployeeId.HasValue)
    {
        <MudPaper Class="pa-5 mb-4" Elevation="3" Style="border-left: 4px solid var(--mud-palette-primary);">
            <div class="d-flex justify-space-between align-center mb-3">
                <MudText Typo="Typo.h6" Style="font-weight: 600;">Ny friskvårdsansökan</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="@(() => _showForm = false)" />
            </div>
            <MudGrid Spacing="3">
                <MudItem xs="12" sm="4"><MudTextField @bind-Value="_formAktivitet" Label="Aktivitet" Variant="Variant.Outlined" Required="true" /></MudItem>
                <MudItem xs="12" sm="4"><MudNumericField T="decimal" @bind-Value="_formBelopp" Label="Belopp (kr)" Variant="Variant.Outlined" /></MudItem>
                <MudItem xs="12" sm="4"><MudDatePicker @bind-Date="_formDatum" Label="Datum" Variant="Variant.Outlined" /></MudItem>
            </MudGrid>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-3" OnClick="SkapaAnsokan"
                       Disabled="@(string.IsNullOrWhiteSpace(_formAktivitet) || _formBelopp <= 0 || _formDatum == null || _saving)">Skicka in</MudButton>
        </MudPaper>
    }
    else if (_showForm)
    {
        <MudAlert Severity="Severity.Warning" Class="mb-4">Ansökan kräver kopplad anställd.</MudAlert>
    }

    @if (_success != null)
    {
        <MudAlert Severity="Severity.Success" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="@(() => _success = null)">@_success</MudAlert>
    }

    @if (_claims.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Text">Inga friskvårdsansökningar registrerade.</MudAlert>
    }
    else
    {
        <MudSimpleTable Hover="true" Elevation="2">
            <thead><tr><th>Anställd</th><th>Aktivitet</th><th>Belopp</th><th>Datum</th><th>Status</th><th></th></tr></thead>
            <tbody>
                @foreach (var c in _claims)
                {
                    <tr>
                        <td><strong>@c.Namn</strong></td>
                        <td>@c.Claim.Aktivitet</td>
                        <td>@c.Claim.Belopp.ToString("N0") kr</td>
                        <td>@c.Claim.Datum.ToString("yyyy-MM-dd")</td>
                        <td><MudChip T="string" Size="Size.Small" Color="@StatusFarg(c.Claim.Status)">@StatusText(c.Claim.Status)</MudChip></td>
                        <td>
                            @if (c.Claim.Status == WellnessClaimStatus.Inskickad && Auth.EmployeeId.HasValue)
                            {
                                <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Success" OnClick="@(() => GodkannClaim(c))">Godkänn</MudButton>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    }
}

@code {
    private List<ClaimVm> _claims = [];
    private bool _loading = true, _saving, _showForm;
    private string? _error, _success;
    private string _formAktivitet = "";
    private decimal _formBelopp = 0;
    private DateTime? _formDatum;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        try
        {
            var claims = await db.WellnessClaims.OrderByDescending(c => c.SkapadVid).ToListAsync();
            var empGuids = claims.Select(c => c.AnstallId).Distinct().ToList();
            var empIds = empGuids.Select(g => new EmployeeId(g)).ToList();
            var employees = await db.Employees.Where(e => empIds.Contains(e.Id)).ToListAsync();
            var names = employees.ToDictionary(e => e.Id.Value, e => $"{e.Fornamn} {e.Efternamn}");
            _claims = claims.Select(c => new ClaimVm(names.GetValueOrDefault(c.AnstallId, "Okänd"), c)).ToList();
        }
        catch (Exception ex) { _error = $"Kunde inte hämta data: {ex.Message}"; }
        finally { _loading = false; }
    }

    private async Task SkapaAnsokan()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        if (!Auth.EmployeeId.HasValue) { _error = "Kräver kopplad anställd."; return; }
        _saving = true; _error = null;
        try
        {
            var claim = WellnessClaim.Skapa(Auth.EmployeeId.Value, _formAktivitet, _formBelopp, DateOnly.FromDateTime(_formDatum!.Value));
            db.WellnessClaims.Add(claim);
            await db.SaveChangesAsync();
            _claims.Insert(0, new ClaimVm(Auth.UserName ?? "Jag", claim));
            _showForm = false; _success = "Friskvårdsansökan inskickad."; _formAktivitet = ""; _formBelopp = 0;
        }
        catch (Exception ex) { _error = $"Kunde inte skapa: {ex.Message}"; }
        finally { _saving = false; }
    }

    private async Task GodkannClaim(ClaimVm vm)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        if (!Auth.EmployeeId.HasValue) { _error = "Kräver kopplad anställd."; return; }
        try { vm.Claim.Godkann(Auth.EmployeeId.Value); await db.SaveChangesAsync(); _success = "Ansökan godkänd."; }
        catch (Exception ex) { _error = $"Fel: {ex.Message}"; }
    }

    private static string StatusText(WellnessClaimStatus s) => s switch { WellnessClaimStatus.Inskickad => "Inskickad", WellnessClaimStatus.Godkand => "Godkänd", WellnessClaimStatus.Avslagen => "Avslagen", _ => s.ToString() };
    private static Color StatusFarg(WellnessClaimStatus s) => s switch { WellnessClaimStatus.Inskickad => Color.Warning, WellnessClaimStatus.Godkand => Color.Success, WellnessClaimStatus.Avslagen => Color.Error, _ => Color.Default };
    private record ClaimVm(string Namn, WellnessClaim Claim);
}

