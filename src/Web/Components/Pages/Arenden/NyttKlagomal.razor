@page "/arenden/klagomal/ny"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.CaseManagement.Domain
@using RegionHR.SharedKernel.Domain
@using Microsoft.EntityFrameworkCore
@inject RegionHRDbContext Db
@inject RegionHR.Web.Services.AuthService Auth
@inject NavigationManager Nav

<PageTitle>OpenHR - Nytt klagomål</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">Nytt klagomål</MudText>

@if (_submitted)
{
    <MudAlert Severity="Severity.Success" Class="mb-4">
        Klagomål inlämnat! Ärendenummer: @_createdId?.ToString("N")[..8].ToUpper()
    </MudAlert>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/arenden/klagomal">Tillbaka till klagomål</MudButton>
}
else
{
    @if (_error != null)
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
    }

    <MudPaper Class="pa-4" Elevation="2">
        <MudGrid Spacing="3">
            <MudItem xs="12" md="6">
                <MudSelect T="GrievanceType" @bind-Value="_typ" Label="Typ av klagomål" Variant="Variant.Outlined" Required="true">
                    <MudSelectItem T="GrievanceType" Value="GrievanceType.FormalltKlagomal">Formellt klagomål</MudSelectItem>
                    <MudSelectItem T="GrievanceType" Value="GrievanceType.Diskriminering">Diskriminering</MudSelectItem>
                    <MudSelectItem T="GrievanceType" Value="GrievanceType.Trakasseri">Trakasseri</MudSelectItem>
                    <MudSelectItem T="GrievanceType" Value="GrievanceType.Arbetsmiljo">Arbetsmiljö</MudSelectItem>
                    <MudSelectItem T="GrievanceType" Value="GrievanceType.Avtalsbrott">Avtalsbrott</MudSelectItem>
                </MudSelect>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="_facklig" Label="Facklig representant (valfritt)" Variant="Variant.Outlined" />
            </MudItem>

            <MudItem xs="12">
                <MudTextField @bind-Value="_beskrivning" Label="Beskrivning" Variant="Variant.Outlined" Lines="5" Required="true"
                    HelperText="Beskriv klagomålet så detaljerat som möjligt. Inkludera datum, plats och inblandade personer." />
            </MudItem>

            <MudItem xs="12" Class="d-flex justify-end gap-2">
                <MudButton Variant="Variant.Outlined" Color="Color.Default" Href="/arenden/klagomal">Avbryt</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit" Disabled="@_submitting" Size="Size.Large">
                    @if (_submitting) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                    Lämna in klagomål
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>
}

@code {
    private GrievanceType _typ = GrievanceType.FormalltKlagomal;
    private string _beskrivning = string.Empty;
    private string? _facklig;
    private bool _submitted;
    private bool _submitting;
    private Guid? _createdId;
    private string? _error;

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(_beskrivning))
        {
            _error = "Beskrivning krävs."; return;
        }

        if (!Auth.EmployeeId.HasValue)
        {
            _error = "Du måste vara kopplad till en anställd."; return;
        }

        _submitting = true;
        _error = null;

        try
        {
            var grievance = Grievance.Skapa(
                EmployeeId.From(Auth.EmployeeId.Value),
                _typ,
                _beskrivning,
                string.IsNullOrWhiteSpace(_facklig) ? null : _facklig);

            await Db.Grievances.AddAsync(grievance);
            await Db.SaveChangesAsync();

            _createdId = grievance.Id.Value;
            _submitted = true;
        }
        catch (Exception ex) { _error = $"Fel vid inlämning: {ex.Message}"; }
        finally { _submitting = false; }
    }
}
