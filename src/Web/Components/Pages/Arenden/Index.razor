@page "/arenden"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.CaseManagement.Domain
@using RegionHR.SharedKernel.Domain
@using Microsoft.EntityFrameworkCore
@using Microsoft.Extensions.Localization
@inject IDbContextFactory<RegionHRDbContext> DbFactory
@inject IStringLocalizer<SharedResources> L

<PageTitle>OpenHR - @L["Cases"]</PageTitle>
<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4" Style="font-weight: 700;">@L["Cases"]</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" StartIcon="@Icons.Material.Filled.Add" Href="/arenden/nytt" Style="min-height: 48px;">@L["NewCase"]</MudButton>
</div>

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
}
else
{
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="4"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Warning" Style="font-weight: 700;">@_vantar</MudText><MudText Typo="Typo.body2">@L["AwaitingApproval"]</MudText></MudPaper></MudItem>
        <MudItem xs="4"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Info" Style="font-weight: 700;">@_underBehandling</MudText><MudText Typo="Typo.body2">@L["UnderReview"]</MudText></MudPaper></MudItem>
        <MudItem xs="4"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Success" Style="font-weight: 700;">@_avslutadeYtd</MudText><MudText Typo="Typo.body2">@L["CompletedYTD"]</MudText></MudPaper></MudItem>
    </MudGrid>

    @if (_rader.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Text">@L["NoCases"]</MudAlert>
    }
    else
    {
        <MudSimpleTable Hover="true" Elevation="2">
            <thead><tr><th>@L["Type"]</th><th>@L["Employee"]</th><th>@L["Description"]</th><th>@L["Status"]</th><th>@L["Created"]</th></tr></thead>
            <tbody>
                @foreach (var r in _rader)
                {
                    <tr>
                        <td><MudChip T="string" Size="Size.Small">@r.Typ</MudChip></td>
                        <td><strong>@r.Anstalld</strong></td>
                        <td>@r.Beskrivning</td>
                        <td><MudChip T="string" Size="Size.Small" Color="@r.StatusFarg">@r.StatusText</MudChip></td>
                        <td>@r.Skapad</td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    }
}

@code {
    private List<ArendeRad> _rader = [];
    private int _vantar, _underBehandling, _avslutadeYtd;
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        try
        {
            var cases = await db.Cases
                .OrderByDescending(c => c.CreatedAt)
                .Take(50)
                .ToListAsync();

            var anstallIds = cases.Select(c => c.AnstallId).Distinct().ToList();
            var employees = await db.Employees
                .Where(e => anstallIds.Contains(e.Id))
                .ToListAsync();
            var names = employees.ToDictionary(e => e.Id, e => $"{e.Fornamn} {e.Efternamn}");

            _rader = cases.Select(c => new ArendeRad(
                MapTyp(c.Typ),
                names.TryGetValue(c.AnstallId, out var n) ? n : L["Unknown"].Value,
                c.Beskrivning,
                MapStatus(c.Status),
                MapStatusColor(c.Status),
                c.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")
            )).ToList();

            var idag = DateTime.UtcNow;
            _vantar = cases.Count(c => c.Status == CaseStatus.VantarGodkannande);
            _underBehandling = cases.Count(c => c.Status == CaseStatus.UnderBehandling);
            _avslutadeYtd = cases.Count(c => c.Status == CaseStatus.Avslutad && c.CreatedAt.Year == idag.Year);
        }
        catch (Exception ex) { _error = $"{L["ErrorLoadingCases"]}: {ex.Message}"; }
        finally { _loading = false; }
    }

    private string MapTyp(CaseType t) => t switch
    {
        CaseType.Franvaro => L["CaseTypeAbsence"],
        CaseType.Anstallningsandring => L["CaseTypeEmploymentChange"],
        CaseType.Lonandring => L["CaseTypeSalaryChange"],
        CaseType.Omplacering => L["CaseTypeRelocation"],
        CaseType.Rehabilitering => L["CaseTypeRehabilitation"],
        CaseType.LAS => L["CaseTypeLAS"],
        _ => t.ToString()
    };

    private string MapStatus(CaseStatus s) => s switch
    {
        CaseStatus.Oppnad => L["Opened"],
        CaseStatus.UnderBehandling => L["UnderReview"],
        CaseStatus.VantarGodkannande => L["AwaitingApproval"],
        CaseStatus.Godkand => L["Approved"],
        CaseStatus.Avslutad => L["Completed"],
        _ => s.ToString()
    };

    private static Color MapStatusColor(CaseStatus s) => s switch
    {
        CaseStatus.VantarGodkannande => Color.Warning,
        CaseStatus.UnderBehandling => Color.Info,
        CaseStatus.Godkand => Color.Success,
        CaseStatus.Avslutad => Color.Success,
        _ => Color.Default
    };

    private record ArendeRad(string Typ, string Anstalld, string Beskrivning, string StatusText, Color StatusFarg, string Skapad);
}

