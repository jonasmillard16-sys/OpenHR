@page "/arenden/mbl"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.CaseManagement.Domain
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<RegionHRDbContext> DbFactory

<PageTitle>OpenHR - MBL-förhandlingar</PageTitle>
<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4" Style="font-weight: 700;">MBL-förhandlingar</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" StartIcon="@Icons.Material.Filled.Add" Style="min-height: 48px;" OnClick="@(() => _showForm = true)">Ny förhandling</MudButton>
</div>

@if (_loading) { <MudProgressCircular Color="Color.Primary" Indeterminate="true" /> }
else if (_error != null) { <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert> }
else
{
    @if (_showForm)
    {
        <MudPaper Class="pa-5 mb-4" Elevation="3" Style="border-left: 4px solid var(--mud-palette-primary);">
            <div class="d-flex justify-space-between align-center mb-3">
                <MudText Typo="Typo.h6" Style="font-weight: 600;">Ny MBL-förhandling</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="@(() => _showForm = false)" />
            </div>
            <MudGrid Spacing="3">
                <MudItem xs="12" sm="6"><MudTextField @bind-Value="_formArende" Label="Ärende" Variant="Variant.Outlined" Required="true" /></MudItem>
                <MudItem xs="12" sm="3">
                    <MudSelect T="MBLType" @bind-Value="_formTyp" Label="Typ" Variant="Variant.Outlined">
                        <MudSelectItem Value="MBLType.Information">Information (§19)</MudSelectItem>
                        <MudSelectItem Value="MBLType.Forhandling">Förhandling (§11-14)</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="3"><MudDatePicker @bind-Date="_formDatum" Label="Datum" Variant="Variant.Outlined" /></MudItem>
            </MudGrid>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-3" OnClick="SkapaMBL"
                       Disabled="@(string.IsNullOrWhiteSpace(_formArende) || _formDatum == null || _saving)">Skapa</MudButton>
        </MudPaper>
    }

    @if (_success != null) { <MudAlert Severity="Severity.Success" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="@(() => _success = null)">@_success</MudAlert> }

    @if (_forhandlingar.Count == 0) { <MudAlert Severity="Severity.Info" Variant="Variant.Text">Inga MBL-förhandlingar registrerade.</MudAlert> }
    else
    {
        <MudSimpleTable Hover="true" Elevation="2">
            <thead><tr><th>Ärende</th><th>Typ</th><th>Datum</th><th>Status</th><th>Fackombud</th><th>AG-ombud</th></tr></thead>
            <tbody>
                @foreach (var m in _forhandlingar)
                {
                    <tr>
                        <td><strong>@m.Arende</strong></td>
                        <td><MudChip T="string" Size="Size.Small">@(m.Typ == MBLType.Information ? "§19 Info" : "§11-14 Förh.")</MudChip></td>
                        <td>@m.Datum.ToString("yyyy-MM-dd")</td>
                        <td><MudChip T="string" Size="Size.Small" Color="@StatusFarg(m.Status)">@StatusText(m.Status)</MudChip></td>
                        <td>@(m.Fackombud ?? "—")</td>
                        <td>@(m.Arbetsgivarombud ?? "—")</td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    }
}

@code {
    private List<MBLNegotiation> _forhandlingar = [];
    private bool _loading = true, _saving, _showForm;
    private string? _error, _success, _formArende = "";
    private MBLType _formTyp = MBLType.Information;
    private DateTime? _formDatum;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        try { _forhandlingar = await db.MBLNegotiations.OrderByDescending(m => m.Datum).ToListAsync(); }
        catch (Exception ex) { _error = $"Kunde inte hämta MBL-data: {ex.Message}"; }
        finally { _loading = false; }
    }

    private async Task SkapaMBL()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        if (string.IsNullOrWhiteSpace(_formArende) || _formDatum == null) return;
        _saving = true; _error = null;
        try
        {
            var mbl = MBLNegotiation.Skapa(_formArende!, _formTyp, DateOnly.FromDateTime(_formDatum.Value));
            db.MBLNegotiations.Add(mbl);
            await db.SaveChangesAsync();
            _forhandlingar.Insert(0, mbl);
            _showForm = false; _success = "MBL-förhandling skapad."; _formArende = "";
        }
        catch (Exception ex) { _error = $"Kunde inte skapa: {ex.Message}"; }
        finally { _saving = false; }
    }

    private static string StatusText(MBLStatus s) => s switch { MBLStatus.Kallad => "Kallad", MBLStatus.Pagaende => "Pågående", MBLStatus.Avslutad => "Avslutad", MBLStatus.Protokollfrd => "Protokollförd", _ => s.ToString() };
    private static Color StatusFarg(MBLStatus s) => s switch { MBLStatus.Kallad => Color.Warning, MBLStatus.Pagaende => Color.Info, MBLStatus.Avslutad => Color.Success, MBLStatus.Protokollfrd => Color.Success, _ => Color.Default };
}

