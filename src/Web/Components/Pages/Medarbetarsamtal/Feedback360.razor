@page "/medarbetarsamtal/360"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Performance.Domain
@using Microsoft.EntityFrameworkCore
@inject RegionHRDbContext Db
@inject RegionHR.Web.Services.AuthService Auth

<PageTitle>OpenHR - 360-feedback</PageTitle>
<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4" Style="font-weight: 700;">360-feedback</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" StartIcon="@Icons.Material.Filled.Add" Style="min-height: 48px;" OnClick="@(() => _showCreate = true)">Ny feedbackrunda</MudButton>
</div>

@if (_loading) { <MudProgressCircular Color="Color.Primary" Indeterminate="true" /> }
else if (_error != null) { <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert> }
else
{
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="3"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Primary" Style="font-weight: 700;">@_rounds.Count</MudText><MudText Typo="Typo.body2">Rundor totalt</MudText></MudPaper></MudItem>
        <MudItem xs="3"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Success" Style="font-weight: 700;">@_rounds.Count(r => r.Round.Status == FeedbackRoundStatus.Stangd)</MudText><MudText Typo="Typo.body2">Avslutade</MudText></MudPaper></MudItem>
        <MudItem xs="3"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Warning" Style="font-weight: 700;">@_rounds.Count(r => r.Round.Status == FeedbackRoundStatus.Oppnad)</MudText><MudText Typo="Typo.body2">Pågående</MudText></MudPaper></MudItem>
        <MudItem xs="3"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Style="font-weight: 700;">@_totalResponses</MudText><MudText Typo="Typo.body2">Svar totalt</MudText></MudPaper></MudItem>
    </MudGrid>

    @if (_showCreate)
    {
        <MudPaper Class="pa-5 mb-4" Elevation="3" Style="border-left: 4px solid var(--mud-palette-primary);">
            <div class="d-flex justify-space-between align-center mb-3">
                <MudText Typo="Typo.h6" Style="font-weight: 600;">Ny feedbackrunda</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="@(() => _showCreate = false)" />
            </div>
            <MudGrid Spacing="3">
                <MudItem xs="12" sm="6">
                    <MudSelect T="Guid?" @bind-Value="_formAnstallId" Label="Anställd" Variant="Variant.Outlined" Required="true">
                        @foreach (var e in _employees) { <MudSelectItem T="Guid?" Value="@((Guid?)e.Id.Value)">@e.Fornamn @e.Efternamn</MudSelectItem> }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6"><MudTextField @bind-Value="_formTitel" Label="Titel" Variant="Variant.Outlined" Required="true" /></MudItem>
            </MudGrid>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-3" OnClick="SkapaRunda"
                       Disabled="@(_formAnstallId == null || string.IsNullOrWhiteSpace(_formTitel) || _saving)">Skapa</MudButton>
        </MudPaper>
    }

    @if (_success != null) { <MudAlert Severity="Severity.Success" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="@(() => _success = null)">@_success</MudAlert> }

    @if (_rounds.Count == 0) { <MudAlert Severity="Severity.Info" Variant="Variant.Text">Inga feedbackrundor registrerade.</MudAlert> }
    else
    {
        <MudSimpleTable Hover="true" Elevation="2">
            <thead><tr><th>Anställd</th><th>Titel</th><th>Status</th><th>Svar</th><th>Snittbetyg</th><th></th></tr></thead>
            <tbody>
                @foreach (var r in _rounds)
                {
                    <tr>
                        <td><strong>@r.AnstallNamn</strong></td>
                        <td>@r.Round.Titel</td>
                        <td><MudChip T="string" Size="Size.Small" Color="@StatusFarg(r.Round.Status)">@StatusText(r.Round.Status)</MudChip></td>
                        <td>@r.AntalSvar</td>
                        <td>@(r.AntalSvar > 0 ? $"{r.SnittBetyg:F1} / 5" : "—")</td>
                        <td>
                            @if (r.Round.Status == FeedbackRoundStatus.Utkast) { <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => OppnaRunda(r.Round))">Öppna</MudButton> }
                            else if (r.Round.Status == FeedbackRoundStatus.Oppnad) { <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning" OnClick="@(() => StangRunda(r.Round))">Stäng</MudButton> }
                        </td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    }
}

@code {
    private List<RoundVm> _rounds = [];
    private List<RegionHR.Core.Domain.Employee> _employees = [];
    private int _totalResponses;
    private bool _loading = true, _saving, _showCreate;
    private string? _error, _success, _formTitel = "";
    private Guid? _formAnstallId;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var rounds = await Db.FeedbackRounds.OrderByDescending(r => r.SkapadVid).ToListAsync();
            var responses = await Db.FeedbackResponses.ToListAsync();
            _employees = await Db.Employees.OrderBy(e => e.Efternamn).ToListAsync();
            var names = _employees.ToDictionary(e => e.Id.Value, e => $"{e.Fornamn} {e.Efternamn}");
            var respByRound = responses.GroupBy(r => r.RoundId).ToDictionary(g => g.Key, g => g.ToList());

            _rounds = rounds.Select(r =>
            {
                var resps = respByRound.GetValueOrDefault(r.Id, []);
                return new RoundVm(names.GetValueOrDefault(r.AnstallId, "Okänd"), r, resps.Count,
                    resps.Count > 0 ? resps.Average(x => x.Betyg) : 0);
            }).ToList();
            _totalResponses = responses.Count;
        }
        catch (Exception ex) { _error = $"Kunde inte hämta data: {ex.Message}"; }
        finally { _loading = false; }
    }

    private async Task SkapaRunda()
    {
        if (_formAnstallId == null || string.IsNullOrWhiteSpace(_formTitel)) return;
        _saving = true; _error = null;
        try
        {
            var round = FeedbackRound.Skapa(_formAnstallId.Value, _formTitel!);
            Db.FeedbackRounds.Add(round);
            await Db.SaveChangesAsync();
            var names = _employees.ToDictionary(e => e.Id.Value, e => $"{e.Fornamn} {e.Efternamn}");
            _rounds.Insert(0, new RoundVm(names.GetValueOrDefault(_formAnstallId.Value, "Okänd"), round, 0, 0));
            _showCreate = false; _success = "Feedbackrunda skapad."; _formTitel = "";
        }
        catch (Exception ex) { _error = $"Kunde inte skapa: {ex.Message}"; }
        finally { _saving = false; }
    }

    private async Task OppnaRunda(FeedbackRound r) { try { r.Oppna(); await Db.SaveChangesAsync(); } catch (Exception ex) { _error = $"Fel: {ex.Message}"; } }
    private async Task StangRunda(FeedbackRound r) { try { r.Stang(); await Db.SaveChangesAsync(); } catch (Exception ex) { _error = $"Fel: {ex.Message}"; } }

    private static string StatusText(FeedbackRoundStatus s) => s switch { FeedbackRoundStatus.Utkast => "Utkast", FeedbackRoundStatus.Oppnad => "Öppen", FeedbackRoundStatus.Stangd => "Stängd", _ => s.ToString() };
    private static Color StatusFarg(FeedbackRoundStatus s) => s switch { FeedbackRoundStatus.Oppnad => Color.Success, FeedbackRoundStatus.Stangd => Color.Info, _ => Color.Default };

    private record RoundVm(string AnstallNamn, FeedbackRound Round, int AntalSvar, double SnittBetyg);
}
