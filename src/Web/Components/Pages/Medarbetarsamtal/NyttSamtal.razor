@page "/medarbetarsamtal/ny"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Performance.Domain
@using RegionHR.Infrastructure.Persistence
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<RegionHRDbContext> DbFactory
@inject NavigationManager Nav

<PageTitle>OpenHR — Nytt medarbetarsamtal</PageTitle>

<MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Variant="Variant.Text"
           Color="Color.Primary" Href="/medarbetarsamtal" Style="margin-bottom: 1rem;">Tillbaka</MudButton>

<MudText Typo="Typo.h4" Class="mb-2" Style="font-weight: 700;">Nytt medarbetarsamtal</MudText>
<MudText Typo="Typo.body2" Class="mb-4" Style="color: var(--mud-palette-text-secondary);">
    Skapar ett nytt medarbetarsamtal via PerformanceReview.Skapa() och sparar i databasen.
</MudText>

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
}
else if (_created != null)
{
    <MudPaper Class="pa-5" Elevation="2" Style="border-left: 4px solid var(--mud-palette-success);">
        <MudText Typo="Typo.h6" Color="Color.Success" Style="font-weight: 700;" Class="mb-3">Medarbetarsamtal skapat</MudText>
        <MudSimpleTable Dense="true" Elevation="0" Class="mb-3">
            <tbody>
                <tr><td><strong>Anställd</strong></td><td>@GetName(_created.AnstallId)</td></tr>
                <tr><td><strong>Chef</strong></td><td>@GetName(_created.ChefId)</td></tr>
                <tr><td><strong>År</strong></td><td>@_created.Ar</td></tr>
                <tr><td><strong>Status</strong></td><td><MudChip T="string" Size="Size.Small" Color="Color.Info">@_created.Status</MudChip></td></tr>
            </tbody>
        </MudSimpleTable>
        <div class="d-flex gap-2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/medarbetarsamtal">Tillbaka till översikt</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="Reset">Skapa ytterligare</MudButton>
        </div>
    </MudPaper>
}
else
{
    <MudPaper Class="pa-5" Elevation="2">
        <MudGrid Spacing="3">
            <MudItem xs="12" sm="4">
                <MudSelect T="Guid?" @bind-Value="_anstallId" Label="Anställd" Variant="Variant.Outlined" Required="true">
                    @foreach (var e in _employees)
                    {
                        <MudSelectItem T="Guid?" Value="@((Guid?)e.Id.Value)">@e.Fornamn @e.Efternamn</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudSelect T="Guid?" @bind-Value="_chefId" Label="Chef / Bedömare" Variant="Variant.Outlined" Required="true">
                    @foreach (var e in _employees)
                    {
                        <MudSelectItem T="Guid?" Value="@((Guid?)e.Id.Value)">@e.Fornamn @e.Efternamn</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudNumericField T="int" @bind-Value="_ar" Label="År" Variant="Variant.Outlined" />
            </MudItem>
        </MudGrid>

        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Class="mt-4"
                   Style="min-height: 48px;" OnClick="Skapa"
                   Disabled="@(_anstallId == null || _chefId == null || _saving)">
            @if (_saving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Skapa medarbetarsamtal
        </MudButton>
    </MudPaper>
}

@code {
    private List<RegionHR.Core.Domain.Employee> _employees = [];
    private PerformanceReview? _created;
    private Guid? _anstallId, _chefId;
    private int _ar = DateTime.Today.Year;
    private bool _loading = true, _saving;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        try
        {
            _employees = await db.Employees.OrderBy(e => e.Efternamn).ToListAsync();
        }
        catch (Exception ex) { _error = $"Kunde inte hämta data: {ex.Message}"; }
        finally { _loading = false; }
    }

    private async Task Skapa()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        if (_anstallId == null || _chefId == null) return;
        _saving = true;
        _error = null;
        StateHasChanged();

        try
        {
            var review = PerformanceReview.Skapa(_anstallId.Value, _chefId.Value, _ar);
            db.PerformanceReviews.Add(review);
            await db.SaveChangesAsync();
            _created = review;
        }
        catch (Exception ex) { _error = $"Kunde inte skapa samtal: {ex.Message}"; }
        finally { _saving = false; }
    }

    private void Reset()
    {
        _created = null;
        _anstallId = null;
        _chefId = null;
        _ar = DateTime.Today.Year;
    }

    private string GetName(Guid id)
    {
        var emp = _employees.FirstOrDefault(e => e.Id.Value == id);
        return emp != null ? $"{emp.Fornamn} {emp.Efternamn}" : "Okänd";
    }
}

