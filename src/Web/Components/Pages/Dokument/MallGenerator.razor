@page "/dokument/mall/generera"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Web.Components.Shared
@using RegionHR.Infrastructure.Documents
@inject DocumentTemplateEngine TemplateEngine
@inject IJSRuntime JS

<PageTitle>OpenHR - Generera dokument</PageTitle>
<OhrBreadcrumb CurrentPage="Generera dokument" />
<MudText Typo="Typo.body1" Class="mb-4" Style="color: var(--mud-palette-text-secondary);">Välj en mall, fyll i uppgifterna, och ladda ned dokumentet som PDF.</MudText>
<MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Variant="Variant.Text" Color="Color.Primary" Href="/dokument/mallar" Style="margin-bottom: 1rem;">Tillbaka</MudButton>

<OhrConversationFlow Steps="@_steps" CurrentStep="@_step" OnBack="@(() => { if (_step > 0) _step--; })">
    @switch (_step)
    {
        case 0:
            <MudText Typo="Typo.h5" Class="mb-4" Style="font-weight: 600;">Vilken typ av dokument?</MudText>
            <MudStack Spacing="3">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Large" FullWidth="true" Style="min-height: 56px;" OnClick="@(() => ValjMall("anstallningsavtal", "Anställningsavtal"))">Anställningsavtal</MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Large" FullWidth="true" Style="min-height: 56px;" OnClick="@(() => ValjMall("tjanstgoringsbevis", "Tjänstgöringsintyg"))">Tjänstgöringsintyg</MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Large" FullWidth="true" Style="min-height: 56px;" OnClick="@(() => ValjMall("loneandring", "Bekräftelse löneändring"))">Bekräftelse löneändring</MudButton>
            </MudStack>
            break;

        case 1:
            <MudText Typo="Typo.h5" Class="mb-4" Style="font-weight: 600;">Fyll i uppgifter — @_mallNamn</MudText>
            <MudText Typo="Typo.body2" Class="mb-3" Style="color: var(--mud-palette-text-secondary);">Systemet har fyllt i det vi kan automatiskt. Komplettera resten.</MudText>
            @foreach (var field in _fields)
            {
                <MudTextField @bind-Value="_fieldValues[field]" Label="@field" Variant="Variant.Outlined" Class="mb-2" />
            }
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" FullWidth="true" Style="min-height: 56px;" Class="mt-3" OnClick="Generera">Förhandsgranska</MudButton>
            break;

        case 2:
            <MudText Typo="Typo.h5" Class="mb-4" Style="font-weight: 600;">Förhandsgranskning — @_mallNamn</MudText>
            <MudPaper Class="pa-6" Elevation="1" Style="white-space: pre-wrap; font-family: 'Courier New', monospace; font-size: 0.85rem; background: #fdfdfd; border: 1px solid #d0d0d0; line-height: 1.7; border-radius: 8px;">
                @_pdfPreview
            </MudPaper>
            <MudAlert Severity="Severity.Info" Variant="Variant.Text" Class="mt-2" Dense="true">
                PDF-generering kräver QuestPDF-paketet. Installera med: dotnet add package QuestPDF
            </MudAlert>
            <div class="d-flex gap-3 mt-4">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" StartIcon="@Icons.Material.Filled.Download" Style="min-height: 48px;" OnClick="LaddaNer">Ladda ner</MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Large" StartIcon="@Icons.Material.Filled.Print" Style="min-height: 48px;" OnClick="SkrivUt">Skriv ut</MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Large" Style="min-height: 48px;" OnClick="@(() => _step = 1)">Redigera</MudButton>
            </div>
            break;
    }
</OhrConversationFlow>

@code {
    private readonly List<string> _steps = ["Malltyp", "Uppgifter", "Förhandsgranskning"];
    private int _step;
    private string _mallId = "", _mallNamn = "";
    private List<string> _fields = [];
    private Dictionary<string, string> _fieldValues = new();
    private string _preview = "";
    private string _pdfPreview = "";

    private void ValjMall(string id, string namn)
    {
        _mallId = id;
        _mallNamn = namn;
        _fields = TemplateEngine.GetFieldNames(id);
        _fieldValues = _fields.ToDictionary(f => f, f => GetDefaultValue(f));
        _step = 1;
    }

    private string GetDefaultValue(string field) => field switch
    {
        "Arbetsgivare" => "Västra Götalandsregionen",
        "OrgNummer" => "232100-0131",
        "Datum" => DateTime.Today.ToString("yyyy-MM-dd"),
        "Kollektivavtal" => "AB",
        _ => ""
    };

    private void Generera()
    {
        _preview = TemplateEngine.Generate(_mallId, _fieldValues);

        // Generate PDF preview using PdfGenerator
        var pdfGen = new RegionHR.Infrastructure.Export.PdfGenerator();
        byte[] pdfBytes;
        if (_mallId == "tjanstgoringsbevis")
        {
            pdfBytes = pdfGen.GenerateTjanstgoringsintyg(new RegionHR.Infrastructure.Export.TjanstgoringsintyData(
                _fieldValues.GetValueOrDefault("Namn", "—"),
                _fieldValues.GetValueOrDefault("Personnummer", "—"),
                _fieldValues.GetValueOrDefault("Arbetsgivare", "Västra Götalandsregionen"),
                _fieldValues.GetValueOrDefault("Startdatum", "—"),
                _fieldValues.GetValueOrDefault("Slutdatum", "—"),
                _fieldValues.GetValueOrDefault("Befattning", "—"),
                _fieldValues.GetValueOrDefault("Anställningsform", "Tillsvidare"),
                _fieldValues.GetValueOrDefault("Sysselsättningsgrad", "100%")
            ));
        }
        else if (_mallId == "anstallningsavtal")
        {
            _ = int.TryParse(_fieldValues.GetValueOrDefault("Sysselsättningsgrad", "100").Replace("%", ""), out var grad);
            _ = decimal.TryParse(_fieldValues.GetValueOrDefault("Månadslön", "0").Replace(" ", ""), out var lon);
            pdfBytes = pdfGen.GenerateAnstallningsavtal(new RegionHR.Infrastructure.Export.AnstallningsavtalData(
                _fieldValues.GetValueOrDefault("Namn", "—"),
                _fieldValues.GetValueOrDefault("Personnummer", "—"),
                _fieldValues.GetValueOrDefault("Arbetsgivare", "Västra Götalandsregionen"),
                _fieldValues.GetValueOrDefault("Befattning", "—"),
                _fieldValues.GetValueOrDefault("Tillträdesdatum", DateTime.Today.ToString("yyyy-MM-dd")),
                _fieldValues.GetValueOrDefault("Anställningsform", "Tillsvidare"),
                grad == 0 ? 100 : grad,
                lon,
                _fieldValues.GetValueOrDefault("Kollektivavtal", "AB")
            ));
        }
        else
        {
            pdfBytes = System.Text.Encoding.UTF8.GetBytes(_preview);
        }
        _pdfPreview = System.Text.Encoding.UTF8.GetString(pdfBytes);
        _step = 2;
    }

    private async Task SkrivUt()
    {
        await JS.InvokeVoidAsync("window.print");
    }

    private async Task LaddaNer()
    {
        var bytes = System.Text.Encoding.UTF8.GetBytes(_pdfPreview);
        var base64 = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("downloadFile", $"{_mallNamn}.txt", base64, "text/plain");
    }
}
