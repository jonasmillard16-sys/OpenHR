@page "/dokument/policyer"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.PolicyManagement.Domain
@using Microsoft.EntityFrameworkCore
@inject RegionHRDbContext Db

<PageTitle>OpenHR - Policyer</PageTitle>
<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4" Style="font-weight: 700;">Policyer</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" StartIcon="@Icons.Material.Filled.Add" Style="min-height: 48px;" OnClick="@(() => _showCreate = true)">Ny policy</MudButton>
</div>

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
}
else
{
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="3"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Primary" Style="font-weight: 700;">@_policies.Count</MudText><MudText Typo="Typo.body2">Policyer totalt</MudText></MudPaper></MudItem>
        <MudItem xs="3"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Success" Style="font-weight: 700;">@_policies.Count(p => p.Policy.Status == PolicyStatus.Publicerad)</MudText><MudText Typo="Typo.body2">Publicerade</MudText></MudPaper></MudItem>
        <MudItem xs="3"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Warning" Style="font-weight: 700;">@_totalBekraftelsekrav</MudText><MudText Typo="Typo.body2">Kräver bekräftelse</MudText></MudPaper></MudItem>
        <MudItem xs="3"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Info" Style="font-weight: 700;">@_totalConfirmations</MudText><MudText Typo="Typo.body2">Bekräftelser totalt</MudText></MudPaper></MudItem>
    </MudGrid>

    @if (_showCreate)
    {
        <MudPaper Class="pa-5 mb-4" Elevation="3" Style="border-left: 4px solid var(--mud-palette-primary);">
            <div class="d-flex justify-space-between align-center mb-3">
                <MudText Typo="Typo.h6" Style="font-weight: 600;">Ny policy</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="@(() => _showCreate = false)" />
            </div>
            <MudGrid Spacing="3">
                <MudItem xs="12" sm="6"><MudTextField @bind-Value="_newTitel" Label="Titel" Variant="Variant.Outlined" Required="true" /></MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="PolicyCategory" @bind-Value="_newKategori" Label="Kategori" Variant="Variant.Outlined">
                        @foreach (var k in Enum.GetValues<PolicyCategory>())
                        {
                            <MudSelectItem Value="@k">@KategoriText(k)</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12"><MudTextField @bind-Value="_newSammanfattning" Label="Sammanfattning" Variant="Variant.Outlined" /></MudItem>
                <MudItem xs="12"><MudTextField @bind-Value="_newInnehall" Label="Innehåll" Variant="Variant.Outlined" Lines="4" Required="true" /></MudItem>
                <MudItem xs="12"><MudCheckBox T="bool" @bind-Value="_newKraverBekraftelse" Label="Kräver bekräftelse från anställda" Color="Color.Primary" /></MudItem>
            </MudGrid>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-3" OnClick="SkapaPolicy"
                       Disabled="@(string.IsNullOrWhiteSpace(_newTitel) || string.IsNullOrWhiteSpace(_newInnehall) || _saving)">Skapa</MudButton>
        </MudPaper>
    }

    @if (_success != null)
    {
        <MudAlert Severity="Severity.Success" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="@(() => _success = null)">@_success</MudAlert>
    }

    @if (_policies.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Text">Inga policyer registrerade.</MudAlert>
    }
    else
    {
        <MudSimpleTable Hover="true" Elevation="2" Class="mb-6">
            <thead><tr><th>Policy</th><th>Kategori</th><th>Version</th><th>Status</th><th>Bekräftade</th><th></th></tr></thead>
            <tbody>
                @foreach (var p in _policies)
                {
                    <tr>
                        <td><strong>@p.Policy.Titel</strong><br /><MudText Typo="Typo.caption">@(p.Policy.Sammanfattning ?? "—")</MudText></td>
                        <td>@KategoriText(p.Policy.Kategori)</td>
                        <td>v@p.Policy.Version</td>
                        <td><MudChip T="string" Size="Size.Small" Color="@StatusColor(p.Policy.Status)">@StatusText(p.Policy.Status)</MudChip></td>
                        <td>
                            @if (p.Policy.KraverBekraftelse && p.Policy.Status == PolicyStatus.Publicerad)
                            {
                                var pct = _totalEmployees > 0 ? (int)(100.0 * p.Confirmations / _totalEmployees) : 0;
                                <MudText Typo="Typo.body2">@p.Confirmations / @_totalEmployees (@pct%)</MudText>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2">—</MudText>
                            }
                        </td>
                        <td>
                            @if (p.Policy.Status == PolicyStatus.Utkast)
                            {
                                <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => PubliceraPolicy(p.Policy))">Publicera</MudButton>
                            }
                            else if (p.Policy.Status == PolicyStatus.Publicerad)
                            {
                                <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary" Href="@($"/dokument/policyer/{p.Policy.Id}")">Visa</MudButton>
                                <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default" OnClick="@(() => ArkiveraPolicy(p.Policy))">Arkivera</MudButton>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>

        @if (_recentConfirmations.Count > 0)
        {
            <MudText Typo="Typo.h6" Class="mb-3">Senaste bekräftelser</MudText>
            <MudSimpleTable Hover="true" Elevation="1">
                <thead><tr><th>Datum</th><th>Anställd</th><th>Policy</th></tr></thead>
                <tbody>
                    @foreach (var c in _recentConfirmations)
                    {
                        <tr><td>@c.Datum</td><td><strong>@c.Namn</strong></td><td>@c.PolicyTitel</td></tr>
                    }
                </tbody>
            </MudSimpleTable>
        }
    }
}

@code {
    private List<PolicyVm> _policies = [];
    private List<RecentConfirmVm> _recentConfirmations = [];
    private int _totalEmployees, _totalBekraftelsekrav, _totalConfirmations;
    private bool _loading = true, _saving, _showCreate;
    private string? _error, _success;
    private string _newTitel = "", _newSammanfattning = "", _newInnehall = "";
    private PolicyCategory _newKategori = PolicyCategory.Ovrigt;
    private bool _newKraverBekraftelse = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var policies = await Db.Policies.OrderByDescending(p => p.SkapadVid).ToListAsync();
            var confirmations = await Db.PolicyConfirmations.ToListAsync();
            _totalEmployees = await Db.Employees.CountAsync();

            var confByPolicy = confirmations.GroupBy(c => c.PolicyId).ToDictionary(g => g.Key, g => g.Count());
            _policies = policies.Select(p => new PolicyVm(p, confByPolicy.GetValueOrDefault(p.Id))).ToList();
            _totalBekraftelsekrav = policies.Count(p => p.KraverBekraftelse && p.Status == PolicyStatus.Publicerad);
            _totalConfirmations = confirmations.Count;

            var recentConfs = confirmations.OrderByDescending(c => c.BekraftadVid).Take(10).ToList();
            if (recentConfs.Count > 0)
            {
                var empIds = recentConfs.Select(c => c.AnstallId).Distinct().ToList();
                var employees = await Db.Employees.Where(e => empIds.Contains(e.Id.Value)).ToListAsync();
                var names = employees.ToDictionary(e => e.Id.Value, e => $"{e.Fornamn} {e.Efternamn}");
                var titles = policies.ToDictionary(p => p.Id, p => p.Titel);
                _recentConfirmations = recentConfs.Select(c => new RecentConfirmVm(
                    c.BekraftadVid.ToLocalTime().ToString("yyyy-MM-dd"),
                    names.GetValueOrDefault(c.AnstallId, "Okänd"),
                    titles.GetValueOrDefault(c.PolicyId, "Okänd"))).ToList();
            }
        }
        catch (Exception ex) { _error = $"Kunde inte hämta policyer: {ex.Message}"; }
        finally { _loading = false; }
    }

    private async Task SkapaPolicy()
    {
        _saving = true; _error = null;
        try
        {
            var policy = Policy.Skapa(_newTitel, _newInnehall, _newKategori, _newKraverBekraftelse, "Admin",
                string.IsNullOrWhiteSpace(_newSammanfattning) ? null : _newSammanfattning);
            Db.Policies.Add(policy);
            await Db.SaveChangesAsync();
            _policies.Insert(0, new PolicyVm(policy, 0));
            _showCreate = false;
            _success = $"Policy \"{_newTitel}\" skapad.";
            _newTitel = ""; _newSammanfattning = ""; _newInnehall = "";
        }
        catch (Exception ex) { _error = $"Kunde inte skapa: {ex.Message}"; }
        finally { _saving = false; }
    }

    private async Task PubliceraPolicy(Policy p)
    {
        try { p.Publicera(); await Db.SaveChangesAsync(); }
        catch (Exception ex) { _error = $"Kunde inte publicera: {ex.Message}"; }
    }

    private async Task ArkiveraPolicy(Policy p)
    {
        try { p.Arkivera(); await Db.SaveChangesAsync(); }
        catch (Exception ex) { _error = $"Kunde inte arkivera: {ex.Message}"; }
    }

    private static string StatusText(PolicyStatus s) => s switch { PolicyStatus.Utkast => "Utkast", PolicyStatus.Publicerad => "Publicerad", PolicyStatus.Arkiverad => "Arkiverad", _ => s.ToString() };
    private static Color StatusColor(PolicyStatus s) => s switch { PolicyStatus.Publicerad => Color.Success, PolicyStatus.Arkiverad => Color.Default, _ => Color.Info };
    private static string KategoriText(PolicyCategory k) => k switch { PolicyCategory.ITSakerhet => "IT-säkerhet", PolicyCategory.Arbetsmiljo => "Arbetsmiljö", PolicyCategory.GDPR => "GDPR", PolicyCategory.Personalhandbok => "Personalhandbok", PolicyCategory.Medicinsk => "Medicinsk", PolicyCategory.Juridisk => "Juridisk", _ => "Övrigt" };

    private record PolicyVm(Policy Policy, int Confirmations);
    private record RecentConfirmVm(string Datum, string Namn, string PolicyTitel);
}
