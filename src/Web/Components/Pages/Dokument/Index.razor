@page "/dokument"
@rendermode InteractiveServer
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Documents.Domain
@using Microsoft.EntityFrameworkCore
@inject RegionHRDbContext Db

<PageTitle>OpenHR - Dokument</PageTitle>
<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4" Style="font-weight: 700;">Dokumenthantering</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" StartIcon="@Icons.Material.Filled.Upload" Style="min-height: 48px;" Href="/dokument/ny">Ladda upp dokument</MudButton>
</div>

<MudSimpleTable Hover="true" Elevation="2">
    <thead>
        <tr>
            <th>Dokumentnamn</th>
            <th>Kategori</th>
            <th>Anställd</th>
            <th>Datum</th>
            <th>GDPR-klassificering</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var d in _documents)
        {
            <tr>
                <td>@d.FileName</td>
                <td>@KategoriText(d.Kategori)</td>
                <td>@d.AnstallId.ToString()[..8]...</td>
                <td>@d.UppladdadVid.ToString("yyyy-MM-dd")</td>
                <td><MudChip T="string" Size="Size.Small" Color="@KlassFarg(d.Klassificering)">@KlassText(d.Klassificering)</MudChip></td>
                <td><MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary">Visa</MudButton></td>
            </tr>
        }
    </tbody>
</MudSimpleTable>

@code {
    private List<Document> _documents = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _documents = await Db.Documents
                .Where(d => !d.IsArchived)
                .OrderByDescending(d => d.UppladdadVid)
                .Take(50)
                .ToListAsync();
        }
        catch
        {
            // Demo data fallback
        }
    }

    private static string KategoriText(DocumentCategory k) => k switch
    {
        DocumentCategory.Anstallningsavtal => "Avtal",
        DocumentCategory.Lakarintyg => "Sjukfrånvaro",
        DocumentCategory.Betyg => "Betyg",
        DocumentCategory.Legitimation => "Legitimation",
        DocumentCategory.Policy => "Policy",
        DocumentCategory.Lonespecifikation => "Lön",
        DocumentCategory.Tjanstgoringsbevis => "Tjänstgöringsbevis",
        DocumentCategory.Ovrigt => "Övrigt",
        _ => k.ToString()
    };

    private static Color KlassFarg(DataClassification k) => k switch
    {
        DataClassification.Normal => Color.Success,
        DataClassification.Kansllig => Color.Error,
        DataClassification.SarskildKategori => Color.Warning,
        _ => Color.Default
    };

    private static string KlassText(DataClassification k) => k switch
    {
        DataClassification.Normal => "Öppen",
        DataClassification.Kansllig => "Känslig",
        DataClassification.SarskildKategori => "Särskild kategori",
        _ => k.ToString()
    };
}
