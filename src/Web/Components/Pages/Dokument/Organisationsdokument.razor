@page "/dokument/organisation"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Documents.Domain
@using Microsoft.EntityFrameworkCore
@inject RegionHRDbContext Db

<PageTitle>OpenHR - Organisationsdokument</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">Organisationsdokument</MudText>
<MudText Typo="Typo.body2" Class="mb-4" Style="color: var(--mud-palette-text-secondary);">Dokument som inte är kopplade till en specifik anställd.</MudText>

@if (_loading) { <MudProgressCircular Color="Color.Primary" Indeterminate="true" /> }
else if (_error != null) { <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert> }
else
{
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="6"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Primary" Style="font-weight: 700;">@_policyer</MudText><MudText Typo="Typo.body2">Policyer</MudText></MudPaper></MudItem>
        <MudItem xs="6"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Style="font-weight: 700;">@_dokument</MudText><MudText Typo="Typo.body2">Uppladdade dokument</MudText></MudPaper></MudItem>
    </MudGrid>

    <MudText Typo="Typo.h6" Class="mb-3">Publicerade policyer</MudText>
    @if (_policyList.Count == 0) { <MudAlert Severity="Severity.Info" Variant="Variant.Text" Class="mb-4">Inga publicerade policyer.</MudAlert> }
    else
    {
        <MudSimpleTable Hover="true" Elevation="2" Class="mb-6">
            <thead><tr><th>Policy</th><th>Kategori</th><th>Version</th><th>Publicerad</th></tr></thead>
            <tbody>
                @foreach (var p in _policyList)
                {
                    <tr><td><strong>@p.Titel</strong></td><td>@p.Kategori</td><td>v@p.Version</td><td>@(p.PubliceradVid?.ToLocalTime().ToString("yyyy-MM-dd") ?? "—")</td></tr>
                }
            </tbody>
        </MudSimpleTable>
    }

    <MudText Typo="Typo.h6" Class="mb-3">Organisationsdokument (uppladdade)</MudText>
    @if (_docList.Count == 0) { <MudAlert Severity="Severity.Info" Variant="Variant.Text">Inga organisationsdokument uppladdade. Använd Dokument → Ladda upp för att lägga till.</MudAlert> }
    else
    {
        <MudSimpleTable Hover="true" Elevation="1">
            <thead><tr><th>Filnamn</th><th>Kategori</th><th>Uppladdad</th></tr></thead>
            <tbody>
                @foreach (var d in _docList)
                {
                    <tr><td><strong>@d.FileName</strong></td><td>@d.Kategori</td><td>@d.UppladdadVid.ToLocalTime().ToString("yyyy-MM-dd")</td></tr>
                }
            </tbody>
        </MudSimpleTable>
    }

    <MudAlert Severity="Severity.Info" Variant="Variant.Text" Class="mt-4">
        Kollektivavtal (AB, HOK, PAN) och lokala avtal hanteras utanför detta system. Kontakta HR-avdelningen för gällande avtalstexter.
    </MudAlert>
}

@code {
    private List<RegionHR.PolicyManagement.Domain.Policy> _policyList = [];
    private List<Document> _docList = [];
    private int _policyer, _dokument;
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _policyList = await Db.Policies
                .Where(p => p.Status == RegionHR.PolicyManagement.Domain.PolicyStatus.Publicerad)
                .OrderByDescending(p => p.PubliceradVid).ToListAsync();
            _policyer = _policyList.Count;

            // Show all non-archived documents as organizational scope
            _docList = await Db.Documents
                .Where(d => !d.IsArchived)
                .OrderByDescending(d => d.UppladdadVid)
                .Take(20).ToListAsync();
            _dokument = _docList.Count;
        }
        catch (Exception ex) { _error = $"Kunde inte hämta data: {ex.Message}"; }
        finally { _loading = false; }
    }
}
