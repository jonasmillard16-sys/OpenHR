@page "/dokument/ny"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Documents.Domain
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Infrastructure.Storage
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<RegionHRDbContext> DbFactory
@inject IFileStorageService Storage
@inject NavigationManager Nav

<PageTitle>OpenHR — Ladda upp dokument</PageTitle>

<MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Variant="Variant.Text"
           Color="Color.Primary" Href="/dokument" Style="margin-bottom: 1rem;">Tillbaka</MudButton>

<MudText Typo="Typo.h4" Class="mb-2" Style="font-weight: 700;">Ladda upp dokument</MudText>
<MudText Typo="Typo.body2" Class="mb-4" Style="color: var(--mud-palette-text-secondary);">
    Filen sparas lokalt via FileStorageService. Metadata persisteras i databasen (Document-entity).
</MudText>

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
}

@if (_uploaded != null)
{
    <MudAlert Severity="Severity.Success" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="@(() => _uploaded = null)">
        @_uploaded
    </MudAlert>
}

<MudPaper Class="pa-5" Elevation="2">
    <MudGrid Spacing="3">
        <MudItem xs="12" sm="6">
            <MudSelect T="Guid?" @bind-Value="_anstallId" Label="Anställd" Variant="Variant.Outlined" Required="true">
                @foreach (var e in _employees)
                {
                    <MudSelectItem T="Guid?" Value="@((Guid?)e.Id.Value)">@e.Fornamn @e.Efternamn</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudSelect T="DocumentCategory" @bind-Value="_kategori" Label="Kategori" Variant="Variant.Outlined">
                @foreach (var k in Enum.GetValues<DocumentCategory>())
                {
                    <MudSelectItem Value="@k">@k</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12">
            <MudTextField @bind-Value="_beskrivning" Label="Beskrivning (valfritt)" Variant="Variant.Outlined" />
        </MudItem>
        <MudItem xs="12">
            <MudFileUpload T="IBrowserFile" Accept=".pdf,.doc,.docx,.jpg,.png,.xlsx,.txt" OnFilesChanged="OnFileSelected">
                <CustomContent>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.CloudUpload"
                               OnClick="@context.OpenFilePickerAsync">
                        Välj fil
                    </MudButton>
                </CustomContent>
            </MudFileUpload>
            @if (_selectedFile != null)
            {
                <MudText Typo="Typo.body2" Class="mt-2">
                    <strong>Vald fil:</strong> @_selectedFile.Name (@FormatSize(_selectedFile.Size)) — @_selectedFile.ContentType
                </MudText>
            }
        </MudItem>
    </MudGrid>

    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Class="mt-4"
               Style="min-height: 48px;" OnClick="LaddaUpp" Disabled="@(_uploading || _selectedFile == null || _anstallId == null)">
        @if (_uploading)
        {
            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
        }
        Ladda upp
    </MudButton>
</MudPaper>

@* Senast uppladdade dokument *@
@if (_recentDocs.Count > 0)
{
    <MudText Typo="Typo.h6" Class="mt-6 mb-3" Style="font-weight: 600;">Senast uppladdade</MudText>
    <MudSimpleTable Hover="true" Elevation="2">
        <thead><tr><th>Fil</th><th>Anställd</th><th>Kategori</th><th>Storlek</th><th>Uppladdad</th></tr></thead>
        <tbody>
            @foreach (var d in _recentDocs.OrderByDescending(d => d.UppladdadVid).Take(10))
            {
                <tr>
                    <td><strong>@d.FileName</strong></td>
                    <td>@GetEmployeeName(d.AnstallId)</td>
                    <td><MudChip T="string" Size="Size.Small">@d.Kategori</MudChip></td>
                    <td>@FormatSize(d.FileSizeBytes)</td>
                    <td>@d.UppladdadVid.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                </tr>
            }
        </tbody>
    </MudSimpleTable>
}

@code {
    private List<RegionHR.Core.Domain.Employee> _employees = [];
    private List<Document> _recentDocs = [];
    private IBrowserFile? _selectedFile;
    private Guid? _anstallId;
    private DocumentCategory _kategori = DocumentCategory.Ovrigt;
    private string _beskrivning = "";
    private string? _error, _uploaded;
    private bool _loading = true, _uploading;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        try
        {
            _employees = await db.Employees.OrderBy(e => e.Efternamn).ToListAsync();
            _recentDocs = await db.Documents.OrderByDescending(d => d.UppladdadVid).Take(10).ToListAsync();
        }
        catch (Exception ex) { _error = $"Kunde inte hämta data: {ex.Message}"; }
        finally { _loading = false; }
    }

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        _selectedFile = e.File;
    }

    private async Task LaddaUpp()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        if (_selectedFile == null || _anstallId == null) return;
        _uploading = true;
        _error = null;
        StateHasChanged();

        try
        {
            // 1. Spara fil via IFileStorageService
            using var stream = _selectedFile.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024); // 10 MB max
            var storagePath = await Storage.UploadAsync(
                _kategori.ToString().ToLower(),
                _selectedFile.Name,
                stream);

            // 2. Skapa Document-metadata via domänens Skapa()
            var doc = Document.Skapa(
                _anstallId.Value,
                _kategori,
                _selectedFile.Name,
                storagePath,
                _selectedFile.Size,
                _selectedFile.ContentType,
                "Admin", // uppladdadAv — auth saknar EmployeeId-koppling
                beskrivning: string.IsNullOrWhiteSpace(_beskrivning) ? null : _beskrivning);

            // 3. Persistera i DB
            db.Documents.Add(doc);
            await db.SaveChangesAsync();

            _recentDocs.Insert(0, doc);
            _uploaded = $"Dokument \"{_selectedFile.Name}\" uppladdat och sparat. Lagringsväg: {storagePath}";
            _selectedFile = null;
            _beskrivning = "";
        }
        catch (Exception ex)
        {
            _error = $"Uppladdning misslyckades: {ex.Message}";
        }
        finally { _uploading = false; }
    }

    private string GetEmployeeName(Guid id)
    {
        var emp = _employees.FirstOrDefault(e => e.Id.Value == id);
        return emp != null ? $"{emp.Fornamn} {emp.Efternamn}" : "Okänd";
    }

    private static string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024):F1} MB";
    }
}

