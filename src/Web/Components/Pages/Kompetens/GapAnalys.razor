@page "/kompetens/gapanalys"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Competence.Domain
@using RegionHR.Positions.Domain
@using RegionHR.Infrastructure.Persistence
@using Microsoft.EntityFrameworkCore
@inject RegionHRDbContext Db

<PageTitle>OpenHR — Gap-analys</PageTitle>

<MudText Typo="Typo.h4" Class="mb-2" Style="font-weight: 700;">Kompetens gap-analys</MudText>
<MudText Typo="Typo.body2" Class="mb-4" Style="color: var(--mud-palette-text-secondary);">
    Jämför anställdas registrerade skills mot positionens kravprofil (PositionSkillRequirement).
    Anställda utan kopplad position visas inte.
</MudText>

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error">@_error</MudAlert>
}
else if (_gapResults.Count == 0)
{
    <MudAlert Severity="Severity.Info">Inga positioner med kravprofil och kopplad anställd hittades.</MudAlert>
}
else
{
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="2" Style="border-top: 4px solid var(--mud-palette-error);">
                <MudText Typo="Typo.h3" Color="Color.Error" Style="font-weight: 700;">@_gapResults.Count(r => r.HarGap)</MudText>
                <MudText Typo="Typo.body2">Med gap</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="2" Style="border-top: 4px solid var(--mud-palette-success);">
                <MudText Typo="Typo.h3" Color="Color.Success" Style="font-weight: 700;">@_gapResults.Count(r => !r.HarGap)</MudText>
                <MudText Typo="Typo.body2">Uppfyller alla krav</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="2">
                <MudText Typo="Typo.h3" Style="font-weight: 700;">@_gapResults.Count</MudText>
                <MudText Typo="Typo.body2">Analyserade</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="2">
                <MudText Typo="Typo.h3" Style="font-weight: 700;">@_totalGapCount</MudText>
                <MudText Typo="Typo.body2">Totala gap</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudSimpleTable Hover="true" Elevation="2">
        <thead>
            <tr><th>Anställd</th><th>Position</th><th>Krav</th><th>Uppfyllda</th><th>Gap</th><th>Täckningsgrad</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var r in _gapResults)
            {
                <tr style="cursor: pointer;" @onclick="@(() => _expanded = _expanded == r ? null : r)">
                    <td><strong>@r.AnstallNamn</strong></td>
                    <td>@r.PositionTitel</td>
                    <td>@r.AntalKrav</td>
                    <td>@r.Uppfyllda</td>
                    <td>
                        @if (r.HarGap)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Error">@r.AntalGap gap</MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Success">0</MudChip>
                        }
                    </td>
                    <td>
                        <MudProgressLinear Value="@r.TackningsgradProcent" Color="@(r.TackningsgradProcent >= 100 ? Color.Success : r.TackningsgradProcent >= 70 ? Color.Warning : Color.Error)"
                                           Style="min-width: 100px;" />
                        <MudText Typo="Typo.caption">@r.TackningsgradProcent%</MudText>
                    </td>
                    <td><MudIconButton Icon="@(_expanded == r ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" Size="Size.Small" /></td>
                </tr>
                @if (_expanded == r)
                {
                    <tr>
                        <td colspan="7" style="padding: 0;">
                            <MudPaper Class="pa-4" Elevation="0" Style="border-top: 2px solid var(--mud-palette-primary); background: var(--mud-palette-background);">
                                <MudText Typo="Typo.subtitle1" Class="mb-2" Style="font-weight: 600;">Detaljerad gap-analys: @r.AnstallNamn</MudText>
                                <MudSimpleTable Dense="true" Elevation="1">
                                    <thead><tr><th>Skill</th><th>Krävd nivå</th><th>Anställds nivå</th><th>Status</th></tr></thead>
                                    <tbody>
                                        @foreach (var d in r.Detaljer)
                                        {
                                            <tr>
                                                <td>@d.SkillNamn</td>
                                                <td><MudRating ReadOnly="true" SelectedValue="@d.KravdNiva" MaxValue="5" Size="Size.Small" /></td>
                                                <td><MudRating ReadOnly="true" SelectedValue="@d.DinNiva" MaxValue="5" Size="Size.Small" /></td>
                                                <td>
                                                    @if (d.DinNiva >= d.KravdNiva)
                                                    {
                                                        <MudChip T="string" Size="Size.Small" Color="Color.Success">Uppfylld</MudChip>
                                                    }
                                                    else if (d.DinNiva == 0)
                                                    {
                                                        <MudChip T="string" Size="Size.Small" Color="Color.Error">Saknas</MudChip>
                                                    }
                                                    else
                                                    {
                                                        <MudChip T="string" Size="Size.Small" Color="Color.Warning">Nivå @d.DinNiva / @d.KravdNiva</MudChip>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </MudSimpleTable>
                            </MudPaper>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </MudSimpleTable>
}

@code {
    private List<GapResult> _gapResults = [];
    private GapResult? _expanded;
    private int _totalGapCount;
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var skills = await Db.Skills.ToListAsync();
            var empSkills = await Db.EmployeeSkills.ToListAsync();
            var requirements = await Db.PositionSkillRequirements.ToListAsync();
            var positions = await Db.Positions_Table
                .Where(p => p.InnehavareAnstallId != null && p.Status == PositionStatus.Aktiv)
                .ToListAsync();
            var employees = await Db.Employees.ToListAsync();

            foreach (var pos in positions)
            {
                var emp = employees.FirstOrDefault(e => e.Id.Value == pos.InnehavareAnstallId);
                if (emp is null) continue;

                var posKrav = requirements.Where(r => r.PositionId == pos.Id).ToList();
                if (posKrav.Count == 0) continue;

                var empSkillsForPerson = empSkills.Where(es => es.AnstallId == emp.Id.Value).ToList();

                var detaljer = posKrav.Select(k =>
                {
                    var skill = skills.FirstOrDefault(s => s.Id == k.SkillId);
                    var es = empSkillsForPerson.FirstOrDefault(es => es.SkillId == k.SkillId);
                    return new GapDetalj(skill?.Namn ?? "?", k.MinNiva, es?.Niva ?? 0);
                }).OrderByDescending(d => Math.Max(0, d.KravdNiva - d.DinNiva)).ToList();

                var uppfyllda = detaljer.Count(d => d.DinNiva >= d.KravdNiva);
                var gap = detaljer.Count(d => d.DinNiva < d.KravdNiva);
                var tackningsgrad = posKrav.Count > 0 ? (int)Math.Round((double)uppfyllda / posKrav.Count * 100) : 100;

                _gapResults.Add(new GapResult(
                    $"{emp.Fornamn} {emp.Efternamn}", pos.Titel,
                    posKrav.Count, uppfyllda, gap, gap > 0, tackningsgrad, detaljer));
            }

            _gapResults = _gapResults.OrderByDescending(r => r.AntalGap).ToList();
            _totalGapCount = _gapResults.Sum(r => r.AntalGap);
        }
        catch (Exception ex) { _error = $"Kunde inte utföra gap-analys: {ex.Message}"; }
        finally { _loading = false; }
    }

    private record GapResult(string AnstallNamn, string PositionTitel, int AntalKrav,
        int Uppfyllda, int AntalGap, bool HarGap, int TackningsgradProcent, List<GapDetalj> Detaljer);
    private record GapDetalj(string SkillNamn, int KravdNiva, int DinNiva);
}
