@page "/lon/korningar"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Payroll.Domain
@using RegionHR.SharedKernel.Domain
@using Microsoft.EntityFrameworkCore
@using Microsoft.Extensions.Localization
@inject RegionHRDbContext Db
@inject IStringLocalizer<SharedResources> L

<PageTitle>OpenHR - @L["PayRuns"]</PageTitle>

<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4" Style="font-weight: 700;">@L["PayRuns"]</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
               StartIcon="@Icons.Material.Filled.Add" Href="/lon/korning/ny"
               Style="min-height: 48px;">
        @L["NewPayrollRun"]
    </MudButton>
</div>

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error">@_error</MudAlert>
}
else if (_korningar.Count == 0)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Text">@L["NoPayrollRuns"]</MudAlert>
}
else
{
    <MudSimpleTable Hover="true" Elevation="2">
        <thead><tr><th>@L["Period"]</th><th>@L["Status"]</th><th>@L["Employees"]</th><th>@L["TotalGross"]</th><th>@L["TotalNet"]</th><th></th></tr></thead>
        <tbody>
            @foreach (var k in _korningar)
            {
                <tr>
                    <td><strong>@k.Period</strong></td>
                    <td><MudChip T="string" Size="Size.Small" Color="@k.StatusFarg">@k.Status</MudChip></td>
                    <td>@k.Antal</td>
                    <td>@k.Brutto</td>
                    <td>@k.Netto</td>
                    <td><MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary" Href="@($"/lon/korning/{k.Id}")">@L["Open"]</MudButton></td>
                </tr>
            }
        </tbody>
    </MudSimpleTable>
}

@code {
    private List<KorningRad> _korningar = [];
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var runs = await Db.PayrollRuns
                .OrderByDescending(r => r.Year)
                .ThenByDescending(r => r.Month)
                .Take(20)
                .ToListAsync();

            _korningar = runs.Select(r => new KorningRad(
                r.Id.Value,
                r.Period,
                MapStatus(r.Status),
                r.AntalAnstallda,
                FormatMoney(r.TotalBrutto),
                FormatMoney(r.TotalNetto),
                MapStatusColor(r.Status)
            )).ToList();
        }
        catch (Exception ex) { _error = $"{L["ErrorLoadingPayroll"]}: {ex.Message}"; }
        finally { _loading = false; }
    }

    private static string FormatMoney(Money m) => $"{m.Amount:N0} kr";

    private string MapStatus(PayrollRunStatus status) => status switch
    {
        PayrollRunStatus.Skapad => L["PayrollCreated"],
        PayrollRunStatus.Paborjad => L["PayrollInProgress"],
        PayrollRunStatus.Beraknad => L["PayrollCalculated"],
        PayrollRunStatus.Granskad => L["PayrollReviewed"],
        PayrollRunStatus.Godkand => L["PayrollApproved"],
        PayrollRunStatus.Utbetald => L["PayrollPaid"],
        PayrollRunStatus.Felaktig => L["PayrollError"],
        _ => status.ToString()
    };

    private static Color MapStatusColor(PayrollRunStatus status) => status switch
    {
        PayrollRunStatus.Utbetald => Color.Success,
        PayrollRunStatus.Godkand => Color.Success,
        PayrollRunStatus.Beraknad => Color.Info,
        PayrollRunStatus.Granskad => Color.Info,
        PayrollRunStatus.Paborjad => Color.Warning,
        PayrollRunStatus.Felaktig => Color.Error,
        _ => Color.Default
    };

    private record KorningRad(Guid Id, string Period, string Status, int Antal, string Brutto, string Netto, Color StatusFarg);
}
