@page "/lon/lonearter"
@rendermode InteractiveServer
@layout RegionHR.Web.Components.Layout.AdminLayout

<PageTitle>OpenHR - Lönearter</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">Lönearter</MudText>

<MudSimpleTable Hover="true" Elevation="2">
    <thead><tr><th>Kod</th><th>Benämning</th><th>Skattekategori</th><th>Semestergrundande</th><th>Pensionsgrundande</th></tr></thead>
    <tbody>
        @foreach (var l in _lonearter)
        {
            <tr>
                <td><strong>@l.Kod</strong></td>
                <td>@l.Benamning</td>
                <td>@l.Skattekategori</td>
                <td>@(l.Semestergrundande ? "✓" : "—")</td>
                <td>@(l.Pensionsgrundande ? "✓" : "—")</td>
            </tr>
        }
    </tbody>
</MudSimpleTable>

@code {
    private List<LoneartRad> _lonearter = [];
    protected override void OnInitialized()
    {
        _lonearter = [
            new("1100", "Månadslön", "A-skatt", true, true),
            new("1310", "OB-tillägg vardag kväll", "A-skatt", true, true),
            new("1311", "OB-tillägg vardag natt", "A-skatt", true, true),
            new("1312", "OB-tillägg helg", "A-skatt", true, true),
            new("1313", "OB-tillägg storhelg", "A-skatt", true, true),
            new("1410", "Övertidstillägg enkel", "A-skatt", false, true),
            new("1411", "Övertidstillägg kvalificerad", "A-skatt", false, true),
            new("2100", "Semesterlön", "A-skatt", false, true),
            new("2200", "Semestertillägg", "A-skatt", false, true),
            new("3100", "Sjuklön dag 2-14", "A-skatt", true, true),
            new("5100", "Traktamente", "Skattefritt", false, false),
            new("5200", "Milersättning", "Skattefritt", false, false),
        ];
    }
    private record LoneartRad(string Kod, string Benamning, string Skattekategori, bool Semestergrundande, bool Pensionsgrundande);
}
