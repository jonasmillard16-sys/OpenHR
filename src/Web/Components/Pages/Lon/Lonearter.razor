@page "/lon/lonearter"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Payroll.Domain
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<RegionHRDbContext> DbFactory

<OhrBreadcrumb CurrentPage="Lönearter" ExtraItems="@(new List<BreadcrumbItem>{new("Lön", "/lon/korningar")})" />

<PageTitle>OpenHR - Lönearter</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">Lönearter</MudText>
<MudText Typo="Typo.body2" Class="mb-4" Style="color: var(--mud-palette-text-secondary);">
    Lönearter är de olika typer av ersättning som kan ingå i en löneutbetalning, till exempel grundlön, övertidsersättning och OB-tillägg.
</MudText>

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
}
else if (_lonearter.Count == 0)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Text">Inga lönearter registrerade.</MudAlert>
}
else
{
    <MudText Typo="Typo.body2" Class="mb-4" Style="color: var(--mud-palette-text-secondary);">@_lonearter.Count lönearter i systemet</MudText>
    <MudSimpleTable Hover="true" Elevation="2">
        <thead><tr><th>Kod</th><th>Benämning</th><th>Skattekategori</th><th>Semestergrundande</th><th>Pensionsgrundande</th><th>Avdrag</th></tr></thead>
        <tbody>
            @foreach (var l in _lonearter)
            {
                <tr>
                    <td><strong>@l.Kod</strong></td>
                    <td>@l.Benamning</td>
                    <td>@l.Skattekategori</td>
                    <td>@(l.ArSemestergrundande ? "✓" : "—")</td>
                    <td>@(l.ArPensionsgrundande ? "✓" : "—")</td>
                    <td>@(l.ArAvdrag ? "Avdrag" : "—")</td>
                </tr>
            }
        </tbody>
    </MudSimpleTable>
}

@code {
    private List<SalaryCode> _lonearter = [];
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        try
        {
            _lonearter = await db.SalaryCodes.OrderBy(s => s.Kod).ToListAsync();
        }
        catch (Exception ex) { _error = $"Kunde inte hämta lönearter: {ex.Message}"; }
        finally { _loading = false; }
    }
}

