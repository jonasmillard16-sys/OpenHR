@page "/lon/korning/ny"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Payroll.Domain
@using RegionHR.SharedKernel.Domain
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<RegionHRDbContext> DbFactory
@inject NavigationManager Nav

<PageTitle>OpenHR - Ny lönekörning</PageTitle>
<MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Variant="Variant.Text" Color="Color.Primary" Href="/lon/korningar" Style="margin-bottom: 1rem;">Tillbaka</MudButton>

<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">Ny lönekörning</MudText>

@if (_error != null) { <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert> }

@if (_created)
{
    <MudPaper Class="pa-5" Elevation="2" Style="border-left: 4px solid var(--mud-palette-success);">
        <MudText Typo="Typo.h5" Color="Color.Success" Style="font-weight: 700;" Class="mb-3">Lönekörning skapad och beräknad</MudText>
        <MudSimpleTable Dense="true" Class="mb-3">
            <tbody>
                <tr><td><strong>Period</strong></td><td>@_run!.Period</td></tr>
                <tr><td><strong>Antal anställda</strong></td><td>@_run.AntalAnstallda</td></tr>
                <tr><td><strong>Total brutto</strong></td><td>@_run.TotalBrutto.Amount.ToString("N0") kr</td></tr>
                <tr><td><strong>Total skatt</strong></td><td>@_run.TotalSkatt.Amount.ToString("N0") kr</td></tr>
                <tr><td><strong>Total netto</strong></td><td>@_run.TotalNetto.Amount.ToString("N0") kr</td></tr>
                <tr><td><strong>Status</strong></td><td><MudChip T="string" Size="Size.Small" Color="Color.Info">Beräknad</MudChip></td></tr>
            </tbody>
        </MudSimpleTable>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="@($"/lon/korning/{_run!.Id.Value}")">Granska körning</MudButton>
    </MudPaper>
}
else
{
    <MudPaper Class="pa-5" Elevation="2">
        <MudGrid Spacing="3">
            <MudItem xs="12" sm="4"><MudNumericField T="int" @bind-Value="_year" Label="År" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" sm="4">
                <MudSelect T="int" @bind-Value="_month" Label="Månad" Variant="Variant.Outlined">
                    @for (var m = 1; m <= 12; m++) { var month = m; <MudSelectItem Value="@month">@System.Globalization.CultureInfo.GetCultureInfo("sv-SE").DateTimeFormat.GetMonthName(month)</MudSelectItem> }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="4" Class="d-flex align-end">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Style="min-height: 48px; width: 100%;" OnClick="SkapaKorning" Disabled="_saving">
                    @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                    Skapa och beräkna
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>
}

@code {
    private int _year = 2026, _month = DateTime.Today.Month;
    private PayrollRun? _run;
    private bool _saving, _created;
    private string? _error;

    private async Task SkapaKorning()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _saving = true; _error = null;
        try
        {
            var run = PayrollRun.Skapa(_year, _month, "System");
            run.Paborja();

            var idag = DateOnly.FromDateTime(DateTime.Today);
            var employees = await db.Employees.Include(e => e.Anstallningar).ToListAsync();

            foreach (var emp in employees)
            {
                var anst = emp.AktivAnstallning(idag);
                if (anst == null) continue;
                var result = PayrollResult.Skapa(run.Id, emp.Id, anst.Id, _year, _month,
                    anst.Manadslon, anst.Sysselsattningsgrad.Value, anst.Kollektivavtal);
                var brutto = anst.Manadslon.Amount * (anst.Sysselsattningsgrad.Value / 100m);
                result.Brutto = Money.SEK(Math.Round(brutto, 0));
                result.Skatt = Money.SEK(Math.Round(brutto * 0.30m, 0));
                result.Netto = Money.SEK(Math.Round(brutto * 0.70m, 0));
                result.Arbetsgivaravgifter = Money.SEK(Math.Round(brutto * 0.3142m, 0));
                result.ArbetsgivaravgiftSats = 31.42m;
                run.LaggTillResultat(result);
            }

            run.MarkeraSomBeraknad();
            db.PayrollRuns.Add(run);
            await db.SaveChangesAsync();
            _run = run;
            _created = true;
        }
        catch (Exception ex) { _error = $"Kunde inte skapa körning: {ex.Message}"; }
        finally { _saving = false; }
    }
}

