@page "/lon/korning/ny"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Web.Components.Shared
@inject NavigationManager Nav

<PageTitle>OpenHR - Ny lönekörning</PageTitle>

<MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Variant="Variant.Text"
           Color="Color.Primary" Href="/lon/korningar" Style="margin-bottom: 1rem;">Tillbaka</MudButton>

<OhrConversationFlow Steps="@_steps" CurrentStep="@_step" OnBack="@(() => { if (_step > 0) _step--; })">
    @switch (_step)
    {
        case 0:
            <MudText Typo="Typo.h5" Class="mb-4" Style="font-weight: 600;">Vilken period?</MudText>
            <MudStack Spacing="3">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" FullWidth="true"
                           Style="min-height: 64px; font-size: 1.25rem;" OnClick="@(() => { _period = "Mars 2026"; _step = 1; })">
                    Mars 2026
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Large" FullWidth="true"
                           Style="min-height: 56px;" OnClick="@(() => { _period = "April 2026"; _step = 1; })">
                    April 2026
                </MudButton>
            </MudStack>
            break;
        case 1:
            <MudText Typo="Typo.h5" Class="mb-4" Style="font-weight: 600;">Starta lönekörning för @_period?</MudText>
            <MudText Typo="Typo.body1" Class="mb-4">Systemet beräknar löner för alla 5 023 anställda. Detta tar ca 3-5 minuter.</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" FullWidth="true"
                       Style="min-height: 64px; font-size: 1.25rem;" OnClick="@(() => _step = 2)">
                Starta beräkning
            </MudButton>
            break;
        case 2:
            <div style="padding: 1rem 0;">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Large" Class="mb-4" Style="display: block; margin: 0 auto;" />
                <MudText Typo="Typo.h4" Color="Color.Success" Style="font-weight: 700; text-align: center;" Class="mb-4">Lönekörning startad — @_period</MudText>

                <MudPaper Class="pa-4 mb-4" Elevation="2">
                    <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight: 600;">Beräkningsresultat</MudText>
                    <MudSimpleTable Dense="true">
                        <tbody>
                            <tr><td><strong>Antal anställda</strong></td><td>432</td></tr>
                            <tr><td><strong>Bruttosumma</strong></td><td>14 200 000 kr</td></tr>
                            <tr><td><strong>Skatt + arbetsgivaravgifter</strong></td><td>8 100 000 kr</td></tr>
                            <tr><td><strong>Nettosumma</strong></td><td>6 100 000 kr</td></tr>
                        </tbody>
                    </MudSimpleTable>
                </MudPaper>

                <MudPaper Class="pa-4 mb-4" Elevation="1">
                    <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight: 600;">Processteg</MudText>
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Justify="Justify.Center" Class="mb-2">
                        <MudChip T="string" Color="Color.Success" Size="Size.Medium">Beräkning</MudChip>
                        <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" />
                        <MudChip T="string" Color="Color.Warning" Size="Size.Medium">Granskning (pågår)</MudChip>
                        <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" />
                        <MudChip T="string" Color="Color.Default" Size="Size.Medium">Godkännande</MudChip>
                        <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" />
                        <MudChip T="string" Color="Color.Default" Size="Size.Medium">Utbetalning</MudChip>
                    </MudStack>
                </MudPaper>

                <MudAlert Severity="Severity.Info" Variant="Variant.Text" Class="mb-4">
                    Lönefil genereras efter godkännande. Utbetalning sker den 25:e.
                </MudAlert>

                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" FullWidth="true"
                           Href="/lon/korningar" Style="min-height: 56px;">
                    Tillbaka till lönekörningar
                </MudButton>
            </div>
            break;
    }
</OhrConversationFlow>

@code {
    private readonly List<string> _steps = ["Välj period", "Bekräfta", "Beräknar..."];
    private int _step;
    private string _period = "";
}
