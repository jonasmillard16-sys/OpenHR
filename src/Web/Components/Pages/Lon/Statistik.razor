@page "/lon/statistik"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Payroll.Domain
@using RegionHR.SharedKernel.Domain
@using Microsoft.EntityFrameworkCore
@inject RegionHRDbContext Db

<PageTitle>OpenHR - Lönestatistik</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">Lönestatistik</MudText>

@if (_loading) { <MudProgressCircular Color="Color.Primary" Indeterminate="true" /> }
else if (_error != null) { <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert> }
else
{
    <MudGrid Spacing="3" Class="mb-6">
        <MudItem xs="6" sm="3"><MudPaper Class="pa-4 text-center" Elevation="2"><MudText Typo="Typo.caption">Totalt brutto (senaste)</MudText><MudText Typo="Typo.h5" Style="font-weight: 700;">@FormatKr(_senasteBrutto)</MudText></MudPaper></MudItem>
        <MudItem xs="6" sm="3"><MudPaper Class="pa-4 text-center" Elevation="2"><MudText Typo="Typo.caption">Totalt AG-avgifter</MudText><MudText Typo="Typo.h5" Style="font-weight: 700;">@FormatKr(_senasteAg)</MudText></MudPaper></MudItem>
        <MudItem xs="6" sm="3"><MudPaper Class="pa-4 text-center" Elevation="2"><MudText Typo="Typo.caption">Totalt netto</MudText><MudText Typo="Typo.h5" Color="Color.Primary" Style="font-weight: 700;">@FormatKr(_senasteNetto)</MudText></MudPaper></MudItem>
        <MudItem xs="6" sm="3"><MudPaper Class="pa-4 text-center" Elevation="2"><MudText Typo="Typo.caption">Körningar</MudText><MudText Typo="Typo.h5" Style="font-weight: 700;">@_runs.Count</MudText></MudPaper></MudItem>
    </MudGrid>

    <MudText Typo="Typo.h6" Class="mb-3">Månad för månad</MudText>
    @if (_runs.Count == 0) { <MudAlert Severity="Severity.Info" Variant="Variant.Text">Inga lönekörningar registrerade.</MudAlert> }
    else
    {
        <MudSimpleTable Hover="true" Elevation="1">
            <thead><tr><th>Period</th><th>Bruttolön</th><th>AG-avgifter</th><th>Nettolön</th><th>Anställda</th></tr></thead>
            <tbody>
                @foreach (var r in _runs)
                {
                    <tr>
                        <td><strong>@r.Period</strong></td>
                        <td>@FormatKr(r.TotalBrutto.Amount)</td>
                        <td>@FormatKr(r.TotalArbetsgivaravgifter.Amount)</td>
                        <td>@FormatKr(r.TotalNetto.Amount)</td>
                        <td>@r.AntalAnstallda</td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    }
}

@code {
    private List<PayrollRun> _runs = [];
    private decimal _senasteBrutto, _senasteAg, _senasteNetto;
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _runs = await Db.PayrollRuns.OrderByDescending(r => r.Year).ThenByDescending(r => r.Month).Take(12).ToListAsync();
            if (_runs.Count > 0)
            {
                _senasteBrutto = _runs[0].TotalBrutto.Amount;
                _senasteAg = _runs[0].TotalArbetsgivaravgifter.Amount;
                _senasteNetto = _runs[0].TotalNetto.Amount;
            }
        }
        catch (Exception ex) { _error = $"Kunde inte hämta lönestatistik: {ex.Message}"; }
        finally { _loading = false; }
    }

    private static string FormatKr(decimal v) => $"{v:N0} kr";
}
