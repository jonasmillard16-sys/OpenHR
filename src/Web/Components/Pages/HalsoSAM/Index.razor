@page "/halsosam"
@layout RegionHR.Web.Components.Layout.AdminLayout

<PageTitle>OpenHR - HälsoSAM</PageTitle>
<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4" Style="font-weight: 700;">HälsoSAM — Rehabilitering</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" StartIcon="@Icons.Material.Filled.Add" Href="/halsosam/ny" Style="min-height: 48px;">Nytt ärende</MudButton>
</div>

<MudGrid Spacing="3" Class="mb-6">
    <MudItem xs="3"><MudPaper Class="pa-4 text-center" Elevation="2"><MudText Typo="Typo.h3" Color="Color.Warning" Style="font-weight: 700;">5</MudText><MudText Typo="Typo.body2">Nya signaler</MudText></MudPaper></MudItem>
    <MudItem xs="3"><MudPaper Class="pa-4 text-center" Elevation="2"><MudText Typo="Typo.h3" Color="Color.Info" Style="font-weight: 700;">8</MudText><MudText Typo="Typo.body2">Aktiv rehab</MudText></MudPaper></MudItem>
    <MudItem xs="3"><MudPaper Class="pa-4 text-center" Elevation="2"><MudText Typo="Typo.h3" Color="Color.Error" Style="font-weight: 700;">3</MudText><MudText Typo="Typo.body2">Väntar uppföljning</MudText></MudPaper></MudItem>
    <MudItem xs="3"><MudPaper Class="pa-4 text-center" Elevation="2"><MudText Typo="Typo.h3" Style="font-weight: 700;">4.2%</MudText><MudText Typo="Typo.body2">Sjukfrånvaro</MudText></MudPaper></MudItem>
</MudGrid>

<MudText Typo="Typo.h6" Class="mb-3">Aktiva rehabiliteringsärenden</MudText>
<MudSimpleTable Hover="true" Elevation="2">
    <thead><tr><th>Anställd</th><th>Trigger</th><th>Status</th><th>Nästa uppföljning</th><th>Ärendeägare</th><th></th></tr></thead>
    <tbody>
        @foreach (var rad in _rader)
        {
            <tr>
                <td><strong>@rad.Namn</strong></td>
                <td>@rad.Trigger</td>
                <td><MudChip T="string" Size="Size.Small" Color="@rad.StatusFarg">@rad.StatusText</MudChip></td>
                <td>@rad.NastaUppfoljning</td>
                <td>@rad.Agare</td>
                <td><MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary" OnClick="@(() => Valj(rad))">Öppna</MudButton></td>
            </tr>
            @if (_valdRad == rad)
            {
                <tr>
                    <td colspan="6">
                        <MudPaper Class="pa-4" Elevation="0" Style="background: var(--mud-palette-background-grey);">
                            <MudText Typo="Typo.subtitle1" Class="mb-2"><strong>@rad.Namn — Rehabiliteringsärende</strong></MudText>
                            <MudText Typo="Typo.body2"><strong>Trigger:</strong> @rad.Trigger</MudText>
                            <MudText Typo="Typo.body2"><strong>Status:</strong> @rad.StatusText</MudText>
                            <MudText Typo="Typo.body2"><strong>Nästa uppföljning:</strong> @rad.NastaUppfoljning</MudText>
                            <MudText Typo="Typo.body2"><strong>Ärendeägare:</strong> @rad.Agare</MudText>
                            <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="@(() => _valdRad = null)" Class="mt-2">Stäng</MudButton>
                        </MudPaper>
                    </td>
                </tr>
            }
        }
    </tbody>
</MudSimpleTable>

<MudText Typo="Typo.h6" Class="mt-6 mb-3" Style="font-weight: 600;">Rehabkedjan — Lagstadgade milstolpar</MudText>
<MudText Typo="Typo.body2" Class="mb-3" Style="color: var(--mud-palette-text-secondary);">
    Systemet bevakar automatiskt var i rehabkedjan varje ärende befinner sig och påminner om kommande milstolpar.
</MudText>

<MudPaper Class="pa-4 mb-4" Elevation="2">
    <MudTimeline TimelinePosition="TimelinePosition.Start">
        @foreach (var m in _rehabkedja)
        {
            <MudTimelineItem Color="@m.Farg" Size="Size.Small"
                             Icon="@(m.Passerad ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Schedule)">
                <ItemContent>
                    <div class="d-flex align-center gap-3">
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="@m.Farg"
                                 Style="min-width: 70px; justify-content: center;">Dag @m.Dag</MudChip>
                        <div>
                            <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">@m.Titel</MudText>
                            <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">@m.Beskrivning</MudText>
                        </div>
                    </div>
                </ItemContent>
            </MudTimelineItem>
        }
    </MudTimeline>
</MudPaper>

<MudText Typo="Typo.h6" Class="mt-4 mb-3" Style="font-weight: 600;">Aktiva rehabärenden — position i kedjan</MudText>
<MudText Typo="Typo.body2" Class="mb-3" Style="color: var(--mud-palette-text-secondary);">
    Systemet räknar sjukdagar automatiskt och visar var i rehabkedjan den anställde befinner sig. Röda markeringar = åtgärd krävs snart.
</MudText>
<MudGrid Spacing="3" Class="mb-6">
    @foreach (var arende in _rehabArenden)
    {
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4" Elevation="2" Style="@($"border-left: 4px solid {(arende.AkutPaminnelse ? "var(--mud-palette-error)" : "var(--mud-palette-info)")}")">
                <div class="d-flex justify-space-between align-center mb-2">
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">@arende.Namn</MudText>
                    <MudChip T="string" Size="Size.Small" Color="@(arende.AkutPaminnelse ? Color.Error : Color.Info)">Dag @arende.SjukDag</MudChip>
                </div>
                <MudProgressLinear Value="@RehabProgress(arende.SjukDag)" Color="@RehabProgressFarg(arende.SjukDag)"
                                   Rounded="true" Size="Size.Medium" Class="mb-2" />
                <div class="d-flex flex-wrap gap-1 mb-2">
                    @foreach (var m in _rehabkedja)
                    {
                        <MudChip T="string" Size="Size.Small"
                                 Variant="@(arende.SjukDag >= m.Dag ? Variant.Filled : Variant.Outlined)"
                                 Color="@(arende.SjukDag >= m.Dag ? Color.Success : arende.NastaMilstolpe == m.Dag ? Color.Warning : Color.Default)">
                            @m.Dag
                        </MudChip>
                    }
                </div>
                <MudText Typo="Typo.body2"><strong>Nuvarande fas:</strong> @arende.NuvarandeFas</MudText>
                <MudText Typo="Typo.body2"><strong>Nästa milstolpe:</strong> Dag @arende.NastaMilstolpe — @arende.NastaAtgard</MudText>
                @if (arende.AkutPaminnelse)
                {
                    <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-2">
                        @arende.Paminnelse
                    </MudAlert>
                }
            </MudPaper>
        </MudItem>
    }
</MudGrid>

<MudText Typo="Typo.h6" Class="mt-6 mb-3">Sjukfrånvaro per enhet</MudText>
<MudSimpleTable Hover="true" Elevation="1">
    <thead><tr><th>Enhet</th><th>Korttid</th><th>Långtid</th><th>Totalt</th><th>Trend</th></tr></thead>
    <tbody>
        <tr><td>Avdelning 32</td><td>2.1%</td><td>2.1%</td><td>4.2%</td><td>+0.3%</td></tr>
        <tr><td>Avdelning 33</td><td>1.8%</td><td>1.5%</td><td>3.3%</td><td>-0.2%</td></tr>
        <tr><td>Akutmottagningen</td><td>3.2%</td><td>2.8%</td><td>6.0%</td><td>+0.8%</td></tr>
        <tr><td>IVA</td><td>1.5%</td><td>0.8%</td><td>2.3%</td><td>-0.5%</td></tr>
    </tbody>
</MudSimpleTable>

@code {
    private RehabRad? _valdRad;

    private void Valj(RehabRad rad) => _valdRad = _valdRad == rad ? null : rad;

    private List<RehabRad> _rader =
    [
        new("Karl Berg", "Upprepad korttidsfrånvaro", "Aktiv", Color.Info, "2026-03-28", "Anna HR"),
        new("Helena Bergström", "Långtidssjuk >14 dagar", "Väntar uppföljning", Color.Warning, "2026-03-20", "Anna HR"),
        new("Per Gustafsson", "Sjukfrånvaro >6 tillfällen/12 mån", "Aktiv", Color.Info, "2026-04-05", "Erik Chef"),
    ];

    private record RehabRad(string Namn, string Trigger, string StatusText, Color StatusFarg, string NastaUppfoljning, string Agare);

    // --- Rehabkedjan ---
    private static readonly List<RehabMilstolpe> _rehabkedja =
    [
        new(1, "Sjukanmälan", "Karensavdrag görs. Arbetsgivaren informeras.", Color.Success, true),
        new(8, "Läkarintyg krävs", "Den anställde måste lämna läkarintyg till arbetsgivaren.", Color.Success, true),
        new(14, "Anmälan till FK", "Arbetsgivaren anmäler till Försäkringskassan och upprättar rehabplan.", Color.Info, true),
        new(90, "FK prövar mot ordinarie arbete", "Försäkringskassan prövar om den anställde kan utföra sitt ordinarie arbete.", Color.Warning, false),
        new(180, "FK prövar mot hela arbetsmarknaden", "Arbetsförmåga prövas mot alla arbeten på hela arbetsmarknaden.", Color.Warning, false),
        new(365, "FK prövar mot normalt förekommande arbete", "Arbetsförmåga prövas mot normalt förekommande arbete. Viktig brytpunkt.", Color.Error, false),
        new(550, "Slutgiltigt beslut", "Försäkringskassan fattar slutgiltigt beslut om sjukpenning.", Color.Error, false),
    ];

    private static readonly List<RehabArendePosition> _rehabArenden =
    [
        new("Helena Bergström", 22, 90, "Rehabplan upprättad, dag 14-anmälan gjord",
            "FK prövar mot ordinarie arbete", true, "Dag 90 närmar sig (68 dagar kvar) — förbered underlag för FK-prövning"),
        new("Karl Berg", 45, 90, "Uppföljningssamtal genomfört, anpassad arbetsåtergång diskuteras",
            "FK prövar mot ordinarie arbete", false, ""),
        new("Erik Nilsson", 160, 180, "Arbetsförmåga prövad mot ordinarie arbete — ej tillräcklig",
            "FK prövar mot hela arbetsmarknaden", true, "Dag 180 om 20 dagar — förbered dokumentation för vidare prövning"),
        new("Sofia Larsson", 340, 365, "Arbetsträning pågår 50%, prognos positiv",
            "FK prövar mot normalt förekommande arbete", true, "Dag 365 om 25 dagar — kritisk brytpunkt, boka möte med den anställde"),
    ];

    private static int RehabProgress(int dag) => Math.Min(100, (int)(dag * 100.0 / 550));

    private static Color RehabProgressFarg(int dag) => dag switch
    {
        >= 365 => Color.Error,
        >= 180 => Color.Warning,
        >= 90 => Color.Info,
        _ => Color.Success,
    };

    private record RehabMilstolpe(int Dag, string Titel, string Beskrivning, Color Farg, bool Passerad);
    private record RehabArendePosition(string Namn, int SjukDag, int NastaMilstolpe, string NuvarandeFas, string NastaAtgard, bool AkutPaminnelse, string Paminnelse);
}
