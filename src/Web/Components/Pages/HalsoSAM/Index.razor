@page "/halsosam"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.HalsoSAM.Domain
@using RegionHR.Infrastructure.Persistence
@using Microsoft.EntityFrameworkCore
@inject RegionHRDbContext Db

<PageTitle>OpenHR — HälsoSAM</PageTitle>

<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4" Style="font-weight: 700;">HälsoSAM — Rehabilitering</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
               Href="/halsosam/ny" StartIcon="@Icons.Material.Filled.Add" Style="min-height: 48px;">
        Nytt rehabärende
    </MudButton>
</div>

<MudText Typo="Typo.body2" Class="mb-4" Style="color: var(--mud-palette-text-secondary);">
    Rehabärenden hämtas från databasen. Milstolpar (dag 14/90/180/365) är planerade uppföljningsdatum
    beräknade från ärendets skapandedatum — inte verifierade mot faktisk sjukfallsstart.
</MudText>

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error">@_error</MudAlert>
}
else
{
    @* KPI *@
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="2" Style="border-top: 4px solid var(--mud-palette-error);">
                <MudText Typo="Typo.h3" Color="Color.Error" Style="font-weight: 700;">@_cases.Count(c => c.Status != RehabStatus.Avslutad)</MudText>
                <MudText Typo="Typo.body2">Aktiva ärenden</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="2" Style="border-top: 4px solid var(--mud-palette-warning);">
                <MudText Typo="Typo.h3" Color="Color.Warning" Style="font-weight: 700;">@CountUpcomingMilestones()</MudText>
                <MudText Typo="Typo.body2">Kommande milstolpar (30 dagar)</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="2">
                <MudText Typo="Typo.h3" Style="font-weight: 700;">@_cases.Count</MudText>
                <MudText Typo="Typo.body2">Totalt i systemet</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="2">
                <MudText Typo="Typo.h3" Style="font-weight: 700;">@_cases.Count(c => c.Status == RehabStatus.Avslutad)</MudText>
                <MudText Typo="Typo.body2">Avslutade</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* Rehabkedjan — statisk referens *@
    <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight: 600;">Rehabkedjan — lagstadgade milstolpar (referens)</MudText>
    <MudAlert Severity="Severity.Info" Variant="Variant.Text" Class="mb-4" Dense="true">
        Dessa milstolpar är lagstadgade steg i den svenska rehabkedjan. I v1.5 beräknas planerade datum
        från ärendets skapandedatum, inte från verifierat sjukfallsstartdatum.
    </MudAlert>
    <MudTimeline TimelineAlign="TimelineAlign.Start" Class="mb-6">
        <MudTimelineItem Color="Color.Success" Size="Size.Small"><MudText Typo="Typo.body2"><strong>Dag 1:</strong> Sjukanmälan, karensavdrag</MudText></MudTimelineItem>
        <MudTimelineItem Color="Color.Success" Size="Size.Small"><MudText Typo="Typo.body2"><strong>Dag 8:</strong> Läkarintyg krävs</MudText></MudTimelineItem>
        <MudTimelineItem Color="Color.Info" Size="Size.Small"><MudText Typo="Typo.body2"><strong>Dag 14:</strong> Anmälan till FK, rehabplan upprättas</MudText></MudTimelineItem>
        <MudTimelineItem Color="Color.Warning" Size="Size.Small"><MudText Typo="Typo.body2"><strong>Dag 90:</strong> FK prövar mot ordinarie arbete</MudText></MudTimelineItem>
        <MudTimelineItem Color="Color.Warning" Size="Size.Small"><MudText Typo="Typo.body2"><strong>Dag 180:</strong> FK prövar mot hela arbetsmarknaden</MudText></MudTimelineItem>
        <MudTimelineItem Color="Color.Error" Size="Size.Small"><MudText Typo="Typo.body2"><strong>Dag 365:</strong> FK prövar mot normalt förekommande arbete</MudText></MudTimelineItem>
    </MudTimeline>

    @* Rehabärenden från DB *@
    <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight: 600;">Rehabärenden</MudText>

    @if (_cases.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Text">Inga rehabärenden i databasen.</MudAlert>
    }
    else
    {
        <MudSimpleTable Hover="true" Elevation="2">
            <thead>
                <tr><th>Anställd</th><th>Trigger</th><th>Status</th><th>Skapad</th><th>Nästa milstolpe</th><th>Rehabplan</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var c in _cases.OrderByDescending(c => c.SkapadVid))
                {
                    var empNamn = GetEmployeeName(c.AnstallId);
                    var nasta = GetNastaMilstolpe(c);
                    <tr style="cursor: pointer;" @onclick="@(() => _expanded = _expanded == c ? null : c)">
                        <td><strong>@empNamn</strong></td>
                        <td>@TriggerText(c.Trigger)</td>
                        <td><MudChip T="string" Size="Size.Small" Color="@StatusFarg(c.Status)">@StatusText(c.Status)</MudChip></td>
                        <td>@c.SkapadVid.ToLocalTime().ToString("yyyy-MM-dd")</td>
                        <td>
                            @if (nasta != null)
                            {
                                var dagar = (nasta.Value.Datum - DateTime.UtcNow).Days;
                                <MudChip T="string" Size="Size.Small" Color="@(dagar < 0 ? Color.Error : dagar < 14 ? Color.Warning : Color.Info)">
                                    Dag @nasta.Value.DagNr (@(dagar < 0 ? $"{-dagar}d sedan" : $"om {dagar}d"))
                                </MudChip>
                            }
                            else
                            {
                                <MudText Typo="Typo.caption">Alla passerade</MudText>
                            }
                        </td>
                        <td>@(string.IsNullOrEmpty(c.RehabPlan) ? "—" : "Ja")</td>
                        <td><MudIconButton Icon="@(_expanded == c ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" Size="Size.Small" /></td>
                    </tr>

                    @if (_expanded == c)
                    {
                        <tr>
                            <td colspan="7" style="padding: 0;">
                                <MudPaper Class="pa-5" Elevation="0" Style="border-top: 2px solid var(--mud-palette-primary); background: var(--mud-palette-background);">
                                    <MudText Typo="Typo.subtitle1" Class="mb-3" Style="font-weight: 600;">@empNamn — Rehabdetaljer</MudText>

                                    <MudGrid Spacing="3" Class="mb-4">
                                        <MudItem xs="6" sm="3">
                                            <MudText Typo="Typo.caption">Trigger</MudText>
                                            <MudText Style="font-weight: 600;">@TriggerText(c.Trigger)</MudText>
                                        </MudItem>
                                        <MudItem xs="6" sm="3">
                                            <MudText Typo="Typo.caption">Ärendeägare HR</MudText>
                                            <MudText Style="font-weight: 600;">@(c.ArendeagareHR != null ? GetEmployeeName(c.ArendeagareHR.Value) : "Ej tilldelad")</MudText>
                                        </MudItem>
                                        <MudItem xs="6" sm="3">
                                            <MudText Typo="Typo.caption">Status</MudText>
                                            <MudText Style="font-weight: 600;">@StatusText(c.Status)</MudText>
                                        </MudItem>
                                        <MudItem xs="6" sm="3">
                                            <MudText Typo="Typo.caption">Rehabplan</MudText>
                                            <MudText Style="font-weight: 600;">@(c.RehabPlan ?? "Ej upprättad")</MudText>
                                        </MudItem>
                                    </MudGrid>

                                    <MudText Typo="Typo.subtitle2" Class="mb-2" Style="font-weight: 600;">Milstolpar (planerade uppföljningsdatum)</MudText>
                                    <MudTimeline TimelineAlign="TimelineAlign.Start" Class="mb-3">
                                        @foreach (var ms in GetMilstolpar(c))
                                        {
                                            var passerad = ms.Datum < DateTime.UtcNow;
                                            <MudTimelineItem Color="@(passerad ? Color.Success : Color.Default)" Size="Size.Small"
                                                             Variant="@(passerad ? Variant.Filled : Variant.Outlined)">
                                                <MudText Typo="Typo.body2">
                                                    <strong>Dag @ms.DagNr</strong> — @ms.Datum.ToLocalTime().ToString("yyyy-MM-dd")
                                                    @if (passerad) { <MudChip T="string" Size="Size.Small" Color="Color.Success">Passerad</MudChip> }
                                                </MudText>
                                            </MudTimelineItem>
                                        }
                                    </MudTimeline>
                                </MudPaper>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </MudSimpleTable>
    }
}

@code {
    private List<RehabCase> _cases = [];
    private Dictionary<RegionHR.SharedKernel.Domain.EmployeeId, string> _empNames = new();
    private RehabCase? _expanded;
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _cases = await Db.RehabCases.ToListAsync();
            var employees = await Db.Employees.ToListAsync();
            _empNames = employees.ToDictionary(
                e => e.Id,
                e => $"{e.Fornamn} {e.Efternamn}");
        }
        catch (Exception ex) { _error = $"Kunde inte hämta data: {ex.Message}"; }
        finally { _loading = false; }
    }

    private string GetEmployeeName(RegionHR.SharedKernel.Domain.EmployeeId id) =>
        _empNames.TryGetValue(id, out var namn) ? namn : "Okänd";

    private record Milstolpe(int DagNr, DateTime Datum);

    private List<Milstolpe> GetMilstolpar(RehabCase c)
    {
        var list = new List<Milstolpe>();
        if (c.Uppfoljning14Dagar.HasValue) list.Add(new(14, c.Uppfoljning14Dagar.Value));
        if (c.Uppfoljning90Dagar.HasValue) list.Add(new(90, c.Uppfoljning90Dagar.Value));
        if (c.Uppfoljning180Dagar.HasValue) list.Add(new(180, c.Uppfoljning180Dagar.Value));
        if (c.Uppfoljning365Dagar.HasValue) list.Add(new(365, c.Uppfoljning365Dagar.Value));
        return list;
    }

    private (int DagNr, DateTime Datum)? GetNastaMilstolpe(RehabCase c)
    {
        var milstolpar = GetMilstolpar(c);
        var nasta = milstolpar.Where(m => m.Datum > DateTime.UtcNow).OrderBy(m => m.Datum).FirstOrDefault();
        if (nasta != null) return (nasta.DagNr, nasta.Datum);
        // Om alla passerade: visa senaste som redan passerad
        var senaste = milstolpar.OrderByDescending(m => m.Datum).FirstOrDefault();
        return senaste != null ? (senaste.DagNr, senaste.Datum) : null;
    }

    private int CountUpcomingMilestones()
    {
        var inom30 = DateTime.UtcNow.AddDays(30);
        return _cases.Sum(c => GetMilstolpar(c).Count(m => m.Datum > DateTime.UtcNow && m.Datum <= inom30));
    }

    private static string TriggerText(RehabTrigger t) => t switch
    {
        RehabTrigger.SexTillfallenTolvManader => "6+ sjuktillfällen/12 mån",
        RehabTrigger.FjortonSammanhangandeDagar => "14+ sammanhängande dagar",
        RehabTrigger.MonsterDetekterat => "Mönster detekterat",
        RehabTrigger.ChefInitierat => "Chef initierat",
        RehabTrigger.MedarbetareInitierat => "Medarbetare initierat",
        _ => t.ToString()
    };

    private static string StatusText(RehabStatus s) => s switch
    {
        RehabStatus.Signal => "Signal",
        RehabStatus.UnderUtredning => "Under utredning",
        RehabStatus.AktivRehab => "Aktiv rehab",
        RehabStatus.Uppfoljning => "Uppföljning",
        RehabStatus.Avslutad => "Avslutad",
        _ => s.ToString()
    };

    private static Color StatusFarg(RehabStatus s) => s switch
    {
        RehabStatus.Signal => Color.Warning,
        RehabStatus.UnderUtredning => Color.Info,
        RehabStatus.AktivRehab => Color.Primary,
        RehabStatus.Uppfoljning => Color.Success,
        RehabStatus.Avslutad => Color.Default,
        _ => Color.Default
    };
}
