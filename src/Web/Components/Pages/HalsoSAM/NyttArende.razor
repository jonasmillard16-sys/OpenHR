@page "/halsosam/ny"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.HalsoSAM.Domain
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<RegionHRDbContext> DbFactory
@inject NavigationManager Nav

<PageTitle>OpenHR - Nytt rehabärende</PageTitle>
<MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Variant="Variant.Text" Color="Color.Primary" Href="/halsosam" Style="margin-bottom: 1rem;">Tillbaka</MudButton>

<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">Nytt rehabärende</MudText>

@if (_loading) { <MudProgressCircular Color="Color.Primary" Indeterminate="true" /> }
else if (_error != null) { <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert> }
else if (_created)
{
    <MudPaper Class="pa-5" Elevation="2" Style="border-left: 4px solid var(--mud-palette-success);">
        <MudText Typo="Typo.h6" Color="Color.Success" Style="font-weight: 700;" Class="mb-3">Rehabärende skapat</MudText>
        <MudText Typo="Typo.body1" Class="mb-3">Ärende för @_valdAnstallNamn — @_valdOrsak</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/halsosam">Tillbaka till översikt</MudButton>
    </MudPaper>
}
else
{
    <MudPaper Class="pa-5" Elevation="2">
        <MudGrid Spacing="3">
            <MudItem xs="12" sm="6">
                <MudSelect T="Guid?" @bind-Value="_formAnstallId" Label="Anställd" Variant="Variant.Outlined" Required="true">
                    @foreach (var e in _employees)
                    { <MudSelectItem T="Guid?" Value="@((Guid?)e.Id.Value)">@e.Fornamn @e.Efternamn</MudSelectItem> }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect T="string" @bind-Value="_valdOrsak" Label="Orsak / Trigger" Variant="Variant.Outlined" Required="true">
                    <MudSelectItem Value="@("Upprepad korttidsfrånvaro")">Upprepad korttidsfrånvaro</MudSelectItem>
                    <MudSelectItem Value="@("Långtidssjuk >14 dagar")">Långtidssjuk >14 dagar</MudSelectItem>
                    <MudSelectItem Value="@("Sjukfrånvaro >6 tillfällen/12 mån")">Sjukfrånvaro >6 tillfällen/12 mån</MudSelectItem>
                    <MudSelectItem Value="@("Arbetsrelaterad ohälsa")">Arbetsrelaterad ohälsa</MudSelectItem>
                </MudSelect>
            </MudItem>
        </MudGrid>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Class="mt-4" Style="min-height: 48px;"
                   OnClick="Skapa" Disabled="@(_formAnstallId == null || string.IsNullOrWhiteSpace(_valdOrsak) || _saving)">
            Skapa rehabärende
        </MudButton>
    </MudPaper>
}

@code {
    private List<RegionHR.Core.Domain.Employee> _employees = [];
    private Guid? _formAnstallId;
    private string _valdOrsak = "", _valdAnstallNamn = "";
    private bool _loading = true, _saving, _created;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        try { _employees = await db.Employees.OrderBy(e => e.Efternamn).ToListAsync(); }
        catch (Exception ex) { _error = $"Kunde inte hämta data: {ex.Message}"; }
        finally { _loading = false; }
    }

    private async Task Skapa()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        if (_formAnstallId == null || string.IsNullOrWhiteSpace(_valdOrsak)) return;
        _saving = true; _error = null;
        try
        {
            var emp = _employees.FirstOrDefault(e => e.Id.Value == _formAnstallId.Value);
            _valdAnstallNamn = emp != null ? $"{emp.Fornamn} {emp.Efternamn}" : "Okänd";
            var trigger = _valdOrsak switch
            {
                "Upprepad korttidsfrånvaro" => RehabTrigger.MonsterDetekterat,
                "Långtidssjuk >14 dagar" => RehabTrigger.FjortonSammanhangandeDagar,
                "Sjukfrånvaro >6 tillfällen/12 mån" => RehabTrigger.SexTillfallenTolvManader,
                _ => RehabTrigger.ChefInitierat
            };
            var rehab = RehabCase.Skapa(new RegionHR.SharedKernel.Domain.EmployeeId(_formAnstallId.Value), trigger);
            db.RehabCases.Add(rehab);
            await db.SaveChangesAsync();
            _created = true;
        }
        catch (Exception ex) { _error = $"Kunde inte skapa: {ex.Message}"; }
        finally { _saving = false; }
    }
}

