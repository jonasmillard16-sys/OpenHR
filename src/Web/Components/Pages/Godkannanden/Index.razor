@page "/godkannanden"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.CaseManagement.Domain
@using RegionHR.SharedKernel.Domain
@using RegionHR.Infrastructure.Persistence
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<RegionHRDbContext> DbFactory
@inject ISnackbar Snackbar

<OhrBreadcrumb CurrentPage="Godkännanden" />

<PageTitle>OpenHR — Godkännanden</PageTitle>

<MudText Typo="Typo.h4" Class="mb-2" Style="font-weight: 700;">Godkännanden</MudText>
<MudText Typo="Typo.body2" Class="mb-4" Style="color: var(--mud-palette-text-secondary);">
    Här ser du ärenden som väntar på ditt godkännande, till exempel ledighetsansökningar och anställningsändringar.
</MudText>

<OhrStatusLegend Items="@_legend" />

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error">@_error</MudAlert>
}
else if (_pending.Count == 0)
{
    <MudAlert Severity="Severity.Success" Variant="Variant.Text">Inga väntande godkännanden.</MudAlert>
}
else
{
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="6" sm="4">
            <MudPaper Class="pa-4 text-center" Elevation="2" Style="border-top: 4px solid var(--mud-palette-warning);">
                <MudText Typo="Typo.h3" Color="Color.Warning" Style="font-weight: 700;">@_pending.Count</MudText>
                <MudText Typo="Typo.body2">Väntar godkännande</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudSimpleTable Hover="true" Elevation="2">
        <thead>
            <tr><th>Typ</th><th>Anställd</th><th>Beskrivning</th><th>Steg</th><th>Godkännare</th><th>Skapad</th><th></th></tr>
        </thead>
        <tbody>
            @foreach (var c in _pending)
            {
                var pendingApproval = c.Godkannanden.LastOrDefault(g => g.Status == ApprovalStatus.Vantar);
                <tr>
                    <td><MudChip T="string" Size="Size.Small">@c.Typ</MudChip></td>
                    <td><strong>@GetEmployeeName(c.AnstallId)</strong></td>
                    <td>@c.Beskrivning</td>
                    <td>@(c.AktuellSteg ?? "—")</td>
                    <td>@(pendingApproval != null ? GetEmployeeName(pendingApproval.GodkannareId) : "—")</td>
                    <td>@c.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")</td>
                    <td>
                        <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Success"
                                   OnClick="@(async () => await GodkannCase(c))">Godkänn</MudButton>
                        @* Avslå borttaget i v1.5 — domänmetod Case.Avsla() saknas.
                           Att kringgå med reflection är inte acceptabelt i runtime. *@
                    </td>
                </tr>
            }
        </tbody>
    </MudSimpleTable>
}

@code {
    private List<Case> _pending = [];
    private Dictionary<EmployeeId, string> _empNames = new();
    private bool _loading = true;
    private string? _error;

    private readonly List<OhrStatusLegend.StatusLegendItem> _legend =
    [
        new("Väntar", Color.Warning, "Ärende väntar på godkännande"),
        new("Godkänd", Color.Success, "Ärende är godkänt"),
        new("Avslagen", Color.Error, "Ärende har avslagits"),
    ];

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        try
        {
            _pending = await db.Cases
                .Include("Godkannanden")
                .Where(c => c.Status == CaseStatus.VantarGodkannande)
                .OrderByDescending(c => c.CreatedAt)
                .ToListAsync();

            var employees = await db.Employees.ToListAsync();
            _empNames = employees.ToDictionary(e => e.Id, e => $"{e.Fornamn} {e.Efternamn}");
        }
        catch (Exception ex) { _error = $"Kunde inte hämta data: {ex.Message}"; }
        finally { _loading = false; }
    }

    private string GetEmployeeName(EmployeeId id) =>
        _empNames.TryGetValue(id, out var namn) ? namn : "Okänd";

    private async Task GodkannCase(Case c)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var approval = c.Godkannanden.LastOrDefault(g => g.Status == ApprovalStatus.Vantar);
        if (approval == null) return;

        // Använder domänmetod Case.Godkann()
        c.Godkann(approval.GodkannareId);
        await db.SaveChangesAsync();
        _pending.Remove(c);
        Snackbar.Add($"Ärende godkänt: {c.Beskrivning}", MudBlazor.Severity.Success);
    }

    // Avslå borttaget i v1.5 — Case.Avsla() domänmetod saknas.
    // Tilläggs när domänmodellen utökas med riktig avslagslogik.
}

