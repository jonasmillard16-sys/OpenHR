@page "/las"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Web.Components.Shared
@using RegionHR.Infrastructure.Persistence
@using RegionHR.LAS.Domain
@using RegionHR.SharedKernel.Domain
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<RegionHRDbContext> DbFactory
@inject ISnackbar Snackbar

<PageTitle>OpenHR - LAS-uppföljning</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">LAS-uppföljning</MudText>

@if (_loading) { <MudProgressCircular Color="Color.Primary" Indeterminate="true" /> }
else if (_error != null) { <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert> }
else
{
    <MudGrid Spacing="3" Class="mb-6">
        <MudItem xs="4"><MudPaper Class="pa-4 text-center" Elevation="2" Style="border-top: 4px solid var(--mud-palette-error);"><MudText Typo="Typo.h3" Color="Color.Error" Style="font-weight: 700;">@_rader.Count(a => a.Status == LASStatus.KritiskNara)</MudText><MudText Typo="Typo.body2">Kritiska (>330 dagar)</MudText></MudPaper></MudItem>
        <MudItem xs="4"><MudPaper Class="pa-4 text-center" Elevation="2" Style="border-top: 4px solid var(--mud-palette-warning);"><MudText Typo="Typo.h3" Color="Color.Warning" Style="font-weight: 700;">@_rader.Count(a => a.Status == LASStatus.NaraGrans)</MudText><MudText Typo="Typo.body2">Varning (>300 dagar)</MudText></MudPaper></MudItem>
        <MudItem xs="4"><MudPaper Class="pa-4 text-center" Elevation="2" Style="border-top: 4px solid var(--mud-palette-success);"><MudText Typo="Typo.h3" Color="Color.Success" Style="font-weight: 700;">@_rader.Count(a => a.Status == LASStatus.UnderGrans)</MudText><MudText Typo="Typo.body2">Under gräns</MudText></MudPaper></MudItem>
    </MudGrid>

    @if (_rader.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Text">Inga LAS-ackumuleringar registrerade.</MudAlert>
    }
    else
    {
        <MudText Typo="Typo.h6" Class="mb-3">LAS-ackumuleringar</MudText>
        <MudSimpleTable Hover="true" Elevation="2">
            <thead><tr><th>Anställd</th><th>Form</th><th>Ackumulerat</th><th>Gräns</th><th>Status</th><th></th></tr></thead>
            <tbody>
                @foreach (var r in _rader)
                {
                    var grans = r.Anstallningsform == RegionHR.SharedKernel.Domain.EmploymentType.SAVA ? 365 : 730;
                    <tr>
                        <td><strong>@r.Namn</strong></td>
                        <td>@r.Anstallningsform</td>
                        <td>@r.AckumuleradeDagar dagar</td>
                        <td>@grans</td>
                        <td><MudChip T="string" Size="Size.Small" Color="@StatusFarg(r.Status)">@StatusText(r.Status)</MudChip></td>
                        <td><MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary" OnClick="@(() => _valdAck = _valdAck == r ? null : r)">Visa</MudButton></td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>

        @if (_valdAck != null)
        {
            <MudPaper Class="pa-5 mt-4" Elevation="3" Style="border-left: 4px solid var(--mud-palette-primary);">
                <div class="d-flex justify-space-between align-center mb-3">
                    <MudText Typo="Typo.h6" Style="font-weight: 700;">@_valdAck.Namn — LAS-detaljer</MudText>
                    <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="@(() => _valdAck = null)" />
                </div>
                <MudGrid Spacing="3" Class="mb-3">
                    <MudItem xs="6" sm="3"><MudText Typo="Typo.caption">Anställningsform</MudText><MudText Typo="Typo.h6" Style="font-weight: 600;">@_valdAck.Anstallningsform</MudText></MudItem>
                    <MudItem xs="6" sm="3"><MudText Typo="Typo.caption">Ackumulerade dagar</MudText><MudText Typo="Typo.h6" Style="font-weight: 700;" Color="@StatusFarg(_valdAck.Status)">@_valdAck.AckumuleradeDagar</MudText></MudItem>
                    <MudItem xs="6" sm="3"><MudText Typo="Typo.caption">Företrädesrätt</MudText><MudText Typo="Typo.h6">@(_valdAck.Ack.HarForetradesratt ? $"Ja (utgår {_valdAck.Ack.ForetradesrattUtgar?.ToString("yyyy-MM-dd")})" : "Nej")</MudText></MudItem>
                </MudGrid>
                @if (_valdAck.Ack.Perioder.Count > 0)
                {
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Perioder</MudText>
                    <MudSimpleTable Dense="true" Elevation="0" Class="mb-3">
                        <thead><tr><th>Från</th><th>Till</th><th>Dagar</th></tr></thead>
                        <tbody>
                            @foreach (var p in _valdAck.Ack.Perioder)
                            {
                                <tr><td>@p.StartDatum.ToString("yyyy-MM-dd")</td><td>@p.SlutDatum.ToString("yyyy-MM-dd")</td><td>@p.AntalDagar</td></tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                }
            </MudPaper>
        }
    }
}

@code {
    private List<LASVm> _rader = [];
    private LASVm? _valdAck;
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        try
        {
            var accs = await db.LASAccumulations.ToListAsync();
            var empIds = accs.Select(a => a.AnstallId).Distinct().ToList();
            var employees = await db.Employees.Where(e => empIds.Contains(e.Id)).ToListAsync();
            var names = employees.ToDictionary(e => e.Id.Value, e => $"{e.Fornamn} {e.Efternamn}");

            _rader = accs
                .OrderByDescending(a => a.AckumuleradeDagar)
                .Select(a => new LASVm(names.GetValueOrDefault(a.AnstallId.Value, "Okänd"), a.Anstallningsform, a.AckumuleradeDagar, a.Status, a))
                .ToList();
        }
        catch (Exception ex) { _error = $"Kunde inte hämta LAS-data: {ex.Message}"; }
        finally { _loading = false; }
    }

    private static string StatusText(LASStatus s) => s switch
    {
        LASStatus.UnderGrans => "Under gräns", LASStatus.NaraGrans => "Nära gräns",
        LASStatus.KritiskNara => "Kritisk", LASStatus.KonverteradTillTillsvidare => "Konverterad",
        _ => s.ToString()
    };
    private static Color StatusFarg(LASStatus s) => s switch
    {
        LASStatus.KritiskNara => Color.Error, LASStatus.NaraGrans => Color.Warning,
        LASStatus.UnderGrans => Color.Success, LASStatus.KonverteradTillTillsvidare => Color.Info,
        _ => Color.Default
    };

    private record LASVm(string Namn, EmploymentType Anstallningsform, int AckumuleradeDagar, LASStatus Status, LASAccumulation Ack);
}

