@page "/rapporter/kostnadssimulering"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.SharedKernel.Domain
@using Microsoft.EntityFrameworkCore
@inject RegionHRDbContext Db

<PageTitle>OpenHR - Kostnadssimulering</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">Kostnadssimulering</MudText>

@if (_loading) { <MudProgressCircular Color="Color.Primary" Indeterminate="true" /> }
else if (_error != null) { <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert> }
else
{
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="6" sm="3"><MudPaper Class="pa-4 text-center" Elevation="2"><MudText Typo="Typo.caption">Total lönekostnad/mån</MudText><MudText Typo="Typo.h5" Style="font-weight: 700;">@FormatKr(_totalLonekostnad)</MudText></MudPaper></MudItem>
        <MudItem xs="6" sm="3"><MudPaper Class="pa-4 text-center" Elevation="2"><MudText Typo="Typo.caption">AG-avgifter/mån</MudText><MudText Typo="Typo.h5" Style="font-weight: 700;">@FormatKr(_totalAg)</MudText></MudPaper></MudItem>
        <MudItem xs="6" sm="3"><MudPaper Class="pa-4 text-center" Elevation="2"><MudText Typo="Typo.caption">Totalkostnad/mån</MudText><MudText Typo="Typo.h5" Color="Color.Primary" Style="font-weight: 700;">@FormatKr(_totalLonekostnad + _totalAg)</MudText></MudPaper></MudItem>
        <MudItem xs="6" sm="3"><MudPaper Class="pa-4 text-center" Elevation="2"><MudText Typo="Typo.caption">Budgeterade positioner</MudText><MudText Typo="Typo.h5" Style="font-weight: 700;">@FormatKr(_budgeteradePositioner)</MudText></MudPaper></MudItem>
    </MudGrid>

    <MudText Typo="Typo.h6" Class="mb-3">Per enhet</MudText>
    @if (_perEnhet.Count > 0)
    {
        <MudSimpleTable Hover="true" Elevation="1">
            <thead><tr><th>Enhet</th><th>Anställda</th><th>Total lön/mån</th><th>AG-avgifter</th><th>Totalkostnad</th></tr></thead>
            <tbody>
                @foreach (var e in _perEnhet)
                {
                    var ag = e.TotalLon * 0.3142m;
                    <tr><td><strong>@e.Namn</strong></td><td>@e.Antal</td><td>@FormatKr(e.TotalLon)</td><td>@FormatKr(ag)</td><td>@FormatKr(e.TotalLon + ag)</td></tr>
                }
            </tbody>
        </MudSimpleTable>
    }
}

@code {
    private decimal _totalLonekostnad, _totalAg, _budgeteradePositioner;
    private List<EnhetKostnad> _perEnhet = [];
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var idag = DateOnly.FromDateTime(DateTime.Today);
            var employees = await Db.Employees.Include(e => e.Anstallningar).ToListAsync();
            var enheter = await Db.OrganizationUnits.ToListAsync();
            var enhetNamn = enheter.ToDictionary(e => e.Id.Value, e => e.Namn);
            var positions = await Db.Positions_Table.ToListAsync();

            _perEnhet = employees.Where(e => e.AktivAnstallning(idag) != null)
                .GroupBy(e => e.AktivAnstallning(idag)!.EnhetId.Value)
                .Select(g => new EnhetKostnad(enhetNamn.GetValueOrDefault(g.Key, "Okänd"), g.Count(), g.Sum(e => e.AktivAnstallning(idag)!.Manadslon.Amount)))
                .OrderByDescending(e => e.TotalLon).ToList();

            _totalLonekostnad = _perEnhet.Sum(e => e.TotalLon);
            _totalAg = _totalLonekostnad * 0.3142m;
            _budgeteradePositioner = positions.Sum(p => p.BudgeteradManadslon);
        }
        catch (Exception ex) { _error = $"Kunde inte beräkna kostnader: {ex.Message}"; }
        finally { _loading = false; }
    }

    private static string FormatKr(decimal v) => $"{v:N0} kr";
    private record EnhetKostnad(string Namn, int Antal, decimal TotalLon);
}
