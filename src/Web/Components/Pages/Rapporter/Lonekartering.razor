@page "/rapporter/lonekartering"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Payroll.Domain
@using RegionHR.SharedKernel.Domain
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<RegionHRDbContext> DbFactory

<PageTitle>OpenHR - Lönekartering</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">Lönekartering</MudText>
<MudText Typo="Typo.body2" Class="mb-4" Style="color: var(--mud-palette-text-secondary);">Analys av löneskillnader enligt diskrimineringslagen.</MudText>

@if (_loading) { <MudProgressCircular Color="Color.Primary" Indeterminate="true" /> }
else if (_error != null) { <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert> }
else if (_rader.Count == 0) { <MudAlert Severity="Severity.Info" Variant="Variant.Text">Inga lönedata att kartera. Kör en lönekörning först.</MudAlert> }
else
{
    <MudSimpleTable Hover="true" Elevation="2">
        <thead><tr><th>Anställd</th><th>Befattning</th><th>Månadslön</th><th>Sysselsättning</th><th>Avvikelse från snitt</th></tr></thead>
        <tbody>
            @foreach (var r in _rader)
            {
                var avv = r.Lon - _snittlon;
                var pct = _snittlon > 0 ? (avv / _snittlon * 100) : 0;
                <tr>
                    <td><strong>@r.Namn</strong></td>
                    <td>@r.Befattning</td>
                    <td>@r.Lon.ToString("N0") kr</td>
                    <td>@r.Sysselsattning%</td>
                    <td><MudChip T="string" Size="Size.Small" Color="@(Math.Abs(pct) > 15 ? Color.Warning : Color.Success)">@(pct >= 0 ? "+" : "")@pct.ToString("F1")%</MudChip></td>
                </tr>
            }
        </tbody>
    </MudSimpleTable>
    <MudText Typo="Typo.body2" Class="mt-3" Style="color: var(--mud-palette-text-secondary);">Snittlön: @_snittlon.ToString("N0") kr. Avvikelser >15% markeras.</MudText>
}

@code {
    private List<LonRad> _rader = [];
    private decimal _snittlon;
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        try
        {
            var idag = DateOnly.FromDateTime(DateTime.Today);
            var employees = await db.Employees.Include(e => e.Anstallningar).ToListAsync();
            _rader = employees
                .Where(e => e.AktivAnstallning(idag) != null)
                .Select(e =>
                {
                    var a = e.AktivAnstallning(idag)!;
                    return new LonRad($"{e.Fornamn} {e.Efternamn}", a.Befattningstitel ?? "—", a.Manadslon.Amount, a.Sysselsattningsgrad.Value);
                })
                .OrderByDescending(r => r.Lon).ToList();
            _snittlon = _rader.Count > 0 ? _rader.Average(r => r.Lon) : 0;
        }
        catch (Exception ex) { _error = $"Kunde inte beräkna lönekartering: {ex.Message}"; }
        finally { _loading = false; }
    }

    private record LonRad(string Namn, string Befattning, decimal Lon, decimal Sysselsattning);
}

