@page "/rapporter"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Reporting.Domain
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<RegionHRDbContext> DbFactory

<PageTitle>OpenHR - Rapporter</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">Rapportbibliotek</MudText>

<MudGrid Spacing="3" Class="mb-6">
    <MudItem xs="4"><MudPaper Class="pa-4 text-center" Elevation="2" Style="border-top: 4px solid var(--mud-palette-primary);"><MudText Typo="Typo.h3" Color="Color.Primary" Style="font-weight: 700;">12</MudText><MudText Typo="Typo.body2">Standardrapporter</MudText></MudPaper></MudItem>
    <MudItem xs="4"><MudPaper Class="pa-4 text-center" Elevation="2" Style="border-top: 4px solid var(--mud-palette-info);"><MudText Typo="Typo.h3" Color="Color.Info" Style="font-weight: 700;">3</MudText><MudText Typo="Typo.body2">Schemalagda</MudText></MudPaper></MudItem>
    <MudItem xs="4"><MudPaper Class="pa-4 text-center" Elevation="2" Style="border-top: 4px solid var(--mud-palette-success);"><MudText Typo="Typo.h3" Color="Color.Success" Style="font-weight: 700;">47</MudText><MudText Typo="Typo.body2">Körda senaste 30 d</MudText></MudPaper></MudItem>
</MudGrid>

<MudText Typo="Typo.h6" Class="mb-3">Standardrapporter</MudText>
<MudSimpleTable Hover="true" Elevation="2">
    <thead><tr><th>Rapport</th><th>Beskrivning</th><th>Kategori</th><th>Format</th><th>Åtgärd</th></tr></thead>
    <tbody>
        <tr><td><strong>Personalförteckning</strong></td><td>Komplett lista över aktiva anställda med befattning och enhet</td><td>Personal</td><td>Excel / PDF</td><td><MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" Href="/rapporter/kor/Personalförteckning">Kör</MudButton></td></tr>
        <tr><td><strong>Löneregister</strong></td><td>Lönespecifikationer per period med brutto, netto och avdrag</td><td>Lön</td><td>Excel / PDF</td><td><MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" Href="/rapporter/kor/Löneregister">Kör</MudButton></td></tr>
        <tr><td><strong>Frånvarostatistik</strong></td><td>Sjukfrånvaro, VAB och övrig frånvaro per enhet och period</td><td>Frånvaro</td><td>Excel / PDF</td><td><MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" Href="/rapporter/kor/Frånvarostatistik">Kör</MudButton></td></tr>
        <tr><td><strong>LAS-status</strong></td><td>Ackumulerade dagar för vikarier och SAVA med varningsnivåer</td><td>Juridik</td><td>Excel / PDF</td><td><MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" Href="/rapporter/kor/LAS-status">Kör</MudButton></td></tr>
        <tr><td><strong>Bemanningsanalys</strong></td><td>Bemanningsgrad per enhet, dag och skifttyp med avvikelser</td><td>Schema</td><td>Excel / PDF</td><td><MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" Href="/rapporter/kor/Bemanningsanalys">Kör</MudButton></td></tr>
    </tbody>
</MudSimpleTable>

<MudText Typo="Typo.h6" Class="mt-6 mb-3">Schemalagda rapporter</MudText>
<MudPaper Elevation="2" Class="pa-4">
    @if (_scheduledReports.Count == 0)
    {
        <MudText Typo="Typo.body2" Color="Color.Tertiary">Inga schemalagda rapporter konfigurerade.</MudText>
    }
    else
    {
        <MudSimpleTable Hover="true">
            <thead>
                <tr>
                    <th>Rapport</th>
                    <th>Cron-uttryck</th>
                    <th>Mottagare</th>
                    <th>Aktiv</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in _scheduledReports)
                {
                    <tr>
                        <td><strong>@r.Namn</strong></td>
                        <td><MudChip T="string" Size="Size.Small" Color="Color.Default">@r.CronExpression</MudChip></td>
                        <td>@(r.MottagareEpost ?? "—")</td>
                        <td>
                            <MudSwitch T="bool" Value="@r.ArSchemalagd" Color="Color.Success" ReadOnly="true" />
                        </td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    }
</MudPaper>

@code {
    private List<ReportDefinition> _scheduledReports = [];

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        try
        {
            _scheduledReports = await db.ReportDefinitions
                .Where(r => r.CronExpression != null)
                .OrderBy(r => r.Namn)
                .ToListAsync();
        }
        catch
        {
            // DB may not be available in dev
        }
    }
}

