@page "/rapporter/flight-risk"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Analytics
@using RegionHR.Infrastructure.Persistence
@using Microsoft.EntityFrameworkCore
@inject FlightRiskService RiskService
@inject RegionHRDbContext Db

<PageTitle>OpenHR — Uppsägningsrisk</PageTitle>

<MudText Typo="Typo.h4" Class="mb-2" Style="font-weight: 700;">Uppsägningsrisk</MudText>
<MudText Typo="Typo.body2" Class="mb-4" Style="color: var(--mud-palette-text-secondary);">
    Regelbaserad heuristik (v1) — beräknad från anställningsdata i realtid. Inte en prediktiv AI-modell.
</MudText>

@if (_loading)
{
    <div style="text-align: center; padding: 3rem;">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        <MudText Typo="Typo.body1" Class="mt-3">Beräknar riskpoäng från personaldata...</MudText>
    </div>
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
}
else if (_results.Count == 0)
{
    <MudAlert Severity="Severity.Info" Class="mb-4">
        Inga anställda med aktiv anställning hittades i databasen.
    </MudAlert>
}
else
{
    @* KPI-kort *@
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="2" Style="border-top: 4px solid var(--mud-palette-error);">
                <MudText Typo="Typo.h3" Color="Color.Error" Style="font-weight: 700;">@_results.Count(r => r.Niva == FlightRiskNiva.Hog)</MudText>
                <MudText Typo="Typo.body2">Hög risk (51+)</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="2" Style="border-top: 4px solid var(--mud-palette-warning);">
                <MudText Typo="Typo.h3" Color="Color.Warning" Style="font-weight: 700;">@_results.Count(r => r.Niva == FlightRiskNiva.Medel)</MudText>
                <MudText Typo="Typo.body2">Medel risk (31-50)</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="2" Style="border-top: 4px solid var(--mud-palette-success);">
                <MudText Typo="Typo.h3" Color="Color.Success" Style="font-weight: 700;">@_results.Count(r => r.Niva == FlightRiskNiva.Lag)</MudText>
                <MudText Typo="Typo.body2">Låg risk (0-30)</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="2">
                <MudText Typo="Typo.h3" Style="font-weight: 700;">@_results.Count</MudText>
                <MudText Typo="Typo.body2">Analyserade</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* Metodik *@
    <MudAlert Severity="Severity.Info" Class="mb-4" Variant="Variant.Text" Dense="true">
        <strong>Beräkningsmetod (v1):</strong> Regelbaserad poäng 0-70 från 4 signaler:
        Tenure 2-4 år (+25), Tidsbegränsad anställning (+20), Bristyrke-heuristik (+15), Deltid &lt;75% (+10).
        Bristyrke identifieras via enkel textmatchning på befattningstitel — inte en kvalificerad klassificering.
    </MudAlert>

    @* Resultattabell *@
    <MudSimpleTable Hover="true" Elevation="2">
        <thead>
            <tr>
                <th>Anställd</th>
                <th>Befattning</th>
                <th>Form</th>
                <th>Tenure</th>
                <th>Lön</th>
                <th>Poäng</th>
                <th>Nivå</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in _results)
            {
                <tr style="cursor: pointer;" @onclick="@(() => _expanded = _expanded == r ? null : r)">
                    <td><strong>@r.Namn</strong></td>
                    <td>@r.Befattning</td>
                    <td>@r.Anstallningsform</td>
                    <td>@r.TenureAr år</td>
                    <td>@r.Manadslon.ToString("N0") kr</td>
                    <td><strong>@r.Poang</strong> / @r.MaxPoang</td>
                    <td>
                        <MudChip T="string" Size="Size.Small" Color="@NivaFarg(r.Niva)">
                            @NivaText(r.Niva)
                        </MudChip>
                    </td>
                    <td>
                        <MudIconButton Icon="@(_expanded == r ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                       Size="Size.Small" />
                    </td>
                </tr>
                @if (_expanded == r)
                {
                    <tr>
                        <td colspan="8" style="padding: 0;">
                            <MudPaper Class="pa-5" Elevation="0" Style="border-top: 2px solid var(--mud-palette-primary); background: var(--mud-palette-background);">
                                <MudText Typo="Typo.subtitle1" Class="mb-3" Style="font-weight: 600;">
                                    Riskfaktorer för @r.Namn
                                </MudText>
                                @if (r.Faktorer.Count == 0)
                                {
                                    <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
                                        Inga riskfaktorer identifierade — poäng 0.
                                    </MudText>
                                }
                                else
                                {
                                    <MudSimpleTable Dense="true" Elevation="1">
                                        <thead>
                                            <tr><th>Signal</th><th>Poäng</th><th>Beskrivning</th><th>Datakälla</th></tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var f in r.Faktorer)
                                            {
                                                <tr>
                                                    <td><strong>@f.Signal</strong></td>
                                                    <td>+@f.Poang</td>
                                                    <td>@f.Beskrivning</td>
                                                    <td><code>@f.Datakalla</code></td>
                                                </tr>
                                            }
                                        </tbody>
                                    </MudSimpleTable>
                                }
                            </MudPaper>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </MudSimpleTable>
}

@code {
    private List<FlightRiskResult> _results = [];
    private FlightRiskResult? _expanded;
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var employees = await Db.Employees
                .Include(e => e.Anstallningar)
                .ToListAsync();

            _results = RiskService.BeraknaForAlla(employees);
        }
        catch (Exception ex)
        {
            _error = $"Kunde inte hämta personaldata: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private static Color NivaFarg(FlightRiskNiva niva) => niva switch
    {
        FlightRiskNiva.Hog => Color.Error,
        FlightRiskNiva.Medel => Color.Warning,
        FlightRiskNiva.Lag => Color.Success,
        _ => Color.Default
    };

    private static string NivaText(FlightRiskNiva niva) => niva switch
    {
        FlightRiskNiva.Hog => "Hög",
        FlightRiskNiva.Medel => "Medel",
        FlightRiskNiva.Lag => "Låg",
        _ => "—"
    };
}
