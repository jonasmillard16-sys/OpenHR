@page "/rapporter/analytics"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Positions.Domain
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<RegionHRDbContext> DbFactory

<PageTitle>OpenHR - Workforce Analytics</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">Workforce Analytics</MudText>

@if (_loading) { <MudProgressCircular Color="Color.Primary" Indeterminate="true" /> }
else if (_error != null) { <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert> }
else
{
    <MudGrid Spacing="3" Class="mb-6">
        <MudItem xs="6" sm="3"><MudPaper Class="pa-4 text-center" Elevation="2"><MudText Typo="Typo.h4" Color="Color.Primary" Style="font-weight: 700;">@_totalAnstallda</MudText><MudText Typo="Typo.body2">Anställda</MudText></MudPaper></MudItem>
        <MudItem xs="6" sm="3"><MudPaper Class="pa-4 text-center" Elevation="2"><MudText Typo="Typo.h4" Color="Color.Success" Style="font-weight: 700;">@_tillsvidareanstallda</MudText><MudText Typo="Typo.body2">Tillsvidareanställda</MudText></MudPaper></MudItem>
        <MudItem xs="6" sm="3"><MudPaper Class="pa-4 text-center" Elevation="2"><MudText Typo="Typo.h4" Color="Color.Warning" Style="font-weight: 700;">@_vikarier</MudText><MudText Typo="Typo.body2">Vikarier/SAVA</MudText></MudPaper></MudItem>
        <MudItem xs="6" sm="3"><MudPaper Class="pa-4 text-center" Elevation="2"><MudText Typo="Typo.h4" Style="font-weight: 700;">@_snittalder</MudText><MudText Typo="Typo.body2">Snittålder</MudText></MudPaper></MudItem>
    </MudGrid>

    <MudText Typo="Typo.h6" Class="mb-3">Per enhet</MudText>
    @if (_perEnhet.Count > 0)
    {
        <MudSimpleTable Hover="true" Elevation="1">
            <thead><tr><th>Enhet</th><th>Antal</th><th>Tillsvidare</th><th>Vikarier</th></tr></thead>
            <tbody>
                @foreach (var e in _perEnhet) { <tr><td><strong>@e.Namn</strong></td><td>@e.Antal</td><td>@e.Tillsvidare</td><td>@e.Vikarier</td></tr> }
            </tbody>
        </MudSimpleTable>
    }
}

@code {
    private int _totalAnstallda, _tillsvidareanstallda, _vikarier, _snittalder;
    private List<EnhetAnalys> _perEnhet = [];
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        try
        {
            var idag = DateOnly.FromDateTime(DateTime.Today);
            var employees = await db.Employees.Include(e => e.Anstallningar).ToListAsync();
            _totalAnstallda = employees.Count;
            _tillsvidareanstallda = employees.Count(e => e.AktivAnstallning(idag)?.ArTillsvidareanstallning == true);
            _vikarier = employees.Count(e => e.AktivAnstallning(idag)?.ArTidsbegransad == true);

            var enheter = await db.OrganizationUnits.ToListAsync();
            var enhetNamn = enheter.ToDictionary(e => e.Id.Value, e => e.Namn);
            _perEnhet = employees
                .Where(e => e.AktivAnstallning(idag) != null)
                .GroupBy(e => e.AktivAnstallning(idag)!.EnhetId.Value)
                .Select(g => new EnhetAnalys(
                    enhetNamn.GetValueOrDefault(g.Key, "Okänd"),
                    g.Count(),
                    g.Count(e => e.AktivAnstallning(idag)!.ArTillsvidareanstallning),
                    g.Count(e => e.AktivAnstallning(idag)!.ArTidsbegransad)))
                .OrderByDescending(e => e.Antal).ToList();

            // Approximate age from personnummer
            var ages = employees.Select(e =>
            {
                try { return DateTime.Today.Year - int.Parse(e.Personnummer.ToString()[..4]); } catch { return 0; }
            }).Where(a => a > 0 && a < 100).ToList();
            _snittalder = ages.Count > 0 ? (int)ages.Average() : 0;
        }
        catch (Exception ex) { _error = $"Kunde inte beräkna analytics: {ex.Message}"; }
        finally { _loading = false; }
    }

    private record EnhetAnalys(string Namn, int Antal, int Tillsvidare, int Vikarier);
}

