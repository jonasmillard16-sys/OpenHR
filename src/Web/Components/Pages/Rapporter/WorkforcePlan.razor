@page "/rapporter/workforce-plan"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Core.Domain
@using RegionHR.Positions.Domain
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Infrastructure.Payroll
@using RegionHR.SharedKernel.Domain
@using Microsoft.EntityFrameworkCore
@inject RegionHRDbContext Db
@inject SwedishTaxCalculator TaxCalc

<PageTitle>OpenHR — Bemanningsrapport</PageTitle>

<MudText Typo="Typo.h4" Class="mb-2" Style="font-weight: 700;">Bemanningsrapport</MudText>
<MudText Typo="Typo.body2" Class="mb-4" Style="color: var(--mud-palette-text-secondary);">
    Headcount, lönekostnad, arbetsgivaravgift och vakansgrad per enhet.
    Beräknat från verkliga anställnings- och positionsdata i databasen.
    Arbetsgivaravgift: @((TaxCalc.Arbetsgivaravgift * 100).ToString("F2"))% (SwedishTaxCalculator).
</MudText>

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error">@_error</MudAlert>
}
else
{
    @* Totala KPI:er *@
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="2">
                <MudText Typo="Typo.h3" Color="Color.Primary" Style="font-weight: 700;">@_rows.Sum(r => r.Headcount)</MudText>
                <MudText Typo="Typo.body2">Anställda (aktiva)</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="2">
                <MudText Typo="Typo.h3" Style="font-weight: 700;">@(_rows.Sum(r => r.Lonekostnad).ToString("N0")) kr</MudText>
                <MudText Typo="Typo.body2">Lönekostnad/mån</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="2">
                <MudText Typo="Typo.h3" Style="font-weight: 700;">@(_rows.Sum(r => r.AGAvgift).ToString("N0")) kr</MudText>
                <MudText Typo="Typo.body2">AG-avgift/mån</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="2">
                <MudText Typo="Typo.h3" Color="@(_totalVakansgrad > 10 ? Color.Warning : Color.Success)" Style="font-weight: 700;">
                    @(_totalVakansgrad.ToString("F0"))%
                </MudText>
                <MudText Typo="Typo.body2">Vakansgrad</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* Per enhet *@
    <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight: 600;">Per enhet</MudText>
    <MudSimpleTable Hover="true" Elevation="2" Class="mb-6">
        <thead>
            <tr><th>Enhet</th><th>Headcount</th><th>Lönekostnad/mån</th><th>AG-avgift/mån</th><th>Total kostnad/mån</th><th>Positioner</th><th>Vakanta</th><th>Vakansgrad</th></tr>
        </thead>
        <tbody>
            @foreach (var r in _rows.OrderByDescending(r => r.Headcount))
            {
                <tr>
                    <td><strong>@r.EnhetNamn</strong></td>
                    <td>@r.Headcount</td>
                    <td>@r.Lonekostnad.ToString("N0") kr</td>
                    <td>@r.AGAvgift.ToString("N0") kr</td>
                    <td><strong>@r.TotalKostnad.ToString("N0") kr</strong></td>
                    <td>@r.AntalPositioner</td>
                    <td>@r.Vakanta</td>
                    <td>
                        <MudChip T="string" Size="Size.Small" Color="@(r.VakansgradProcent > 20 ? Color.Error : r.VakansgradProcent > 0 ? Color.Warning : Color.Success)">
                            @r.VakansgradProcent.ToString("F0")%
                        </MudChip>
                    </td>
                </tr>
            }
            <tr style="font-weight: 700; border-top: 2px solid var(--mud-palette-lines-default);">
                <td>Totalt</td>
                <td>@_rows.Sum(r => r.Headcount)</td>
                <td>@_rows.Sum(r => r.Lonekostnad).ToString("N0") kr</td>
                <td>@_rows.Sum(r => r.AGAvgift).ToString("N0") kr</td>
                <td>@_rows.Sum(r => r.TotalKostnad).ToString("N0") kr</td>
                <td>@_rows.Sum(r => r.AntalPositioner)</td>
                <td>@_rows.Sum(r => r.Vakanta)</td>
                <td>@_totalVakansgrad.ToString("F0")%</td>
            </tr>
        </tbody>
    </MudSimpleTable>

    @* Budget vs faktiskt *@
    @if (_budgetRows.Count > 0)
    {
        <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight: 600;">Budget vs faktiskt (@DateTime.Today.Year)</MudText>
        <MudSimpleTable Hover="true" Elevation="2">
            <thead>
                <tr><th>Enhet</th><th>Budg. pos.</th><th>Fakt. pos.</th><th>Budg. kostnad</th><th>Fakt. kostnad</th><th>Avvikelse</th></tr>
            </thead>
            <tbody>
                @foreach (var b in _budgetRows)
                {
                    var avvikelse = b.FaktiskKostnad - b.BudgeteradKostnad;
                    <tr>
                        <td><strong>@b.EnhetNamn</strong></td>
                        <td>@b.BudgeteradePositioner</td>
                        <td>@b.FaktiskaPositioner</td>
                        <td>@b.BudgeteradKostnad.ToString("N0") kr</td>
                        <td>@b.FaktiskKostnad.ToString("N0") kr</td>
                        <td>
                            <MudChip T="string" Size="Size.Small" Color="@(avvikelse > 0 ? Color.Error : avvikelse < 0 ? Color.Success : Color.Default)">
                                @(avvikelse > 0 ? "+" : "")@avvikelse.ToString("N0") kr
                            </MudChip>
                        </td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    }
}

@code {
    private List<EnhetRad> _rows = [];
    private List<BudgetRad> _budgetRows = [];
    private double _totalVakansgrad;
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var idag = DateOnly.FromDateTime(DateTime.Today);
            var agSats = TaxCalc.Arbetsgivaravgift;

            // Hämta data
            var employees = await Db.Employees.Include(e => e.Anstallningar).ToListAsync();
            var positions = await Db.Positions_Table.ToListAsync();
            var enheter = await Db.OrganizationUnits.ToListAsync();
            var budgets = await Db.HeadcountPlans.Where(h => h.Ar == DateTime.Today.Year).ToListAsync();

            var enhetNamn = enheter.ToDictionary(e => e.Id.Value, e => e.Namn);

            // Beräkna per enhet
            // Aktiv anställning: Employment.Giltighetsperiod.IsActiveOn(idag)
            var aktivaAnstallningar = employees
                .SelectMany(e => e.Anstallningar
                    .Where(a => a.Giltighetsperiod.IsActiveOn(idag))
                    .Select(a => new { Employee = e, Employment = a }))
                .ToList();

            var perEnhet = aktivaAnstallningar
                .GroupBy(x => x.Employment.EnhetId)
                .Select(g =>
                {
                    var enhetId = g.Key;
                    var headcount = g.Count();
                    var lonekostnad = g.Sum(x => x.Employment.Manadslon.Amount);
                    var agAvgift = Math.Round(lonekostnad * agSats, 0);
                    var positioner = positions.Where(p => p.EnhetId == enhetId.Value).ToList();
                    var vakanta = positioner.Count(p => p.Status == PositionStatus.Vakant);
                    var totalPos = positioner.Count;
                    var vakansgrad = totalPos > 0 ? (double)vakanta / totalPos * 100 : 0;

                    return new EnhetRad(
                        enhetNamn.TryGetValue(enhetId.Value, out var namn) ? namn : "Okänd enhet",
                        headcount, lonekostnad, agAvgift, lonekostnad + agAvgift,
                        totalPos, vakanta, Math.Round(vakansgrad, 0));
                })
                .ToList();

            _rows = perEnhet;

            var totalPos = _rows.Sum(r => r.AntalPositioner);
            _totalVakansgrad = totalPos > 0 ? (double)_rows.Sum(r => r.Vakanta) / totalPos * 100 : 0;

            // Budget vs faktiskt
            _budgetRows = budgets.Select(b => new BudgetRad(
                enhetNamn.TryGetValue(b.EnhetId, out var n) ? n : "Okänd",
                b.BudgeteradePositioner, b.FaktiskaPositioner,
                b.BudgeteradKostnad, b.FaktiskKostnad
            )).ToList();
        }
        catch (Exception ex) { _error = $"Kunde inte beräkna: {ex.Message}"; }
        finally { _loading = false; }
    }

    private record EnhetRad(string EnhetNamn, int Headcount, decimal Lonekostnad, decimal AGAvgift, decimal TotalKostnad, int AntalPositioner, int Vakanta, double VakansgradProcent);
    private record BudgetRad(string EnhetNamn, int BudgeteradePositioner, int FaktiskaPositioner, decimal BudgeteradKostnad, decimal FaktiskKostnad);
}
