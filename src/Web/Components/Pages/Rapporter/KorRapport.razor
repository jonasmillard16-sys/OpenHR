@page "/rapporter/kor/{Namn}"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<RegionHRDbContext> DbFactory
@inject IJSRuntime JS

<PageTitle>OpenHR - @Namn</PageTitle>
<MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Variant="Variant.Text" Color="Color.Primary" Href="/rapporter" Style="margin-bottom: 1rem;">Tillbaka</MudButton>

<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">@Namn</MudText>

@if (_running)
{
    <div style="text-align: center; padding: 2rem;">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        <MudText Typo="Typo.h6" Class="mt-4">Genererar rapport...</MudText>
    </div>
}
else if (_result != null)
{
    <MudAlert Severity="Severity.Success" Class="mb-4">Rapport genererad med @_result.Count rader.</MudAlert>

    <MudSimpleTable Hover="true" Elevation="2" Class="mb-4">
        <thead><tr>@foreach (var h in _headers) { <th>@h</th> }</tr></thead>
        <tbody>
            @foreach (var row in _result.Take(20))
            {
                <tr>@foreach (var cell in row) { <td>@cell</td> }</tr>
            }
        </tbody>
    </MudSimpleTable>

    @if (_result.Count > 20)
    {
        <MudText Typo="Typo.body2" Class="mb-4" Style="color: var(--mud-palette-text-secondary);">Visar 20 av @_result.Count rader. Ladda ner för komplett data.</MudText>
    }

    <div class="d-flex gap-2">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" StartIcon="@Icons.Material.Filled.Download" Style="min-height: 48px;" OnClick="ExporteraExcel">
            Ladda ner som Excel
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Large" StartIcon="@Icons.Material.Filled.ContentCopy" Style="min-height: 48px;" OnClick="VisaCsv">
            Exportera CSV
        </MudButton>
    </div>

    @if (_visarCsv)
    {
        <MudPaper Class="pa-4 mt-4" Elevation="2" Style="border-left: 4px solid var(--mud-palette-primary);">
            <div class="d-flex justify-space-between align-center mb-3">
                <MudText Typo="Typo.h6" Style="font-weight: 600;">CSV-export — @Namn</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="@(() => _visarCsv = false)" />
            </div>
            <MudTextField T="string" Value="@_csvInnehall" Variant="Variant.Outlined" Lines="12"
                          Style="font-family: 'Courier New', monospace; font-size: 0.8rem;" ReadOnly="true" />
            <div class="d-flex gap-2 mt-3">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.ContentCopy" OnClick="KopieraCsv">
                    @(_kopierad ? "Kopierat!" : "Kopiera till urklipp")
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.Download" OnClick="LaddaNerCsv">
                    Ladda ner CSV
                </MudButton>
            </div>
        </MudPaper>
    }
}

@code {
    [Parameter] public string Namn { get; set; } = "";
    private bool _running = true;
    private string? _error;
    private List<string> _headers = [];
    private List<List<string>> _result = [];

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        await Task.Delay(500); // Simulate generation time

        switch (Namn)
        {
            case "Personalförteckning":
                _headers = ["Namn", "Personnummer", "Enhet", "Befattning", "Anställd sedan"];
                try
                {
                    var emps = await db.Employees.Include(e => e.Anstallningar).Take(100).ToListAsync();
                    _result = emps.Select(e => new List<string>
                    {
                        $"{e.Fornamn} {e.Efternamn}",
                        e.Personnummer.ToMaskedString(),
                        "-",
                        e.Anstallningar.FirstOrDefault()?.Befattningstitel ?? "-",
                        e.Anstallningar.FirstOrDefault()?.Giltighetsperiod.Start.ToString() ?? "-"
                    }).ToList();
                }
                catch (Exception ex) { _error = $"Kunde inte hämta personalförteckning: {ex.Message}"; }
                break;

            case "Löneregister":
                _headers = ["Namn", "Personnummer", "Befattning", "Brutto", "Skatt", "Netto", "AG-avgift"];
                try
                {
                    var loneEmps = await db.Employees.Include(e => e.Anstallningar).Take(100).ToListAsync();
                    _result = loneEmps.Select(e =>
                    {
                        var anst = e.Anstallningar.FirstOrDefault();
                        var brutto = anst?.Manadslon.Amount ?? 30000m;
                        var skatt = Math.Round(brutto * 0.32m, 0);
                        var netto = brutto - skatt;
                        var avgift = Math.Round(brutto * 0.3142m, 0);
                        return new List<string>
                        {
                            $"{e.Fornamn} {e.Efternamn}", e.Personnummer.ToMaskedString(),
                            anst?.Befattningstitel ?? "—",
                            $"{brutto:N0} kr", $"-{skatt:N0} kr", $"{netto:N0} kr", $"{avgift:N0} kr"
                        };
                    }).ToList();
                }
                catch (Exception ex) { _error = $"Kunde inte hämta löneregister: {ex.Message}"; }
                break;

            case "Frånvarostatistik":
                _headers = ["Typ", "Antal ansökningar", "Totalt dagar"];
                try
                {
                    var leaves = await db.LeaveRequests.ToListAsync();
                    _result = leaves.GroupBy(l => l.Typ).Select(g => new List<string>
                        { g.Key.ToString(), g.Count().ToString(), g.Sum(l => l.AntalDagar).ToString() }).ToList();
                }
                catch (Exception ex) { _error = $"Kunde inte hämta frånvarostatistik: {ex.Message}"; }
                break;

            case "LAS-status":
                _headers = ["Namn", "Anställningsform", "Ackumulerade dagar", "Status"];
                try
                {
                    var accs = await db.LASAccumulations.ToListAsync();
                    var lasEmpIds = accs.Select(a => a.AnstallId.Value).Distinct().ToList();
                    var lasEmps = await db.Employees.Where(e => lasEmpIds.Contains(e.Id.Value)).ToListAsync();
                    var lasNames = lasEmps.ToDictionary(e => e.Id.Value, e => $"{e.Fornamn} {e.Efternamn}");
                    _result = accs.OrderByDescending(a => a.AckumuleradeDagar).Select(a => new List<string>
                        { lasNames.GetValueOrDefault(a.AnstallId.Value, "Okänd"), a.Anstallningsform.ToString(), a.AckumuleradeDagar.ToString(), a.Status.ToString() }).ToList();
                }
                catch (Exception ex) { _error = $"Kunde inte hämta LAS-status: {ex.Message}"; }
                break;

            case "Bemanningsanalys":
                _headers = ["Enhet", "Dag", "Kväll", "Natt", "Totalt"];
                try
                {
                    var idagBem = DateOnly.FromDateTime(DateTime.Today);
                    var todayShifts = await db.ScheduledShifts.Where(s => s.Datum == idagBem).ToListAsync();
                    var bemEmps = await db.Employees.Include(e => e.Anstallningar).ToListAsync();
                    var empEnhBem = new Dictionary<Guid, Guid>();
                    foreach (var be in bemEmps) { var ba = be.AktivAnstallning(idagBem); if (ba != null) empEnhBem[be.Id.Value] = ba.EnhetId.Value; }
                    var enhBem = await db.OrganizationUnits.ToListAsync();
                    _result = enhBem.Select(enhet => {
                        var es = todayShifts.Where(s => empEnhBem.GetValueOrDefault(s.AnstallId.Value) == enhet.Id.Value).ToList();
                        return new List<string> { enhet.Namn, es.Count(s => s.PassTyp == RegionHR.Scheduling.Domain.ShiftType.Dag).ToString(), es.Count(s => s.PassTyp == RegionHR.Scheduling.Domain.ShiftType.Kvall).ToString(), es.Count(s => s.PassTyp == RegionHR.Scheduling.Domain.ShiftType.Natt).ToString(), es.Count.ToString() };
                    }).Where(r => int.Parse(r[4]) > 0).ToList();
                }
                catch (Exception ex) { _error = $"Kunde inte hämta bemanningsanalys: {ex.Message}"; }
                break;

            default:
                _headers = ["Kolumn 1", "Kolumn 2", "Kolumn 3"];
                _result = [["Ingen data tillgänglig för denna rapport", "", ""]];
                break;
        }
        _running = false;
    }

    private bool _visarCsv;
    private string _csvInnehall = "";
    private bool _kopierad;

    private string GenereraCsv()
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine(string.Join(";", _headers));
        foreach (var row in _result)
            sb.AppendLine(string.Join(";", row));
        return sb.ToString();
    }

    private void VisaCsv()
    {
        _csvInnehall = GenereraCsv();
        _visarCsv = true;
        _kopierad = false;
    }

    private async Task KopieraCsv()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", _csvInnehall);
        _kopierad = true;
    }

    private async Task LaddaNerCsv()
    {
        var bytes = System.Text.Encoding.UTF8.GetBytes(_csvInnehall);
        var base64 = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("downloadFile", $"{Namn}.csv", base64, "text/csv");
    }

    private async Task ExporteraExcel()
    {
        var csv = GenereraCsv();
        var bytes = System.Text.Encoding.UTF8.GetBytes(csv);
        var base64 = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("downloadFile", $"{Namn}.csv", base64, "text/csv");
    }
}

