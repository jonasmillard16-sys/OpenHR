@page "/karriar"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Competence.Domain
@using RegionHR.Infrastructure.Persistence
@using Microsoft.EntityFrameworkCore
@inject RegionHRDbContext Db

<PageTitle>OpenHR — Skills-katalog</PageTitle>

<MudText Typo="Typo.h4" Class="mb-2" Style="font-weight: 700;">Skills-katalog</MudText>
<MudText Typo="Typo.body2" Class="mb-4" Style="color: var(--mud-palette-text-secondary);">
    Organisationens normaliserade kompetenser. Data hämtas från databasen.
</MudText>

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error">@_error</MudAlert>
}
else
{
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="2">
                <MudText Typo="Typo.h3" Color="Color.Primary" Style="font-weight: 700;">@_skills.Count</MudText>
                <MudText Typo="Typo.body2">Skills i katalogen</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="2">
                <MudText Typo="Typo.h3" Style="font-weight: 700;">@_employeeSkills.Select(es => es.AnstallId).Distinct().Count()</MudText>
                <MudText Typo="Typo.body2">Anställda med skills</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="2">
                <MudText Typo="Typo.h3" Style="font-weight: 700;">@_employeeSkills.Count</MudText>
                <MudText Typo="Typo.body2">Registrerade kompetenser</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="2">
                <MudText Typo="Typo.h3" Style="font-weight: 700;">@_requirements.Count</MudText>
                <MudText Typo="Typo.body2">Positionskrav</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* Filter *@
    <div class="d-flex gap-2 mb-3">
        <MudChip T="string" Color="@(_filterKategori == null ? Color.Primary : Color.Default)"
                 OnClick="@(() => _filterKategori = null)">Alla (@_skills.Count)</MudChip>
        @foreach (var kat in Enum.GetValues<SkillCategory>())
        {
            var count = _skills.Count(s => s.Kategori == kat);
            <MudChip T="string" Color="@(_filterKategori == kat ? Color.Primary : Color.Default)"
                     OnClick="@(() => _filterKategori = kat)">@kat (@count)</MudChip>
        }
    </div>

    <MudSimpleTable Hover="true" Elevation="2">
        <thead>
            <tr><th>Skill</th><th>Kategori</th><th>Beskrivning</th><th>Anställda</th><th>Snitt nivå</th></tr>
        </thead>
        <tbody>
            @foreach (var s in FilteredSkills)
            {
                var empSkills = _employeeSkills.Where(es => es.SkillId == s.Id).ToList();
                var avgNiva = empSkills.Count > 0 ? empSkills.Average(es => es.Niva) : 0;
                <tr>
                    <td><strong>@s.Namn</strong></td>
                    <td><MudChip T="string" Size="Size.Small" Color="@KategoriFarg(s.Kategori)">@s.Kategori</MudChip></td>
                    <td>@(s.Beskrivning ?? "—")</td>
                    <td>@empSkills.Count</td>
                    <td>
                        @if (empSkills.Count > 0)
                        {
                            <MudRating ReadOnly="true" SelectedValue="@((int)Math.Round(avgNiva))" MaxValue="5" Size="Size.Small" />
                        }
                        else
                        {
                            <MudText Typo="Typo.caption">—</MudText>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </MudSimpleTable>

    @if (FilteredSkills.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Class="mt-4">Inga skills matchar filtret.</MudAlert>
    }
}

@code {
    private List<Skill> _skills = [];
    private List<EmployeeSkill> _employeeSkills = [];
    private List<PositionSkillRequirement> _requirements = [];
    private SkillCategory? _filterKategori;
    private bool _loading = true;
    private string? _error;

    private List<Skill> FilteredSkills => _filterKategori is null
        ? _skills
        : _skills.Where(s => s.Kategori == _filterKategori).ToList();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _skills = await Db.Skills.OrderBy(s => s.Kategori).ThenBy(s => s.Namn).ToListAsync();
            _employeeSkills = await Db.EmployeeSkills.ToListAsync();
            _requirements = await Db.PositionSkillRequirements.ToListAsync();
        }
        catch (Exception ex)
        {
            _error = $"Kunde inte hämta skills: {ex.Message}";
        }
        finally { _loading = false; }
    }

    private static Color KategoriFarg(SkillCategory k) => k switch
    {
        SkillCategory.Klinisk => Color.Error,
        SkillCategory.Teknisk => Color.Info,
        SkillCategory.Ledarskap => Color.Warning,
        SkillCategory.Administration => Color.Success,
        _ => Color.Default
    };
}
