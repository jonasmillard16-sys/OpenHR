@page "/karriar/min-utveckling"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Competence.Domain
@using RegionHR.Infrastructure.Persistence
@using Microsoft.EntityFrameworkCore
@inject RegionHRDbContext Db
@inject RegionHR.Web.Services.AuthService Auth

<PageTitle>OpenHR — Min utvecklingsplan</PageTitle>

<MudText Typo="Typo.h4" Class="mb-2" Style="font-weight: 700;">Min utvecklingsplan</MudText>
<MudText Typo="Typo.body2" Class="mb-4" Style="color: var(--mud-palette-text-secondary);">
    Dina registrerade kompetenser och eventuella gap mot din positions kravprofil.
</MudText>

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error">@_error</MudAlert>
}
else if (_mySkills.Count == 0 && _gapItems.Count == 0)
{
    <MudAlert Severity="Severity.Info">Inga kompetenser registrerade för dig ännu.</MudAlert>
}
else
{
    <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight: 600;">Dina kompetenser</MudText>
    @if (_mySkills.Count > 0)
    {
        <MudSimpleTable Hover="true" Elevation="2" Class="mb-4">
            <thead><tr><th>Skill</th><th>Kategori</th><th>Din nivå</th></tr></thead>
            <tbody>
                @foreach (var ms in _mySkills)
                {
                    <tr>
                        <td><strong>@ms.SkillNamn</strong></td>
                        <td><MudChip T="string" Size="Size.Small">@ms.Kategori</MudChip></td>
                        <td><MudRating ReadOnly="true" SelectedValue="@ms.Niva" MaxValue="5" Size="Size.Small" /></td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    }

    @if (_positionNamn != null)
    {
        <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight: 600;">Gap mot position: @_positionNamn</MudText>
        @if (_gapItems.Count > 0)
        {
            <MudSimpleTable Hover="true" Elevation="2" Class="mb-4">
                <thead><tr><th>Skill</th><th>Krävd nivå</th><th>Din nivå</th><th>Gap</th></tr></thead>
                <tbody>
                    @foreach (var g in _gapItems)
                    {
                        <tr>
                            <td><strong>@g.SkillNamn</strong></td>
                            <td><MudRating ReadOnly="true" SelectedValue="@g.KravdNiva" MaxValue="5" Size="Size.Small" /></td>
                            <td><MudRating ReadOnly="true" SelectedValue="@g.DinNiva" MaxValue="5" Size="Size.Small" /></td>
                            <td>
                                @if (g.Gap > 0)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Error">-@g.Gap</MudChip>
                                }
                                else
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Success">OK</MudChip>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        }
        else
        {
            <MudAlert Severity="Severity.Success" Variant="Variant.Text">Inga gap — du uppfyller alla krav för din position.</MudAlert>
        }
    }
    else
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Text" Class="mb-4">
            Ingen position kopplad — gap-analys ej tillgänglig.
        </MudAlert>
    }
}

@code {
    private List<MySkillVm> _mySkills = [];
    private List<GapVm> _gapItems = [];
    private string? _positionNamn;
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Hämta första anställd som har skills (i produktion: inloggad användare)
            var allSkills = await Db.Skills.ToListAsync();
            var allEmpSkills = await Db.EmployeeSkills.ToListAsync();

            // Hitta en anställd med skills att visa
            var anstallId = allEmpSkills.Select(es => es.AnstallId).Distinct().FirstOrDefault();
            if (anstallId == Guid.Empty) { _loading = false; return; }

            var myEmpSkills = allEmpSkills.Where(es => es.AnstallId == anstallId).ToList();
            _mySkills = myEmpSkills.Select(es =>
            {
                var skill = allSkills.FirstOrDefault(s => s.Id == es.SkillId);
                return new MySkillVm(skill?.Namn ?? "?", skill?.Kategori.ToString() ?? "?", es.Niva);
            }).OrderBy(s => s.SkillNamn).ToList();

            // Hitta position via InnehavareAnstallId
            var position = await Db.Positions_Table
                .FirstOrDefaultAsync(p => p.InnehavareAnstallId == anstallId);

            if (position != null)
            {
                _positionNamn = position.Titel;
                var krav = await Db.PositionSkillRequirements
                    .Where(r => r.PositionId == position.Id).ToListAsync();

                _gapItems = krav.Select(k =>
                {
                    var skill = allSkills.FirstOrDefault(s => s.Id == k.SkillId);
                    var empSkill = myEmpSkills.FirstOrDefault(es => es.SkillId == k.SkillId);
                    var dinNiva = empSkill?.Niva ?? 0;
                    return new GapVm(skill?.Namn ?? "?", k.MinNiva, dinNiva, Math.Max(0, k.MinNiva - dinNiva));
                }).OrderByDescending(g => g.Gap).ToList();
            }
        }
        catch (Exception ex) { _error = $"Kunde inte hämta data: {ex.Message}"; }
        finally { _loading = false; }
    }

    private record MySkillVm(string SkillNamn, string Kategori, int Niva);
    private record GapVm(string SkillNamn, int KravdNiva, int DinNiva, int Gap);
}
