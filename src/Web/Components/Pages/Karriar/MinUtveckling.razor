@page "/karriar/min-utveckling"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Competence.Domain
@using RegionHR.Core.Domain
@using RegionHR.Infrastructure.Persistence
@using Microsoft.EntityFrameworkCore
@inject RegionHRDbContext Db

<PageTitle>OpenHR — Utvecklingsplan</PageTitle>

<MudText Typo="Typo.h4" Class="mb-2" Style="font-weight: 700;">Utvecklingsplan</MudText>
<MudText Typo="Typo.body2" Class="mb-4" Style="color: var(--mud-palette-text-secondary);">
    Visa en anställds kompetenser och gap mot positionens kravprofil.
</MudText>

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error">@_error</MudAlert>
}
else
{
    <MudSelect T="Guid?" @bind-Value="_selectedAnstallId" Label="Välj anställd" Variant="Variant.Outlined"
               Class="mb-4" Style="max-width: 400px;">
        @foreach (var emp in _employeesWithSkills)
        {
            <MudSelectItem T="Guid?" Value="@((Guid?)emp.Id.Value)">@emp.Fornamn @emp.Efternamn</MudSelectItem>
        }
    </MudSelect>

    @if (_selectedAnstallId != null)
    {
        var selected = _employeesWithSkills.FirstOrDefault(e => e.Id.Value == _selectedAnstallId);
        if (selected != null)
        {
            var myEmpSkills = _allEmpSkills.Where(es => es.AnstallId == selected.Id.Value).ToList();

            <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight: 600;">
                Kompetenser — @selected.Fornamn @selected.Efternamn
            </MudText>

            @if (myEmpSkills.Count > 0)
            {
                <MudSimpleTable Hover="true" Elevation="2" Class="mb-4">
                    <thead><tr><th>Skill</th><th>Kategori</th><th>Nivå</th></tr></thead>
                    <tbody>
                        @foreach (var es in myEmpSkills)
                        {
                            var skill = _allSkills.FirstOrDefault(s => s.Id == es.SkillId);
                            <tr>
                                <td><strong>@(skill?.Namn ?? "?")</strong></td>
                                <td>@(skill?.Kategori.ToString() ?? "?")</td>
                                <td><MudRating ReadOnly="true" SelectedValue="@es.Niva" MaxValue="5" Size="Size.Small" /></td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            }
            else
            {
                <MudAlert Severity="Severity.Info" Class="mb-4">Inga kompetenser registrerade.</MudAlert>
            }

            var position = _allPositions.FirstOrDefault(p => p.InnehavareAnstallId == selected.Id.Value);

            @if (position != null)
            {
                var posKrav = _allRequirements.Where(r => r.PositionId == position.Id).ToList();
                <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight: 600;">
                    Gap mot position: @position.Titel
                </MudText>

                @if (posKrav.Count > 0)
                {
                    <MudSimpleTable Hover="true" Elevation="2" Class="mb-4">
                        <thead><tr><th>Skill</th><th>Krävd nivå</th><th>Anställds nivå</th><th>Status</th></tr></thead>
                        <tbody>
                            @foreach (var k in posKrav)
                            {
                                var skill = _allSkills.FirstOrDefault(s => s.Id == k.SkillId);
                                var empSkill = myEmpSkills.FirstOrDefault(es => es.SkillId == k.SkillId);
                                var dinNiva = empSkill?.Niva ?? 0;
                                <tr>
                                    <td>@(skill?.Namn ?? "?")</td>
                                    <td><MudRating ReadOnly="true" SelectedValue="@k.MinNiva" MaxValue="5" Size="Size.Small" /></td>
                                    <td><MudRating ReadOnly="true" SelectedValue="@dinNiva" MaxValue="5" Size="Size.Small" /></td>
                                    <td>
                                        @if (dinNiva >= k.MinNiva)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Success">Uppfylld</MudChip>
                                        }
                                        else if (dinNiva == 0)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Error">Saknas</MudChip>
                                        }
                                        else
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Warning">@dinNiva / @k.MinNiva</MudChip>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                }
                else
                {
                    <MudAlert Severity="Severity.Info">Positionen har inga definierade krav.</MudAlert>
                }
            }
            else
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Text" Class="mb-4">
                    Ingen position kopplad — gap-analys ej tillgänglig.
                </MudAlert>
            }
        }
    }
    else
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Text">Välj en anställd ovan för att se kompetenser och gap.</MudAlert>
    }
}

@code {
    private List<Employee> _employeesWithSkills = [];
    private List<Skill> _allSkills = [];
    private List<EmployeeSkill> _allEmpSkills = [];
    private List<PositionSkillRequirement> _allRequirements = [];
    private List<RegionHR.Positions.Domain.Position> _allPositions = [];
    private Guid? _selectedAnstallId;
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _allSkills = await Db.Skills.ToListAsync();
            _allEmpSkills = await Db.EmployeeSkills.ToListAsync();
            _allRequirements = await Db.PositionSkillRequirements.ToListAsync();
            _allPositions = await Db.Positions_Table
                .Where(p => p.InnehavareAnstallId != null)
                .ToListAsync();

            // Visa bara anställda som har minst en skill registrerad
            var anstallIdsWithSkills = _allEmpSkills.Select(es => es.AnstallId).Distinct().ToHashSet();
            var allEmployees = await Db.Employees.ToListAsync();
            _employeesWithSkills = allEmployees
                .Where(e => anstallIdsWithSkills.Contains(e.Id.Value))
                .OrderBy(e => e.Efternamn)
                .ToList();
        }
        catch (Exception ex) { _error = $"Kunde inte hämta data: {ex.Message}"; }
        finally { _loading = false; }
    }
}
