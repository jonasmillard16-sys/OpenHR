@page "/utbildning"
@rendermode InteractiveServer
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.LMS.Domain
@using Microsoft.EntityFrameworkCore
@inject RegionHRDbContext Db

<PageTitle>OpenHR - Utbildning</PageTitle>
<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4" Style="font-weight: 700;">Utbildningskatalog</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" StartIcon="@Icons.Material.Filled.Add" Style="min-height: 48px;">Ny utbildning</MudButton>
</div>

<MudSimpleTable Hover="true" Elevation="2">
    <thead>
        <tr>
            <th>Kursnamn</th>
            <th>Kategori</th>
            <th>Format</th>
            <th>Längd</th>
            <th>Anmälda</th>
            <th>Genomförda</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var c in _courses)
        {
            <tr>
                <td>@c.Namn</td>
                <td>@(c.ArObligatorisk ? "Obligatorisk" : (c.Kategori ?? "—"))</td>
                <td>@FormatText(c.Format)</td>
                <td>@LangdText(c.LangdMinuter)</td>
                <td>@AnmaladeCount(c.Id)</td>
                <td>@GenomfordaCount(c.Id)</td>
                <td><MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary" OnClick="@(() => ValjKurs(c))">Visa</MudButton></td>
            </tr>
            @if (_valdKurs == c)
            {
                <tr>
                    <td colspan="7">
                        <MudPaper Class="pa-4" Elevation="0" Style="background: var(--mud-palette-background-grey);">
                            <MudText Typo="Typo.subtitle1" Class="mb-2"><strong>@c.Namn</strong></MudText>
                            <MudText Typo="Typo.body2"><strong>Kategori:</strong> @(c.ArObligatorisk ? "Obligatorisk" : (c.Kategori ?? "—"))</MudText>
                            <MudText Typo="Typo.body2"><strong>Format:</strong> @FormatText(c.Format)</MudText>
                            <MudText Typo="Typo.body2"><strong>Längd:</strong> @LangdText(c.LangdMinuter)</MudText>
                            <MudText Typo="Typo.body2"><strong>Anmälda:</strong> @AnmaladeCount(c.Id)</MudText>
                            <MudText Typo="Typo.body2"><strong>Genomförda:</strong> @GenomfordaCount(c.Id)</MudText>
                            <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="@(() => _valdKurs = null)" Class="mt-2">Stäng</MudButton>
                        </MudPaper>
                    </td>
                </tr>
            }
        }
    </tbody>
</MudSimpleTable>

@code {
    private List<Course> _courses = [];
    private Course? _valdKurs;
    private List<CourseEnrollment> _enrollments = [];

    private void ValjKurs(Course c) => _valdKurs = _valdKurs == c ? null : c;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _courses = await Db.Courses
                .OrderByDescending(c => c.SkapadVid)
                .Take(50)
                .ToListAsync();

            var courseIds = _courses.Select(c => c.Id).ToList();
            _enrollments = await Db.CourseEnrollments
                .Where(e => courseIds.Contains(e.CourseId))
                .ToListAsync();
        }
        catch
        {
            // Demo data fallback
        }
    }

    private int AnmaladeCount(Guid courseId) =>
        _enrollments.Count(e => e.CourseId == courseId && e.Progress != EnrollmentProgress.Avbruten);

    private int GenomfordaCount(Guid courseId) =>
        _enrollments.Count(e => e.CourseId == courseId && e.Progress == EnrollmentProgress.Genomford);

    private static string FormatText(CourseFormat f) => f switch
    {
        CourseFormat.Klassrum => "Fysisk",
        CourseFormat.Elearning => "E-learning",
        CourseFormat.Blandat => "Hybrid",
        CourseFormat.Workshop => "Workshop",
        _ => f.ToString()
    };

    private static string LangdText(int minuter)
    {
        if (minuter >= 480) return $"{minuter / 480} dagar";
        if (minuter >= 60) return $"{minuter / 60} tim";
        return $"{minuter} min";
    }
}
