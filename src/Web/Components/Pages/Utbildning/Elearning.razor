@page "/utbildning/elearning"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.LMS.Domain
@using RegionHR.Infrastructure.Persistence
@using Microsoft.EntityFrameworkCore
@inject RegionHRDbContext Db

<PageTitle>OpenHR — E-learning</PageTitle>

<MudText Typo="Typo.h4" Class="mb-2" Style="font-weight: 700;">E-learning</MudText>
<MudText Typo="Typo.body2" Class="mb-4" Style="color: var(--mud-palette-text-secondary);">
    Kurskatalog och kursanmälningar från databasen. Adminvy.
</MudText>

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error">@_error</MudAlert>
}
else
{
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="2">
                <MudText Typo="Typo.h3" Color="Color.Primary" Style="font-weight: 700;">@_courses.Count</MudText>
                <MudText Typo="Typo.body2">Kurser</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="2">
                <MudText Typo="Typo.h3" Style="font-weight: 700;">@_enrollments.Count</MudText>
                <MudText Typo="Typo.body2">Anmälningar</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="2">
                <MudText Typo="Typo.h3" Color="Color.Warning" Style="font-weight: 700;">@_courses.Count(c => c.ArObligatorisk)</MudText>
                <MudText Typo="Typo.body2">Obligatoriska</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Class="pa-4 text-center" Elevation="2">
                <MudText Typo="Typo.h3" Color="Color.Success" Style="font-weight: 700;">@_enrollments.Count(e => e.Progress == EnrollmentProgress.Genomford)</MudText>
                <MudText Typo="Typo.body2">Genomförda</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* Ny anmälan *@
    @if (_showEnroll)
    {
        <MudPaper Class="pa-5 mb-4" Elevation="3" Style="border-left: 4px solid var(--mud-palette-primary);">
            <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight: 600;">Ny kursanmälan</MudText>
            <MudGrid Spacing="3">
                <MudItem xs="12" sm="6">
                    <MudSelect T="Guid?" @bind-Value="_enrollAnstallId" Label="Anställd" Variant="Variant.Outlined">
                        @foreach (var e in _employees)
                        {
                            <MudSelectItem T="Guid?" Value="@((Guid?)e.Id.Value)">@e.Fornamn @e.Efternamn</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="Guid?" @bind-Value="_enrollCourseId" Label="Kurs" Variant="Variant.Outlined">
                        @foreach (var c in _courses)
                        {
                            <MudSelectItem T="Guid?" Value="@((Guid?)c.Id)">@c.Namn (@c.Format)</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            </MudGrid>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-3" OnClick="SparaAnmalan">Anmäl</MudButton>
        </MudPaper>
    }

    @if (_success != null)
    {
        <MudAlert Severity="Severity.Success" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="@(() => _success = null)">@_success</MudAlert>
    }

    @* Kurskatalog *@
    <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight: 600;">Kurskatalog</MudText>
    @if (_courses.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Text" Class="mb-4">Inga kurser i databasen.</MudAlert>
    }
    else
    {
        <MudSimpleTable Hover="true" Elevation="2" Class="mb-6">
            <thead><tr><th>Kurs</th><th>Format</th><th>Längd</th><th>Obligatorisk</th><th>Kategori</th><th>Anmälda</th><th></th></tr></thead>
            <tbody>
                @foreach (var c in _courses)
                {
                    var antalAnmalda = _enrollments.Count(e => e.CourseId == c.Id);
                    <tr>
                        <td><strong>@c.Namn</strong><br /><MudText Typo="Typo.caption">@c.Beskrivning</MudText></td>
                        <td><MudChip T="string" Size="Size.Small">@c.Format</MudChip></td>
                        <td>@c.LangdMinuter min</td>
                        <td>@(c.ArObligatorisk ? "Ja" : "Nej")</td>
                        <td>@(c.Kategori ?? "—")</td>
                        <td>@antalAnmalda</td>
                        <td><MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary"
                                       OnClick="@(() => { _enrollCourseId = c.Id; _showEnroll = true; })">Anmäl</MudButton></td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    }

    @* Anmälningar *@
    <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight: 600;">Kursanmälningar</MudText>
    @if (_enrollments.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Text">Inga kursanmälningar.</MudAlert>
    }
    else
    {
        <MudSimpleTable Hover="true" Elevation="2">
            <thead><tr><th>Anställd</th><th>Kurs</th><th>Progress</th><th>Anmäld</th><th>Påbörjad</th><th>Genomförd</th></tr></thead>
            <tbody>
                @foreach (var e in _enrollments.OrderByDescending(e => e.AnmalanVid))
                {
                    <tr>
                        <td><strong>@GetEmployeeName(e.AnstallId)</strong></td>
                        <td>@GetCourseName(e.CourseId)</td>
                        <td><MudChip T="string" Size="Size.Small" Color="@ProgressColor(e.Progress)">@ProgressText(e.Progress)</MudChip></td>
                        <td>@e.AnmalanVid.ToLocalTime().ToString("yyyy-MM-dd")</td>
                        <td>@(e.PaborjadVid?.ToLocalTime().ToString("yyyy-MM-dd") ?? "—")</td>
                        <td>@(e.GenomfordVid?.ToLocalTime().ToString("yyyy-MM-dd") ?? "—")</td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    }
}

@code {
    private List<Course> _courses = [];
    private List<CourseEnrollment> _enrollments = [];
    private List<RegionHR.Core.Domain.Employee> _employees = [];
    private bool _loading = true, _showEnroll;
    private string? _error, _success;
    private Guid? _enrollAnstallId, _enrollCourseId;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _courses = await Db.Courses.ToListAsync();
            _enrollments = await Db.CourseEnrollments.ToListAsync();
            _employees = await Db.Employees.OrderBy(e => e.Efternamn).ToListAsync();
        }
        catch (Exception ex) { _error = $"Kunde inte hämta data: {ex.Message}"; }
        finally { _loading = false; }
    }

    private async Task SparaAnmalan()
    {
        if (_enrollAnstallId == null || _enrollCourseId == null) return;
        var enrollment = CourseEnrollment.Anmala(_enrollAnstallId.Value, _enrollCourseId.Value);
        Db.CourseEnrollments.Add(enrollment);
        await Db.SaveChangesAsync();
        _enrollments.Add(enrollment);
        _showEnroll = false;
        _success = $"{GetEmployeeName(_enrollAnstallId.Value)} anmäld till {GetCourseName(_enrollCourseId.Value)}.";
    }

    private string GetEmployeeName(Guid id)
    {
        var emp = _employees.FirstOrDefault(e => e.Id.Value == id);
        return emp != null ? $"{emp.Fornamn} {emp.Efternamn}" : "Okänd";
    }

    private string GetCourseName(Guid id) => _courses.FirstOrDefault(c => c.Id == id)?.Namn ?? "Okänd";

    private static Color ProgressColor(EnrollmentProgress p) => p switch
    {
        EnrollmentProgress.Genomford => Color.Success,
        EnrollmentProgress.Paborjad => Color.Warning,
        EnrollmentProgress.Anmalad => Color.Info,
        EnrollmentProgress.Underkand => Color.Error,
        _ => Color.Default
    };

    private static string ProgressText(EnrollmentProgress p) => p switch
    {
        EnrollmentProgress.Anmalad => "Anmäld",
        EnrollmentProgress.Paborjad => "Påbörjad",
        EnrollmentProgress.Genomford => "Genomförd",
        EnrollmentProgress.Underkand => "Underkänd",
        EnrollmentProgress.Avbruten => "Avbruten",
        _ => p.ToString()
    };
}
