@page "/integrationer"
@layout RegionHR.Web.Components.Layout.AdminLayout

<PageTitle>OpenHR - Integrationer</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">Integrationer</MudText>
<MudAlert Severity="Severity.Info" Variant="Variant.Text" Class="mb-4">
    OpenHR har inbyggda lokala generatorer för AGI-XML (Skatteverket) och pain.001 (bankfil). Externa livekopplingar kräver konfiguration mot respektive system.
</MudAlert>

<MudText Typo="Typo.h6" Class="mb-3">Interna generatorer (lokala)</MudText>
<MudSimpleTable Hover="true" Elevation="2" Class="mb-6">
    <thead><tr><th>Generator</th><th>Format</th><th>Riktning</th><th>Status</th></tr></thead>
    <tbody>
        <tr><td><strong>AGI-XML (Skatteverket)</strong></td><td>XML</td><td>Generering</td><td><MudChip T="string" Size="Size.Small" Color="Color.Success">Tillgänglig</MudChip></td></tr>
        <tr><td><strong>pain.001 (Nordea)</strong></td><td>ISO 20022 XML</td><td>Generering</td><td><MudChip T="string" Size="Size.Small" Color="Color.Success">Tillgänglig</MudChip></td></tr>
        <tr><td><strong>SCB-export</strong></td><td>CSV/XML</td><td>Generering</td><td><MudChip T="string" Size="Size.Small" Color="Color.Info">Lokal</MudChip></td></tr>
        <tr><td><strong>PDF-generering</strong></td><td>PDF</td><td>Generering</td><td><MudChip T="string" Size="Size.Small" Color="Color.Success">Tillgänglig</MudChip></td></tr>
        <tr><td><strong>CSV-export</strong></td><td>CSV</td><td>Generering</td><td><MudChip T="string" Size="Size.Small" Color="Color.Success">Tillgänglig</MudChip></td></tr>
    </tbody>
</MudSimpleTable>

<MudText Typo="Typo.h6" Class="mb-3">Externa integrationer (kräver konfiguration)</MudText>
<MudSimpleTable Hover="true" Elevation="1">
    <thead><tr><th>System</th><th>Protokoll</th><th>Riktning</th><th>Status</th></tr></thead>
    <tbody>
        <tr><td>Försäkringskassan</td><td>SSBTEK</td><td>Båda</td><td><MudChip T="string" Size="Size.Small" Color="Color.Default">Ej konfigurerad</MudChip></td></tr>
        <tr><td>AD / Entra ID</td><td>SCIM 2.0</td><td>Ut</td><td><MudChip T="string" Size="Size.Small" Color="Color.Default">Ej konfigurerad</MudChip></td></tr>
        <tr><td>Platsbanken</td><td>REST API</td><td>Ut</td><td><MudChip T="string" Size="Size.Small" Color="Color.Default">Ej konfigurerad</MudChip></td></tr>
        <tr><td>Bank (löneutbetalning)</td><td>pain.001</td><td>Ut</td><td><MudChip T="string" Size="Size.Small" Color="Color.Default">Ej konfigurerad</MudChip></td></tr>
        <tr><td>E-post (SMTP)</td><td>MailKit</td><td>Ut</td><td><MudChip T="string" Size="Size.Small" Color="Color.Default">Ej konfigurerad</MudChip></td></tr>
        <tr><td>SMS-gateway</td><td>HTTP</td><td>Ut</td><td><MudChip T="string" Size="Size.Small" Color="Color.Default">Ej konfigurerad</MudChip></td></tr>
    </tbody>
</MudSimpleTable>
