@page "/integrationer/platsbanken"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Recruitment.Domain
@using Microsoft.EntityFrameworkCore
@inject RegionHRDbContext Db

<PageTitle>OpenHR - Platsbanken</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">Platsbanken-integration</MudText>
<MudAlert Severity="Severity.Info" Variant="Variant.Text" Class="mb-4">Lokal förhandsvy. Extern publicering till Arbetsförmedlingen kräver API-koppling (utanför scope).</MudAlert>

@if (_loading) { <MudProgressCircular Color="Color.Primary" Indeterminate="true" /> }
else if (_error != null) { <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert> }
else if (_vakanser.Count == 0) { <MudAlert Severity="Severity.Info" Variant="Variant.Text">Inga publicerade vakanser.</MudAlert> }
else
{
    <MudSimpleTable Hover="true" Elevation="2">
        <thead><tr><th>Titel</th><th>Enhet</th><th>Anställningsform</th><th>Sista dag</th><th>Ansökningar</th><th>Platsbanken</th></tr></thead>
        <tbody>
            @foreach (var v in _vakanser)
            {
                <tr>
                    <td><strong>@v.Titel</strong></td>
                    <td>@v.Enhet</td>
                    <td>@v.Anstallningsform</td>
                    <td>@v.SistaAnsokningsDag.ToString("yyyy-MM-dd")</td>
                    <td>@v.AntalAnsokngar</td>
                    <td><MudChip T="string" Size="Size.Small" Color="@(v.PubliceradPlatsbanken ? Color.Success : Color.Default)">@(v.PubliceradPlatsbanken ? "Publicerad" : "Ej publicerad")</MudChip></td>
                </tr>
            }
        </tbody>
    </MudSimpleTable>
}

@code {
    private List<VakansVm> _vakanser = [];
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var vacancies = await Db.Vacancies.Where(v => v.Status == VacancyStatus.Publicerad).ToListAsync();
            var enheter = await Db.OrganizationUnits.ToListAsync();
            var enhetNamn = enheter.ToDictionary(e => e.Id.Value, e => e.Namn);
            _vakanser = vacancies.Select(v => new VakansVm(v.Titel, enhetNamn.GetValueOrDefault(v.EnhetId.Value, "—"), v.Anstallningsform, v.SistaAnsokningsDag, v.Ansokngar.Count, v.PubliceradPlatsbanken)).ToList();
        }
        catch (Exception ex) { _error = $"Kunde inte hämta data: {ex.Message}"; }
        finally { _loading = false; }
    }

    private record VakansVm(string Titel, string Enhet, RegionHR.SharedKernel.Domain.EmploymentType Anstallningsform, DateOnly SistaAnsokningsDag, int AntalAnsokngar, bool PubliceradPlatsbanken);
}
