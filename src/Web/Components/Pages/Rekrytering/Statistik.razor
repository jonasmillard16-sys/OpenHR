@page "/rekrytering/statistik"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Recruitment.Domain
@using Microsoft.EntityFrameworkCore
@inject RegionHRDbContext Db

<PageTitle>OpenHR - Rekryteringsstatistik</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">Rekryteringsstatistik</MudText>

@if (_loading) { <MudProgressCircular Color="Color.Primary" Indeterminate="true" /> }
else if (_error != null) { <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert> }
else
{
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="3"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Primary" Style="font-weight: 700;">@_totalVakanser</MudText><MudText Typo="Typo.body2">Vakanser totalt</MudText></MudPaper></MudItem>
        <MudItem xs="3"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Success" Style="font-weight: 700;">@_tillsatta</MudText><MudText Typo="Typo.body2">Tillsatta</MudText></MudPaper></MudItem>
        <MudItem xs="3"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Warning" Style="font-weight: 700;">@_totalAnsokngar</MudText><MudText Typo="Typo.body2">Ansökningar</MudText></MudPaper></MudItem>
        <MudItem xs="3"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Style="font-weight: 700;">@(_totalVakanser > 0 ? $"{(double)_totalAnsokngar / _totalVakanser:F1}" : "0")</MudText><MudText Typo="Typo.body2">Snitt ansökningar/vakans</MudText></MudPaper></MudItem>
    </MudGrid>

    @if (_perStatus.Count > 0)
    {
        <MudText Typo="Typo.h6" Class="mb-3">Per status</MudText>
        <MudSimpleTable Hover="true" Elevation="1">
            <thead><tr><th>Status</th><th>Antal</th></tr></thead>
            <tbody>@foreach (var kv in _perStatus) { <tr><td>@kv.Key</td><td>@kv.Value</td></tr> }</tbody>
        </MudSimpleTable>
    }
}

@code {
    private int _totalVakanser, _tillsatta, _totalAnsokngar;
    private Dictionary<string, int> _perStatus = [];
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var vacancies = await Db.Vacancies.ToListAsync();
            _totalVakanser = vacancies.Count;
            _tillsatta = vacancies.Count(v => v.Status == VacancyStatus.Tillsatt);
            _totalAnsokngar = vacancies.Sum(v => v.Ansokngar.Count);
            _perStatus = vacancies.GroupBy(v => v.Status.ToString()).ToDictionary(g => g.Key, g => g.Count());
        }
        catch (Exception ex) { _error = $"Kunde inte hämta statistik: {ex.Message}"; }
        finally { _loading = false; }
    }
}
