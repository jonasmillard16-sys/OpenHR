@page "/rekrytering/vakanser"
@rendermode InteractiveServer
@layout RegionHR.Web.Components.Layout.AdminLayout

<PageTitle>OpenHR - Rekrytering</PageTitle>
<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4" Style="font-weight: 700;">Rekrytering</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" StartIcon="@Icons.Material.Filled.Add" Style="min-height: 48px;">Ny vakans</MudButton>
</div>
<MudGrid Spacing="3" Class="mb-4">
    <MudItem xs="3"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Primary" Style="font-weight: 700;">5</MudText><MudText Typo="Typo.body2">Öppna vakanser</MudText></MudPaper></MudItem>
    <MudItem xs="3"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Style="font-weight: 700;">23</MudText><MudText Typo="Typo.body2">Ansökningar</MudText></MudPaper></MudItem>
    <MudItem xs="3"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Style="font-weight: 700;">3</MudText><MudText Typo="Typo.body2">Intervjuer planerade</MudText></MudPaper></MudItem>
    <MudItem xs="3"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Success" Style="font-weight: 700;">2</MudText><MudText Typo="Typo.body2">Tillsatta (YTD)</MudText></MudPaper></MudItem>
</MudGrid>
<MudSimpleTable Hover="true" Elevation="2">
    <thead><tr><th>Vakans</th><th>Enhet</th><th>Ansökningar</th><th>Status</th><th>Sista dag</th><th></th></tr></thead>
    <tbody>
        <tr><td><strong>Sjuksköterska</strong></td><td>Avd 32</td><td>8</td><td><MudChip T="string" Size="Size.Small" Color="Color.Success">Publicerad</MudChip></td><td>2026-04-01</td><td><MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary">Öppna</MudButton></td></tr>
        <tr><td><strong>Undersköterska</strong></td><td>IVA</td><td>12</td><td><MudChip T="string" Size="Size.Small" Color="Color.Success">Publicerad</MudChip></td><td>2026-03-25</td><td><MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary">Öppna</MudButton></td></tr>
        <tr><td><strong>Läkare</strong></td><td>Akuten</td><td>3</td><td><MudChip T="string" Size="Size.Small" Color="Color.Warning">Utkast</MudChip></td><td>—</td><td><MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary">Öppna</MudButton></td></tr>
    </tbody>
</MudSimpleTable>
