@page "/rekrytering/vakanser"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Recruitment.Domain
@using RegionHR.SharedKernel.Domain
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<RegionHRDbContext> DbFactory

<PageTitle>OpenHR - Rekrytering</PageTitle>
<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4" Style="font-weight: 700;">Rekrytering</MudText>
</div>

@if (_loading) { <MudProgressCircular Color="Color.Primary" Indeterminate="true" /> }
else if (_error != null) { <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert> }
else
{
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="3"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Primary" Style="font-weight: 700;">@_vakanser.Count</MudText><MudText Typo="Typo.body2">Vakanser totalt</MudText></MudPaper></MudItem>
        <MudItem xs="3"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Success" Style="font-weight: 700;">@_vakanser.Count(v => v.Status == VacancyStatus.Publicerad)</MudText><MudText Typo="Typo.body2">Publicerade</MudText></MudPaper></MudItem>
        <MudItem xs="3"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Info" Style="font-weight: 700;">@_vakanser.Count(v => v.Status == VacancyStatus.Stangd)</MudText><MudText Typo="Typo.body2">Stängda</MudText></MudPaper></MudItem>
        <MudItem xs="3"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Warning" Style="font-weight: 700;">@_totalAnsokngar</MudText><MudText Typo="Typo.body2">Ansökningar</MudText></MudPaper></MudItem>
    </MudGrid>

    @if (_vakanser.Count == 0) { <MudAlert Severity="Severity.Info" Variant="Variant.Text">Inga vakanser registrerade.</MudAlert> }
    else
    {
        <MudSimpleTable Hover="true" Elevation="2">
            <thead><tr><th>Titel</th><th>Anställningsform</th><th>Status</th><th>Sista dag</th><th>Ansökningar</th><th></th></tr></thead>
            <tbody>
                @foreach (var v in _vakanser)
                {
                    <tr>
                        <td><strong>@v.Titel</strong><br /><MudText Typo="Typo.caption">@v.EnhetNamn</MudText></td>
                        <td>@v.Anstallningsform</td>
                        <td><MudChip T="string" Size="Size.Small" Color="@StatusFarg(v.Status)">@StatusText(v.Status)</MudChip></td>
                        <td>@(v.SistaAnsokningsDag.ToString("yyyy-MM-dd"))</td>
                        <td>@v.AntalAnsokngar</td>
                        <td><MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary" OnClick="@(() => _valdVakans = _valdVakans == v ? null : v)">Visa</MudButton></td>
                    </tr>
                    @if (_valdVakans == v)
                    {
                        <tr><td colspan="6">
                            <MudPaper Class="pa-4" Elevation="0" Style="background: var(--mud-palette-background-grey);">
                                <MudText Typo="Typo.body2" Class="mb-2">@v.Beskrivning</MudText>
                                @if (v.AntalAnsokngar > 0)
                                {
                                    <MudText Typo="Typo.subtitle2" Class="mb-1">Ansökningar:</MudText>
                                    @foreach (var a in v.Ansokngar)
                                    {
                                        <MudText Typo="Typo.body2">@a.Namn — @a.Epost — <MudChip T="string" Size="Size.Small">@a.Status</MudChip></MudText>
                                    }
                                }
                                <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="@(() => _valdVakans = null)" Class="mt-2">Stäng</MudButton>
                            </MudPaper>
                        </td></tr>
                    }
                }
            </tbody>
        </MudSimpleTable>
    }
}

@code {
    private List<VakansVm> _vakanser = [];
    private VakansVm? _valdVakans;
    private int _totalAnsokngar;
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        try
        {
            var vacancies = await db.Vacancies.OrderByDescending(v => v.SistaAnsokningsDag).ToListAsync();
            var enheter = await db.OrganizationUnits.ToListAsync();
            var enhetNamn = enheter.ToDictionary(e => e.Id.Value, e => e.Namn);

            _vakanser = vacancies.Select(v => new VakansVm(
                v.Titel, enhetNamn.GetValueOrDefault(v.EnhetId.Value, "—"),
                v.Anstallningsform, v.Status, v.SistaAnsokningsDag,
                v.Beskrivning, v.Ansokngar.Count,
                v.Ansokngar.Select(a => new AnsVm(a.Namn, a.Epost, a.Status.ToString())).ToList()
            )).ToList();
            _totalAnsokngar = vacancies.Sum(v => v.Ansokngar.Count);
        }
        catch (Exception ex) { _error = $"Kunde inte hämta vakanser: {ex.Message}"; }
        finally { _loading = false; }
    }

    private static string StatusText(VacancyStatus s) => s switch
    {
        VacancyStatus.Utkast => "Utkast", VacancyStatus.Publicerad => "Publicerad",
        VacancyStatus.Stangd => "Stängd", VacancyStatus.Tillsatt => "Tillsatt", _ => s.ToString()
    };
    private static Color StatusFarg(VacancyStatus s) => s switch
    {
        VacancyStatus.Publicerad => Color.Success, VacancyStatus.Stangd => Color.Info,
        VacancyStatus.Tillsatt => Color.Primary, _ => Color.Default
    };

    private record AnsVm(string Namn, string Epost, string Status);
    private record VakansVm(string Titel, string EnhetNamn, EmploymentType Anstallningsform, VacancyStatus Status, DateOnly SistaAnsokningsDag, string Beskrivning, int AntalAnsokngar, List<AnsVm> Ansokngar);
}

