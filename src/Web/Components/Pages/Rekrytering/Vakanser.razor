@page "/rekrytering/vakanser"
@rendermode InteractiveServer
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Recruitment.Domain
@using Microsoft.EntityFrameworkCore
@inject RegionHRDbContext Db

<PageTitle>OpenHR - Rekrytering</PageTitle>
<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4" Style="font-weight: 700;">Rekrytering</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" StartIcon="@Icons.Material.Filled.Add" Style="min-height: 48px;" OnClick="@(() => _showForm = true)">Ny vakans</MudButton>
</div>

@if (_showForm)
{
    <MudPaper Class="pa-6 mb-4" Elevation="3" Style="border-left: 4px solid var(--mud-palette-primary);">
        <div class="d-flex justify-space-between align-center mb-3">
            <MudText Typo="Typo.h6" Style="font-weight: 600;">Skapa ny vakans</MudText>
            <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="@(() => _showForm = false)" />
        </div>
        <MudTextField @bind-Value="_newTitel" Label="Titel" Variant="Variant.Outlined" Class="mb-3" />
        <MudTextField @bind-Value="_newEnhet" Label="Enhet" Variant="Variant.Outlined" Class="mb-3" />
        <MudTextField @bind-Value="_newAnstallningsform" Label="Anställningsform" Variant="Variant.Outlined" Class="mb-3" />
        <MudTextField @bind-Value="_newBeskrivning" Label="Beskrivning" Variant="Variant.Outlined" Lines="3" Class="mb-3" />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                   Style="min-height: 48px;" OnClick="SkapaVakans">Skapa</MudButton>
    </MudPaper>
}

@if (_skapad)
{
    <MudAlert Severity="Severity.Success" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="@(() => _skapad = false)">Vakans skapad!</MudAlert>
}

<MudGrid Spacing="3" Class="mb-4">
    <MudItem xs="3"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Primary" Style="font-weight: 700;">@_oppnaVakanser</MudText><MudText Typo="Typo.body2">Öppna vakanser</MudText></MudPaper></MudItem>
    <MudItem xs="3"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Style="font-weight: 700;">@_antalAnsokngar</MudText><MudText Typo="Typo.body2">Ansökningar</MudText></MudPaper></MudItem>
    <MudItem xs="3"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Style="font-weight: 700;">@_intervjuerPlanerade</MudText><MudText Typo="Typo.body2">Intervjuer planerade</MudText></MudPaper></MudItem>
    <MudItem xs="3"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Success" Style="font-weight: 700;">@_tillsatta</MudText><MudText Typo="Typo.body2">Tillsatta (YTD)</MudText></MudPaper></MudItem>
</MudGrid>
<MudSimpleTable Hover="true" Elevation="2">
    <thead><tr><th>Vakans</th><th>Anst.form</th><th>Ansökningar</th><th>Status</th><th>Sista dag</th><th></th></tr></thead>
    <tbody>
        @foreach (var v in _vacancies)
        {
            <tr>
                <td><strong>@v.Titel</strong></td>
                <td>@v.Anstallningsform</td>
                <td>@v.Ansokngar.Count</td>
                <td><MudChip T="string" Size="Size.Small" Color="@VakansFarg(v.Status)">@VakansText(v.Status)</MudChip></td>
                <td>@v.SistaAnsokningsDag.ToString("yyyy-MM-dd")</td>
                <td><MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary" OnClick="@(() => ValjVakans(v))">Öppna</MudButton></td>
            </tr>
            @if (_valdVakans == v)
            {
                <tr>
                    <td colspan="6">
                        <MudPaper Class="pa-4" Elevation="0" Style="background: var(--mud-palette-background-grey);">
                            <MudText Typo="Typo.subtitle1" Class="mb-2"><strong>@v.Titel</strong></MudText>
                            <MudText Typo="Typo.body2"><strong>Anställningsform:</strong> @v.Anstallningsform</MudText>
                            <MudText Typo="Typo.body2"><strong>Ansökningar:</strong> @v.Ansokngar.Count</MudText>
                            <MudText Typo="Typo.body2"><strong>Status:</strong> @VakansText(v.Status)</MudText>
                            <MudText Typo="Typo.body2"><strong>Sista ansökningsdag:</strong> @v.SistaAnsokningsDag.ToString("yyyy-MM-dd")</MudText>
                            <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="@(() => _valdVakans = null)" Class="mt-2">Stäng</MudButton>
                        </MudPaper>
                    </td>
                </tr>
            }
        }
    </tbody>
</MudSimpleTable>

@code {
    private bool _showForm;
    private bool _skapad;
    private string _newTitel = "";
    private string _newEnhet = "";
    private string _newAnstallningsform = "";
    private string _newBeskrivning = "";

    private void SkapaVakans()
    {
        _showForm = false;
        _skapad = true;
        _newTitel = "";
        _newEnhet = "";
        _newAnstallningsform = "";
        _newBeskrivning = "";
    }

    private List<Vacancy> _vacancies = [];
    private Vacancy? _valdVakans;

    private void ValjVakans(Vacancy v) => _valdVakans = _valdVakans == v ? null : v;

    private int _oppnaVakanser = 5;
    private int _antalAnsokngar = 23;
    private int _intervjuerPlanerade = 3;
    private int _tillsatta = 2;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _vacancies = await Db.Vacancies
                .Include(v => v.Ansokngar)
                .OrderByDescending(v => v.SistaAnsokningsDag)
                .Take(50)
                .ToListAsync();

            if (_vacancies.Count > 0)
            {
                _oppnaVakanser = _vacancies.Count(v => v.Status == VacancyStatus.Publicerad);
                _antalAnsokngar = _vacancies.SelectMany(v => v.Ansokngar).Count();
                _intervjuerPlanerade = _vacancies.SelectMany(v => v.Ansokngar)
                    .Count(a => a.Status == ApplicationStatus.Intervju);
                _tillsatta = _vacancies.Count(v => v.Status == VacancyStatus.Tillsatt);
            }
        }
        catch
        {
            // Demo data fallback — keep initial values
        }
    }

    private static Color VakansFarg(VacancyStatus s) => s switch
    {
        VacancyStatus.Publicerad => Color.Success,
        VacancyStatus.Utkast => Color.Warning,
        VacancyStatus.Stangd => Color.Default,
        VacancyStatus.Tillsatt => Color.Info,
        _ => Color.Default
    };

    private static string VakansText(VacancyStatus s) => s switch
    {
        VacancyStatus.Publicerad => "Publicerad",
        VacancyStatus.Utkast => "Utkast",
        VacancyStatus.Stangd => "Stängd",
        VacancyStatus.Tillsatt => "Tillsatt",
        _ => s.ToString()
    };
}
