@page "/rekrytering/onboarding"
@rendermode InteractiveServer
@layout RegionHR.Web.Components.Layout.AdminLayout

<PageTitle>OpenHR - Onboarding</PageTitle>
<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4" Style="font-weight: 700;">Onboarding</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" StartIcon="@Icons.Material.Filled.PersonAdd" Style="min-height: 48px;" OnClick="@(() => _showForm = true)">Ny onboarding</MudButton>
</div>

@if (_showForm)
{
    <MudPaper Class="pa-6 mb-4" Elevation="3" Style="border-left: 4px solid var(--mud-palette-primary);">
        <div class="d-flex justify-space-between align-center mb-3">
            <MudText Typo="Typo.h6" Style="font-weight: 600;">Skapa ny onboarding</MudText>
            <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="@(() => _showForm = false)" />
        </div>
        <MudTextField @bind-Value="_newAnstelld" Label="Anställd" Variant="Variant.Outlined" Class="mb-3" />
        <MudTextField @bind-Value="_newStartdatum" Label="Startdatum" Variant="Variant.Outlined" Class="mb-3" />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                   Style="min-height: 48px;" OnClick="SkapaOnboarding">Skapa</MudButton>
    </MudPaper>
}

@if (_skapad)
{
    <MudAlert Severity="Severity.Success" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="@(() => _skapad = false)">Onboarding skapad!</MudAlert>
}

<MudGrid Spacing="3" Class="mb-6">
    <MudItem xs="3"><MudPaper Class="pa-4 text-center" Elevation="2" Style="border-top: 4px solid var(--mud-palette-primary);"><MudText Typo="Typo.h3" Color="Color.Primary" Style="font-weight: 700;">@_arenden.Count</MudText><MudText Typo="Typo.body2">Aktiva</MudText></MudPaper></MudItem>
    <MudItem xs="3"><MudPaper Class="pa-4 text-center" Elevation="2" Style="border-top: 4px solid var(--mud-palette-warning);"><MudText Typo="Typo.h3" Color="Color.Warning" Style="font-weight: 700;">@_arenden.Count(a => a.Procent < 50)</MudText><MudText Typo="Typo.body2">Tidig fas</MudText></MudPaper></MudItem>
    <MudItem xs="3"><MudPaper Class="pa-4 text-center" Elevation="2" Style="border-top: 4px solid var(--mud-palette-info);"><MudText Typo="Typo.h3" Color="Color.Info" Style="font-weight: 700;">@_arenden.Count(a => a.Procent >= 50 && a.Procent < 100)</MudText><MudText Typo="Typo.body2">Pågående</MudText></MudPaper></MudItem>
    <MudItem xs="3"><MudPaper Class="pa-4 text-center" Elevation="2" Style="border-top: 4px solid var(--mud-palette-success);"><MudText Typo="Typo.h3" Color="Color.Success" Style="font-weight: 700;">7</MudText><MudText Typo="Typo.body2">Klara (YTD)</MudText></MudPaper></MudItem>
</MudGrid>

<MudText Typo="Typo.h6" Class="mb-3">Aktiva onboardingärenden</MudText>
@foreach (var a in _arenden)
{
    <MudPaper Class="pa-4 mb-4" Elevation="2">
        <div class="d-flex justify-space-between align-center mb-2">
            <div>
                <MudText Typo="Typo.h6" Style="font-weight: 600;">@a.Namn</MudText>
                <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">@a.Befattning — @a.Enhet | Startdatum: @a.Startdatum</MudText>
            </div>
            <MudChip T="string" Size="Size.Small" Color="@(a.Procent == 100 ? Color.Success : a.Procent >= 60 ? Color.Info : Color.Warning)">@a.Procent % klart</MudChip>
        </div>
        <MudProgressLinear Value="@a.Procent" Color="@(a.Procent == 100 ? Color.Success : a.Procent >= 60 ? Color.Info : Color.Warning)" Rounded="true" Size="Size.Large" Class="mb-3" />
        <MudGrid Spacing="2">
            @foreach (var steg in a.Checklista)
            {
                <MudItem xs="12" sm="6" md="4" lg="2">
                    <MudPaper Class="pa-3 text-center" Elevation="1" Style="@($"border-left: 3px solid {(steg.Klar ? "var(--mud-palette-success)" : "var(--mud-palette-text-disabled)}")}")">
                        <MudIcon Icon="@(steg.Klar ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.RadioButtonUnchecked)"
                                 Color="@(steg.Klar ? Color.Success : Color.Default)" />
                        <MudText Typo="Typo.body2" Style="font-weight: 500;">@steg.Namn</MudText>
                        <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">@steg.Ansvarig</MudText>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
    </MudPaper>
}

@code {
    private bool _showForm;
    private bool _skapad;
    private string _newAnstelld = "";
    private string _newStartdatum = "";

    private void SkapaOnboarding()
    {
        _showForm = false;
        _skapad = true;
        _newAnstelld = "";
        _newStartdatum = "";
    }

    private List<OnboardingArende> _arenden =
    [
        new("Sara Johansson", "Sjuksköterska", "Kirurgi avd 3", "2026-04-01",
        [
            new("IT-konto", "IT-avdelningen", false),
            new("Passerkort", "Säkerhet", false),
            new("Brandskydd", "Utbildning", false),
            new("Hygienutbildning", "Vårdhygien", false),
            new("Introduktion", "Enhetschef", false),
        ]),
        new("Erik Bergström", "Systemutvecklare", "IT-avdelningen", "2026-03-15",
        [
            new("IT-konto", "IT-avdelningen", true),
            new("Passerkort", "Säkerhet", true),
            new("Brandskydd", "Utbildning", true),
            new("Hygienutbildning", "Vårdhygien", false),
            new("Introduktion", "Enhetschef", false),
        ]),
        new("Fatima Al-Hassan", "Undersköterska", "Geriatrik avd 1", "2026-03-20",
        [
            new("IT-konto", "IT-avdelningen", true),
            new("Passerkort", "Säkerhet", true),
            new("Brandskydd", "Utbildning", true),
            new("Hygienutbildning", "Vårdhygien", true),
            new("Introduktion", "Enhetschef", false),
        ]),
        new("Anders Nilsson", "Läkare", "Akutmottagningen", "2026-03-10",
        [
            new("IT-konto", "IT-avdelningen", true),
            new("Passerkort", "Säkerhet", true),
            new("Brandskydd", "Utbildning", true),
            new("Hygienutbildning", "Vårdhygien", true),
            new("Introduktion", "Enhetschef", true),
        ]),
    ];

    private class OnboardingArende(string namn, string befattning, string enhet, string startdatum, List<ChecklisteSteg> checklista)
    {
        public string Namn { get; set; } = namn;
        public string Befattning { get; set; } = befattning;
        public string Enhet { get; set; } = enhet;
        public string Startdatum { get; set; } = startdatum;
        public List<ChecklisteSteg> Checklista { get; set; } = checklista;
        public int Procent => Checklista.Count == 0 ? 0 : (int)(Checklista.Count(s => s.Klar) * 100.0 / Checklista.Count);
    }

    private class ChecklisteSteg(string namn, string ansvarig, bool klar)
    {
        public string Namn { get; set; } = namn;
        public string Ansvarig { get; set; } = ansvarig;
        public bool Klar { get; set; } = klar;
    }
}
