@page "/rekrytering/intern"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Recruitment.Domain
@using Microsoft.EntityFrameworkCore
@inject RegionHRDbContext Db

<PageTitle>OpenHR - Intern jobbmarknad</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">Intern jobbmarknad</MudText>
<MudText Typo="Typo.body2" Class="mb-4" Style="color: var(--mud-palette-text-secondary);">Publicerade vakanser öppna för internrekrytering.</MudText>

@if (_loading) { <MudProgressCircular Color="Color.Primary" Indeterminate="true" /> }
else if (_error != null) { <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert> }
else if (_vakanser.Count == 0) { <MudAlert Severity="Severity.Info" Variant="Variant.Text">Inga publicerade vakanser just nu.</MudAlert> }
else
{
    @foreach (var v in _vakanser)
    {
        <MudPaper Class="pa-4 mb-3" Elevation="2">
            <MudText Typo="Typo.h6" Style="font-weight: 600;">@v.Titel</MudText>
            <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">@v.EnhetNamn — @v.Anstallningsform — Sista dag: @v.SistaAnsokningsDag.ToString("yyyy-MM-dd")</MudText>
            <MudText Typo="Typo.body1" Class="mt-2">@v.Beskrivning</MudText>
        </MudPaper>
    }
}

@code {
    private List<VakansVm> _vakanser = [];
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var vacancies = await Db.Vacancies.Where(v => v.Status == VacancyStatus.Publicerad).OrderBy(v => v.SistaAnsokningsDag).ToListAsync();
            var enheter = await Db.OrganizationUnits.ToListAsync();
            var enhetNamn = enheter.ToDictionary(e => e.Id.Value, e => e.Namn);
            _vakanser = vacancies.Select(v => new VakansVm(v.Titel, enhetNamn.GetValueOrDefault(v.EnhetId.Value, "—"), v.Anstallningsform, v.SistaAnsokningsDag, v.Beskrivning)).ToList();
        }
        catch (Exception ex) { _error = $"Kunde inte hämta vakanser: {ex.Message}"; }
        finally { _loading = false; }
    }

    private record VakansVm(string Titel, string EnhetNamn, RegionHR.SharedKernel.Domain.EmploymentType Anstallningsform, DateOnly SistaAnsokningsDag, string Beskrivning);
}
