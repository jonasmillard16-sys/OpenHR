@page "/rekrytering/intern"
@rendermode InteractiveServer
@layout RegionHR.Web.Components.Layout.AdminLayout

<PageTitle>OpenHR - Intern jobbmarknad</PageTitle>
<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4" Style="font-weight: 700;">Intern jobbmarknad</MudText>
    <MudChip T="string" Size="Size.Large" Color="Color.Primary">@_tjanster.Count lediga tjänster</MudChip>
</div>

<MudGrid Spacing="3" Class="mb-4">
    <MudItem xs="3">
        <MudPaper Class="pa-3 text-center" Elevation="1">
            <MudText Typo="Typo.h4" Color="Color.Primary" Style="font-weight: 700;">@_tjanster.Count</MudText>
            <MudText Typo="Typo.body2">Öppna tjänster</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="3">
        <MudPaper Class="pa-3 text-center" Elevation="1">
            <MudText Typo="Typo.h4" Color="Color.Success" Style="font-weight: 700;">@_tjanster.Count(t => t.Ny)</MudText>
            <MudText Typo="Typo.body2">Nya denna vecka</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="3">
        <MudPaper Class="pa-3 text-center" Elevation="1">
            <MudText Typo="Typo.h4" Color="Color.Warning" Style="font-weight: 700;">@_tjanster.Count(t => t.DagarKvar <= 7)</MudText>
            <MudText Typo="Typo.body2">Stänger snart</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="3">
        <MudPaper Class="pa-3 text-center" Elevation="1">
            <MudText Typo="Typo.h4" Color="Color.Info" Style="font-weight: 700;">@_antalIntresse</MudText>
            <MudText Typo="Typo.body2">Intresseanmälningar totalt</MudText>
        </MudPaper>
    </MudItem>
</MudGrid>

@if (_bekraftad)
{
    <MudAlert Severity="Severity.Success" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="@(() => _bekraftad = false)">
        Intresseanmälan skickad! Du får bekräftelse via e-post.
    </MudAlert>
}

<MudTextField @bind-Value="_sok" Label="Sök tjänst eller enhet..." Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Class="mb-4" />

<MudStack Spacing="3">
    @foreach (var t in FiltreradeTjanster())
    {
        <MudPaper Class="pa-5" Elevation="2" Style="border-left: 4px solid var(--mud-palette-primary);">
            <div class="d-flex justify-space-between align-center mb-2">
                <div class="d-flex align-center gap-2">
                    <MudText Typo="Typo.h6" Style="font-weight: 600;">@t.Titel</MudText>
                    @if (t.Ny)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Success">Ny</MudChip>
                    }
                    @if (t.DagarKvar <= 7)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning">@t.DagarKvar dagar kvar</MudChip>
                    }
                </div>
                <MudText Typo="Typo.caption">Sista ansökningsdag: @t.SistaDag</MudText>
            </div>
            <div class="d-flex gap-4 mb-2">
                <MudText Typo="Typo.body2"><strong>Enhet:</strong> @t.Enhet</MudText>
                <MudText Typo="Typo.body2"><strong>Anställningsform:</strong> @t.Anstallningsform</MudText>
                <MudText Typo="Typo.body2"><strong>Omfattning:</strong> @t.Omfattning</MudText>
            </div>
            <MudText Typo="Typo.body2" Class="mb-3">@t.Beskrivning</MudText>
            <div class="d-flex justify-space-between align-center">
                <MudText Typo="Typo.caption">@t.AntalIntresse intresseanmälningar</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Medium"
                           StartIcon="@Icons.Material.Filled.Send"
                           OnClick="@(() => SkickaIntresse(t))">Intresseanmälan</MudButton>
            </div>
        </MudPaper>
    }
</MudStack>

@code {
    private string _sok = "";
    private bool _bekraftad;
    private int _antalIntresse = 34;
    private List<InternTjanst> _tjanster = [];

    protected override void OnInitialized()
    {
        _tjanster =
        [
            new("Sjuksköterska, Akutmottagningen", "Akutmottagningen, Sjukhus Norr", "Tillsvidare", "100 %",
                "Vi söker en erfaren sjuksköterska till vår akutmottagning. Du arbetar i team med läkare och undersköterskor i en dynamisk miljö.",
                "2026-04-01", 8, true, 15),
            new("Undersköterska, Geriatrik avd 14", "Geriatriska kliniken", "Tillsvidare", "75–100 %",
                "Hos oss arbetar du med äldre patienter i en trivsam miljö. Vi söker dig som är engagerad och har erfarenhet av geriatrik.",
                "2026-03-28", 5, true, 11),
            new("Teamledare, HR-avdelningen", "HR-avdelningen, Regionkontoret", "Tillsvidare", "100 %",
                "HR-avdelningen söker en teamledare för rekryterings- och kompetensgruppen. Du leder ett team på 6 medarbetare.",
                "2026-04-15", 29, false, 3),
            new("Biomedicinsk analytiker", "Klinisk kemi, Laboratoriet", "Vikariat 12 mån", "100 %",
                "Vikariat som biomedicinsk analytiker vid klinisk kemiska laboratoriet. Vi söker dig med BMA-examen och gärna erfarenhet av klinisk kemi.",
                "2026-03-25", 3, false, 7),
            new("Fysioterapeut, Rehabenheten", "Rehabenheten, Sjukhus Söder", "Tillsvidare", "80–100 %",
                "Vi utökar teamet och söker fysioterapeut med intresse för ortopedisk rehabilitering. Möjlighet till specialistutbildning.",
                "2026-04-10", 24, false, 5),
        ];
    }

    private List<InternTjanst> FiltreradeTjanster()
    {
        if (string.IsNullOrWhiteSpace(_sok))
            return _tjanster;

        var s = _sok.ToLower();
        return _tjanster.Where(t =>
            t.Titel.ToLower().Contains(s) ||
            t.Enhet.ToLower().Contains(s) ||
            t.Beskrivning.ToLower().Contains(s)).ToList();
    }

    private void SkickaIntresse(InternTjanst t)
    {
        t.AntalIntresse++;
        _antalIntresse++;
        _bekraftad = true;
    }

    private record InternTjanst(string Titel, string Enhet, string Anstallningsform, string Omfattning,
        string Beskrivning, string SistaDag, int DagarKvar, bool Ny, int AntalIntresse)
    {
        public int AntalIntresse { get; set; } = AntalIntresse;
    }
}
