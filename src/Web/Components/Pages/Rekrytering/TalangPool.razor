@page "/rekrytering/talangpool"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Recruitment.Domain
@using RegionHR.Infrastructure.Persistence
@using Microsoft.EntityFrameworkCore
@inject RegionHRDbContext Db

<PageTitle>OpenHR — Talangpool</PageTitle>

<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4" Style="font-weight: 700;">Talangpool</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
               StartIcon="@Icons.Material.Filled.PersonAdd" Style="min-height: 48px;"
               OnClick="@(() => _showForm = !_showForm)">Lägg till kandidat</MudButton>
</div>

<MudText Typo="Typo.body2" Class="mb-4" Style="color: var(--mud-palette-text-secondary);">
    Manuell talangpool — kandidater som kan vara aktuella för framtida rekryteringar.
    Data hämtas från databasen. Ingen CV-parsning eller automation.
</MudText>

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error">@_error</MudAlert>
}
else
{
    @if (_showForm)
    {
        <MudPaper Class="pa-5 mb-4" Elevation="3" Style="border-left: 4px solid var(--mud-palette-primary);">
            <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight: 600;">Lägg till kandidat</MudText>
            <MudGrid Spacing="3">
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_formNamn" Label="Namn" Variant="Variant.Outlined" Required="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_formEpost" Label="E-post" Variant="Variant.Outlined" Required="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_formKompetens" Label="Kompetensområde" Variant="Variant.Outlined"
                                  Placeholder="T.ex. IVA, akutsjukvård" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_formAnteckningar" Label="Anteckningar" Variant="Variant.Outlined"
                                  Placeholder="Bakgrund, kontakthistorik" />
                </MudItem>
            </MudGrid>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-3" OnClick="SparaKandidat">Spara</MudButton>
        </MudPaper>
    }

    @if (_success != null)
    {
        <MudAlert Severity="Severity.Success" Class="mb-4" ShowCloseIcon="true"
                  CloseIconClicked="@(() => _success = null)">@_success</MudAlert>
    }

    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="6" sm="4">
            <MudPaper Class="pa-4 text-center" Elevation="2">
                <MudText Typo="Typo.h3" Color="Color.Primary" Style="font-weight: 700;">@_candidates.Count</MudText>
                <MudText Typo="Typo.body2">Kandidater i pool</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="4">
            <MudPaper Class="pa-4 text-center" Elevation="2">
                <MudText Typo="Typo.h3" Style="font-weight: 700;">@_candidates.Select(c => c.KompetensOmrade).Where(k => k != null).Distinct().Count()</MudText>
                <MudText Typo="Typo.body2">Kompetensområden</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @if (_candidates.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Text">Inga kandidater i talangpoolen.</MudAlert>
    }
    else
    {
        <MudSimpleTable Hover="true" Elevation="2">
            <thead>
                <tr><th>Namn</th><th>E-post</th><th>Kompetens</th><th>Anteckningar</th><th>Tillagd</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var c in _candidates.OrderByDescending(c => c.SkapadVid))
                {
                    <tr style="cursor: pointer;" @onclick="@(() => _expanded = _expanded == c ? null : c)">
                        <td><strong>@c.Namn</strong></td>
                        <td>@c.Epost</td>
                        <td>@(c.KompetensOmrade ?? "—")</td>
                        <td style="max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@(c.Anteckningar ?? "—")</td>
                        <td>@c.SkapadVid.ToLocalTime().ToString("yyyy-MM-dd")</td>
                        <td><MudIconButton Icon="@(_expanded == c ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" Size="Size.Small" /></td>
                    </tr>
                    @if (_expanded == c)
                    {
                        <tr>
                            <td colspan="6" style="padding: 0;">
                                <MudPaper Class="pa-4" Elevation="0" Style="border-top: 2px solid var(--mud-palette-primary); background: var(--mud-palette-background);">
                                    <MudGrid Spacing="3">
                                        <MudItem xs="12" sm="6">
                                            <MudText Typo="Typo.caption">Namn</MudText>
                                            <MudText Style="font-weight: 600;">@c.Namn</MudText>
                                        </MudItem>
                                        <MudItem xs="12" sm="6">
                                            <MudText Typo="Typo.caption">E-post</MudText>
                                            <MudText Style="font-weight: 600;">@c.Epost</MudText>
                                        </MudItem>
                                        <MudItem xs="12" sm="6">
                                            <MudText Typo="Typo.caption">Kompetensområde</MudText>
                                            <MudText Style="font-weight: 600;">@(c.KompetensOmrade ?? "Ej angivet")</MudText>
                                        </MudItem>
                                        <MudItem xs="12" sm="6">
                                            <MudText Typo="Typo.caption">Tillagd</MudText>
                                            <MudText Style="font-weight: 600;">@c.SkapadVid.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</MudText>
                                        </MudItem>
                                        @if (c.Anteckningar != null)
                                        {
                                            <MudItem xs="12">
                                                <MudText Typo="Typo.caption">Anteckningar</MudText>
                                                <MudText>@c.Anteckningar</MudText>
                                            </MudItem>
                                        }
                                        @if (c.UrsprungsAnsokanId != null)
                                        {
                                            <MudItem xs="12">
                                                <MudText Typo="Typo.caption">Ursprungsansökan</MudText>
                                                <MudText Style="font-weight: 600;">@c.UrsprungsAnsokanId</MudText>
                                            </MudItem>
                                        }
                                    </MudGrid>
                                </MudPaper>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </MudSimpleTable>
    }
}

@code {
    private List<TalentPoolEntry> _candidates = [];
    private TalentPoolEntry? _expanded;
    private bool _loading = true, _showForm;
    private string? _error, _success;
    private string _formNamn = "", _formEpost = "", _formKompetens = "", _formAnteckningar = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _candidates = await Db.TalentPoolEntries.ToListAsync();
        }
        catch (Exception ex) { _error = $"Kunde inte hämta data: {ex.Message}"; }
        finally { _loading = false; }
    }

    private async Task SparaKandidat()
    {
        if (string.IsNullOrWhiteSpace(_formNamn) || string.IsNullOrWhiteSpace(_formEpost)) return;
        var kandidat = TalentPoolEntry.Skapa(
            _formNamn, _formEpost,
            string.IsNullOrWhiteSpace(_formKompetens) ? null : _formKompetens,
            string.IsNullOrWhiteSpace(_formAnteckningar) ? null : _formAnteckningar);
        Db.TalentPoolEntries.Add(kandidat);
        await Db.SaveChangesAsync();
        _candidates.Add(kandidat);
        _showForm = false;
        _success = $"Kandidat {_formNamn} tillagd i talangpoolen.";
        _formNamn = ""; _formEpost = ""; _formKompetens = ""; _formAnteckningar = "";
    }
}
