@page "/rekrytering/pipeline"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Recruitment.Domain
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<RegionHRDbContext> DbFactory

<PageTitle>OpenHR - Rekryteringspipeline</PageTitle>
<OhrBreadcrumb CurrentPage="Rekryteringspipeline" />
<MudText Typo="Typo.h4" Class="mb-2" Style="font-weight: 700;">Rekryteringspipeline</MudText>
<MudPaper Class="pa-3 mb-4" Elevation="0" Style="background: var(--mud-palette-background-grey); border-radius: 8px;">
    <MudText Typo="Typo.body2" Class="mb-1">Här ser du alla öppna tjänster och var kandidaterna befinner sig i processen. En ansökan går igenom dessa steg:</MudText>
    <MudText Typo="Typo.body2" Class="mb-1"><strong>Inkommen</strong> – ansökan har registrerats och väntar på granskning.</MudText>
    <MudText Typo="Typo.body2" Class="mb-1"><strong>Granskning</strong> – HR eller chef läser igenom ansökan.</MudText>
    <MudText Typo="Typo.body2" Class="mb-1"><strong>Intervju</strong> – kandidaten kallas till intervju.</MudText>
    <MudText Typo="Typo.body2" Class="mb-1"><strong>Referenstagning</strong> – referenser kontrolleras.</MudText>
    <MudText Typo="Typo.body2"><strong>Erbjudande / Avslag</strong> – kandidaten får besked.</MudText>
</MudPaper>

@if (_loading) { <MudProgressCircular Color="Color.Primary" Indeterminate="true" /> }
else if (_error != null) { <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert> }
else if (_vakanser.Count == 0) { <MudAlert Severity="Severity.Info" Variant="Variant.Text">Inga vakanser med ansökningar.</MudAlert> }
else
{
    @foreach (var v in _vakanser)
    {
        <MudPaper Class="pa-4 mb-4" Elevation="2">
            <MudText Typo="Typo.h6" Style="font-weight: 600;" Class="mb-2">@v.Titel</MudText>
            <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);" Class="mb-3">@v.EnhetNamn — @v.AntalAnsokngar ansökningar</MudText>
            @if (v.AntalAnsokngar > 0)
            {
                <MudSimpleTable Dense="true" Elevation="0">
                    <thead><tr><th>Kandidat</th><th>E-post</th><th>Status</th></tr></thead>
                    <tbody>
                        @foreach (var a in v.Ansokngar)
                        {
                            <tr><td><strong>@a.Namn</strong></td><td>@a.Epost</td><td><MudChip T="string" Size="Size.Small">@a.Status</MudChip></td></tr>
                        }
                    </tbody>
                </MudSimpleTable>
            }
        </MudPaper>
    }
}

@code {
    private List<VakansVm> _vakanser = [];
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        try
        {
            var vacancies = await db.Vacancies.Where(v => v.Status == VacancyStatus.Publicerad || v.Status == VacancyStatus.Stangd).OrderByDescending(v => v.SistaAnsokningsDag).ToListAsync();
            var enheter = await db.OrganizationUnits.ToListAsync();
            var enhetNamn = enheter.ToDictionary(e => e.Id.Value, e => e.Namn);
            _vakanser = vacancies.Where(v => v.Ansokngar.Count > 0).Select(v => new VakansVm(v.Titel, enhetNamn.GetValueOrDefault(v.EnhetId.Value, "—"), v.Ansokngar.Count, v.Ansokngar.Select(a => new AnsVm(a.Namn, a.Epost, a.Status.ToString())).ToList())).ToList();
        }
        catch (Exception ex) { _error = $"Kunde inte hämta pipeline: {ex.Message}"; }
        finally { _loading = false; }
    }

    private record AnsVm(string Namn, string Epost, string Status);
    private record VakansVm(string Titel, string EnhetNamn, int AntalAnsokngar, List<AnsVm> Ansokngar);
}

