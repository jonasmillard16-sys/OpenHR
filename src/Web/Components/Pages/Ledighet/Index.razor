@page "/ledighet"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Leave.Domain
@using Microsoft.EntityFrameworkCore
@using Microsoft.Extensions.Localization
@inject RegionHRDbContext Db
@inject IStringLocalizer<SharedResources> L

<PageTitle>OpenHR - @L["LeaveManagement"]</PageTitle>
<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4" Style="font-weight: 700;">@L["LeaveManagement"]</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" StartIcon="@Icons.Material.Filled.Add" Href="/ledighet/ny" Style="min-height: 48px;">@L["NewApplication"]</MudButton>
</div>

@if (_error != null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
}

<MudGrid Spacing="3" Class="mb-4">
    <MudItem xs="3"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Warning" Style="font-weight: 700;">@_vantar</MudText><MudText Typo="Typo.body2">@L["AwaitingApproval"]</MudText></MudPaper></MudItem>
    <MudItem xs="3"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Success" Style="font-weight: 700;">@_godkanda</MudText><MudText Typo="Typo.body2">@L["ApprovedThisMonth"]</MudText></MudPaper></MudItem>
    <MudItem xs="3"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Error" Style="font-weight: 700;">@_sjuk</MudText><MudText Typo="Typo.body2">@L["SickLeaveActive"]</MudText></MudPaper></MudItem>
    <MudItem xs="3"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Style="font-weight: 700;">@_vab</MudText><MudText Typo="Typo.body2">@L["ChildCareLeaveActive"]</MudText></MudPaper></MudItem>
</MudGrid>

<MudSimpleTable Hover="true" Elevation="2">
    <thead><tr><th>@L["Employee"]</th><th>@L["Type"]</th><th>@L["Period"]</th><th>@L["Days"]</th><th>@L["Status"]</th><th></th></tr></thead>
    <tbody>
        @foreach (var row in _rader)
        {
            <tr>
                <td><strong>@row.Namn</strong></td>
                <td>@row.TypText</td>
                <td>@row.Period</td>
                <td>@row.Dagar</td>
                <td><MudChip T="string" Size="Size.Small" Color="@row.StatusFarg">@row.StatusText</MudChip></td>
                <td>
                    @if (row.KanGodkannas && _canApprove)
                    {
                        <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Success"
                                   OnClick="@(() => Godkann(row))">@L["Approve"]</MudButton>
                        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error" Class="ml-1"
                                   OnClick="@(() => Neka(row))">@L["Reject"]</MudButton>
                    }
                </td>
            </tr>
        }
    </tbody>
</MudSimpleTable>

@code {
    private List<LedighetRad> _rader = [];
    private int _vantar, _godkanda, _sjuk, _vab;
    private string? _error;

    [Inject] private RegionHR.Web.Services.AuthService Auth { get; set; } = default!;
    private bool _canApprove => Auth.EmployeeId.HasValue;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var requests = await Db.LeaveRequests
                .OrderByDescending(r => r.SkapadVid)
                .Take(50)
                .ToListAsync();

            // Resolve employee names
            var anstallIds = requests.Select(r => r.AnstallId).Distinct().ToList();
            var employees = await Db.Employees
                .Where(e => anstallIds.Contains(e.Id.Value))
                .ToDictionaryAsync(e => e.Id.Value, e => e.FulltNamn);

            _rader = requests.Select(r => new LedighetRad(
                r.Id,
                employees.GetValueOrDefault(r.AnstallId, L["Unknown"].Value),
                MapTyp(r.Typ),
                $"{r.FranDatum:d/M} - {r.TillDatum:d/M}",
                r.AntalDagar.ToString(),
                MapStatusText(r.Status),
                MapStatusColor(r.Status),
                r.Status == LeaveRequestStatus.Inskickad
            )).ToList();

            // Summary counts
            var now = DateTime.Today;
            _vantar = requests.Count(r => r.Status == LeaveRequestStatus.Inskickad);
            _godkanda = requests.Count(r => r.Status == LeaveRequestStatus.Godkand
                && r.FranDatum.Month == now.Month && r.FranDatum.Year == now.Year);
            _sjuk = requests.Count(r => r.Typ == LeaveType.Sjukfranvaro
                && (r.Status == LeaveRequestStatus.Inskickad || r.Status == LeaveRequestStatus.Godkand)
                && r.TillDatum >= DateOnly.FromDateTime(now));
            _vab = requests.Count(r => r.Typ == LeaveType.VAB
                && (r.Status == LeaveRequestStatus.Inskickad || r.Status == LeaveRequestStatus.Godkand)
                && r.TillDatum >= DateOnly.FromDateTime(now));
        }
        catch (Exception ex)
        {
            _error = $"{L["ErrorLoadingLeave"]}: {ex.Message}";
        }
    }

    private async Task Godkann(LedighetRad row)
    {
        if (!Auth.EmployeeId.HasValue) { _error = L["ApprovalRequiresEmployee"]; return; }
        try
        {
            var req = await Db.LeaveRequests.FirstOrDefaultAsync(r => r.Id == row.Id);
            if (req == null) return;
            req.Godkann(Auth.EmployeeId.Value, null);
            await Db.SaveChangesAsync();

            var idx = _rader.IndexOf(row);
            if (idx >= 0)
            {
                _rader[idx] = row with { StatusText = L["Approved"], StatusFarg = Color.Success, KanGodkannas = false };
                _vantar = Math.Max(0, _vantar - 1);
                _godkanda++;
            }
        }
        catch (Exception ex)
        {
            _error = $"{L["ErrorApproving"]}: {ex.Message}";
        }
    }

    private async Task Neka(LedighetRad row)
    {
        if (!Auth.EmployeeId.HasValue) { _error = L["RejectionRequiresEmployee"]; return; }
        try
        {
            var req = await Db.LeaveRequests.FirstOrDefaultAsync(r => r.Id == row.Id);
            if (req == null) return;
            req.Avvisa(Auth.EmployeeId.Value, L["RejectedByManager"]);
            await Db.SaveChangesAsync();

            var idx = _rader.IndexOf(row);
            if (idx >= 0)
            {
                _rader[idx] = row with { StatusText = L["Rejected"], StatusFarg = Color.Error, KanGodkannas = false };
                _vantar = Math.Max(0, _vantar - 1);
            }
        }
        catch (Exception ex)
        {
            _error = $"{L["ErrorRejecting"]}: {ex.Message}";
        }
    }

    private string MapTyp(LeaveType typ) => typ switch
    {
        LeaveType.Semester => L["Vacation"],
        LeaveType.Sjukfranvaro => L["SickLeave"],
        LeaveType.Foraldraledighet => L["ParentalLeave"],
        LeaveType.VAB => L["ChildCareLeave"],
        LeaveType.Tjanstledighet => L["LeaveOfAbsence"],
        LeaveType.Komptid => L["CompTime"],
        LeaveType.Utbildning => L["Education"],
        _ => typ.ToString()
    };

    private string MapStatusText(LeaveRequestStatus status) => status switch
    {
        LeaveRequestStatus.Utkast => L["Draft"],
        LeaveRequestStatus.Inskickad => L["Waiting"],
        LeaveRequestStatus.Godkand => L["Approved"],
        LeaveRequestStatus.Avslagen => L["Rejected"],
        LeaveRequestStatus.Aterkallad => L["Withdrawn"],
        _ => status.ToString()
    };

    private static Color MapStatusColor(LeaveRequestStatus status) => status switch
    {
        LeaveRequestStatus.Inskickad => Color.Warning,
        LeaveRequestStatus.Godkand => Color.Success,
        LeaveRequestStatus.Avslagen => Color.Error,
        LeaveRequestStatus.Aterkallad => Color.Default,
        _ => Color.Info
    };

    private record LedighetRad(Guid Id, string Namn, string TypText, string Period, string Dagar, string StatusText, Color StatusFarg, bool KanGodkannas);
}
