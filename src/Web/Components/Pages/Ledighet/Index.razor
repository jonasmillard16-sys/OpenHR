@page "/ledighet"
@rendermode InteractiveServer
@layout RegionHR.Web.Components.Layout.AdminLayout

<PageTitle>OpenHR - Ledighetshantering</PageTitle>
<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4" Style="font-weight: 700;">Ledighetshantering</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" StartIcon="@Icons.Material.Filled.Add" Href="/ledighet/ny" Style="min-height: 48px;">Ny ansökan</MudButton>
</div>

<MudGrid Spacing="3" Class="mb-4">
    <MudItem xs="3"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Warning" Style="font-weight: 700;">6</MudText><MudText Typo="Typo.body2">Väntar godkännande</MudText></MudPaper></MudItem>
    <MudItem xs="3"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Success" Style="font-weight: 700;">23</MudText><MudText Typo="Typo.body2">Godkända (mars)</MudText></MudPaper></MudItem>
    <MudItem xs="3"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Color="Color.Error" Style="font-weight: 700;">4</MudText><MudText Typo="Typo.body2">Sjukfrånvaro (aktiv)</MudText></MudPaper></MudItem>
    <MudItem xs="3"><MudPaper Class="pa-3 text-center" Elevation="1"><MudText Typo="Typo.h4" Style="font-weight: 700;">2</MudText><MudText Typo="Typo.body2">VAB (aktiv)</MudText></MudPaper></MudItem>
</MudGrid>

<MudSimpleTable Hover="true" Elevation="2">
    <thead><tr><th>Anställd</th><th>Typ</th><th>Period</th><th>Dagar</th><th>Status</th><th></th></tr></thead>
    <tbody>
        <tr><td><strong>Anna Svensson</strong></td><td>Semester</td><td>21-25 mars</td><td>5</td><td><MudChip T="string" Size="Size.Small" Color="Color.Warning">Väntar</MudChip></td><td><MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Success">Godkänn</MudButton> <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error">Nej</MudButton></td></tr>
        <tr><td><strong>Karl Berg</strong></td><td>Sjukfrånvaro</td><td>14 mars &#8594;</td><td>3+</td><td><MudChip T="string" Size="Size.Small" Color="Color.Error">Sjuk</MudChip></td><td></td></tr>
        <tr><td><strong>Erik Johansson</strong></td><td>Semester</td><td>17-21 mars</td><td>5</td><td><MudChip T="string" Size="Size.Small" Color="Color.Success">Godkänd</MudChip></td><td></td></tr>
        <tr><td><strong>Per Gustafsson</strong></td><td>VAB</td><td>17-18 mars</td><td>2</td><td><MudChip T="string" Size="Size.Small" Color="Color.Info">Rapporterad</MudChip></td><td></td></tr>
    </tbody>
</MudSimpleTable>
