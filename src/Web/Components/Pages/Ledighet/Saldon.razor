@page "/ledighet/saldon"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Leave.Domain
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<RegionHRDbContext> DbFactory

<PageTitle>OpenHR - Semestersaldon</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">Semestersaldon @DateTime.Today.Year</MudText>

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error">@_error</MudAlert>
}
else if (_rader.Count == 0)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Text">Inga semestersaldon registrerade för @DateTime.Today.Year.</MudAlert>
}
else
{
    <MudSimpleTable Hover="true" Elevation="2">
        <thead><tr><th>Anställd</th><th>Tilldelning</th><th>Uttagna</th><th>Sparade</th><th>Tillgängliga</th></tr></thead>
        <tbody>
            @foreach (var row in _rader)
            {
                <tr>
                    <td><strong>@row.Namn</strong></td>
                    <td>@row.Tilldelning</td>
                    <td>@row.Uttagna</td>
                    <td>@row.Sparade</td>
                    <td><strong>@row.Tillgangliga</strong></td>
                </tr>
            }
        </tbody>
    </MudSimpleTable>
}

@code {
    private List<SaldoRad> _rader = [];
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        try
        {
            var balances = await db.VacationBalances
                .Where(b => b.Ar == DateTime.Today.Year)
                .ToListAsync();

            var anstallGuids = balances.Select(b => b.AnstallId).Distinct().ToList();
            var anstallIds = anstallGuids.Select(g => new EmployeeId(g)).ToList();
            var employees = await db.Employees
                .Where(e => anstallIds.Contains(e.Id))
                .ToListAsync();
            var names = employees.ToDictionary(e => e.Id.Value, e => $"{e.Fornamn} {e.Efternamn}");

            _rader = balances
                .Select(b => new SaldoRad(
                    names.GetValueOrDefault(b.AnstallId, "Okänd"),
                    b.Tilldelning,
                    b.UttagnaDagar,
                    b.SparadeDagar,
                    b.TillgangligaDagar))
                .OrderBy(r => r.Namn)
                .ToList();
        }
        catch (Exception ex) { _error = $"Kunde inte hämta semestersaldon: {ex.Message}"; }
        finally { _loading = false; }
    }

    private record SaldoRad(string Namn, int Tilldelning, int Uttagna, int Sparade, int Tillgangliga);
}

