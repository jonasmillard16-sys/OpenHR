@page "/ledighet/saldon"
@rendermode InteractiveServer
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Leave.Domain
@using Microsoft.EntityFrameworkCore
@inject RegionHRDbContext Db

<PageTitle>OpenHR - Semestersaldon</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">Semestersaldon @DateTime.Today.Year</MudText>

<MudSimpleTable Hover="true" Elevation="2">
    <thead><tr><th>Anställd</th><th>Tilldelning</th><th>Uttagna</th><th>Sparade</th><th>Tillgängliga</th></tr></thead>
    <tbody>
        @foreach (var row in _rader)
        {
            <tr>
                <td><strong>@row.Namn</strong></td>
                <td>@row.Tilldelning</td>
                <td>@row.Uttagna</td>
                <td>@row.Sparade</td>
                <td><strong>@row.Tillgangliga</strong></td>
            </tr>
        }
    </tbody>
</MudSimpleTable>

@code {
    private List<SaldoRad> _rader = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var balances = await Db.VacationBalances
                .Where(b => b.Ar == DateTime.Today.Year)
                .Take(100)
                .ToListAsync();

            if (balances.Count > 0)
            {
                // Resolve employee names
                var anstallIds = balances.Select(b => b.AnstallId).Distinct().ToList();
                var employees = await Db.Employees
                    .Where(e => anstallIds.Contains(e.Id.Value))
                    .ToDictionaryAsync(e => e.Id.Value, e => e.FulltNamn);

                _rader = balances.Select(b => new SaldoRad(
                    employees.GetValueOrDefault(b.AnstallId, "Okänd"),
                    b.Tilldelning,
                    b.UttagnaDagar,
                    b.SparadeDagar,
                    b.TillgangligaDagar
                )).ToList();
                return;
            }
        }
        catch
        {
            // Fall through to demo data
        }

        // Demo data fallback
        _rader =
        [
            new("Anna Svensson", 25, 7, 5, 23),
            new("Karl Berg", 31, 10, 3, 24),
            new("Lisa Holm", 25, 5, 0, 20),
            new("Erik Johansson", 32, 15, 8, 25),
            new("Maria Lindgren", 25, 3, 2, 24),
        ];
    }

    private record SaldoRad(string Namn, int Tilldelning, int Uttagna, int Sparade, int Tillgangliga);
}
