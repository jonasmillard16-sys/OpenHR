@page "/ledighet/ny"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Leave.Domain
@using RegionHR.Infrastructure.Persistence
@using Microsoft.EntityFrameworkCore
@using Microsoft.Extensions.Localization
@inject IDbContextFactory<RegionHRDbContext> DbFactory
@inject NavigationManager Nav
@inject IStringLocalizer<SharedResources> L

<PageTitle>OpenHR — @L["NewLeaveRequest"]</PageTitle>

<MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Variant="Variant.Text"
           Color="Color.Primary" Href="/ledighet" Style="margin-bottom: 1rem;">@L["Back"]</MudButton>

<MudText Typo="Typo.h4" Class="mb-2" Style="font-weight: 700;">@L["NewLeaveRequest"]</MudText>
<MudText Typo="Typo.body2" Class="mb-4" Style="color: var(--mud-palette-text-secondary);">
    @L["LeaveRequestSaved"]
</MudText>

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
}
else if (_created != null)
{
    <MudPaper Class="pa-5" Elevation="2" Style="border-left: 4px solid var(--mud-palette-success);">
        <MudText Typo="Typo.h6" Color="Color.Success" Style="font-weight: 700;" Class="mb-3">@L["ApplicationSubmitted"]</MudText>
        <MudSimpleTable Dense="true" Elevation="0" Class="mb-3">
            <tbody>
                <tr><td><strong>@L["Employee"]</strong></td><td>@GetEmployeeName(_created.AnstallId)</td></tr>
                <tr><td><strong>@L["Type"]</strong></td><td>@_created.Typ</td></tr>
                <tr><td><strong>@L["From"]</strong></td><td>@_created.FranDatum.ToString("yyyy-MM-dd")</td></tr>
                <tr><td><strong>@L["To"]</strong></td><td>@_created.TillDatum.ToString("yyyy-MM-dd")</td></tr>
                <tr><td><strong>@L["WorkDays"]</strong></td><td>@_created.AntalDagar</td></tr>
                <tr><td><strong>@L["Status"]</strong></td><td><MudChip T="string" Size="Size.Small" Color="Color.Info">@_created.Status</MudChip></td></tr>
                @if (_created.Beskrivning != null)
                {
                    <tr><td><strong>@L["Description"]</strong></td><td>@_created.Beskrivning</td></tr>
                }
            </tbody>
        </MudSimpleTable>
        <div class="d-flex gap-2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/ledighet">@L["BackToOverview"]</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="Reset">@L["CreateAnother"]</MudButton>
        </div>
    </MudPaper>
}
else
{
    <MudPaper Class="pa-5" Elevation="2">
        <MudGrid Spacing="3">
            <MudItem xs="12" sm="6">
                <MudSelect T="Guid?" @bind-Value="_anstallId" Label="@L["Employee"]" Variant="Variant.Outlined" Required="true">
                    @foreach (var e in _employees)
                    {
                        <MudSelectItem T="Guid?" Value="@((Guid?)e.Id.Value)">@e.Fornamn @e.Efternamn</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect T="LeaveType" @bind-Value="_typ" Label="@L["LeaveType"]" Variant="Variant.Outlined">
                    @foreach (var t in Enum.GetValues<LeaveType>())
                    {
                        <MudSelectItem Value="@t">@TypText(t)</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudDatePicker @bind-Date="_franDatum" Label="@L["From"]" Variant="Variant.Outlined" Required="true" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudDatePicker @bind-Date="_tillDatum" Label="@L["To"]" Variant="Variant.Outlined" Required="true" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_beskrivning" Label="@L["DescriptionOptional"]" Variant="Variant.Outlined" />
            </MudItem>
        </MudGrid>

        @if (_anstallId != null && _balans != null)
        {
            <MudAlert Severity="Severity.Info" Class="mt-3" Variant="Variant.Text" Dense="true">
                @L["VacationBalance"] @_balans.Ar: @_balans.TillgangligaDagar @L["DaysAvailable"]
                (@L["Allocation"] @_balans.Tilldelning, @L["DaysTaken"] @_balans.UttagnaDagar, @L["DaysSaved"] @_balans.SparadeDagar)
            </MudAlert>
        }

        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Class="mt-4"
                   Style="min-height: 48px;" OnClick="Skapa"
                   Disabled="@(_anstallId == null || _franDatum == null || _tillDatum == null || _saving)">
            @if (_saving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            @L["SubmitApplication"]
        </MudButton>
    </MudPaper>
}

@code {
    private List<RegionHR.Core.Domain.Employee> _employees = [];
    private Dictionary<Guid, VacationBalance> _balansPerAnstall = [];
    private LeaveRequest? _created;
    private VacationBalance? _balans;
    private Guid? _anstallId;
    private LeaveType _typ = LeaveType.Semester;
    private DateTime? _franDatum, _tillDatum;
    private string _beskrivning = "";
    private bool _loading = true, _saving;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        try
        {
            _employees = await db.Employees.OrderBy(e => e.Efternamn).ToListAsync();
            var year = DateTime.Today.Year;
            var balances = await db.VacationBalances
                .Where(b => b.Ar == year)
                .ToListAsync();
            _balansPerAnstall = balances.ToDictionary(b => b.AnstallId);
        }
        catch (Exception ex) { _error = $"{L["ErrorLoadingData"]}: {ex.Message}"; }
        finally { _loading = false; }
    }

    private async Task Skapa()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        if (_anstallId == null || _franDatum == null || _tillDatum == null) return;
        _saving = true;
        _error = null;
        StateHasChanged();

        try
        {
            var from = DateOnly.FromDateTime(_franDatum.Value);
            var to = DateOnly.FromDateTime(_tillDatum.Value);

            // 1. Skapa via domänens factory
            var request = LeaveRequest.Skapa(
                _anstallId.Value, _typ, from, to,
                string.IsNullOrWhiteSpace(_beskrivning) ? null : _beskrivning);

            // 2. Skicka in (Utkast -> Inskickad)
            request.SkickaIn();

            // 3. Persistera
            db.LeaveRequests.Add(request);
            await db.SaveChangesAsync();

            _created = request;
        }
        catch (Exception ex) { _error = $"{L["ErrorCreatingRequest"]}: {ex.Message}"; }
        finally { _saving = false; }
    }

    // Uppdatera saldo när anställd väljs
    private Guid? _lastAnstallId;
    protected override void OnAfterRender(bool firstRender)
    {
        if (_anstallId != null && _anstallId != _lastAnstallId)
        {
            _lastAnstallId = _anstallId;
            _balansPerAnstall.TryGetValue(_anstallId.Value, out var b);
            _balans = b;
            StateHasChanged();
        }
    }

    private void Reset()
    {
        _created = null;
        _anstallId = null;
        _franDatum = null;
        _tillDatum = null;
        _beskrivning = "";
        _balans = null;
        _lastAnstallId = null;
    }

    private string GetEmployeeName(Guid id)
    {
        var emp = _employees.FirstOrDefault(e => e.Id.Value == id);
        return emp != null ? $"{emp.Fornamn} {emp.Efternamn}" : L["Unknown"].Value;
    }

    private string TypText(LeaveType t) => t switch
    {
        LeaveType.Semester => L["Vacation"],
        LeaveType.Sjukfranvaro => L["SickLeave"],
        LeaveType.Foraldraledighet => L["ParentalLeave"],
        LeaveType.VAB => L["ChildCareLeave"],
        LeaveType.Tjanstledighet => L["LeaveOfAbsence"],
        LeaveType.Komptid => L["CompTime"],
        LeaveType.Utbildning => L["Education"],
        _ => t.ToString()
    };
}

