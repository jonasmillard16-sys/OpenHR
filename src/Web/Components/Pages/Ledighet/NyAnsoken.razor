@page "/ledighet/ny"
@rendermode InteractiveServer
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Web.Components.Shared
@inject NavigationManager Nav

<PageTitle>OpenHR - Ny ledighetsansökan</PageTitle>
<MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Variant="Variant.Text" Color="Color.Primary" Href="/ledighet" Style="margin-bottom: 1rem;">Tillbaka</MudButton>

<OhrConversationFlow Steps="@_steps" CurrentStep="@_step" OnBack="@(() => { if (_step > 0) _step--; })">
    @switch (_step)
    {
        case 0:
            <MudText Typo="Typo.h5" Class="mb-4" Style="font-weight: 600;">Vilken typ av ledighet?</MudText>
            <MudStack Spacing="3">
                @foreach (var typ in _typer)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Large" FullWidth="true" Style="min-height: 56px; font-size: 1.125rem;" OnClick="@(() => { _typ = typ.Name; _step = 1; })">
                        @typ.Icon @typ.Name
                    </MudButton>
                }
            </MudStack>
            break;
        case 1:
            <MudText Typo="Typo.h5" Class="mb-4" Style="font-weight: 600;">Vilka dagar?</MudText>
            <MudDateRangePicker Label="Välj period" @bind-DateRange="_dateRange" Class="mb-4" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" FullWidth="true" Style="min-height: 56px;" OnClick="@(() => _step = 2)" Disabled="@(_dateRange?.Start == null)">
                Nästa
            </MudButton>
            break;
        case 2:
            <div style="padding: 1rem 0;">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Large" Class="mb-4" Style="display: block; margin: 0 auto;" />
                <MudText Typo="Typo.h4" Color="Color.Success" Style="font-weight: 700; text-align: center;" Class="mb-4">Klart!</MudText>

                <MudPaper Class="pa-4 mb-4" Elevation="2">
                    <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight: 600;">Sammanfattning</MudText>
                    <MudSimpleTable Dense="true">
                        <tbody>
                            <tr><td><strong>Ledighetstyp</strong></td><td>@_typ</td></tr>
                            <tr><td><strong>Från</strong></td><td>@(_dateRange?.Start?.ToString("yyyy-MM-dd") ?? "—")</td></tr>
                            <tr><td><strong>Till</strong></td><td>@(_dateRange?.End?.ToString("yyyy-MM-dd") ?? "—")</td></tr>
                            <tr><td><strong>Antal dagar</strong></td><td>@AntalDagar()</td></tr>
                            <tr><td><strong>Godkännare (chef)</strong></td><td>Eva Nilsson</td></tr>
                            <tr><td><strong>Ärendenummer</strong></td><td>@_arendenummer</td></tr>
                        </tbody>
                    </MudSimpleTable>
                </MudPaper>

                <MudAlert Severity="Severity.Info" Variant="Variant.Text" Class="mb-4">
                    Din chef har fått en notis om din ansökan.
                </MudAlert>

                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" FullWidth="true" Href="/ledighet" Style="min-height: 56px;">
                    Tillbaka till ledighetsöversikt
                </MudButton>
            </div>
            break;
    }
</OhrConversationFlow>

@code {
    private readonly List<string> _steps = ["Typ", "Period", "Klart!"];
    private int _step;
    private string _typ = "";
    private MudBlazor.DateRange? _dateRange;
    private string _arendenummer = "";

    protected override void OnInitialized()
    {
        _arendenummer = $"LED-{DateTime.Now:yyyyMMdd}-{Random.Shared.Next(1000, 9999)}";
    }

    private int AntalDagar()
    {
        if (_dateRange?.Start == null || _dateRange?.End == null) return 0;
        return (int)(_dateRange.End.Value - _dateRange.Start.Value).TotalDays + 1;
    }

    private record LeaveType(string Icon, string Name);
    private static readonly LeaveType[] _typer =
    [
        new("\U0001F334", "Semester"),
        new("\U0001F476", "Föräldraledighet"),
        new("\U0001F3E0", "VAB"),
        new("\U0001F4DA", "Tjänstledighet"),
        new("\u23F0", "Komptid")
    ];
}
