@page "/ledighet/kalender"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Leave.Domain
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<RegionHRDbContext> DbFactory

<PageTitle>OpenHR - Teamkalender</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">Teamkalender — @_currentMonth.ToString("MMMM yyyy", _sv)</MudText>

@if (_error != null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
}

@* Month navigation *@
<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4" Spacing="2">
    <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft" OnClick="PreviousMonth" />
    <MudText Typo="Typo.h6" Style="font-weight: 600; min-width: 160px; text-align: center;">
        @_currentMonth.ToString("MMMM yyyy", _sv)
    </MudText>
    <MudIconButton Icon="@Icons.Material.Filled.ChevronRight" OnClick="NextMonth" />
    <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="GoToToday">Idag</MudButton>
</MudStack>

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else
{
    @* Monthly calendar grid *@
    <MudPaper Elevation="2" Class="pa-3 mb-6">
        <div style="display: grid; grid-template-columns: repeat(7, 1fr); gap: 2px;">
            @foreach (var dayName in _dayNames)
            {
                <div style="text-align: center; font-weight: 600; padding: 8px 4px; background: var(--mud-palette-background-grey); border-radius: 4px;">
                    @dayName
                </div>
            }

            @for (var i = 0; i < _firstDayOffset; i++)
            {
                <div style="min-height: 80px; padding: 4px;"></div>
            }

            @for (var day = 1; day <= _daysInMonth; day++)
            {
                var currentDay = day;
                var date = new DateOnly(_currentMonth.Year, _currentMonth.Month, currentDay);
                var isToday = date == DateOnly.FromDateTime(DateTime.Today);
                var dayLeaves = GetLeavesForDate(date);
                var hasLeave = dayLeaves.Count > 0;
                var isWeekend = date.DayOfWeek == DayOfWeek.Saturday || date.DayOfWeek == DayOfWeek.Sunday;

                <div @onclick="@(() => ShowDayDetails(date))"
                     style="min-height: 80px; padding: 4px; border: 1px solid var(--mud-palette-lines-default);
                            border-radius: 4px; cursor: @(hasLeave ? "pointer" : "default");
                            background: @(isToday ? "var(--mud-palette-primary-lighten)" : isWeekend ? "var(--mud-palette-background-grey)" : "transparent");
                            transition: background 0.15s;">
                    <div style="font-weight: @(isToday ? "700" : "400"); font-size: 0.85rem;
                                color: @(isToday ? "var(--mud-palette-primary)" : "inherit");">
                        @currentDay
                    </div>
                    @foreach (var leave in dayLeaves.Take(3))
                    {
                        <MudChip T="string" Size="Size.Small" Style="@($"font-size: 0.7rem; height: 20px; margin: 1px 0; background: {leave.Color}; color: white;")"
                                 Class="px-1">
                            @leave.ShortName
                        </MudChip>
                    }
                    @if (dayLeaves.Count > 3)
                    {
                        <MudText Typo="Typo.caption" Style="font-size: 0.65rem;">+@(dayLeaves.Count - 3) till</MudText>
                    }
                </div>
            }
        </div>
    </MudPaper>

    @* Legend *@
    <MudStack Row="true" Spacing="4" Class="mb-6">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
            <div style="width: 16px; height: 16px; border-radius: 3px; background: #0e7490;"></div>
            <MudText Typo="Typo.body2">Semester</MudText>
        </MudStack>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
            <div style="width: 16px; height: 16px; border-radius: 3px; background: #dc2626;"></div>
            <MudText Typo="Typo.body2">Sjuk</MudText>
        </MudStack>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
            <div style="width: 16px; height: 16px; border-radius: 3px; background: #f59e0b;"></div>
            <MudText Typo="Typo.body2">VAB</MudText>
        </MudStack>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
            <div style="width: 16px; height: 16px; border-radius: 3px; background: #7c3aed;"></div>
            <MudText Typo="Typo.body2">Föräldraledighet</MudText>
        </MudStack>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
            <div style="width: 16px; height: 16px; border-radius: 3px; background: #6b7280;"></div>
            <MudText Typo="Typo.body2">Tjänstledighet</MudText>
        </MudStack>
    </MudStack>

    @* Day detail popover *@
    @if (_selectedDate.HasValue)
    {
        var selectedLeaves = GetLeavesForDate(_selectedDate.Value);
        <MudPaper Elevation="4" Class="pa-4 mb-4" Style="border-left: 4px solid var(--mud-palette-primary);">
            <div class="d-flex justify-space-between align-center mb-2">
                <MudText Typo="Typo.h6" Style="font-weight: 600;">
                    @_selectedDate.Value.ToString("dddd d MMMM yyyy", _sv)
                </MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="@(() => _selectedDate = null)" />
            </div>
            @if (selectedLeaves.Count > 0)
            {
                <MudSimpleTable Dense="true" Hover="true" Elevation="0">
                    <thead><tr><th>Anställd</th><th>Typ</th><th>Period</th></tr></thead>
                    <tbody>
                        @foreach (var leave in selectedLeaves)
                        {
                            <tr>
                                <td>@leave.EmployeeName</td>
                                <td><MudChip T="string" Size="Size.Small" Style="@($"background: {leave.Color}; color: white;")">@leave.Type</MudChip></td>
                                <td>@leave.StartDate.ToString("d MMM", _sv) – @leave.EndDate.ToString("d MMM", _sv)</td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            }
            else
            {
                <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">Inga ledigheter denna dag.</MudText>
            }
        </MudPaper>
    }

    @* Weekly team overview *@
    @if (_weekDates.Count > 0)
    {
        <MudText Typo="Typo.h5" Class="mb-3 mt-4" Style="font-weight: 600;">Veckovy — v.@System.Globalization.ISOWeek.GetWeekOfYear(DateTime.Today)</MudText>
        @if (_weekEmployees.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Text">Inga ledigheter registrerade denna vecka.</MudAlert>
        }
        else
        {
            <MudSimpleTable Hover="true" Elevation="2" Dense="true">
                <thead>
                    <tr>
                        <th>Anställd</th>
                        @foreach (var d in _weekDates)
                        {
                            <th>@d.ToString("ddd d/M", _sv)</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var emp in _weekEmployees)
                    {
                        <tr>
                            <td>@emp.Name</td>
                            @foreach (var cell in emp.Days)
                            {
                                <td style="@(cell.Bg != null ? $"background: {cell.Bg};" : "")">@cell.Symbol</td>
                            }
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        }
    }
}

@code {
    private static readonly System.Globalization.CultureInfo _sv = System.Globalization.CultureInfo.GetCultureInfo("sv-SE");
    private readonly string[] _dayNames = ["Mån", "Tis", "Ons", "Tor", "Fre", "Lör", "Sön"];

    private DateOnly _currentMonth;
    private int _daysInMonth;
    private int _firstDayOffset;
    private DateOnly? _selectedDate;
    private bool _loading = true;
    private string? _error;

    private List<LeaveEntry> _leaveEntries = [];
    private Dictionary<Guid, string> _empNames = [];

    // Weekly view
    private List<DateOnly> _weekDates = [];
    private List<WeekRow> _weekEmployees = [];

    protected override async Task OnInitializedAsync()
    {
        _currentMonth = new DateOnly(DateTime.Today.Year, DateTime.Today.Month, 1);
        CalculateMonthLayout();
        await LoadLeaveDataAsync();
        BuildWeekView();
        _loading = false;
    }

    private void CalculateMonthLayout()
    {
        _daysInMonth = DateTime.DaysInMonth(_currentMonth.Year, _currentMonth.Month);
        var firstDay = new DateOnly(_currentMonth.Year, _currentMonth.Month, 1);
        _firstDayOffset = ((int)firstDay.DayOfWeek + 6) % 7;
    }

    private async Task LoadLeaveDataAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        try
        {
            var monthStart = new DateOnly(_currentMonth.Year, _currentMonth.Month, 1);
            var monthEnd = new DateOnly(_currentMonth.Year, _currentMonth.Month, _daysInMonth);

            var requests = await db.LeaveRequests
                .Where(r => r.FranDatum <= monthEnd && r.TillDatum >= monthStart
                    && (r.Status == LeaveRequestStatus.Inskickad || r.Status == LeaveRequestStatus.Godkand))
                .ToListAsync();

            var anstallGuids = requests.Select(r => r.AnstallId).Distinct().ToList();
            var anstallIds = anstallGuids.Select(g => new EmployeeId(g)).ToList();
            var employees = await db.Employees
                .Where(e => anstallIds.Contains(e.Id))
                .ToListAsync();
            _empNames = employees.ToDictionary(e => e.Id.Value, e => $"{e.Fornamn} {e.Efternamn}");

            _leaveEntries = requests.Select(r => new LeaveEntry(
                _empNames.GetValueOrDefault(r.AnstallId, "Okänd"),
                TypText(r.Typ),
                r.FranDatum,
                r.TillDatum,
                TypColor(r.Typ)
            )).ToList();

            _error = null;
        }
        catch (Exception ex)
        {
            _error = $"Kunde inte hämta ledighetsdata: {ex.Message}";
            _leaveEntries = [];
        }
    }

    private void BuildWeekView()
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        var monday = today.AddDays(-((int)today.DayOfWeek + 6) % 7);
        _weekDates = Enumerable.Range(0, 5).Select(i => monday.AddDays(i)).ToList();

        var weekStart = _weekDates[0];
        var weekEnd = _weekDates[^1];

        var weekLeaves = _leaveEntries
            .Where(l => l.StartDate <= weekEnd && l.EndDate >= weekStart)
            .ToList();

        var empGroups = weekLeaves
            .GroupBy(l => l.EmployeeName)
            .OrderBy(g => g.Key);

        _weekEmployees = empGroups.Select(g =>
        {
            var days = _weekDates.Select(d =>
            {
                var leave = g.FirstOrDefault(l => d >= l.StartDate && d <= l.EndDate);
                return leave != null
                    ? new DayCell(TypSymbol(leave.Type), leave.Color + "30")
                    : new DayCell("\u2705", null);
            }).ToList();
            return new WeekRow(g.Key, days);
        }).ToList();
    }

    private List<LeaveEntry> GetLeavesForDate(DateOnly date) =>
        _leaveEntries.Where(l => date >= l.StartDate && date <= l.EndDate).ToList();

    private void ShowDayDetails(DateOnly date) =>
        _selectedDate = _selectedDate == date ? null : date;

    private async Task PreviousMonth()
    {
        _currentMonth = _currentMonth.AddMonths(-1);
        _selectedDate = null;
        CalculateMonthLayout();
        await LoadLeaveDataAsync();
        BuildWeekView();
    }

    private async Task NextMonth()
    {
        _currentMonth = _currentMonth.AddMonths(1);
        _selectedDate = null;
        CalculateMonthLayout();
        await LoadLeaveDataAsync();
        BuildWeekView();
    }

    private async Task GoToToday()
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        _currentMonth = new DateOnly(today.Year, today.Month, 1);
        _selectedDate = today;
        CalculateMonthLayout();
        await LoadLeaveDataAsync();
        BuildWeekView();
    }

    private static string TypText(LeaveType t) => t switch
    {
        LeaveType.Semester => "Semester",
        LeaveType.Sjukfranvaro => "Sjuk",
        LeaveType.VAB => "VAB",
        LeaveType.Foraldraledighet => "Föräldraledighet",
        LeaveType.Tjanstledighet => "Tjänstledighet",
        LeaveType.Komptid => "Komptid",
        LeaveType.Utbildning => "Utbildning",
        _ => t.ToString()
    };

    private static string TypColor(LeaveType t) => t switch
    {
        LeaveType.Semester => "#0e7490",
        LeaveType.Sjukfranvaro => "#dc2626",
        LeaveType.VAB => "#f59e0b",
        LeaveType.Foraldraledighet => "#7c3aed",
        LeaveType.Tjanstledighet => "#6b7280",
        _ => "#6b7280"
    };

    private static string TypSymbol(string type) => type switch
    {
        "Semester" => "\U0001F334",
        "Sjuk" => "\U0001F912",
        "VAB" => "\U0001F476",
        "Föräldraledighet" => "\U0001F476",
        _ => "\U0001F4C5"
    };

    private record LeaveEntry(string EmployeeName, string Type, DateOnly StartDate, DateOnly EndDate, string Color)
    {
        public string ShortName => EmployeeName.Split(' ')[0][..Math.Min(3, EmployeeName.Split(' ')[0].Length)] +
                                   " " + Type[..Math.Min(3, Type.Length)];
    }

    private record DayCell(string Symbol, string? Bg);
    private record WeekRow(string Name, List<DayCell> Days);
}

