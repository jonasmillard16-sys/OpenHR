@page "/ledighet/kalender"
@rendermode InteractiveServer
@layout RegionHR.Web.Components.Layout.AdminLayout

<PageTitle>OpenHR - Teamkalender</PageTitle>
<MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">Teamkalender — Mars 2026</MudText>
<MudText Typo="Typo.body1" Class="mb-4" Style="color: var(--mud-palette-text-secondary);">Avdelning 32</MudText>

<MudSimpleTable Hover="true" Elevation="2" Dense="true">
    <thead><tr><th>Anställd</th><th>Mån 17</th><th>Tis 18</th><th>Ons 19</th><th>Tor 20</th><th>Fre 21</th></tr></thead>
    <tbody>
        @foreach (var rad in _data)
        {
            <tr>
                <td>@rad.Namn</td>
                @foreach (var dag in rad.Dagar)
                {
                    <td style="@(dag.Bakgrund != null ? $"background: {dag.Bakgrund};" : "")">@dag.Symbol</td>
                }
            </tr>
        }
    </tbody>
</MudSimpleTable>

<MudStack Row="true" Spacing="4" Class="mt-3">
    <MudText Typo="Typo.body2">@OK Arbetar</MudText>
    <MudText Typo="Typo.body2">@Palm Semester</MudText>
    <MudText Typo="Typo.body2">@Sjuk Sjuk</MudText>
    <MudText Typo="Typo.body2">@Barn VAB</MudText>
</MudStack>

@code {
    private const string OK = "\u2705";
    private const string Palm = "\U0001F334";
    private const string Sjuk = "\U0001F912";
    private const string Barn = "\U0001F476";

    private List<KalenderRad> _data = [];

    protected override void OnInitialized()
    {
        _data =
        [
            new("Anna Svensson", [D(OK), D(OK), D(OK), D(OK), D(Palm, "#d4e6f1")]),
            new("Karl Berg", [D(Sjuk, "#f5b7b1"), D(Sjuk, "#f5b7b1"), D(Sjuk, "#f5b7b1"), D(Sjuk, "#f5b7b1"), D(Sjuk, "#f5b7b1")]),
            new("Lisa Holm", [D(OK), D(OK), D(OK), D(OK), D(OK)]),
            new("Erik Johansson", [D(Palm, "#d4e6f1"), D(Palm, "#d4e6f1"), D(Palm, "#d4e6f1"), D(Palm, "#d4e6f1"), D(Palm, "#d4e6f1")]),
            new("Per Gustafsson", [D(Barn, "#fdebd0"), D(Barn, "#fdebd0"), D(OK), D(OK), D(OK)]),
        ];
    }

    private static DagCell D(string symbol, string? bg = null) => new(symbol, bg);
    private record DagCell(string Symbol, string? Bakgrund);
    private record KalenderRad(string Namn, List<DagCell> Dagar);
}
