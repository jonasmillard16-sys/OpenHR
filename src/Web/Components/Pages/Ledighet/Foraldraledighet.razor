@page "/ledighet/foraldraledighet"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Leave.Domain
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<RegionHRDbContext> DbFactory

<PageTitle>OpenHR - Föräldraledighet</PageTitle>
<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4" Style="font-weight: 700;">Föräldraledighet</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" StartIcon="@Icons.Material.Filled.Add" Style="min-height: 48px;" OnClick="@(() => _showForm = true)">Ny ansökan</MudButton>
</div>

@* Statisk referensinformation om FK-regler — ej live-data *@
<MudText Typo="Typo.h6" Class="mb-3">480-dagarsöversikt (Försäkringskassans regler)</MudText>
<MudGrid Spacing="3" Class="mb-4">
    <MudItem xs="3">
        <MudPaper Class="pa-3 text-center" Elevation="1">
            <MudText Typo="Typo.h4" Color="Color.Primary" Style="font-weight: 700;">480</MudText>
            <MudText Typo="Typo.body2">Totalt dagar per barn</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="3">
        <MudPaper Class="pa-3 text-center" Elevation="1">
            <MudText Typo="Typo.h4" Color="Color.Info" Style="font-weight: 700;">390</MudText>
            <MudText Typo="Typo.body2">Sjukpenningnivå</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="3">
        <MudPaper Class="pa-3 text-center" Elevation="1">
            <MudText Typo="Typo.h4" Color="Color.Warning" Style="font-weight: 700;">90</MudText>
            <MudText Typo="Typo.body2">Lägstanivå (180 kr/dag)</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="3">
        <MudPaper Class="pa-3 text-center" Elevation="1">
            <MudText Typo="Typo.h4" Color="Color.Success" Style="font-weight: 700;">240</MudText>
            <MudText Typo="Typo.body2">Dagar per förälder</MudText>
        </MudPaper>
    </MudItem>
</MudGrid>

<MudAlert Severity="Severity.Info" Class="mb-4">
    Varje förälder har 240 dagar varav 90 dagar är reserverade och kan inte överlåtas.
    195 dagar på sjukpenningnivå + 45 dagar på lägstanivå per förälder.
</MudAlert>

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
}
else
{
    @* Ny ansökan *@
    @if (_showForm)
    {
        <MudPaper Class="pa-5 mb-4" Elevation="3" Style="border-left: 4px solid var(--mud-palette-primary);">
            <div class="d-flex justify-space-between align-center mb-3">
                <MudText Typo="Typo.h6" Style="font-weight: 600;">Ny föräldraledighetansökan</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="@(() => _showForm = false)" />
            </div>
            <MudGrid Spacing="3">
                <MudItem xs="12" sm="4">
                    <MudSelect T="Guid?" @bind-Value="_formAnstallId" Label="Anställd" Variant="Variant.Outlined" Required="true">
                        @foreach (var e in _employees)
                        {
                            <MudSelectItem T="Guid?" Value="@((Guid?)e.Id.Value)">@e.Fornamn @e.Efternamn</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudDatePicker @bind-Date="_formFran" Label="Från" Variant="Variant.Outlined" Required="true" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudDatePicker @bind-Date="_formTill" Label="Till" Variant="Variant.Outlined" Required="true" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_formBeskrivning" Label="Beskrivning (valfritt)" Variant="Variant.Outlined" />
                </MudItem>
            </MudGrid>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-3"
                       OnClick="SkapaAnsolan"
                       Disabled="@(_formAnstallId == null || _formFran == null || _formTill == null || _saving)">
                @if (_saving)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                Skicka in ansökan
            </MudButton>
        </MudPaper>
    }

    @if (_success != null)
    {
        <MudAlert Severity="Severity.Success" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="@(() => _success = null)">@_success</MudAlert>
    }

    @* Registrerade föräldraledigheter *@
    <MudText Typo="Typo.h6" Class="mb-3">Registrerade föräldraledigheter</MudText>
    @if (_rader.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Text" Class="mb-4">Inga föräldraledigheter registrerade.</MudAlert>
    }
    else
    {
        <MudSimpleTable Hover="true" Elevation="2" Class="mb-6">
            <thead><tr><th>Anställd</th><th>Period</th><th>Dagar</th><th>Status</th><th>Beskrivning</th></tr></thead>
            <tbody>
                @foreach (var r in _rader)
                {
                    <tr>
                        <td><strong>@r.Namn</strong></td>
                        <td>@r.FranDatum.ToString("yyyy-MM-dd") – @r.TillDatum.ToString("yyyy-MM-dd")</td>
                        <td>@r.AntalDagar</td>
                        <td><MudChip T="string" Size="Size.Small" Color="@StatusColor(r.Status)">@StatusText(r.Status)</MudChip></td>
                        <td>@(r.Beskrivning ?? "—")</td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    }

    @* Statisk referens: fördelning sjukpenningnivå vs lägstanivå *@
    <MudText Typo="Typo.h6" Class="mt-6 mb-3">Fördelning sjukpenningnivå vs lägstanivå (FK-regler)</MudText>
    <MudSimpleTable Hover="true" Elevation="1">
        <thead><tr><th>Nivå</th><th>Dagar per förälder</th><th>Totalt per barn</th><th>Ersättning</th><th>Överlåtbart</th></tr></thead>
        <tbody>
            <tr>
                <td><strong>Sjukpenningnivå</strong></td>
                <td>195</td>
                <td>390</td>
                <td>Ca 80% av SGI (max 1 116 kr/dag)</td>
                <td><MudChip T="string" Size="Size.Small" Color="Color.Warning">105 dagar</MudChip></td>
            </tr>
            <tr>
                <td><strong>Lägstanivå</strong></td>
                <td>45</td>
                <td>90</td>
                <td>180 kr/dag</td>
                <td><MudChip T="string" Size="Size.Small" Color="Color.Warning">45 dagar</MudChip></td>
            </tr>
            <tr>
                <td><strong>Reserverade (ej överlåtbara)</strong></td>
                <td>90</td>
                <td>180</td>
                <td>Sjukpenningnivå</td>
                <td><MudChip T="string" Size="Size.Small" Color="Color.Error">0 dagar</MudChip></td>
            </tr>
        </tbody>
    </MudSimpleTable>
}

@code {
    private List<ForaldraRad> _rader = [];
    private List<RegionHR.Core.Domain.Employee> _employees = [];
    private bool _loading = true, _saving, _showForm;
    private string? _error, _success;

    // Formulärfält
    private Guid? _formAnstallId;
    private DateTime? _formFran, _formTill;
    private string _formBeskrivning = "";

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        try
        {
            var requests = await db.LeaveRequests
                .Where(r => r.Typ == LeaveType.Foraldraledighet)
                .OrderByDescending(r => r.SkapadVid)
                .ToListAsync();

            _employees = await db.Employees.OrderBy(e => e.Efternamn).ToListAsync();
            var names = _employees.ToDictionary(e => e.Id.Value, e => $"{e.Fornamn} {e.Efternamn}");

            _rader = requests.Select(r => new ForaldraRad(
                names.GetValueOrDefault(r.AnstallId, "Okänd"),
                r.FranDatum, r.TillDatum, r.AntalDagar, r.Status, r.Beskrivning
            )).ToList();
        }
        catch (Exception ex) { _error = $"Kunde inte hämta data: {ex.Message}"; }
        finally { _loading = false; }
    }

    private async Task SkapaAnsolan()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        if (_formAnstallId == null || _formFran == null || _formTill == null) return;
        _saving = true;
        _error = null;

        try
        {
            var from = DateOnly.FromDateTime(_formFran.Value);
            var to = DateOnly.FromDateTime(_formTill.Value);

            var request = LeaveRequest.Skapa(
                _formAnstallId.Value, LeaveType.Foraldraledighet, from, to,
                string.IsNullOrWhiteSpace(_formBeskrivning) ? null : _formBeskrivning);
            request.SkickaIn();

            db.LeaveRequests.Add(request);
            await db.SaveChangesAsync();

            var emp = _employees.FirstOrDefault(e => e.Id.Value == _formAnstallId.Value);
            var namn = emp != null ? $"{emp.Fornamn} {emp.Efternamn}" : "Okänd";

            _rader.Insert(0, new ForaldraRad(namn, from, to, request.AntalDagar, request.Status, request.Beskrivning));
            _showForm = false;
            _success = $"Föräldraledighetansökan inskickad för {namn}.";
            _formAnstallId = null; _formFran = null; _formTill = null; _formBeskrivning = "";
        }
        catch (Exception ex) { _error = $"Kunde inte skapa ansökan: {ex.Message}"; }
        finally { _saving = false; }
    }

    private static Color StatusColor(LeaveRequestStatus s) => s switch
    {
        LeaveRequestStatus.Godkand => Color.Success,
        LeaveRequestStatus.Inskickad => Color.Warning,
        LeaveRequestStatus.Avslagen => Color.Error,
        LeaveRequestStatus.Aterkallad => Color.Default,
        _ => Color.Info
    };

    private static string StatusText(LeaveRequestStatus s) => s switch
    {
        LeaveRequestStatus.Utkast => "Utkast",
        LeaveRequestStatus.Inskickad => "Inskickad",
        LeaveRequestStatus.Godkand => "Godkänd",
        LeaveRequestStatus.Avslagen => "Avslagen",
        LeaveRequestStatus.Aterkallad => "Återkallad",
        _ => s.ToString()
    };

    private record ForaldraRad(string Namn, DateOnly FranDatum, DateOnly TillDatum, int AntalDagar, LeaveRequestStatus Status, string? Beskrivning);
}

