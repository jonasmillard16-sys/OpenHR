@page "/anstallda/{Id:guid}/anstallning"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Web.Components.Shared
@inject NavigationManager Nav

<PageTitle>OpenHR - Ändra anställning</PageTitle>
<MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Variant="Variant.Text" Color="Color.Primary" Href="@($"/anstallda/{Id}")" Style="margin-bottom: 1rem;">Tillbaka</MudButton>

<OhrConversationFlow Steps="@_steps" CurrentStep="@_step" OnBack="@(() => { if (_step > 0) _step--; })">
    @switch (_step)
    {
        case 0:
            <MudText Typo="Typo.h5" Class="mb-4" Style="font-weight: 600;">Vad vill du ändra?</MudText>
            <MudStack Spacing="3">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Large" FullWidth="true" Style="min-height: 56px;" OnClick="@(() => { _andringstyp = "Intern förflyttning"; _step = 1; })">Intern förflyttning (ny enhet)</MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Large" FullWidth="true" Style="min-height: 56px;" OnClick="@(() => { _andringstyp = "Löneändring"; _step = 1; })">Löneändring</MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Large" FullWidth="true" Style="min-height: 56px;" OnClick="@(() => { _andringstyp = "Ändra sysselsättningsgrad"; _step = 1; })">Ändra sysselsättningsgrad</MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Large" FullWidth="true" Style="min-height: 56px;" OnClick="@(() => { _andringstyp = "Befattningsändring"; _step = 1; })">Befattningsändring</MudButton>
            </MudStack>
            break;
        case 1:
            <MudText Typo="Typo.h5" Class="mb-4" Style="font-weight: 600;">@_andringstyp</MudText>
            <MudDatePicker Label="Gäller från" @bind-Date="_giltigFran" Variant="Variant.Outlined" Class="mb-3" />
            <MudTextField @bind-Value="_nyttVarde" Label="Nytt värde" Variant="Variant.Outlined" Class="mb-3" Placeholder="@(_andringstyp == "Löneändring" ? "T.ex. 32000" : "T.ex. Avdelning 33")" />
            <MudTextField @bind-Value="_motivering" Label="Motivering" Variant="Variant.Outlined" Class="mb-3" Lines="3" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" FullWidth="true" Style="min-height: 56px;" OnClick="@(() => _step = 2)">Skicka till godkännande</MudButton>
            break;
        case 2:
            <div style="text-align: center; padding: 2rem 0;">
                <MudText Typo="Typo.h4" Color="Color.Success" Style="font-weight: 700;" Class="mb-4">Ändring skickad</MudText>
                <MudText Typo="Typo.body1">@_andringstyp skickad till godkännande.</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Class="mt-6" Href="@($"/anstallda/{Id}")">Tillbaka</MudButton>
            </div>
            break;
    }
</OhrConversationFlow>

@code {
    [Parameter] public Guid Id { get; set; }
    private readonly List<string> _steps = ["Typ", "Detaljer", "Klart!"];
    private int _step;
    private string _andringstyp = "", _nyttVarde = "", _motivering = "";
    private DateTime? _giltigFran = DateTime.Today;
}
