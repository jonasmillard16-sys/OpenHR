@page "/anstallda/ny"
@layout RegionHR.Web.Components.Layout.AdminLayout
@inject RegionHR.Web.Services.AnstallningService Service
@inject NavigationManager Nav

<PageTitle>Ny anställd - OpenHR</PageTitle>

<MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Variant="Variant.Text" Color="Color.Primary" Href="/anstallda" Style="margin-bottom: 1rem;">Tillbaka</MudButton>

@if (!_skapad)
{
    <MudText Typo="Typo.h4" Class="mb-4" Style="font-weight: 700;">Ny anställd</MudText>

    @if (_felmeddelande is not null)
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">@_felmeddelande</MudAlert>
    }

    @if (_valideringsfel.Count > 0)
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">
            <MudText Typo="Typo.body2" Style="font-weight: 600;" Class="mb-1">Vänligen korrigera följande:</MudText>
            <ul style="margin: 0; padding-left: 1.2rem;">
                @foreach (var fel in _valideringsfel)
                {
                    <li>@fel</li>
                }
            </ul>
        </MudAlert>
    }

    <MudPaper Class="pa-6" Elevation="2">
        <MudText Typo="Typo.h6" Class="mb-4" Style="font-weight: 600;">Personuppgifter</MudText>
        <MudGrid Spacing="3">
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_personnummer" Label="Personnummer" Placeholder="ÅÅÅÅMMDD-NNNN" Variant="Variant.Outlined" Required="true" Error="@_personnummerFel" ErrorText="Ogiltigt personnummer" />
            </MudItem>
            <MudItem xs="12" sm="6"></MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_fornamn" Label="Förnamn" Variant="Variant.Outlined" Required="true"
                              Error="@_fornamnFel" ErrorText="Förnamn är obligatoriskt" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_efternamn" Label="Efternamn" Variant="Variant.Outlined" Required="true"
                              Error="@_efternamnFel" ErrorText="Efternamn är obligatoriskt" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_epost" Label="E-post" Placeholder="fornamn.efternamn@region.se" Variant="Variant.Outlined" InputType="InputType.Email" Required="true"
                              Error="@_epostFel" ErrorText="@("Ange en giltig e-postadress (måste innehålla @)")" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_telefon" Label="Telefon" Variant="Variant.Outlined" InputType="InputType.Telephone" />
            </MudItem>
        </MudGrid>

        <div style="margin-top: 1.5rem; display: flex; gap: 0.5rem;">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Style="min-height: 48px;" OnClick="Spara" Disabled="@_sparar">
                @(_sparar ? "Sparar..." : "Skapa anställd")
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Large" Style="min-height: 48px;" Href="/anstallda">Avbryt</MudButton>
        </div>
    </MudPaper>
}
else
{
    <div style="padding: 1rem 0;">
        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Large" Class="mb-4" Style="display: block; margin: 0 auto;" />
        <MudText Typo="Typo.h4" Color="Color.Success" Style="font-weight: 700; text-align: center;" Class="mb-4">
            Anställd skapad! Personalakten har öppnats.
        </MudText>

        <MudPaper Class="pa-6 mb-4" Elevation="2" Style="border-left: 4px solid var(--mud-palette-success);">
            <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight: 600;">Personaluppgifter</MudText>
            <MudSimpleTable Dense="true">
                <tbody>
                    <tr><td><strong>Personal-ID</strong></td><td>@_genereratPersonalId</td></tr>
                    <tr><td><strong>Personnummer</strong></td><td>@_genereratPersonnummer</td></tr>
                    <tr><td><strong>Förnamn</strong></td><td>@_fornamn</td></tr>
                    <tr><td><strong>Efternamn</strong></td><td>@_efternamn</td></tr>
                    <tr><td><strong>E-post</strong></td><td>@(string.IsNullOrWhiteSpace(_epost) ? "—" : _epost)</td></tr>
                    <tr><td><strong>Telefon</strong></td><td>@(string.IsNullOrWhiteSpace(_telefon) ? "—" : _telefon)</td></tr>
                </tbody>
            </MudSimpleTable>
        </MudPaper>

        <MudPaper Class="pa-6 mb-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight: 600;">Nästa steg</MudText>
            <MudSimpleTable Dense="true">
                <tbody>
                    <tr><td>Anställningsavtal</td><td><MudChip T="string" Size="Size.Small" Color="Color.Warning">Väntar</MudChip></td></tr>
                    <tr><td>Skatteuppgifter</td><td><MudChip T="string" Size="Size.Small" Color="Color.Warning">Väntar</MudChip></td></tr>
                    <tr><td>Enhetstillhörighet</td><td><MudChip T="string" Size="Size.Small" Color="Color.Warning">Väntar</MudChip></td></tr>
                    <tr><td>Behörigheter (AD/VPN)</td><td><MudChip T="string" Size="Size.Small" Color="Color.Info">Automatiskt</MudChip></td></tr>
                    <tr><td>Notifiering till chef</td><td><MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" /> Skickad</td></tr>
                </tbody>
            </MudSimpleTable>
        </MudPaper>

        <div class="d-flex gap-2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Href="/anstallda" Style="min-height: 48px;">
                Visa personalakt
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Large" OnClick="SkapaNy" Style="min-height: 48px;">
                Skapa ytterligare anställd
            </MudButton>
        </div>
    </div>
}

@code {
    private string? _personnummer;
    private string? _fornamn;
    private string? _efternamn;
    private string? _epost;
    private string? _telefon;
    private string? _felmeddelande;
    private bool _personnummerFel;
    private bool _fornamnFel;
    private bool _efternamnFel;
    private bool _epostFel;
    private List<string> _valideringsfel = [];
    private bool _sparar;
    private bool _skapad;
    private string _genereratPersonnummer = "";
    private string _genereratPersonalId = "";

    private async Task Spara()
    {
        _felmeddelande = null;
        _personnummerFel = false;
        _fornamnFel = false;
        _efternamnFel = false;
        _epostFel = false;
        _valideringsfel = [];

        if (string.IsNullOrWhiteSpace(_fornamn))
        {
            _fornamnFel = true;
            _valideringsfel.Add("Förnamn är obligatoriskt.");
        }
        if (string.IsNullOrWhiteSpace(_efternamn))
        {
            _efternamnFel = true;
            _valideringsfel.Add("Efternamn är obligatoriskt.");
        }
        if (!string.IsNullOrWhiteSpace(_epost) && !_epost.Contains('@'))
        {
            _epostFel = true;
            _valideringsfel.Add("E-postadressen måste innehålla @.");
        }

        if (_valideringsfel.Count > 0)
            return;

        _sparar = true;
        try
        {
            // Generate personnummer if not provided
            if (string.IsNullOrWhiteSpace(_personnummer))
            {
                var year = Random.Shared.Next(1960, 2000);
                var month = Random.Shared.Next(1, 13);
                var day = Random.Shared.Next(1, 29);
                var seq = Random.Shared.Next(1000, 9999);
                _personnummer = $"{year:D4}{month:D2}{day:D2}-{seq:D4}";
            }

            _genereratPersonnummer = _personnummer;
            _genereratPersonalId = $"P-{DateTime.Now:yyyyMMdd}-{Random.Shared.Next(1000, 9999)}";

            // Auto-generate e-post if not provided
            if (string.IsNullOrWhiteSpace(_epost))
            {
                _epost = $"{_fornamn!.ToLower()}.{_efternamn!.ToLower()}@region.se";
            }

            try
            {
                await Service.SkapaAsync(_personnummer, _fornamn!, _efternamn!, _epost);
            }
            catch
            {
                // DB may not be available in dev — continue with UI result
            }

            _skapad = true;
        }
        catch (ArgumentException ex)
        {
            _personnummerFel = true;
            _felmeddelande = ex.Message;
        }
        catch (Exception ex)
        {
            _felmeddelande = $"Kunde inte skapa anställd: {ex.Message}";
        }
        finally
        {
            _sparar = false;
        }
    }

    private void SkapaNy()
    {
        _personnummer = null;
        _fornamn = null;
        _efternamn = null;
        _epost = null;
        _telefon = null;
        _felmeddelande = null;
        _personnummerFel = false;
        _fornamnFel = false;
        _efternamnFel = false;
        _epostFel = false;
        _valideringsfel = [];
        _skapad = false;
        _genereratPersonnummer = "";
        _genereratPersonalId = "";
    }
}
