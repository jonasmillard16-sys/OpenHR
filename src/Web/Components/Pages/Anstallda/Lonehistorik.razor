        <tr><td>2025-01-01</td><td>27 000 kr</td><td>28 500 kr</td><td style="color: green;">+1 500 kr (+5,6%)</td><td>Löneöversyn 2025</td><td>Anna HR</td></tr>
        <tr><td>2023-06-01</td><td>25 500 kr</td><td>27 000 kr</td><td style="color: green;">+1 500 kr (+5,9%)</td><td>Befordran till Ssk</td><td>Erik Chef</td></tr>
        <tr><td>2015-08-01</td><td>—</td><td>25 500 kr</td><td>—</td><td>Nyanställning</td><td>—</td></tr>
    </tbody>
</MudSimpleTable>

@code {
    [Parameter] public Guid Id { get; set; }
}
