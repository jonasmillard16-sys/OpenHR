@page "/anstallda/{Id:guid}"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using Microsoft.EntityFrameworkCore
@using RegionHR.Payroll.Domain
@using RegionHR.Leave.Domain
@using RegionHR.Competence.Domain
@using RegionHR.Audit.Domain
@using RegionHR.SharedKernel.Domain
@inject RegionHR.Web.Services.AnstallningService Service
@inject IDbContextFactory<RegionHR.Infrastructure.Persistence.RegionHRDbContext> DbFactory
@inject NavigationManager Nav

<PageTitle>OpenHR - Anställd</PageTitle>

<OhrBreadcrumb CurrentPage="@(_emp != null ? $"{_emp.Fornamn} {_emp.Efternamn}" : "Anställd")" ExtraItems="@(new List<BreadcrumbItem>{new("Personal", "/anstallda")})" />

<MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Variant="Variant.Text"
           Color="Color.Primary" Href="/anstallda" Style="margin-bottom: 1rem;">Tillbaka</MudButton>

@if (_emp != null)
{
    <div class="d-flex justify-space-between align-center mb-4">
        <div>
            <MudText Typo="Typo.h4" Style="font-weight: 700;">@_emp.Fornamn @_emp.Efternamn</MudText>
            <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary);">@_emp.Personnummer.ToMaskedString()</MudText>
        </div>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
                   StartIcon="@Icons.Material.Filled.Edit" Href="@($"/anstallda/{Id}/redigera")"
                   Style="min-height: 48px;">
            Redigera
        </MudButton>
    </div>

    <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true">
        <MudTabPanel Text="Personuppgifter" Icon="@Icons.Material.Filled.Person">
            <MudGrid Spacing="3">
                <MudItem xs="12" md="6">
                    <MudText Typo="Typo.h6" Class="mb-3">Kontaktuppgifter</MudText>
                    <MudSimpleTable Dense="true">
                        <tbody>
                            <tr><td><strong>E-post</strong></td><td>@(_emp.Epost ?? "—")</td></tr>
                            <tr><td><strong>Telefon</strong></td><td>@(_emp.Telefon ?? "—")</td></tr>
                            <tr><td><strong>Adress</strong></td><td>@(_emp.Adress?.Gatuadress ?? "—")</td></tr>
                            <tr><td><strong>Postnummer</strong></td><td>@(_emp.Adress?.Postnummer ?? "—")</td></tr>
                            <tr><td><strong>Ort</strong></td><td>@(_emp.Adress?.Ort ?? "—")</td></tr>
                        </tbody>
                    </MudSimpleTable>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudText Typo="Typo.h6" Class="mb-3">Skatteuppgifter</MudText>
                    <MudSimpleTable Dense="true">
                        <tbody>
                            <tr><td><strong><OhrTerm Term="Skattetabell" /></strong></td><td>@(_emp.Skattetabell?.ToString() ?? "—")</td></tr>
                            <tr><td><strong>Skattekolumn</strong></td><td>@(_emp.Skattekolumn?.ToString() ?? "—")</td></tr>
                            <tr><td><strong>Kommun</strong></td><td>@(_emp.Kommun ?? "—")</td></tr>
                            <tr><td><strong>Kommunalskatt</strong></td><td>@(_emp.KommunalSkattesats.HasValue ? $"{_emp.KommunalSkattesats.Value}%" : "—")</td></tr>
                            <tr><td><strong>Kyrkoavgift</strong></td><td>@(_emp.HarKyrkoavgift ? $"Ja ({_emp.Kyrkoavgiftssats}%)" : "Nej")</td></tr>
                        </tbody>
                    </MudSimpleTable>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        <MudTabPanel Text="Anställningar" Icon="@Icons.Material.Filled.Work">
            @if (_emp.Anstallningar.Count == 0)
            {
                <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary);">Inga anställningar registrerade.</MudText>
            }
            else
            {
                <MudSimpleTable Hover="true">
                    <thead>
                        <tr>
                            <th>Form</th>
                            <th>Befattning</th>
                            <th>Enhet</th>
                            <th>L&#246;n</th>
                            <th>Grad</th>
                            <th>Fr&#229;n</th>
                            <th>Till</th>
                            <th>Avtal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var a in _emp.Anstallningar.OrderByDescending(x => x.Giltighetsperiod.Start))
                        {
                            var isActive = a.Giltighetsperiod.IsActiveOn(DateOnly.FromDateTime(DateTime.Today));
                            <tr>
                                <td>
                                    <MudChip T="string" Size="Size.Small" Color="@(isActive ? Color.Success : Color.Default)">
                                        @a.Anstallningsform
                                    </MudChip>
                                </td>
                                <td>@(a.Befattningstitel ?? "—")</td>
                                <td>@GetEnhetsNamn(a.EnhetId)</td>
                                <td>@a.Manadslon.Amount.ToString("N0") kr</td>
                                <td>@a.Sysselsattningsgrad.Value%</td>
                                <td>@a.Giltighetsperiod.Start.ToString("yyyy-MM-dd")</td>
                                <td>@(a.Giltighetsperiod.End?.ToString("yyyy-MM-dd") ?? "Tillsvidare (utan slutdatum)")</td>
                                <td>@a.Kollektivavtal</td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            }
        </MudTabPanel>

        <MudTabPanel Text="L&#246;n" Icon="@Icons.Material.Filled.Payments">
            @if (_lonehistorik.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Text">Ingen l&#246;nehistorik fr&#229;n l&#246;nek&#246;rningar.</MudAlert>
            }
            else
            {
                <MudSimpleTable Hover="true">
                    <thead>
                        <tr><th>Period</th><th>Brutto</th><th>Skatt</th><th>Netto</th><th>OB</th><th>&#214;vertid</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var l in _lonehistorik)
                        {
                            <tr>
                                <td>@l.Period</td>
                                <td>@($"{l.Brutto:N0} kr")</td>
                                <td>@($"-{l.Skatt:N0} kr")</td>
                                <td><strong>@($"{l.Netto:N0} kr")</strong></td>
                                <td>@(l.OB > 0 ? $"{l.OB:N0} kr" : "—")</td>
                                <td>@(l.Overtid > 0 ? $"{l.Overtid:N0} kr" : "—")</td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            }
        </MudTabPanel>

        <MudTabPanel Text="Fr&#229;nvaro" Icon="@Icons.Material.Filled.EventBusy">
            <MudText Typo="Typo.h6" Class="mb-3">Fr&#229;nvarohistorik</MudText>
            @if (_franvaro.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Text">Ingen fr&#229;nvaro registrerad.</MudAlert>
            }
            else
            {
                <MudSimpleTable Hover="true">
                    <thead><tr><th>Period</th><th>Typ</th><th>Dagar</th><th>Status</th></tr></thead>
                    <tbody>
                        @foreach (var f in _franvaro)
                        {
                            <tr>
                                <td>@f.FranDatum.ToString("yyyy-MM-dd") – @f.TillDatum.ToString("yyyy-MM-dd")</td>
                                <td>@MapLeaveType(f.Typ)</td>
                                <td>@f.AntalDagar</td>
                                <td><MudChip T="string" Size="Size.Small" Color="@MapLeaveStatusColor(f.Status)">@MapLeaveStatus(f.Status)</MudChip></td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            }
        </MudTabPanel>

        <MudTabPanel Text="LAS" Icon="@Icons.Material.Filled.Warning">
            <MudText Typo="Typo.h6" Class="mb-3">LAS-information</MudText>
            <MudAlert Severity="Severity.Info" Class="mb-3">Tillsvidareanställd — LAS ej tillämpligt</MudAlert>
            <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
                Denna anställd har en tillsvidareanställning. LAS-ackumulering f&#246;r konvertering gäller inte.
            </MudText>
        </MudTabPanel>

        <MudTabPanel Text="Kompetens" Icon="@Icons.Material.Filled.School">
            <MudText Typo="Typo.h6" Class="mb-3">Kompetenser</MudText>
            @if (_kompetenser.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Text" Class="mb-4">Inga kompetenser registrerade.</MudAlert>
            }
            else
            {
                <MudSimpleTable Hover="true" Class="mb-4">
                    <thead><tr><th>Kompetens</th><th>Kategori</th><th>Niv&#229;</th></tr></thead>
                    <tbody>
                        @foreach (var k in _kompetenser)
                        {
                            <tr><td>@k.SkillNamn</td><td>@k.Kategori</td><td>@k.Niva / 5</td></tr>
                        }
                    </tbody>
                </MudSimpleTable>
            }
            <MudText Typo="Typo.h6" Class="mb-3">Certifieringar</MudText>
            @if (_certifieringar.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Text">Inga certifieringar registrerade.</MudAlert>
            }
            else
            {
                <MudSimpleTable Hover="true">
                    <thead><tr><th>Certifiering</th><th>Utfärdare</th><th>Giltig fr&#229;n</th><th>Giltig t.o.m.</th><th>Status</th></tr></thead>
                    <tbody>
                        @foreach (var c in _certifieringar)
                        {
                            <tr>
                                <td>@c.Namn</td>
                                <td>@(c.Utfardare ?? "—")</td>
                                <td>@(c.GiltigFran?.ToString("yyyy-MM-dd") ?? "—")</td>
                                <td>@(c.GiltigTill?.ToString("yyyy-MM-dd") ?? "—")</td>
                                <td><MudChip T="string" Size="Size.Small" Color="@CertStatusColor(c.Status)">@CertStatusText(c.Status)</MudChip></td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            }
        </MudTabPanel>

        <MudTabPanel Text="Dokument" Icon="@Icons.Material.Filled.Description">
            <MudText Typo="Typo.h6" Class="mb-3">Dokument i personalakten</MudText>
            @if (_dokument.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Text">Inga dokument uppladdade f&#246;r denna anställd.</MudAlert>
            }
            else
            {
                <MudSimpleTable Hover="true">
                    <thead><tr><th>Filnamn</th><th>Kategori</th><th>Uppladdad</th><th>Beskrivning</th></tr></thead>
                    <tbody>
                        @foreach (var d in _dokument)
                        {
                            <tr>
                                <td>@d.FileName</td>
                                <td>@d.Kategori</td>
                                <td>@d.UppladdadVid.ToLocalTime().ToString("yyyy-MM-dd")</td>
                                <td>@(d.Beskrivning ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            }
        </MudTabPanel>

        <MudTabPanel Text="&#196;ndringshistorik" Icon="@Icons.Material.Filled.History">
            <MudText Typo="Typo.h6" Class="mb-3">&#196;ndringshistorik</MudText>
            <MudText Typo="Typo.body2" Class="mb-4" Style="color: var(--mud-palette-text-secondary);">
                Visar direkta &#228;ndringar p&#229; denna anst&#228;lld fr&#229;n granskningsloggen.
            </MudText>
            @if (_auditEntries.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Text">Inga &#228;ndringar loggade f&#246;r denna anst&#228;lld.</MudAlert>
            }
            else
            {
                <MudTimeline TimelinePosition="TimelinePosition.Start">
                    @foreach (var entry in _auditEntries)
                    {
                        <MudTimelineItem Color="@AuditColor(entry.Action)" Size="Size.Small">
                            <ItemContent>
                                <MudPaper Class="pa-3 mb-1" Elevation="1">
                                    <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">@entry.Timestamp.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</MudText>
                                    <MudText Typo="Typo.body1" Style="font-weight: 500;">@AuditSummary(entry)</MudText>
                                    <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">@(entry.UserName ?? entry.UserId)</MudText>
                                </MudPaper>
                            </ItemContent>
                        </MudTimelineItem>
                    }
                </MudTimeline>
            }
        </MudTabPanel>
    </MudTabs>
}
else if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else
{
    <MudAlert Severity="Severity.Error">Anställd hittades inte.</MudAlert>
}

@code {
    [Parameter] public Guid Id { get; set; }
    private RegionHR.Core.Domain.Employee? _emp;
    private bool _loading = true;
    private List<LonRad> _lonehistorik = [];
    private List<LeaveRequest> _franvaro = [];
    private List<KompetensRad> _kompetenser = [];
    private List<Certification> _certifieringar = [];
    private List<RegionHR.Documents.Domain.Document> _dokument = [];
    private List<AuditEntry> _auditEntries = [];
    private Dictionary<OrganizationId, string> _enhetsNamn = new();

    private string GetEnhetsNamn(OrganizationId id) =>
        _enhetsNamn.TryGetValue(id, out var namn) ? namn : "—";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _emp = await Service.HamtaAsync(EmployeeId.From(Id));

            await using var db = await DbFactory.CreateDbContextAsync();

            var enheter = await db.OrganizationUnits.ToListAsync();
            _enhetsNamn = enheter.ToDictionary(e => e.Id, e => e.Namn);

            // Lönehistorik
            var payResults = await db.PayrollResults
                .Where(r => r.AnstallId == EmployeeId.From(Id))
                .OrderByDescending(r => r.Year).ThenByDescending(r => r.Month)
                .Take(12).ToListAsync();
            _lonehistorik = payResults.Select(r => new LonRad(
                $"{r.Year}-{r.Month:D2}", r.Brutto.Amount, r.Skatt.Amount, r.Netto.Amount,
                r.OBTillagg.Amount, r.Overtidstillagg.Amount)).ToList();

            // Frånvaro
            _franvaro = await db.LeaveRequests
                .Where(r => r.AnstallId == Id)
                .OrderByDescending(r => r.FranDatum)
                .Take(20).ToListAsync();

            // Kompetenser (EmployeeSkill + Skill name)
            var empSkills = await db.EmployeeSkills
                .Where(es => es.AnstallId == Id).ToListAsync();
            if (empSkills.Count > 0)
            {
                var skillIds = empSkills.Select(es => es.SkillId).Distinct().ToList();
                var skills = await db.Skills
                    .Where(s => skillIds.Contains(s.Id)).ToListAsync();
                var skillNames = skills.ToDictionary(s => s.Id, s => (s.Namn, s.Kategori.ToString()));
                _kompetenser = empSkills.Select(es =>
                {
                    skillNames.TryGetValue(es.SkillId, out var info);
                    return new KompetensRad(info.Namn ?? "Okänd", info.Item2 ?? "—", es.Niva);
                }).OrderByDescending(k => k.Niva).ToList();
            }

            // Certifieringar
            _certifieringar = await db.Certifications
                .Where(c => c.AnstallId == Id).ToListAsync();

            // Dokument
            _dokument = await db.Documents
                .Where(d => d.AnstallId == Id)
                .OrderByDescending(d => d.UppladdadVid).ToListAsync();

            // Ändringshistorik (direkta Employee-ändringar)
            _auditEntries = await db.AuditEntries
                .Where(e => e.EntityType == "Employee" && e.EntityId == Id.ToString())
                .OrderByDescending(e => e.Timestamp)
                .Take(20).ToListAsync();
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Detalj load error: {ex.Message}");
        }
        _loading = false;
    }

    private record LonRad(string Period, decimal Brutto, decimal Skatt, decimal Netto, decimal OB, decimal Overtid);
    private record KompetensRad(string SkillNamn, string Kategori, int Niva);

    private static string MapLeaveType(LeaveType t) => t switch
    {
        LeaveType.Semester => "Semester",
        LeaveType.Sjukfranvaro => "Sjukfrånvaro",
        LeaveType.Foraldraledighet => "Föräldraledighet",
        LeaveType.VAB => "VAB",
        LeaveType.Tjanstledighet => "Tjänstledighet",
        LeaveType.Komptid => "Komptid",
        LeaveType.Utbildning => "Utbildning",
        _ => t.ToString()
    };

    private static string MapLeaveStatus(LeaveRequestStatus s) => s switch
    {
        LeaveRequestStatus.Utkast => "Utkast",
        LeaveRequestStatus.Inskickad => "Inskickad",
        LeaveRequestStatus.Godkand => "Godkänd",
        LeaveRequestStatus.Avslagen => "Avslagen",
        LeaveRequestStatus.Aterkallad => "Återkallad",
        _ => s.ToString()
    };

    private static Color MapLeaveStatusColor(LeaveRequestStatus s) => s switch
    {
        LeaveRequestStatus.Godkand => Color.Success,
        LeaveRequestStatus.Inskickad => Color.Warning,
        LeaveRequestStatus.Avslagen => Color.Error,
        _ => Color.Default
    };

    private static Color CertStatusColor(CertificationStatus s) => s switch
    {
        CertificationStatus.Giltig => Color.Success,
        CertificationStatus.UtgarSnart => Color.Warning,
        CertificationStatus.Utgangen => Color.Error,
        CertificationStatus.Saknas => Color.Default,
        _ => Color.Default
    };

    private static string CertStatusText(CertificationStatus s) => s switch
    {
        CertificationStatus.Giltig => "Giltig",
        CertificationStatus.UtgarSnart => "Utgår snart",
        CertificationStatus.Utgangen => "Utgången",
        CertificationStatus.Saknas => "Saknas",
        _ => s.ToString()
    };

    private static Color AuditColor(AuditAction a) => a switch
    {
        AuditAction.Create => Color.Primary,
        AuditAction.Update => Color.Warning,
        AuditAction.Delete => Color.Error,
        _ => Color.Default
    };

    private static string AuditSummary(AuditEntry e) => e.Action switch
    {
        AuditAction.Create => "Anställd skapad i systemet",
        AuditAction.Update => e.NewValues is not null ? $"Uppdaterad: {(e.NewValues.Length > 80 ? e.NewValues[..80] + "..." : e.NewValues)}" : "Uppgifter uppdaterade",
        AuditAction.Delete => "Post borttagen",
        _ => ""
    };
}
