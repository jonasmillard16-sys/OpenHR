@page "/resor"
@layout RegionHR.Web.Components.Layout.AdminLayout
@using RegionHR.Infrastructure.Persistence
@using RegionHR.Infrastructure.Payroll
@using RegionHR.Travel.Domain
@using RegionHR.SharedKernel.Domain
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<RegionHRDbContext> DbFactory
@inject TraktamentsCalculator TraktCalc
@inject RegionHR.Web.Services.AuthService Auth

<PageTitle>OpenHR - Resor och utlägg</PageTitle>
<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4" Style="font-weight: 700;">Resor och utlägg</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" StartIcon="@Icons.Material.Filled.Add" Style="min-height: 48px;" OnClick="@(() => _showForm = true)">Nytt resekrav</MudButton>
</div>

@if (_error != null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
}

@if (_showForm && Auth.EmployeeId.HasValue)
{
    <MudPaper Class="pa-5 mb-4" Elevation="3" Style="border-left: 4px solid var(--mud-palette-primary);">
        <div class="d-flex justify-space-between align-center mb-3">
            <MudText Typo="Typo.h6" Style="font-weight: 600;">Nytt resekrav</MudText>
            <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="@(() => _showForm = false)" />
        </div>
        <MudGrid Spacing="3">
            <MudItem xs="12" sm="6"><MudDatePicker @bind-Date="_formDatum" Label="Resedatum" Variant="Variant.Outlined" Required="true" /></MudItem>
            <MudItem xs="12" sm="6"><MudTextField @bind-Value="_formBeskrivning" Label="Beskrivning" Variant="Variant.Outlined" Required="true" /></MudItem>
        </MudGrid>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-3" OnClick="SkapaResekrav"
                   Disabled="@(_formDatum == null || string.IsNullOrWhiteSpace(_formBeskrivning) || _saving)">Skapa</MudButton>
    </MudPaper>
}
else if (_showForm)
{
    <MudAlert Severity="Severity.Warning" Class="mb-4">Resekrav kräver kopplad anställd.</MudAlert>
}

@if (_success != null)
{
    <MudAlert Severity="Severity.Success" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="@(() => _success = null)">@_success</MudAlert>
}

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_claims.Count == 0)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Text" Class="mb-4">Inga resekrav registrerade.</MudAlert>
}
else
{
    <MudSimpleTable Hover="true" Elevation="2" Class="mb-4">
        <thead><tr><th>Anställd</th><th>Datum</th><th>Beskrivning</th><th>Belopp</th><th>Status</th><th></th></tr></thead>
        <tbody>
            @foreach (var c in _claims)
            {
                <tr>
                    <td><strong>@c.Namn</strong></td>
                    <td>@c.Datum.ToString("yyyy-MM-dd")</td>
                    <td>@c.Beskrivning</td>
                    <td>@c.Belopp.ToString("N0") kr</td>
                    <td><MudChip T="string" Size="Size.Small" Color="@StatusFarg(c.Status)">@StatusText(c.Status)</MudChip></td>
                    <td>
                        @if (c.Status == TravelClaimStatus.Inskickad && Auth.EmployeeId.HasValue)
                        {
                            <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Success" OnClick="@(() => AttesteraKrav(c))">Godkänn</MudButton>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </MudSimpleTable>
}

<MudDivider Class="my-6" />

@* Traktamente calculator — kept as real calculation logic *@
<MudText Typo="Typo.h5" Class="mb-3" Style="font-weight: 700;">Beräkna traktamente</MudText>
<MudText Typo="Typo.body2" Class="mb-4" Style="color: var(--mud-palette-text-secondary);">Beräkning enligt Skatteverkets regler.</MudText>

<MudPaper Class="pa-6 mb-4" Elevation="3" Style="border-left: 4px solid var(--mud-palette-primary);">
    <MudGrid Spacing="3">
        <MudItem xs="12" md="3"><MudDatePicker @bind-Date="_traktAvresa" Label="Avresedatum" Variant="Variant.Outlined" /></MudItem>
        <MudItem xs="12" md="3"><MudDatePicker @bind-Date="_traktHemkomst" Label="Hemkomstdatum" Variant="Variant.Outlined" /></MudItem>
        <MudItem xs="12" md="2">
            <MudSelect T="string" @bind-Value="_traktTyp" Label="Typ" Variant="Variant.Outlined">
                <MudSelectItem T="string" Value="@("Inrikes")">Inrikes</MudSelectItem>
                <MudSelectItem T="string" Value="@("Utrikes")">Utrikes</MudSelectItem>
            </MudSelect>
        </MudItem>
        @if (_traktTyp == "Utrikes")
        {
            <MudItem xs="12" md="2">
                <MudSelect T="string" @bind-Value="_traktLand" Label="Land" Variant="Variant.Outlined">
                    @foreach (var l in new[] { "Norge", "Danmark", "Finland", "Tyskland", "Frankrike", "Storbritannien", "USA" })
                    {
                        <MudSelectItem T="string" Value="@l">@l</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
        }
        else
        {
            <MudItem xs="12" md="2">
                <MudSelect T="bool" @bind-Value="_traktHotell" Label="Hotell" Variant="Variant.Outlined">
                    <MudSelectItem T="bool" Value="true">Ja</MudSelectItem>
                    <MudSelectItem T="bool" Value="false">Nej</MudSelectItem>
                </MudSelect>
            </MudItem>
        }
        <MudItem xs="12" md="2" Class="d-flex align-end">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Style="min-height: 48px; width: 100%;" OnClick="BeraknaTraktamente">Beräkna</MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

@if (_traktResultat is not null)
{
    <MudPaper Class="pa-6 mb-4" Elevation="2" Style="border-left: 4px solid var(--mud-palette-success);">
        <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight: 600;">Beräkningsresultat</MudText>
        <MudText Typo="Typo.body2" Class="mb-3">@_traktResultat.Beskrivning</MudText>
        <MudGrid Spacing="3">
            <MudItem xs="6" md="3"><MudText Typo="Typo.caption">Antal dagar</MudText><MudText Typo="Typo.h5" Style="font-weight: 700;">@_traktResultat.AntalDagar</MudText></MudItem>
            <MudItem xs="6" md="3"><MudText Typo="Typo.caption">Dagtraktamente</MudText><MudText Typo="Typo.h5" Style="font-weight: 700;">@_traktResultat.Dagtraktamente.ToString("N0") kr</MudText></MudItem>
            <MudItem xs="6" md="3"><MudText Typo="Typo.caption">Nattillägg</MudText><MudText Typo="Typo.h5" Style="font-weight: 700;">@_traktResultat.Natttillagg.ToString("N0") kr</MudText></MudItem>
            <MudItem xs="6" md="3"><MudText Typo="Typo.caption">Totalt</MudText><MudText Typo="Typo.h5" Color="Color.Success" Style="font-weight: 700;">@_traktResultat.Totalt.ToString("N0") kr</MudText></MudItem>
        </MudGrid>
    </MudPaper>
}
@if (_traktFel is not null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="@(() => _traktFel = null)">@_traktFel</MudAlert>
}

@code {
    private List<ClaimVm> _claims = [];
    private bool _loading = true, _saving, _showForm;
    private string? _error, _success;
    private DateTime? _formDatum;
    private string _formBeskrivning = "";

    // Traktamente
    private DateTime? _traktAvresa = DateTime.Today, _traktHemkomst = DateTime.Today.AddDays(2);
    private string _traktTyp = "Inrikes", _traktLand = "Norge";
    private bool _traktHotell;
    private TraktamentsBerakning? _traktResultat;
    private string? _traktFel;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        try
        {
            var claims = await db.TravelClaims.OrderByDescending(c => c.ReseDatum).Take(50).ToListAsync();
            var empIds = claims.Select(c => c.AnstallId.Value).Distinct().ToList();
            var employees = await db.Employees.Where(e => empIds.Contains(e.Id.Value)).ToListAsync();
            var names = employees.ToDictionary(e => e.Id.Value, e => $"{e.Fornamn} {e.Efternamn}");

            _claims = claims.Select(c => new ClaimVm(c.Id, names.GetValueOrDefault(c.AnstallId.Value, "Okänd"),
                c.ReseDatum, c.Beskrivning, c.TotalBelopp.Amount, c.Status, c)).ToList();
        }
        catch (Exception ex) { _error = $"Kunde inte hämta resekrav: {ex.Message}"; }
        finally { _loading = false; }
    }

    private async Task SkapaResekrav()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        if (!Auth.EmployeeId.HasValue || _formDatum == null || string.IsNullOrWhiteSpace(_formBeskrivning)) return;
        _saving = true; _error = null;
        try
        {
            var claim = TravelClaim.Skapa(EmployeeId.From(Auth.EmployeeId.Value), _formBeskrivning, DateOnly.FromDateTime(_formDatum.Value));
            claim.SkickaIn();
            db.TravelClaims.Add(claim);
            await db.SaveChangesAsync();
            _claims.Insert(0, new ClaimVm(claim.Id, Auth.UserName ?? "Jag", claim.ReseDatum, claim.Beskrivning, claim.TotalBelopp.Amount, claim.Status, claim));
            _showForm = false; _success = "Resekrav skapat."; _formBeskrivning = ""; _formDatum = null;
        }
        catch (Exception ex) { _error = $"Kunde inte skapa: {ex.Message}"; }
        finally { _saving = false; }
    }

    private async Task AttesteraKrav(ClaimVm vm)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        if (!Auth.EmployeeId.HasValue) { _error = "Kräver kopplad anställd."; return; }
        try
        {
            vm.Entity.Attestera(Auth.UserName ?? "Chef");
            await db.SaveChangesAsync();
            _success = "Resekrav godkänt.";
        }
        catch (Exception ex) { _error = $"Fel: {ex.Message}"; }
    }

    private void BeraknaTraktamente()
    {
        _traktResultat = null; _traktFel = null;
        if (_traktAvresa == null || _traktHemkomst == null) { _traktFel = "Ange datum."; return; }
        try
        {
            _traktResultat = _traktTyp == "Inrikes"
                ? TraktCalc.BeraknaInrikes(_traktAvresa.Value, _traktHemkomst.Value, _traktHotell)
                : TraktCalc.BeraknaUtrikes(_traktLand, _traktAvresa.Value, _traktHemkomst.Value);
        }
        catch (Exception ex) { _traktFel = ex.Message; }
    }

    private static string StatusText(TravelClaimStatus s) => s switch
    {
        TravelClaimStatus.Utkast => "Utkast", TravelClaimStatus.Inskickad => "Inskickad",
        TravelClaimStatus.Godkand => "Godkänd", TravelClaimStatus.Utbetald => "Utbetald",
        TravelClaimStatus.Avslagen => "Avslagen", _ => s.ToString()
    };
    private static Color StatusFarg(TravelClaimStatus s) => s switch
    {
        TravelClaimStatus.Inskickad => Color.Warning, TravelClaimStatus.Godkand or TravelClaimStatus.Utbetald => Color.Success,
        TravelClaimStatus.Avslagen => Color.Error, _ => Color.Default
    };

    private record ClaimVm(Guid Id, string Namn, DateOnly Datum, string Beskrivning, decimal Belopp, TravelClaimStatus Status, TravelClaim Entity);
}

