@page "/resor"
@rendermode InteractiveServer
@layout RegionHR.Web.Components.Layout.AdminLayout

<PageTitle>OpenHR - Resor och utlägg</PageTitle>
<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4" Style="font-weight: 700;">Resor och utlägg</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" StartIcon="@Icons.Material.Filled.Add" Style="min-height: 48px;">Nytt resekrav</MudButton>
</div>

@if (_meddelande is not null)
{
    <MudAlert Severity="Severity.Success" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="@(() => _meddelande = null)">@_meddelande</MudAlert>
}

<MudSimpleTable Hover="true" Elevation="2">
    <thead><tr><th>Anställd</th><th>Datum</th><th>Belopp</th><th>Status</th><th></th></tr></thead>
    <tbody>
        @foreach (var rad in _rader)
        {
            <tr>
                <td><strong>@rad.Namn</strong></td>
                <td>@rad.Datum</td>
                <td>@rad.Belopp</td>
                <td><MudChip T="string" Size="Size.Small" Color="@rad.StatusFarg">@rad.StatusText</MudChip></td>
                <td>
                    @if (rad.StatusText == "Inskickad")
                    {
                        <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Success" OnClick="@(() => Godkann(rad))">Godkänn</MudButton>
                    }
                </td>
            </tr>
        }
    </tbody>
</MudSimpleTable>

@code {
    private string? _meddelande;

    private List<ReseRad> _rader = [];

    protected override void OnInitialized()
    {
        _rader =
        [
            new("Erik Johansson", "2026-03-10", "4 850 kr", "Inskickad", Color.Warning),
            new("Anna Svensson", "2026-02-25", "2 300 kr", "Godkänd", Color.Success),
            new("Lisa Holm", "2026-02-15", "6 720 kr", "Utbetald", Color.Success),
        ];
    }

    private void Godkann(ReseRad rad)
    {
        var idx = _rader.IndexOf(rad);
        if (idx >= 0)
        {
            _rader[idx] = rad with { StatusText = "Godkänd", StatusFarg = Color.Success };
        }
        _meddelande = $"Resekrav för {rad.Namn} ({rad.Belopp}) godkänt.";
    }

    private record ReseRad(string Namn, string Datum, string Belopp, string StatusText, Color StatusFarg);
}
